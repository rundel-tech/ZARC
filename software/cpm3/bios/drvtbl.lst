  35:				;
  36:				;
  37:				;
  38:				; *************
  39:				; * Externals *
  40:				; *************
  41:				;
  42:				;
  43:				                public @dtbl
  44:				; Pointers to XDPH structures.
  45:				                extrn xdph0, xdph1, xdph2, xdph3
  46:				                extrn xdph4, xdph5, xdph6, xdph7
  47:				                extrn xdph8, xdph9, xdph10, xdph11
  48:				                extrn xdph12, xdph13, xdph14, xdph15
  49:				;
  50:				;
  51:				;
  52:				; *************
  53:				; * Main Code *
  54:				; *************
  55:				;
  56:				;
  57:				                cseg                            ; Use common bank
  58:				;
  59:				;
  60:				; Define a single pointer to a XDPH for drive "d". This is required as the
  61:				; "`" mechanism only works in a macro.
  62:				ins_word        macro d
  63:				                word xdph`d
  64:				                endm
  65:				;
  66:				;
  67:				; Drive table as defined in CP/M 3 System Guide section 3.3.1. It is a list
  68:				; of pointers to the Disk Parameter Headers for each logical drive name, A
  69:				; through P. This inserts a zero where required rather than using the external
  70:				; symbols to do it. This is because LINK always treats externals as relative.
  71:     -	0000'         	@dtbl
  72:				                .aseg
  73:     -	0000          	drive           set 0
  74:     -	0000' 00000000	                rept CP3_NUM_DISKS_MAX
	              00000000
	              00000000
	              00000000
	              00000000
	              00000000
	              00000000
	              00000000
  84:				                .cseg
  85:				;
  86:     -	0020'         	                end



