   2:				; * CP/M 3 BIOS for ZARC Z80 Computer                   *
   3:				; * "Drive Table" module                                *
   4:				; * Version: V1.0                                       *
   5:				; * Merlin Skinner, 8/2/2023                            *
   6:				; *******************************************************
   7:				;
   8:				; Modified from DRI's DRVTBL.ASM. Modified for ZARC and its memory card.
   9:				;
  10:				;
