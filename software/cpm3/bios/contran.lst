 593:				; **********
 594:				; * Tables *
 595:				; **********
 596:				;
 597:				;
 598:				; Console output translation table. Each entry consists of four bytes:
 599:				; 0 - character received after Esc. Zero terminates table.
 600:				; 1 - data byte, used for some entries
 601:				; 2 & 3 - vector to handling routine
 602:     -	0228' 4100    	cot_list        byte "A", 0     ; Cursor up
 603:     -	022A' 4001    	                word coth_same
 604:     -	022C' 4200    	                byte "B", 0     ; Cursor down
 605:     -	022E' 4001    	                word coth_same
 606:     -	0230' 4300    	                byte "C", 0     ; Cursor right
 607:     -	0232' 4001    	                word coth_same
 608:     -	0234' 4400    	                byte "D", 0     ; Cursor left
 609:     -	0236' 4001    	                word coth_same
 610:     -	0238' 4500    	                byte "E", 0     ; Home cursor and clear screen
 611:     -	023A' 6801    	                word coth_cls
 612:     -	023C' 4800    	                byte "H", 0     ; Cursor home
