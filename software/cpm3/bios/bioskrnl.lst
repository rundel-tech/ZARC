**** bios.i ****
   1:				; *******************************************************
   2:				; * CP/M 3 BIOS for ZARC Z80 Computer Include File      *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 23/1/2023                             *
   5:				; *******************************************************
   6:				;
   7:				;
   8:				;
   9:				; *************
  10:				; * Constants *
  11:				; *************
  12:				;
  13:				;
  14:     -	0003'         	BIOS_CPM_VER        equ 3               ; Supported CP/M version
  15:				;
  16:				; BIOS version
  17:     -	0001'         	BIOS_MAJ_VER        equ 1
  18:     -	0000'         	BIOS_MIN_VER        equ 0
  19:				;
  20:     -	0040'         	STACK_SIZE      equ 64                  ; Stack space allocation
  21:				; The interrupt stack need only be deep enough to meet the requirements of the
  22:				; interrupt service routines plus a NMI. As the monitor switches to its own
  23:				; stack for NMIs, this is a light requirement.
  24:     -	0010'         	INT_STACK_SIZE      equ 16              ; Interrupt service routine stack size
  25:				;
  26:     -	0100'         	DISK_SPT            equ 256             ; Logical sectors per track
  27:     -	0004'         	CPM_PER_PHYS_SECT   equ MMC_SECTOR_SIZE / CPM_SECTOR_SIZE  
  28:     -	0040'         	DISK_PHYS_SPT       equ DISK_SPT / CPM_PER_PHYS_SECT
  29:     -	01FF'         	DISK_DSM            equ 511             ; Maximum block number
  30:				; Minimum partition size. This allows for the system area, 8 CP/M 2.2 drives
  31:				; and 16 CP/M 3 drives with one shared between the two systems.
  32:     -	0000'         	CPM_MIN_PRT_SIZE    equ CPM_SYS_SIZE + ((NUM_DISKS + CP3_NUM_DISKS - 1) * CPM_DISK_SIZE)  ; In bytes
  33:     -	8800'         	CPM_MIN_PRT_SIZE_MS equ CPM_MIN_PRT_SIZE / MMC_SECTOR_SIZE  ; In MMC sectors
  34:     -	8000'         	CPM_TRACK_SIZE      equ DISK_SPT * CPM_SECTOR_SIZE   ; "Track" size in bytes
  35:     -	0020'         	CPM_SYS_TRACKS      equ CPM_SYS_SIZE / CPM_TRACK_SIZE   ; System area size in tracks
  36:     -	0020'         	CPM_DRIVE_TRACKS    equ CPM_DISK_SIZE / CPM_TRACK_SIZE  ; Drive size in tracks
  37:				;
  38:				; *** DEVTBL constants from MODEBAUD.LIB ***
  39:				;
  40:				; Equates for mode byte bit fields in CHRTBL (@CTBL)
  41:     -	0001'         	mb$input            equ 00000001b       ; device may do input
  42:     -	0002'         	mb$output           equ 00000010b       ; device may do output
  43:     -	0003'         	mb$in$out           equ mb$input+mb$output
  44:     -	0004'         	mb$soft$baud		equ 00000100b       ; software selectable baud rates
  45:     -	0008'         	mb$serial           equ 00001000b       ; device may use protocol
  46:     -	0010'         	mb$xon$xoff         equ 00010000b       ; XON/XOFF protocol enabled
  47:				;
  48:				; Baud rates
  49:     -	0000'         	baud$none           equ 0       ; no baud rate associated with this device
  50:     -	0001'         	baud$50             equ 1       ; 50 baud
  51:     -	0002'         	baud$75             equ 2       ; 75 baud
  52:     -	0003'         	baud$110            equ 3       ; 110 baud
  53:     -	0004'         	baud$134            equ 4       ; 134.5 baud
  54:     -	0005'         	baud$150            equ 5       ; 150 baud
  55:     -	0006'         	baud$300            equ 6       ; 300 baud
  56:     -	0007'         	baud$600            equ 7       ; 600 baud
  57:     -	0008'         	baud$1200           equ 8       ; 1200 baud
  58:     -	0009'         	baud$1800           equ 9       ; 1800 baud
  59:     -	000A'         	baud$2400           equ 10      ; 2400 baud
  60:     -	000B'         	baud$3600           equ 11      ; 3600 baud
  61:     -	000C'         	baud$4800           equ 12      ; 4800 baud
  62:     -	000D'         	baud$7200           equ 13      ; 7200 baud
  63:     -	000E'         	baud$9600           equ 14      ; 9600 baud
  64:     -	000F'         	baud$19200          equ 15      ; 19.2k baud
  65:				;
  66:				;
  67:				; CPMLDR BIOS common area. We can't use this for CP/M 3 itself as this is
  68:				; required for CPMLDR. However, we can use it for variables once CPMLDR itself
  69:				; has finished.
  70:     -	FC00'         	CPMLDR_B_C_START    equ 0xfc00          ; Start address
  71:     -	03E0'         	CPMLDR_B_C_MAXLEN   equ INT_VEC_TABLE - CPMLDR_B_C_START    ; Maximum length
  72:				;
  73:				; Allocate space for variables in this block.
  74:     -	        	                ALLOC CPMLDR_B_C_START
  75:     -	        	                ALL_BLOCK COM_SEC_BUFFER, MMC_SECTOR_SIZE   ; Sector buffer
  76:				; Monitor call stack.
  77:     -	        	                ALL_BLOCK MC_STACK, STACKS_SIZE
  78:     -	FE80          	MC_STK_TOP_P1   equ all_addr                                ; Stack top + 1
  79:				; Interrupts stack.
  80:     -	        	                ALL_BLOCK INT_STACK, STACKS_SIZE
  81:     -	FF00          	INT_STK_TOP_P1  equ all_addr                                ; Stack top + 1
  82:     -	        	                ALL_END CPMLDR_B_C_LEN
  83:				;
  84:     -	0001'         	                assert CPMLDR_B_C_LEN <= CPMLDR_B_C_MAXLEN
**** bioskrnl.z80 ****
  49:				;
  50:				;
  51:     -	FFFF'         	true equ -1
  52:     -	0000'         	false equ not true
  53:				
  54:     -	FFFF'         	banked equ true
  55:				
  56:				
  57:				;          Copyright (C), 1982
  58:				;         Digital Research, Inc
  59:				;             P.O. Box 579
  60:				;        Pacific Grove, CA  93950
  61:				
  62:				
  63:				;   This is the invariant portion of the modular BIOS and is
  64:				;    distributed as source for informational purposes only.
  65:				;    All desired modifications should be performed by
  66:				;    adding or changing externally defined modules.
  67:				;    This allows producing "standard" I/O modules that
  68:				;    can be combined to support a particular system 
  69:				;    configuration.
  70:				
  71:     -	000D'         	cr      equ 13
  72:     -	000A'         	lf      equ 10
  73:     -	0007'         	bell    equ 7
  74:     -	0011'         	ctlQ    equ 'Q'-'@'
  75:     -	0013'         	ctlS    equ 'S'-'@'
  76:				
  77:     -	0100'         	ccp     equ 0100h    ; Console Command Processor gets loaded into the TPA
  78:				
  79:				    cseg        ; GENCPM puts CSEG stuff in common memory
  80:				
  81:				
  82:				    ; variables in system data page
  83:				
  84:				    extern @covec,@civec,@aovec,@aivec,@lovec ; I/O redirection vectors
  85:				    extern @mxtpa               ; addr of system entry point
  86:				    extern @bnkbf               ; 128 byte scratch buffer
  87:				
  88:				    ; initialization
  89:				
  90:				    extern ?init                ; general initialization and signon
  91:				    extern ?ldccp,?rlccp        ; load & reload CCP for BOOT & WBOOT
  92:				
  93:				    ; user defined character I/O routines
  94:				
  95:				    extern ?ci,?co,?cist,?cost  ; each take device in <B>
  96:				    extern ?cinit               ; (re)initialize device in <C>
  97:				    extern @ctbl                ; physical character device table
  98:				
  99:				    ; disk communication data items
 100:				
 101:				    extern @dtbl                ; table of pointers to XDPHs
 102:				    public @adrv,@rdrv,@trk,@sect   ; parameters for disk I/O
 103:				    public @dma,@dbnk,@cnt      ;    ''       ''   ''  ''
 104:				
 105:				    ; memory control
 106:				
 107:				    public @cbnk                ; current bank
 108:				    extern ?xmove,?move         ; select move bank, and block move
 109:				    extern ?bank                ; select CPU bank
 110:				
 111:				    ; clock support
 112:				
 113:				    extern ?time                ; signal time operation
 114:				    extern tiini                ; Initialise time
 115:				
 116:				    ; general utility routines
 117:				
 118:				    public ?pmsg,?pdec          ; print message, print number from 0 to 65535
 119:				    public ?pderr               ; print BIOS disk error message header
 120:				
 121:				    ; ZARC extensions
 122:				
 123:				    extern strtup, mcall, super, intdis, inten
 124:				    extern tird, tiels, tielg
 125:				
 126:				    ; External names for BIOS entry points
 127:				
 128:				    public ?boot,?wboot,?const,?conin,?cono,?list,?auxo,?auxi
 129:				    public ?home,?sldsk,?sttrk,?stsec,?stdma,?read,?write
 130:				    public ?lists,?sctrn
 131:				    public ?conos,?auxis,?auxos,?dvtbl,?devin,?drtbl
 132:				    public ?mltio,?flush,?mov,?tim,?bnksl,?stbnk,?xmov
 133:				
 134:				    ; For contran, which needs consistent names with CP/M 2.2
 135:				    public const
 136:				
 137:				    ; BIOS Jump vector.
 138:				
 139:				        ; All BIOS routines are invoked by calling these
 140:				        ;    entry points.
 141:				
 142:    0+10	0000' C30000  	?boot:      jp    boot          ; initial entry on cold start
 143:   10+10	0003' C38A00  	?wboot:     jp    wboot         ; reentry on program exit, warm start
 144:				
 145:   20+10	0006' C39E01  	?const:     jp    const         ; return console input status
 146:   30+10	0009' C3B901  	?conin:     jp    conin         ; return console input character
 147:   40+10	000C' C30101  	?cono:      jp    conout        ; send console output character
 148:   50+10	000F' C30D01  	?list:      jp    list          ; send list output character
 149:   60+10	0012' C30701  	?auxo:      jp    auxout        ; send auxiliary output character
 150:   70+10	0015' C3BF01  	?auxi:      jp    auxin         ; return auxiliary input character
 151:				
 152:   80+10	0018' C36E00  	?home:      jp    home          ; set disks to logical home
 153:   90+10	001B' C33F00  	?sldsk:     jp    seldsk        ; select disk drive, return disk parameter info
 154:  100+10	001E' C37100  	?sttrk:     jp    settrk        ; set disk track
 155:  110+10	0021' C37700  	?stsec:     jp    setsec        ; set disk sector
 156:  120+10	0024' C37D00  	?stdma:     jp    setdma        ; set disk I/O memory address
 157:  130+10	0027' C39400  	?read:      jp    read          ; read physical block(s)
 158:  140+10	002A' C3AA00  	?write:     jp    write         ; write physical block(s)
 159:				
 160:  150+10	002D' C33901  	?lists:     jp    listst        ; return list device status
 161:  160+10	0030' C38900  	?sctrn:     jp    sectrn        ; translate logical to physical sector
 162:				
 163:  170+10	0033' C32D01  	?conos:     jp    conost        ; return console output status
 164:  180+10	0036' C3A401  	?auxis:     jp    auxist        ; return aux input status
 165:  190+10	0039' C33301  	?auxos:     jp    auxost        ; return aux output status
 166:  200+10	003C' C3F900  	?dvtbl:     jp    devtbl        ; return address of device def table
 167:  210+10	003F' C30000  	?devin:     jp    ?cinit        ; change baud rate of device
 168:				
 169:  220+10	0042' C3FD00  	?drtbl:     jp    getdrv        ; return address of disk drive table
 170:  230+10	0045' C3CB00  	?mltio:     jp    multio        ; set multiple record count for disk I/O
 171:  240+10	0048' C3CF00  	?flush:     jp    flush         ; flush BIOS maintained disk caching
 172:				
 173:  250+10	004B' C30000  	?mov:       jp    ?move         ; block move memory to memory
 174:  260+10	004E' C30000  	?tim:       jp    ?time         ; Signal Time and Date operation
 175:  270+10	0051' C35102  	?bnksl:     jp    bnksel        ; select bank for code execution and default DMA
 176:  280+10	0054' C38500  	?stbnk:     jp    setbnk        ; select different bank for disk I/O DMA operations.
 177:  290+10	0057' C30000  	?xmov:      jp    ?xmove        ; set source and destination banks for one operation
 178:				
 179:  300+10	005A' C30000  	            jp 0                ; reserved for future expansion
 180:  310+10	005D' C30000  	            jp 0                ; reserved for future expansion
 181:  320+10	0060' C30000  	            jp 0                ; reserved for future expansion
 182:				
 183:				; ZARC-specific items follow.
 184:     -	0063' 5A5243  	                byte "ZRC"              ; ZARC BIOS ID *1
 185:     -	0066' 000100  	                byte 0, BIOS_MAJ_VER, BIOS_MIN_VER  ; BIOS_VER (version)
 186:  330+10	0069' C30000  	                jp strtup               ; ZARC CP/M startup (not used)
 187:  340+10	006C' C30000  	                jp mcall                ; Call monitor function
 188:  350+10	006F' C30000  	                jp super                ; Set supervisor state
 189:  360+10	0072' C30000  	                jp intdis               ; Disable interrupt and keep count
 190:  370+10	0075' C30000  	                jp inten                ; Enable interrupts if safe.
 191:  380+10	0078' C30000  	                jp tird                 ; Read time and date (ZARC format)
 192:  390+10	007B' C30000  	                jp tiels                ; Set elapsed time
 193:  400+10	007E' C30000  	                jp tielg                ; Get elapsed time
 194:				;
 195:				; *1 - this is "ZARC" truncated to three bytes to maintain alignment with other
 196:				; jumps. This may be useful if the BIOS is ever called from C.
 197:				
 198:				
 199:				    ; BOOT
 200:				    ;    Initial entry point for system startup.
 201:				
 202:				    dseg    ; this part can be banked
 203:				
 204:     -	0000"         	boot:
 205:     -	0000" 31F900  	    ld    sp,boot$stack
 206:     -	0003" 0E0F    	    ld    c,15        ; initialise all 16 character devices
 207:     -	0005"         	c$init$loop:
 208:     -	0005" C5      	    push    bc
 209:     -	0006" CD0000  	    call    ?cinit
 210:     -	0009" C1      	    pop    bc
 211:     -	000A" 0D      	    dec    c
 212:     -	000B" F20500  	    jp    p,c$init$loop
 213:				
 214:     -	000E" CD0000  	    call ?init    ; perform any additional system initialization
 215:				            ; and print sign on message
 216:				
 217:     -	0011" 010010  	    ld    bc,16*256+0
 218:     -	0014" 210000  	    ld    hl,@dtbl    ; init all 16 logical disk drives
 219:     -	0017"         	d$init$loop:
 220:     -	0017" C5      	    push    bc        ; save remaining count and abs drive
 221:     -	0018" 5E      	    ld    e,(hl)
 222:     -	0019" 23      	    inc    hl
 223:     -	001A" 56      	    ld    d,(hl)
 224:     -	001B" 23      	    inc    hl        ; grab @drv entry
 225:     -	001C" 7B      	    ld    a,e
 226:     -	001D" B2      	    or    d
 227:     -	001E" CA3600  	    jp    z,d$init$next    ; if null, no drive
 228:     -	0021" E5      	    push    hl        ; save @drv pointer 
 229:     -	0022" EB      	    ex    de,hl        ; XDPH address in <HL>
 230:     -	0023" 2B      	    dec    hl
 231:     -	0024" 2B      	    dec    hl
 232:     -	0025" 7E      	    ld    a,(hl)
 233:     -	0026" 326802  	    ld    (@rdrv),a    ; get relative drive code
 234:     -	0029" 79      	    ld    a,c
 235:     -	002A" 326702  	    ld    (@adrv),a    ; get absolute drive code
 236:     -	002D" 2B      	    dec    hl        ; point to init pointer
 237:     -	002E" 56      	    ld    d,(hl)
 238:     -	002F" 2B      	    dec    hl
 239:     -	0030" 5E      	    ld    e,(hl)        ; get init pointer
 240:     -	0031" EB      	    ex    de,hl
 241:     -	0032" CDE201  	    call    ipchl        ; call init routine
