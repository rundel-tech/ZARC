 773:     -	0094" 2A6702  	    ld    hl,(@adrv)
 774:     -	0097" 2600    	    ld    h,0
 775:     -	0099" 29      	    add    hl,hl        ; get drive code and double it
 776:     -	009A" 110000  	    ld    de,@dtbl
 777:     -	009D" 19      	    add    hl,de        ; make address of table entry
 778:     -	009E" 7E      	    ld    a,(hl)
 779:     -	009F" 23      	    inc    hl
 780:     -	00A0" 66      	    ld    h,(hl)
 781:     -	00A1" 6F      	    ld    l,a        ; fetch table entry
 782:     -	00A2" E5      	    push    hl        ; save address of table
 783:     -	00A3" 11F8FF  	    ld    de,-8
 784:     -	00A6" 19      	    add    hl,de        ; point to read routine address
 785:     -	00A7" C3BD00  	    jp    rw$common    ; use common code
 786:				
 787:				
 788:				    ; WRITE
 789:				    ;    Write physical sector from currently selected drive.
 790:				    ;        Finds address of proper write routine from
 791:				    ;        extended disk parameter header (XDPH).
 792:				
 793:     -	00AA"         	write:
