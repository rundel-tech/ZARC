 521: 2113+7	01C3' 0600    	    ld    b,0
 522:				; We can enable and disable interrupts directly here because we know the DI nest
 523:				; count is zero. The idea is to make the scan atomic as far as interrupts are
 524:				; concerned. The timekeeping interrupt will wake the system from time to time
 525:				; anyway.
