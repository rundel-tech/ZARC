 797:     -	00B0" 110000  	    ld    de,@dtbl
 798:     -	00B3" 19      	    add    hl,de        ; make address of table entry
 799:     -	00B4" 7E      	    ld    a,(hl)
 800:     -	00B5" 23      	    inc    hl
 801:     -	00B6" 66      	    ld    h,(hl)
 802:     -	00B7" 6F      	    ld    l,a        ; fetch table entry
 803:     -	00B8" E5      	    push    hl        ; save address of table
 804:     -	00B9" 11F6FF  	    ld    de,-10
 805:     -	00BC" 19      	    add    hl,de        ; point to write routine address
 806:				
 807:     -	00BD"         	rw$common:
