 811:     -	00C0" 6F      	    ld    l,a        ; get address of routine
 812:     -	00C1" D1      	    pop    de        ; recover address of table
 813:     -	00C2" 1B      	    dec    de
 814:     -	00C3" 1B      	    dec    de        ; point to relative drive
 815:     -	00C4" 1A      	    ld    a,(de)
