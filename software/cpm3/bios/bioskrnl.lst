 708:     -	0072" 60      	    ld    h,b
 709:     -	0073" 226902  	    ld    (@trk),hl
 710:     -	0076" C9      	    ret
 711:				
 712:				
 713:				    ; SETSEC
 714:				    ;    Set Sector.  Saves sector number from <BC>
 715:				    ;        in @sect for further operations.
 716:				
 717:     -	0077"         	setsec:
 718:     -	0077" 69      	    ld    l,c
 719:     -	0078" 60      	    ld    h,b
 720:     -	0079" 226B02  	    ld    (@sect),hl
 721:     -	007C" C9      	    ret
 722:				
 723:				
 724:				    ; SETDMA
 725:				    ;    Set Disk Memory Address.  Saves DMA address
 726:				    ;        from <BC> in @DMA and sets @DBNK to @CBNK
 727:				    ;        so that further disk operations take place
 728:				    ;        in current bank.
 729:				
 730:     -	007D"         	setdma:
 731:     -	007D" 69      	    ld    l,c
 732:     -	007E" 60      	    ld    h,b
 733:     -	007F" 226D02  	    ld    (@dma),hl
 734:				
 735:     -	0082" 3A7102  	    ld    a,(@cbnk)    ; default DMA bank is current bank
 736:				            ; fall through to set DMA bank
 737:				
 738:				    ; SETBNK
 739:				    ;    Set Disk Memory Bank.  Saves bank number
 740:				    ;        in @DBNK for future disk data
 741:				    ;        transfers.
 742:				
 743:     -	0085"         	setbnk:
 744:     -	0085" 327002  	    ld    (@dbnk),a
 745:     -	0088" C9      	    ret
 746:				
 747:				
 748:				    ; SECTRN
 749:				    ;    Sector Translate.  Indexes skew table in <DE>
 750:				    ;        with sector in <BC>.  Returns physical sector
 751:				    ;        in <HL>.  If no skew table (<DE>=0) then
 752:				    ;        returns physical=logical.
 753:				
 754:     -	0089"         	sectrn:
 755:     -	0089" 69      	    ld    l,c
 756:     -	008A" 60      	    ld    h,b
 757:     -	008B" 7A      	    ld    a,d
 758:     -	008C" B3      	    or    e
 759:     -	008D" C8      	    ret    z
 760:     -	008E" EB      	    ex    de,hl
 761:     -	008F" 09      	    add    hl,bc
 762:     -	0090" 6E      	    ld    l,(hl)
 763:     -	0091" 2600    	    ld    h,0
 764:     -	0093" C9      	    ret
 765:				
 766:				
 767:				    ; READ
 768:				    ;    Read physical record from currently selected drive.
 769:				    ;        Finds address of proper read routine from
 770:				    ;        extended disk parameter header (XDPH).
 771:				
