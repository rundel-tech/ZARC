**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm.i ****
   1:				; *******************************************************
   2:				; * ZARC Monitor CP/M 2.2 Definitions                   *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 26/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Definitions related to CP/M running under the monitor programme. It may also
   8:				; be used for CP/M applications.
   9:				;
  10:				; Note that ld80 only considers the first six characters of labels significant.
  11:				;
  12:				; The following conditionals are intended to allow the same include file to be
  13:				; used in the defining module and elsewhere as required. Some includes are used
  14:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  15:				; the extern and public statements are not desirable.
  16:				;
  17:     -	0000'         	            ifdef monitor           ; Meaningful for monitor build only
  30:				            endif
  31:				;
  32:				;
  33:				;
  34:				; ****************
  35:				; * Memory Usage *
  36:				; ****************
  37:				;
  38:				;
  39:				; Note: memory banks are allocated by the monitor's initialisation code.
  40:     -	0004'         	MMAP_CPM_PAGES      equ 4               ; Number of 16 kB pages
  41:				;
  42:				; The MS byte of INT_VEC_TABLE comes from the Z80 I register, and the LS byte
  43:				; from the FPGA. The 0xe0 offset is chosen to allow the table to reside at the
  44:				; top of memory (0xffe0 to 0xffff).
  45:     -	FFE0'         	INT_VEC_TABLE   equ 0xffe0              ; Interrupt mode 2 vector table
  46:				;
  47:				; Copied from CP/M manual appendix A.
  48:				; MSIZE             equ 64              ; CP/M version memory size in kilobytes
  49:				;
  50:				; "BIAS" is the address offset from 0x3400 for memory systems other than 16 K.
  51:				;BIAS               equ (MSIZE-20) * 1024
  52:     -	A200'         	CPM_BIAS            equ 0xa200          ; For CompuPro64K_CPM
  53:     -	D600'         	CCP_START           equ 0x3400 + CPM_BIAS   ; Base of CCP
  54:     -	DE06'         	BDOS_START          equ CCP_START + 0x0806  ; Base of BDOS
  55:     -	EC00'         	BIOS_START          equ CCP_START + 0x1600  ; Base of BIOS
  56:     -	002C'         	BIOS_CPM_START_SEC  equ 44              ; First CP/M sector of BIOS
  57:     -	1000'         	BIOS_MAX_SIZE       equ 4096            ; 2 KB allocation for BIOS stored on MMC (ZARC)
  58:     -	0100'         	TPA_START           equ 0x0100          ; Transient Programme Area
  59:				;
  60:				; Page zero.
  61:     -	0003'         	IOBYTE              equ 0x0003          ; Intel I/O byte
  62:     -	0004'         	CDISK               equ 0x0004          ; Current disk (0="A") & user no. (in high nibble)
  63:     -	005C'         	FCB1                equ 0x005c          ; Default FCB 1
  64:     -	006C'         	FCB2                equ 0x006c          ; Default FCB 2 (overwritten if FCB 1 is opened)
  65:				; Default 128-byte disk buffer, also filled with the command line when a transient
  66:				; is loaded under the CCP.
  67:     -	0080'         	DEF_BUFFER          equ 0x80
  68:     -	0080'         	DEF_BUFFER_SIZE     equ 0x80
  69:				;
  70:				; IOBYTE bit definitions.
  71:     -	0003'         	IOB_CON_MASK        equ 0x03
  72:     -	000C'         	IOB_RDR_MASK        equ 0x0c
  73:     -	0030'         	IOB_PUN_MASK        equ 0x30
  74:     -	00C0'         	IOB_LST_MASK        equ 0xc0
  75:				;
  76:				; BIOS option bits.
  77:     -	        	BITDEF BIOS_OPT_DEBUG, 0                ; Enable BIOS debugging messages
  78:     -	        	BITDEF BIOS_OPT_NOINTS, 1               ; Disables interrupts (use basic I/O mode)
  79:     -	        	BITDEF BIOS_OPT_RAWCON, 2               ; Disables ADM-3A to VT-100 translation
  80:				;
  81:				;
  82:				;
  83:				; ***************
  84:				; * Disk System *
  85:				; ***************
  86:				;
  87:				;
  88:				; Note: NUM_DISKS reduced to 9 from 16 in preparation for adding CP/M 3 support.
  89:     -	0080'         	CPM_SECTOR_SIZE     equ 128             ; CP/M disk sector size
  90:     -	0009'         	NUM_DISKS           equ 9               ; Number of disk drives
  91:     -	0010'         	NUM_DISKS_MAX       equ 16              ; Maximum number of disk drives
  92:     -	0000'         	CPM_SYS_SIZE        equ 1024 * 1024     ; System area size (bytes)
  93:     -	0000'         	CPM_DISK_SIZE       equ 1024 * 1024     ; Disk size (bytes)
  94:     -	0800'         	CPM_BLOCK_SIZE      equ 2048            ; Allocation block size (bytes)
  95:     -	0200'         	CPM_DIR_ENTRIES     equ 512             ; Number of directory entries
  96:     -	0008'         	FILENAME_SIZE       equ 8               ; Filename size
  97:     -	0003'         	FILEEXT_SIZE        equ 3               ; File extension size
  98:     -	001A'         	FILE_EOF            equ 0x1a            ; End of file (^Z)
  99:     -	000F'         	MAX_USER            equ 15              ; Maximum user number
 100:				;
 101:     -	0001'         	BDOS_READ_SEQ_EOF   equ 1               ; Sequential read EOF error code
 102:				;
 103:				; CP/M 2.2 Disk Parameter Header (DPH) structure.
 104:     -	        	                STRUCT
 105:     -	        	                STR_WORD DPH_XLT        ; Address of sector translation table
 106:     -	        	                STR_WORD DPH_SCRATCH0   ; BDOS scratch area
 107:     -	        	                STR_WORD DPH_SCRATCH1
 108:     -	        	                STR_WORD DPH_SCRATCH2
 109:     -	        	                STR_WORD DPH_DIRBF      ; BDOS directory scratch area
 110:     -	        	                STR_WORD DPH_DPB        ; Pointer to DPB
 111:     -	        	                STR_WORD DPH_CSV        ; Pointer to the directory checksum vector
 112:     -	        	                STR_WORD DPH_ALV        ; Pointer to the allocation vector
 113:     -	        	                STR_END DPH_SIZE
 114:				;
 115:				;
 116:				; CP/M 2.2 Disk Parameter Block (DPB) structure.
 117:     -	        	                STRUCT
 118:     -	        	                STR_WORD DPB_SPT        ; Number of 128-byte records per track
 119:     -	        	                STR_BYTE DPB_BSH        ; Block shift. 3 => 1k, 4 => 2k, 5 => 4k....
 120:     -	        	                STR_BYTE DPB_BLM        ; Block mask. 7 => 1k, 0Fh => 2k, 1Fh => 4k...
 121:     -	        	                STR_BYTE DPB_EXM        ; Extent mask
 122:     -	        	                STR_WORD DPB_DSM        ; Maximum block number
 123:     -	        	                STR_WORD DPB_DRM        ; Maximum directory entry number
 124:     -	        	                STR_BYTE DPB_AL0        ; Directory allocation bitmap
 125:     -	        	                STR_BYTE DPB_AL1
 126:     -	        	                STR_WORD DPB_CKS        ; Checksum vector size, 0 for a fixed disc
 127:     -	        	                STR_WORD DPB_OFF        ; Offset, number of reserved tracks
 128:     -	        	                STR_END DPB_SIZE
 129:				;
 130:				;
 131:				; Directory entry structure.
 132:     -	        	                STRUCT
 133:     -	        	                STR_BYTE DIRE_USER      ; User number. 0xe5 if entry unused
 134:     -	        	                STR_BLOCK DIRE_NAME, FILENAME_SIZE  ; Filename
 135:     -	        	                STR_BLOCK DIRE_TYP, FILEEXT_SIZE    ; File type
 136:     -	        	                STR_BYTE DIRE_EX        ; Extent counter, low byte (0-31)
 137:     -	        	                STR_BYTE DIRE_S1        ; Reserved, set to 0
 138:     -	        	                STR_BYTE DIRE_S2        ; Extent counter, high byte
 139:     -	        	                STR_BYTE DIRE_RC        ; Record count (low byte)
 140:     -	        	                STR_BLOCK DIRE_ALLOC, 16 ; Associated block numbers
 141:     -	        	                STR_END DIRE_SIZE
 142:				;
 143:     -	0001'         	                assert DIRE_SIZE = 0x20
 144:				;
 145:				;
 146:				; File Control Block (FCB) structure.
 147:     -	        	                STRUCT
 148:     -	        	                STR_BYTE FCB_DRIVE      ; Drive. 0 for default, 1-16 for A-P
 149:     -	        	                STR_BLOCK FCB_NAME, FILENAME_SIZE   ; Filename in ASCII upper-case
 150:     -	        	                STR_BLOCK FCB_TYP, FILEEXT_SIZE     ; File type
 151:     -	        	                STR_BYTE FCB_EX         ; Current extent (*)
 152:     -	        	                STR_BYTE FCB_S1         ; Reserved (*)
 153:     -	        	                STR_BYTE FCB_S2         ; Extent high byte (*)
 154:     -	        	                STR_BYTE FCB_RC         ; Record count (*)
 155:     -	        	                STR_BLOCK FCB_ALLOC, 16 ; Associated block numbers
 156:     -	        	                STR_BYTE FCB_CR         ; Current record within extent
 157:     -	        	                STR_BLOCK FCB_RECORD, 3 ; Record number (low byte first)
 158:     -	        	                STR_END FCB_SIZE
 159:				;
 160:				; * - Set this to 0 when opening a file and then leave it to CP/M. You can
 161:				; rewind a file by setting EX, RC, S2 and CR to 0.
 162:				;
 163:				;
 164:				;
 165:				; **************
 166:				; * BIOS Calls *
 167:				; **************
 168:				;
 169:				;
 170:				; Calculate offsets into jump tables. Entries here must match the jump table in
 171:				; the BIOS. The base address of the BIOS must be added to these addresses. A
 172:				; call routine might look like:
 173:				;
 174:				; Call BIOS, allowing for its unknown base address.
 175:				; Call with:
 176:				; BC - operand (depends on BIOS function called)
 177:				; DE - operand (depends on BIOS function called)
 178:				; HL - offset for the routine (e.g. BIOS_CONIN)
 179:				; call_bios       push de
 180:				;                 ex de, hl
 181:				;                 ld hl, (1)              ; Find WBOOT (warm boot) address
 182:				;                 add hl, de              ; Add offset
 183:				;                 pop de
 184:				;                 jp (hl)                 ; Jump to BIOS then return to caller
 185:				;
 186:				; The above method is a bit clumsy, but then application code shouldn't normally
 187:				; call the BIOS directly.
 188:				;
 189:     -	        	    JPTBL_START 0                   ; Generate offsets as BIOS_START isn't always known
 190:				;
 191:				; Note - cold start routine omitted to align with use of address at (1) to find BIOS.
 192:     -	        	    JPTBL_ENTRY BIOS_WBOOT          ; Warm boot - reload command processor
 193:     -	        	    JPTBL_ENTRY BIOS_CONST          ; Console status
 194:     -	        	    JPTBL_ENTRY BIOS_CONIN          ; Console input
 195:     -	        	    JPTBL_ENTRY BIOS_CONOUT         ; Console output
 196:     -	        	    JPTBL_ENTRY BIOS_PLIST          ; Printer output
 197:     -	        	    JPTBL_ENTRY BIOS_PUNCH          ; Paper tape punch output
 198:     -	        	    JPTBL_ENTRY BIOS_READER         ; Paper tape reader input
 199:     -	        	    JPTBL_ENTRY BIOS_HOME           ; Move disc head to track 0
 200:     -	        	    JPTBL_ENTRY BIOS_SELDSK         ; Select disc drive
 201:     -	        	    JPTBL_ENTRY BIOS_SETTRK         ; Set track number
 202:     -	        	    JPTBL_ENTRY BIOS_SETSEC         ; Set sector number
 203:     -	        	    JPTBL_ENTRY BIOS_SETDMA         ; Set DMA address
 204:     -	        	    JPTBL_ENTRY BIOS_READ           ; Read a sector
 205:     -	        	    JPTBL_ENTRY BIOS_WRITE          ; Write a sector
 206:				; CP/M 2 functions.
 207:     -	        	    JPTBL_ENTRY BIOS_LISTST         ; Status of list device
 208:     -	        	    JPTBL_ENTRY BIOS_SECTRAN        ; Sector translation for skewing
 209:				; CP/M 3 functions. From https://www.seasip.info/Cpm/bios.html
 210:     -	        	    JPTBL_ENTRY BIOS_CONOST         ; Status of console output
 211:     -	        	    JPTBL_ENTRY BIOS_AUXIST         ; Status of auxiliary input
 212:     -	        	    JPTBL_ENTRY BIOS_AUXOST         ; Status of auxiliary output
 213:     -	        	    JPTBL_ENTRY BIOS_DEVTBL         ; Address of devices table
 214:     -	        	    JPTBL_ENTRY BIOS_DEVINI         ; Initialise a device
 215:     -	        	    JPTBL_ENTRY BIOS_DRVTBL         ; Address of discs table
 216:     -	        	    JPTBL_ENTRY BIOS_MULTIO         ; Read/write multiple sectors
 217:     -	        	    JPTBL_ENTRY BIOS_FLUSH          ; Flush host buffers
 218:     -	        	    JPTBL_ENTRY BIOS_MOVE           ; Move a block of memory
 219:     -	        	    JPTBL_ENTRY BIOS_TIME           ; Real time clock
 220:     -	        	    JPTBL_ENTRY BIOS_SELMEM         ; Select memory bank
 221:     -	        	    JPTBL_ENTRY BIOS_SETBNK         ; Select bank for DMA operation
 222:     -	        	    JPTBL_ENTRY BIOS_XMOVE          ; Preload banks for MOVE
 223:     -	        	    JPTBL_ENTRY BIOS_USERF          ; System-depedent functions
 224:     -	        	    JPTBL_ENTRY BIOS_RESERV1        ; Reserved
 225:     -	        	    JPTBL_ENTRY BIOS_RESERV2        ; Reserved
 226:				; ZARC-specific items.
 227:     -	        	    JPTBL_BLOCK BIOS_ID, 3          ; BIOS ID ("ZRC")
 228:     -	        	    JPTBL_BLOCK BIOS_VER, 3         ; Version (see below)
 229:     -	        	    JPTBL_ENTRY BIOS_STARTUP        ; CP/M startup entry point
 230:     -	        	    JPTBL_ENTRY BIOS_MON_CALL       ; Call monitor function
 231:     -	        	    JPTBL_ENTRY BIOS_SUPER          ; Set supervisor state
 232:     -	        	    JPTBL_ENTRY BIOS_INT_DISABLE    ; Disable interrupts and keep count
 233:     -	        	    JPTBL_ENTRY BIOS_INT_ENABLE     ; Enable interrupts if safe
 234:     -	        	    JPTBL_ENTRY BIOS_TIRD           ; Read time and date (ZARC format)
 235:     -	        	    JPTBL_ENTRY BIOS_SET_TIMER      ; Set timer
 236:     -	        	    JPTBL_ENTRY BIOS_GET_TIMER      ; Get timer
 237:				;
 238:     -	        	    JPTBL_END BIOS_JPTBL_NEXT
 239:				;
 240:				; BIOS_VER is <reserved (zero)>, <major version>, <minor version>. The reserved
 241:				; byte may flag capabilities at some point.
 242:				;
 243:				;
 244:				;
 245:				; **************
 246:				; * BDOS Calls *
 247:				; **************
 248:				;
 249:				;
 250:				; From http://www.gaby.de/cpm/manuals/archive/cpm22htm/ch5.htm#Section_5.2
 251:				; In general, the function number is passed in register C with the information
 252:				; address in the double byte pair DE. Single byte values are returned in register
 253:				; A, with double byte values returned in HL. A zero value is returned when the
 254:				; function number is out of range. For reasons of compatibility, register A = L
 255:				; and register B = H upon return in all cases. Example call:
 256:				;   ld c, BDOS_CONIN    ; Read next character
 257:				;   call BDOS           ; Return character in A
 258:				;
 259:     -	0005'         	BDOS        equ 5               ; BDOS entry point
 260:				;
 261:     -	0000'         	BDOS_SYS_RST        equ 0       ; System Reset
 262:     -	0001'         	BDOS_CON_IN         equ 1       ; Console Input
 263:     -	0002'         	BDOS_CON_OUT        equ 2       ; Console Output
 264:     -	0003'         	BDOS_RDR_IN         equ 3       ; Reader Input
 265:     -	0004'         	BDOS_PUN_OUT        equ 4       ; Punch Output
 266:     -	0005'         	BDOS_LST_OUT        equ 5       ; List Output
 267:     -	0006'         	BDOS_DIRECT_CON_IO  equ 6       ; Direct Console I/O
 268:     -	0007'         	BDOS_GET_IO_BYTE    equ 7       ; Get I/O Byte
 269:     -	0008'         	BDOS_SET_IO_BYTE    equ 8       ; Set I/O Byte
 270:     -	0009'         	BDOS_PRINT_STRING   equ 9       ; Print String
 271:     -	000A'         	BDOS_READ_CON_BUFF  equ 10      ; Read Console Buffer
 272:     -	000B'         	BDOS_GET_CON_STAT   equ 11      ; Get Console Status
 273:     -	000C'         	BDOS_VERSION        equ 12      ; Return Version Number
 274:     -	000D'         	BDOS_RESET_DISK_SYS equ 13      ; Reset Disk System
 275:     -	000E'         	BDOS_SEL_DISK       equ 14      ; Select Disk
 276:     -	000F'         	BDOS_OPEN_FILE      equ 15      ; Open File
 277:     -	0010'         	BDOS_CLOSE_FILE     equ 16      ; Close File
 278:     -	0011'         	BDOS_SEARCH_FIRST   equ 17      ; Search for first matching directory entry
 279:     -	0012'         	BDOS_SEARCH_NEXT    equ 18      ; Search for next matching directory entry
 280:     -	0013'         	BDOS_DELETE_FILE    equ 19      ; Delete File
 281:     -	0014'         	BDOS_READ_SEQ       equ 20      ; Read Sequential
 282:     -	0015'         	BDOS_WRITE_SEQ      equ 21      ; Write Sequential
 283:     -	0016'         	BDOS_MAKE_FILE      equ 22      ; Make File
 284:     -	0017'         	BDOS_RENAME_FILE    equ 23      ; Rename File
 285:     -	0018'         	BDOS_GET_LOGIN_VEC  equ 24      ; Return Login Vector
 286:     -	0019'         	BDOS_GET_CURR_DISK  equ 25      ; Return Current Disk
 287:     -	001A'         	BDOS_SET_DMA_ADDR   equ 26      ; Set DMA Address
 288:     -	001B'         	BDOS_GET_ALLOC_ADDR equ 27      ; Get Addr (Alloc)
 289:     -	001C'         	BDOS_WRITE_PROT     equ 28      ; Write Protect Disk
 290:     -	001D'         	BDOS_GET_RO_VEC     equ 29      ; Get R/O Vector
 291:     -	001E'         	BDOS_SET_FILE_ATTR  equ 30      ; Set File Attributes
 292:     -	001F'         	BDOS_GET_DPB        equ 31      ; Get Addr (Disk Parms)
 293:     -	0020'         	BDOS_GET_SET_USER   equ 32      ; Set/Get User Code
 294:     -	0021'         	BDOS_READ_RANDOM    equ 33      ; Read Random
 295:     -	0022'         	BDOS_WRITE_RANDOM   equ 34      ; Write Random
 296:     -	0023'         	BDOS_GET_FILE_SIZE  equ 35      ; Compute File Size
 297:     -	0024'         	BDOS_SET_RANDOM_REC equ 36      ; Set Random Record
 298:     -	0025'         	BDOS_RESET_DRIVES   equ 37      ; Selectively reset disc drives
 299:     -	0028'         	BDOS_WR_RND_ZFILL   equ 40      ; Write Random with Zero Fill
 300:     -	002C'         	BDOS_F_MULTISEC     equ 44      ; Set number of records to read/write at once
 301:     -	0031'         	BDOS_S_SYSVAR       equ 49      ; Access the System Control Block
 302:     -	0032'         	BDOS_S_BIOS         equ 50      ; Use the BIOS
 303:     -	003B'         	BDOS_P_LOAD         equ 59      ; Load overlay
 304:     -	003C'         	BDOS_CALL_RSX       equ 60      ; Call to RSX
 305:     -	0062'         	BDOS_DISK_CLEAN     equ 98      ; Clean up disc
 306:     -	0063'         	BDOS_F_TRUNCATE     equ 99      ; Truncate file
 307:     -	0068'         	BDOS_T_SET          equ 104     ; Set date and time
 308:     -	006C'         	BDOS_P_CODE         equ 108     ; Get/put program return code
 309:     -	006D'         	BDOS_C_MODE         equ 109     ; Set or get console mode
 310:     -	006E'         	BDOS_C_DELIMIT      equ 110     ; Get/set string delimiter
 311:     -	006F'         	BDOS_C_WRITEBLK     equ 111     ; Send block of text to console
 312:     -	0070'         	BDOS_L_WRITEBLK     equ 112     ; Send block of text to printer
 313:     -	0098'         	BDOS_F_PARSE        equ 152     ; Parse filename
 314:				;
 315:				; Functions 28 and 32 should be avoided in application programs to maintain upward
 316:				; compatibility with CP/M.
 317:				;
 318:				; Direct Console I/O (BDOS_DIRECT_CON_IO) command codes. There are additional
 319:				; codes supported by CP/M 3 (see cpm3.i).
 320:     -	00FF'         	DCONIO_GET_NO_WT    equ 0xff    ; Get character (no echo) else return zero
 321:     -	0000'         	DCONIO_PUT          equ 0x00    ; Put (write) character
 322:				;
 323:				; BDOS_S_BIOS (function 50) parameter block.
 324:     -	        	                STRUCT
 325:     -	        	                STR_BYTE SBM_FUNC       ; BIOS function (0-32)
 326:     -	        	                STR_BYTE SBM_A
 327:     -	        	                STR_BYTE SBM_C
 328:     -	        	                STR_BYTE SBM_B
 329:     -	        	                STR_BYTE SBM_E
 330:     -	        	                STR_BYTE SBM_D
 331:     -	        	                STR_BYTE SBM_L
 332:     -	        	                STR_BYTE SBM_H
 333:     -	        	                STR_END SBM_SIZE
 334:				;
 335:				;
 336:				
**** move.z80 ****
