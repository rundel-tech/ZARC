 893:				; *****************
 894:				; * TPA Variables *
 895:				; *****************
 896:				;
 897:				;
 898:				; Variables located in CP/M bank 0. Variables that must be available when the
 899:				; monitor is paged in are in the common area above.
 900:				; Note: linker "-c" option is used, so no data is initialised here.
 901:				; All code and variables must be in the code segment.
 902:				;                dseg                ; Data segment
 903:				;
 904:     -	04BF'         	bg_sp           defs 2              ; Background stack pointer
 905:				; Drive variables are named to match those in the BIOS proper to make code more
 906:				; portable.
 907:     -	04C1'         	@rdrv           defs 1              ; Drive number
 908:     -	04C2'         	@trk            defs 2              ; Selected disk @trk
 909:     -	04C4'         	@sect           defs 2              ; Selected disk sector
 910:     -	04C6'         	@dma            defs 2              ; Selected "DMA" address
 911:				;
 912:				; Generate allocation buffers for each drive, allowing two bits per block. The
 913:				; start addresses are bdos_all_<drive>.
 914:				all_buff_gen    macro d
 915:				bdos_all_`d     defs (DISK_DSM / 4) + 2  ; Allocation vector for this drive
 916:				                endm
 917:				;
 918:     -	0000'         	drive           set 0
 919:     -	        	                rept CP3_NUM_DISKS
 923:				;
 924:     -	08D0'         	dir_buffer      defs MMC_SECTOR_SIZE    ; Directory buffer
 925:     -	0AD0'         	data_buffer     defs MMC_SECTOR_SIZE    ; Data buffer
 926:				;
 927:     -	0CD0'         	                defs STACKS_SIZE    ; Local stack
 928:     -	0D50'         	lo_stk_top_p1                       ; Stack top + 1
 929:				;
 930:				;
 931:     -	0D50'         	comm_start                          ; Common area code is next
 932:     -	0D50'         	                end



