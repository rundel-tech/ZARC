 777:				;
 778:				;
 779:				;
 780:				; Define a single pointer to a XDPH for drive "d". This is required as the
 781:				; "`" mechanism only works in a macro.
 782:				ins_word        macro d
 783:				                word xdph`d
 784:				                endm
 785:				;
 786:				;
 787:				; Drive table as defined in CP/M 3 System Guide section 3.3.1. It is a list
 788:				; of pointers to the Disk Parameter Headers for each logical drive name, A
 789:				; through P.
 790:     -	0368'         	drive_table
 791:     -	0000'         	drive           set 0
 792:     -	0368' 8203A503	                rept CP3_NUM_DISKS
	              C803EB03
	              0E043104
	              54047704
 796:				;
 797:				;
 798:				; Extended Disk Parameter Headers (XDPH)
 799:				; This is based on the CP/M 2.2 DPH, but there are differences.
 800:				;
 801:				xdph_gen        macro d
 802:				; Extended parameters go *before* the label. See CP/M 3 System Guide section
 803:				; 4.7.3. The "real" BIOS will use these vectors to call the appropriate
 804:				; routines, but the loader BIOS just goes there directly as we have only one
 805:				; device.
 806:				disk_xdph_`d    word WRITE              ; Sector write
 807:				                word READ               ; Sector read
 808:				                word SELDSK             ; Drive login
 809:				                word init_drive         ; Drive initialisation
 810:				                byte d                  ; Relative drive on controller
 811:				                byte 0                  ; Media type always known
 812:				; DPH follows. See CP/M 3 System Guide section 3.3.2. Note that this differs
 813:				; slightly to the CP/M 2.2 definitions.
 814:				; DRI's DPH macro gives odd results with ZMAC, so this is hard coded along with
 815:				; the DPB.
 816:				xdph`d          word 0                  ; XLT No sector translation
 817:				                dc 9, 0                 ; BDOS scratch area
 818:				                byte 0                  ; MF Media flag
 819:				                word mc_dpb             ; DPB Pointer to DPB
 820:				                word 0                  ; CSV No check required for fixed disk
 821:				                word bdos_all_`d        ; ALV Allocation area
 822:				                word dir_bcb            ; DIRBCB Directory Buffer Control Block
 823:				                word data_bcb           ; DTABCB Data Buffer Control Block
 824:				                word 0xffff             ; HASH No directory hashing
 825:				                byte 0                  ; HBANK Hash bank (not used)
 826:				                endm
 827:				;
 828:				; Build XDPH list.
