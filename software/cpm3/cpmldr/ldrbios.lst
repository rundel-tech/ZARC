 837:				;
 838:				;
 839:				; Disk Parameter Block (DPB).
 840:				; This is similar to the CP/M 2.2 implementation, but we add the offset in the
 841:				; read and write routines rather than modifying the DPB OFF field on the fly.
 842:				; See FS_Calculations.ods for derivation. As only a single DPB is required as
 843:				; all drives are identical.
 844:				; I tried using the DRI dpb macro, but this failed due to "Not relocatable"
 845:				; errors in the arithmetic.
 846:     -	0490' 0001    	mc_dpb          word DISK_SPT   ; SPT logical sectors per track
 847:     -	0492' 04      	                byte 4          ; BSH data allocation block shift factor
 848:     -	0493' 0F      	                byte 15         ; BLM is the data allocation block mask (2^[BSH-1])
 849:     -	0494' 00      	                byte 0          ; EXM is the extent mask
 850:     -	0495' FF01    	                word DISK_DSM   ; DSM maximum block number
 851:     -	0497' FF01    	                word CPM_DIR_ENTRIES - 1    ; DRM maximum directory entry number
 852:     -	0499' FF      	                byte 0xff       ; AL0, AL1 determine reserved directory blocks
 853:     -	049A' 00      	                byte 0
 854:     -	049B' 0080    	                word 0x8000     ; CKS directory check vector (not used)
 855:     -	049D' 0000    	                word 0          ; OFF number of reserved tracks
 856:				; Assumed by PSH and PHM values
 857:     -	0001'         	                assert MMC_SECTOR_SIZE = 512
 858:     -	049F' 02      	                byte 2          ; PSH physical record shift factor
 859:     -	04A0' 03      	                byte 3          ; PHM physical record mask
 860:				;
 861:     -	0001'         	                assert ($ - mc_dpb) = CP3_DPB_SIZE
 862:				;
 863:				;
 864:				; Directory Buffer Control Block. A Buffer Control Block (BCB) locates physical
 865:				; record buffers for the BDOS. The BDOS uses the BCB to manage the physical
 866:				; record buffers during processing. More than one Disk Parameter Header can
 867:				; specify the same BCB. As this is an unbanked system (for LDRBIOS), there is
 868:				; only one BCB. This is replaced by list on a banked system.
 869:     -	04A1' FF      	dir_bcb         byte 0xff       ; DRV
 870:     -	04A2'..04A4'00	                dc 3, 0         ; REC#
 871:     -	04A5' 00      	                byte 0          ; WFLG
 872:     -	04A6' 00      	                byte 0          ; Scratch byte
 873:     -	04A7' 0000    	                word 0          ; TRACK
 874:     -	04A9' 0000    	                word 0          ; SECTOR
 875:     -	04AB' D008    	                word dir_buffer ; BUFFAD directory buffer
 876:     -	04AD' 00      	                byte 0          ; BANK
 877:     -	04AE' 0000    	                word 0          ; LINK to next BCB in a banked system or zero
 878:				;
 879:				;
 880:				; Data Buffer Control Block.
 881:     -	04B0' FF      	data_bcb        byte 0xff       ; DRV
 882:     -	04B1'..04B3'00	                dc 3, 0         ; REC#
 883:     -	04B4' 00      	                byte 0          ; WFLG
 884:     -	04B5' 00      	                byte 0          ; Scratch byte
 885:     -	04B6' 0000    	                word 0          ; @trk
 886:     -	04B8' 0000    	                word 0          ; SECTOR
 887:     -	04BA' D00A    	                word data_buffer ; BUFFAD data buffer
 888:     -	04BC' 00      	                byte 0          ; BANK
 889:     -	04BD' 0000    	                word 0          ; LINK to next BCB in a banked system or zero
