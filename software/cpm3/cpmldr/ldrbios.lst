   1:				; *******************************************************
   2:				; * CPMLDR BIOS for ZARC Z80 Computer                   *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 10/12/2022                          *
   5:				; *******************************************************
   6:				;
   7:				; This is loosely based on the ZARC CP/M 2.2 BIOS. It forms part of CPMLDR.COM
   8:				; as follows:
   9:				;
  10:				; CPMLDR.REL (supplied by DRI)
  11:				; ldrbios.rel (assembled version of this file)
  12:				; ldrbios_comm.rel (section of BIOS in common memory)
  13:				;
  14:				; These three sections are combined to produce CPMLDR.COM. This is written to
  15:				; the memory card and used to boot CP/M 3. Strangely, CPMLDR.REL does not
  16:				; appear to have any depenencies and relies on the BIOS jump table for
  17:				; communication. ldrbios_comm.cim is simply appended to the file.
  18:				;
  19:				; V1.0 - initial version.
  20:				;
  21:				;
  22:				; Initial Memory Map (CP/M Mode)
  23:				; This will become CP/M bank 0.
  24:				; 
  25:				; 0 (0000 - 3FFF): [CPM0]   writeable
  26:				; 1 (4000 - 7FFF): [CPM1]   writeable
  27:				; 2 (8000 - BFFF): [CPM2]   writeable
  28:				; 3 (C000 - FFFF): [CPMC]   writeable, supervisor (CP/M 3 common bank)
  29:				;
  30:				; ZARC banks 0 to 2 will change according to the CP/M 3 bank selected.
  31:				;
  32:				; When running CP/M 3, memory is mapped as shown above when CP/M bank 0 is
  33:				; selected. Note that ZARC bank 3 is the only one with I/O (supervisor) access.
  34:				; This one bank is maintained when calls are made to the monitor. Page numbers
  35:				; for CP/M may vary, and are allocated using the monitor's mpall function.
  36:				;
  37:				; Memory Map (Monitor Mode)
  38:				; 
  39:				; 0 (0000 - 3FFF): 3f [MONP]   read only, supervisor - monitor program
  40:				; 1 (4000 - 7FFF): 3e [MOND]   writeable - monitor variables, buffers etc.
  41:				; 2 (8000 - BFFF): (not used)
  42:				; 3 (C000 - FFFF): [CPMC]   writeable - variables and stack common with CP/M.
  43:				;
  44:				; This is the default map used by the monitor, and is selected when the monitor
  45:				; is active either for user commands or when its support routines are called.
  46:				; Pages are mapped into bank 2 (8000 - BFFF) as required to support this. Page
  47:				; 0x3f is selected in hardware when memory mapping is not active, so on reset
  48:				; the monitor (page 0x3f at address 0) is entered.
  49:				;
  50:				;
  51:				                title ZARC CPMLDR BIOS
  52:				;
  53:				;
  54:				;
  55:				; ************
  56:				; * Includes *
  57:				; ************
  58:				;
  59:				                include "macros.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/macros.i ****
   1:				; ***********************************
   2:				; * ZARC Macro Definitions          *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 30/7/2020         *
   5:				; ***********************************
   6:				;
   7:				;
   8:				;
   9:				; **********
  10:				; * Macros *
  11:				; **********
  12:				;
  13:				;
  14:				; Initialise enumeration.
  15:				; The absolute segment is used so the offsets are not marked as relocatable. This
  16:				; avoids "Not relocatable" errors.
  17:				ENUM_START      macro
  18:				                .aseg
  19:				enum_counter    set 0
  20:				                endm
  21:				;
  22:				; Invoke for each item.
  23:				ENUM            macro x
  24:				x               equ enum_counter
  25:				enum_counter    set enum_counter + 1
  26:				                endm
  27:				;
  28:				ENUM_END        macro x
  29:				x               set enum_counter    ; Set label to count of items
  30:				                .cseg
  31:				                endm
  32:				;
  33:				;
  34:				; Initialise a structure. This is used to generate offsets for data structures.
  35:				; The absolute segment is used so the offsets are not marked as relocatable. This
  36:				; avoids "Not relocatable" errors.
  37:				STRUCT          macro
  38:				                .aseg
  39:				str_offset      set 0
  40:				                endm
  41:				;
  42:				; Add a byte entry.
  43:				STR_BYTE        macro x
  44:				x               equ str_offset
  45:				str_offset      set str_offset + 1
  46:				                endm
  47:				;
  48:				; Add a word (16-bit) entry.
  49:				STR_WORD        macro x
  50:				x               equ str_offset
  51:				str_offset      set str_offset + 2
  52:				                endm
  53:				;
  54:				; Add a 3 byte (24-bit) entry.
  55:				STR_24BIT       macro x
  56:				x               equ str_offset
  57:				str_offset      set str_offset + 3
  58:				                endm
  59:				;
  60:				; Add a long (32-bit) entry.
  61:				STR_LONG        macro x
  62:				x               equ str_offset
  63:				str_offset      set str_offset + 4
  64:				                endm
  65:				;
  66:				; Add an arbitrary length entry.
  67:				STR_BLOCK       macro x, size   ; <name>, <size>
  68:				x               equ str_offset
  69:				str_offset      set str_offset + size
  70:				                endm
  71:				;
  72:				; End of structure (used to set size)
  73:				STR_END         macro x
  74:				x               equ str_offset
  75:				                .cseg
  76:				                endm
  77:				;
  78:				;
  79:				; Allocate space. This is used to generate variable addresses, affectively
  80:				; providing a new variables segment. Allocated size is kept track of separately
  81:				; to the address as the latter may overflow in certain error cases.
  82:				ALLOC           macro x
  83:				                .aseg
  84:				all_addr        set x
  85:				all_size        set 0
  86:				                endm
  87:				;
  88:				; Add a byte entry.
  89:				ALL_BYTE        macro x
  90:				x               equ all_addr
  91:				all_addr        set all_addr + 1
  92:				all_size        set all_size + 1
  93:				                endm
  94:				;
  95:				; Add a word (16-bit) entry.
  96:				ALL_WORD        macro x
  97:				x               equ all_addr
  98:				all_addr        set all_addr + 2
  99:				all_size        set all_size + 2
 100:				                endm
 101:				;
 102:				; Add a 3 byte (24-bit) entry.
 103:				ALL_24BIT       macro x
 104:				x               equ all_addr
 105:				all_addr        set all_addr + 3
 106:				all_size        set all_size + 3
 107:				                endm
 108:				;
 109:				; Add a long (32-bit) entry.
 110:				ALL_LONG        macro x
 111:				x               equ all_addr
 112:				all_addr        set all_addr + 4
 113:				all_size        set all_size + 4
 114:				                endm
 115:				;
 116:				; Add an arbitrary length entry.
 117:				ALL_BLOCK       macro x, size   ; <name>, <size>
 118:				x               equ all_addr
 119:				all_addr        set all_addr + size
 120:				all_size        set all_size + size
 121:				                endm
 122:				;
 123:				; End of allocated space. Returns size of block.
 124:				ALL_END         macro x
 125:				x               equ all_size
 126:				                .cseg
 127:				                endm
 128:				;
 129:				;
 130:				; Calculate offsets into jump tables.
 131:				; The absolute segment is used so the offsets are not marked as relocatable. This
 132:				; avoids "Not relocatable" errors.
 133:				JPTBL_START     macro x
 134:				                .aseg
 135:				jptbl_addr      set x               ; Set start address
 136:				                endm
 137:				;
 138:				; Invoke for each item.
 139:				JPTBL_ENTRY     macro x
 140:				x               equ jptbl_addr
 141:				jptbl_addr      set jptbl_addr + 3
 142:				                endm
 143:				;
 144:				; Invoke for a data block in the jump table
 145:				JPTBL_BLOCK     macro x, size   ; <name>, <size>
 146:				x               equ jptbl_addr
 147:				jptbl_addr      set jptbl_addr + size
 148:				                endm
 149:				;
 150:				JPTBL_END       macro x
 151:				x               set jptbl_addr      ; Set label to next address
 152:				                .cseg
 153:				                endm
 154:				;
 155:				;
 156:				; Define bits and masks. This is inspired by the Commodore Amiga BITDEF mechanism.
 157:				; Given:
 158:				; BITDEF I2C_CSR_STOP, 2
 159:				; Yields:
 160:				; I2C_CSR_STOP_BIT  EQU 2       ; Bit number
 161:				; I2C_CSR_STOP_MASK EQU 1<<2    ; Bit mask
 162:				BITDEF          macro n, b      ; <Name>, <bit>
 163:				n`_BIT          equ b
 164:				n`_MASK         equ 1 << b
 165:				                endm
 166:				;
 167:				;
 168:				; Force alignment. This asserts an appropriate number of zero bytes to achieve
 169:				; the required alignment. Note that these macros cannot work for relocatable
 170:				; files.
 171:				; 16-bit
 172:				ALIGN_WORD      macro
 173:				                if $ and 1
 174:				                    byte 0
 175:				                endif
 176:				                endm
 177:				;
 178:				; 32-bit
 179:				ALIGN_LONG      macro
 180:				                ALIGN_WORD
 181:				                if $ and 2
 182:				                    byte 0, 0
 183:				                endif
 184:				                endm
 185:				;
 186:				;
 187:				; Write message to console (short for "call conwms").
 188:				CON_WR_MSG      macro
 189:				                rst 08
 190:				                endm
 191:				;
 192:				;
 193:				; Write character to console (short for "call conwch").
 194:				CON_WR_CHAR     macro
 195:				                rst 16
 196:				                endm
 197:				
**** ldrbios.z80 ****
