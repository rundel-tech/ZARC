 601: 2783+4	02AD' AF      	                xor a
 602: 2787+10	02AE' C9      	                ret
 603: 2797+7	02AF' 3EFF    	ttyist_char     ld a, 0xff              ; Flag character available
 604: 2804+10	02B1' C9      	                ret
 605:				;
 606:				;
 607:				; Input character. This will wait if no character is available.
 608: 2814+13	02B2' 3A0500  	tty_in          ld a, (itenfl)          ; Fetch int. enable flag (I/O mode)
 609: 2827+4	02B5' A7      	                and a
 610: 2831+7+5	02B6' 281A    	                jr z, s1rch_in
 611:				; In normal mode, we will poll the serial receiver to await a character
 612:				; rather than having the hardware stop the machine. This latter method prevents
 613:				; interrupts from being serviced. Basic mode is useful if there are issues with
 614:				; the interrupt system. If the interrupts are disabled, this clearly cannot work
 615:				; so the system panics.
 616: 2838+13	02B8' 3A0600  	                ld a, (itdsct)          ; DI nest count
 617: 2851+4	02BB' A7      	                and a
 618: 2855+10+7	02BC' C46F06  	                call nz, bpanic         ; Panic if count != 0
 619:				;
 620:				; The objective of this code is to have the machine halted until we can complete
 621:				; the operation. A simple wait loop would be simpler, but would give no indication
 622:				; that the machine is stalled.
 623:				; We can enable and disable interrupts directly here because we know the DI nest
 624:				; count is zero.
 625: 2865+4	02BF' F3      	                di
 626: 2869+11	02C0' DB10    	s1rch_loop      in a, (IOA_SER1_CSR)     ; Read status
