1844:				;
1845:				;
1846:				; Disk Parameter Block (DPB).
1847:				; This is used for all drives, but the OFF entry is adjusted by SELDSK to the
1848:				; appropriate value.
1849:				; See FS_Calculations.ods for derivation.
1850:     -	0939' 0001    	disk_dpb        word DISK_SPT   ; SPT sectors per track
1851:     -	093B' 04      	                byte 4          ; BSH data allocation block shift factor
1852:     -	093C' 0F      	                byte 15         ; BLM is the data allocation block mask (2^[BSH-1])
1853:     -	093D' 00      	                byte 0          ; EXM is the extent mask
1854:     -	093E' FF01    	                word DISK_DSM   ; DSM maximum block number
1855:     -	0940' FF01    	                word 511        ; DRM maximum directory entry number
1856:     -	0942' FF      	                byte 0xff       ; AL0, AL1 determine reserved directory blocks
1857:     -	0943' 00      	                byte 0
1858:     -	0944' 0000    	                word 0          ; CKS is the size of the directory check vector
1859:     -	0946' 0000    	disk_dpb_off    word 0          ; OFF number of reserved tracks
1860:				;
1861:				; Anything after this point cannot be assumed to be loaded from MMC.
1862:				; The following won't work when using relocatable files.
1863:				;                assert $ <= BIOS_START + BIOS_MAX_SIZE  ; Don't exceed size allocation
