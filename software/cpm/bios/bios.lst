**** bios.z80 ****
  71:				                include "cpm.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm.i ****
   1:				; *******************************************************
   2:				; * ZARC Monitor CP/M 2.2 Definitions                   *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 26/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Definitions related to CP/M running under the monitor programme. It may also
   8:				; be used for CP/M applications.
   9:				;
  10:				; Note that ld80 only considers the first six characters of labels significant.
  11:				;
  12:				; The following conditionals are intended to allow the same include file to be
  13:				; used in the defining module and elsewhere as required. Some includes are used
  14:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  15:				; the extern and public statements are not desirable.
  16:				;
  17:     -	0000'         	            ifdef monitor           ; Meaningful for monitor build only
  30:				            endif
  31:				;
  32:				;
  33:				;
  34:				; ****************
  35:				; * Memory Usage *
  36:				; ****************
  37:				;
  38:				;
  39:				; Note: memory banks are allocated by the monitor's initialisation code.
  40:     -	0004'         	MMAP_CPM_PAGES      equ 4               ; Number of 16 kB pages
  41:				;
  42:				; The MS byte of INT_VEC_TABLE comes from the Z80 I register, and the LS byte
  43:				; from the FPGA. The 0xe0 offset is chosen to allow the table to reside at the
  44:				; top of memory (0xffe0 to 0xffff).
  45:     -	FFE0'         	INT_VEC_TABLE   equ 0xffe0              ; Interrupt mode 2 vector table
  46:				;
  47:				; Copied from CP/M manual appendix A.
  48:				; MSIZE             equ 64              ; CP/M version memory size in kilobytes
  49:				;
  50:				; "BIAS" is the address offset from 0x3400 for memory systems other than 16 K.
  51:				;BIAS               equ (MSIZE-20) * 1024
  52:     -	A200'         	CPM_BIAS            equ 0xa200          ; For CompuPro64K_CPM
  53:     -	D600'         	CCP_START           equ 0x3400 + CPM_BIAS   ; Base of CCP
  54:     -	DE06'         	BDOS_START          equ CCP_START + 0x0806  ; Base of BDOS
  55:     -	EC00'         	BIOS_START          equ CCP_START + 0x1600  ; Base of BIOS
  56:     -	002C'         	BIOS_CPM_START_SEC  equ 44              ; First CP/M sector of BIOS
  57:     -	1000'         	BIOS_MAX_SIZE       equ 4096            ; 2 KB allocation for BIOS stored on MMC (ZARC)
  58:     -	0100'         	TPA_START           equ 0x0100          ; Transient Programme Area
  59:				;
  60:				; Page zero.
  61:     -	0003'         	IOBYTE              equ 0x0003          ; Intel I/O byte
  62:     -	0004'         	CDISK               equ 0x0004          ; Current disk (0="A") & user no. (in high nibble)
  63:     -	005C'         	FCB1                equ 0x005c          ; Default FCB 1
  64:     -	006C'         	FCB2                equ 0x006c          ; Default FCB 2 (overwritten if FCB 1 is opened)
  65:				; Default 128-byte disk buffer, also filled with the command line when a transient
  66:				; is loaded under the CCP.
  67:     -	0080'         	DEF_BUFFER          equ 0x80
  68:     -	0080'         	DEF_BUFFER_SIZE     equ 0x80
  69:				;
  70:				; IOBYTE bit definitions.
  71:     -	0003'         	IOB_CON_MASK        equ 0x03
  72:     -	000C'         	IOB_RDR_MASK        equ 0x0c
  73:     -	0030'         	IOB_PUN_MASK        equ 0x30
  74:     -	00C0'         	IOB_LST_MASK        equ 0xc0
  75:				;
  76:				; BIOS option bits.
  77:     -	        	BITDEF BIOS_OPT_DEBUG, 0                ; Enable BIOS debugging messages
  78:     -	        	BITDEF BIOS_OPT_NOINTS, 1               ; Disables interrupts (use basic I/O mode)
  79:     -	        	BITDEF BIOS_OPT_RAWCON, 2               ; Disables ADM-3A to VT-100 translation
  80:				;
  81:				;
  82:				;
  83:				; ***************
  84:				; * Disk System *
  85:				; ***************
  86:				;
  87:				;
  88:				; Note: NUM_DISKS reduced to 9 from 16 in preparation for adding CP/M 3 support.
  89:     -	0080'         	CPM_SECTOR_SIZE     equ 128             ; CP/M disk sector size
  90:     -	0009'         	NUM_DISKS           equ 9               ; Number of disk drives
  91:     -	0010'         	NUM_DISKS_MAX       equ 16              ; Maximum number of disk drives
  92:     -	0000'         	CPM_SYS_SIZE        equ 1024 * 1024     ; System area size (bytes)
  93:     -	0000'         	CPM_DISK_SIZE       equ 1024 * 1024     ; Disk size (bytes)
  94:     -	0800'         	CPM_BLOCK_SIZE      equ 2048            ; Allocation block size (bytes)
  95:     -	0200'         	CPM_DIR_ENTRIES     equ 512             ; Number of directory entries
  96:     -	0008'         	FILENAME_SIZE       equ 8               ; Filename size
  97:     -	0003'         	FILEEXT_SIZE        equ 3               ; File extension size
  98:     -	001A'         	FILE_EOF            equ 0x1a            ; End of file (^Z)
  99:     -	000F'         	MAX_USER            equ 15              ; Maximum user number
 100:				;
 101:     -	0001'         	BDOS_READ_SEQ_EOF   equ 1               ; Sequential read EOF error code
 102:				;
 103:				; CP/M 2.2 Disk Parameter Header (DPH) structure.
 104:     -	        	                STRUCT
 105:     -	        	                STR_WORD DPH_XLT        ; Address of sector translation table
 106:     -	        	                STR_WORD DPH_SCRATCH0   ; BDOS scratch area
 107:     -	        	                STR_WORD DPH_SCRATCH1
 108:     -	        	                STR_WORD DPH_SCRATCH2
 109:     -	        	                STR_WORD DPH_DIRBF      ; BDOS directory scratch area
 110:     -	        	                STR_WORD DPH_DPB        ; Pointer to DPB
 111:     -	        	                STR_WORD DPH_CSV        ; Pointer to the directory checksum vector
 112:     -	        	                STR_WORD DPH_ALV        ; Pointer to the allocation vector
 113:     -	        	                STR_END DPH_SIZE
 114:				;
 115:				;
 116:				; CP/M 2.2 Disk Parameter Block (DPB) structure.
 117:     -	        	                STRUCT
 118:     -	        	                STR_WORD DPB_SPT        ; Number of 128-byte records per track
 119:     -	        	                STR_BYTE DPB_BSH        ; Block shift. 3 => 1k, 4 => 2k, 5 => 4k....
 120:     -	        	                STR_BYTE DPB_BLM        ; Block mask. 7 => 1k, 0Fh => 2k, 1Fh => 4k...
 121:     -	        	                STR_BYTE DPB_EXM        ; Extent mask
 122:     -	        	                STR_WORD DPB_DSM        ; Maximum block number
 123:     -	        	                STR_WORD DPB_DRM        ; Maximum directory entry number
 124:     -	        	                STR_BYTE DPB_AL0        ; Directory allocation bitmap
 125:     -	        	                STR_BYTE DPB_AL1
 126:     -	        	                STR_WORD DPB_CKS        ; Checksum vector size, 0 for a fixed disc
 127:     -	        	                STR_WORD DPB_OFF        ; Offset, number of reserved tracks
 128:     -	        	                STR_END DPB_SIZE
 129:				;
 130:				;
 131:				; Directory entry structure.
 132:     -	        	                STRUCT
 133:     -	        	                STR_BYTE DIRE_USER      ; User number. 0xe5 if entry unused
 134:     -	        	                STR_BLOCK DIRE_NAME, FILENAME_SIZE  ; Filename
 135:     -	        	                STR_BLOCK DIRE_TYP, FILEEXT_SIZE    ; File type
 136:     -	        	                STR_BYTE DIRE_EX        ; Extent counter, low byte (0-31)
 137:     -	        	                STR_BYTE DIRE_S1        ; Reserved, set to 0
 138:     -	        	                STR_BYTE DIRE_S2        ; Extent counter, high byte
 139:     -	        	                STR_BYTE DIRE_RC        ; Record count (low byte)
 140:     -	        	                STR_BLOCK DIRE_ALLOC, 16 ; Associated block numbers
 141:     -	        	                STR_END DIRE_SIZE
 142:				;
 143:     -	0001'         	                assert DIRE_SIZE = 0x20
 144:				;
 145:				;
 146:				; File Control Block (FCB) structure.
 147:     -	        	                STRUCT
 148:     -	        	                STR_BYTE FCB_DRIVE      ; Drive. 0 for default, 1-16 for A-P
 149:     -	        	                STR_BLOCK FCB_NAME, FILENAME_SIZE   ; Filename in ASCII upper-case
 150:     -	        	                STR_BLOCK FCB_TYP, FILEEXT_SIZE     ; File type
 151:     -	        	                STR_BYTE FCB_EX         ; Current extent (*)
 152:     -	        	                STR_BYTE FCB_S1         ; Reserved (*)
 153:     -	        	                STR_BYTE FCB_S2         ; Extent high byte (*)
 154:     -	        	                STR_BYTE FCB_RC         ; Record count (*)
 155:     -	        	                STR_BLOCK FCB_ALLOC, 16 ; Associated block numbers
 156:     -	        	                STR_BYTE FCB_CR         ; Current record within extent
 157:     -	        	                STR_BLOCK FCB_RECORD, 3 ; Record number (low byte first)
 158:     -	        	                STR_END FCB_SIZE
 159:				;
 160:				; * - Set this to 0 when opening a file and then leave it to CP/M. You can
 161:				; rewind a file by setting EX, RC, S2 and CR to 0.
 162:				;
 163:				;
 164:				;
 165:				; **************
 166:				; * BIOS Calls *
 167:				; **************
 168:				;
 169:				;
 170:				; Calculate offsets into jump tables. Entries here must match the jump table in
 171:				; the BIOS. The base address of the BIOS must be added to these addresses. A
 172:				; call routine might look like:
 173:				;
 174:				; Call BIOS, allowing for its unknown base address.
 175:				; Call with:
 176:				; BC - operand (depends on BIOS function called)
 177:				; DE - operand (depends on BIOS function called)
 178:				; HL - offset for the routine (e.g. BIOS_CONIN)
 179:				; call_bios       push de
 180:				;                 ex de, hl
 181:				;                 ld hl, (1)              ; Find WBOOT (warm boot) address
 182:				;                 add hl, de              ; Add offset
 183:				;                 pop de
 184:				;                 jp (hl)                 ; Jump to BIOS then return to caller
 185:				;
 186:				; The above method is a bit clumsy, but then application code shouldn't normally
 187:				; call the BIOS directly.
 188:				;
 189:     -	        	    JPTBL_START 0                   ; Generate offsets as BIOS_START isn't always known
 190:				;
 191:				; Note - cold start routine omitted to align with use of address at (1) to find BIOS.
 192:     -	        	    JPTBL_ENTRY BIOS_WBOOT          ; Warm boot - reload command processor
 193:     -	        	    JPTBL_ENTRY BIOS_CONST          ; Console status
 194:     -	        	    JPTBL_ENTRY BIOS_CONIN          ; Console input
 195:     -	        	    JPTBL_ENTRY BIOS_CONOUT         ; Console output
 196:     -	        	    JPTBL_ENTRY BIOS_PLIST          ; Printer output
 197:     -	        	    JPTBL_ENTRY BIOS_PUNCH          ; Paper tape punch output
 198:     -	        	    JPTBL_ENTRY BIOS_READER         ; Paper tape reader input
 199:     -	        	    JPTBL_ENTRY BIOS_HOME           ; Move disc head to track 0
 200:     -	        	    JPTBL_ENTRY BIOS_SELDSK         ; Select disc drive
 201:     -	        	    JPTBL_ENTRY BIOS_SETTRK         ; Set track number
 202:     -	        	    JPTBL_ENTRY BIOS_SETSEC         ; Set sector number
 203:     -	        	    JPTBL_ENTRY BIOS_SETDMA         ; Set DMA address
 204:     -	        	    JPTBL_ENTRY BIOS_READ           ; Read a sector
 205:     -	        	    JPTBL_ENTRY BIOS_WRITE          ; Write a sector
 206:				; CP/M 2 functions.
 207:     -	        	    JPTBL_ENTRY BIOS_LISTST         ; Status of list device
 208:     -	        	    JPTBL_ENTRY BIOS_SECTRAN        ; Sector translation for skewing
 209:				; CP/M 3 functions (not supported yet). From https://www.seasip.info/Cpm/bios.html
 210:     -	        	    JPTBL_ENTRY BIOS_CONOST         ; Status of console output
 211:     -	        	    JPTBL_ENTRY BIOS_AUXIST         ; Status of auxiliary input
 212:     -	        	    JPTBL_ENTRY BIOS_AUXOST         ; Status of auxiliary output
 213:     -	        	    JPTBL_ENTRY BIOS_DEVTBL         ; Address of devices table
 214:     -	        	    JPTBL_ENTRY BIOS_DEVINI         ; Initialise a device
 215:     -	        	    JPTBL_ENTRY BIOS_DRVTBL         ; Address of discs table
 216:     -	        	    JPTBL_ENTRY BIOS_MULTIO         ; Read/write multiple sectors
 217:     -	        	    JPTBL_ENTRY BIOS_FLUSH          ; Flush host buffers
 218:     -	        	    JPTBL_ENTRY BIOS_MOVE           ; Move a block of memory
 219:     -	        	    JPTBL_ENTRY BIOS_TIME           ; Real time clock
 220:     -	        	    JPTBL_ENTRY BIOS_SELMEM         ; Select memory bank
 221:     -	        	    JPTBL_ENTRY BIOS_SETBNK         ; Select bank for DMA operation
 222:     -	        	    JPTBL_ENTRY BIOS_XMOVE          ; Preload banks for MOVE
 223:     -	        	    JPTBL_ENTRY BIOS_USERF          ; System-depedent functions
 224:     -	        	    JPTBL_ENTRY BIOS_RESERV1        ; Reserved
 225:     -	        	    JPTBL_ENTRY BIOS_RESERV2        ; Reserved
 226:				; ZARC-specific items.
 227:     -	        	    JPTBL_BLOCK BIOS_ID, 3          ; BIOS ID ("ZRC")
 228:     -	        	    JPTBL_BLOCK BIOS_VER, 3         ; Version (see below)
 229:     -	        	    JPTBL_ENTRY BIOS_STARTUP        ; CP/M startup entry point
 230:     -	        	    JPTBL_ENTRY BIOS_MON_CALL       ; Call monitor function
 231:     -	        	    JPTBL_ENTRY BIOS_SUPER          ; Set supervisor state
 232:     -	        	    JPTBL_ENTRY BIOS_INT_DISABLE    ; Disable interrupts and keep count
 233:     -	        	    JPTBL_ENTRY BIOS_INT_ENABLE     ; Enable interrupts if safe
 234:     -	        	    JPTBL_ENTRY BIOS_TIRD           ; Read time and date (ZARC format)
 235:     -	        	    JPTBL_ENTRY BIOS_SET_TIMER      ; Set timer
 236:     -	        	    JPTBL_ENTRY BIOS_GET_TIMER      ; Get timer
 237:				;
 238:     -	        	    JPTBL_END BIOS_JPTBL_NEXT
 239:				;
 240:				; BIOS_VER is <reserved (zero)>, <major version>, <minor version>. The reserved
 241:				; byte may flag capabilities at some point.
 242:				;
 243:				;
 244:				;
 245:				; **************
 246:				; * BDOS Calls *
 247:				; **************
 248:				;
 249:				;
 250:				; From http://www.gaby.de/cpm/manuals/archive/cpm22htm/ch5.htm#Section_5.2
 251:				; In general, the function number is passed in register C with the information
 252:				; address in the double byte pair DE. Single byte values are returned in register
 253:				; A, with double byte values returned in HL. A zero value is returned when the
 254:				; function number is out of range. For reasons of compatibility, register A = L
 255:				; and register B = H upon return in all cases. Example call:
 256:				;   ld c, BDOS_CONIN    ; Read next character
 257:				;   call BDOS           ; Return character in A
 258:				;
 259:     -	0005'         	BDOS        equ 5               ; BDOS entry point
 260:				;
 261:     -	0000'         	BDOS_SYS_RST        equ 0       ; System Reset
 262:     -	0001'         	BDOS_CON_IN         equ 1       ; Console Input
 263:     -	0002'         	BDOS_CON_OUT        equ 2       ; Console Output
 264:     -	0003'         	BDOS_RDR_IN         equ 3       ; Reader Input
 265:     -	0004'         	BDOS_PUN_OUT        equ 4       ; Punch Output
 266:     -	0005'         	BDOS_LST_OUT        equ 5       ; List Output
 267:     -	0006'         	BDOS_DIRECT_CON_IO  equ 6       ; Direct Console I/O
 268:     -	0007'         	BDOS_GET_IO_BYTE    equ 7       ; Get I/O Byte
 269:     -	0008'         	BDOS_SET_IO_BYTE    equ 8       ; Set I/O Byte
 270:     -	0009'         	BDOS_PRINT_STRING   equ 9       ; Print String
 271:     -	000A'         	BDOS_READ_CON_BUFF  equ 10      ; Read Console Buffer
 272:     -	000B'         	BDOS_GET_CON_STAT   equ 11      ; Get Console Status
 273:     -	000C'         	BDOS_VERSION        equ 12      ; Return Version Number
 274:     -	000D'         	BDOS_RESET_DISK_SYS equ 13      ; Reset Disk System
 275:     -	000E'         	BDOS_SEL_DISK       equ 14      ; Select Disk
 276:     -	000F'         	BDOS_OPEN_FILE      equ 15      ; Open File
 277:     -	0010'         	BDOS_CLOSE_FILE     equ 16      ; Close File
 278:     -	0011'         	BDOS_SEARCH_FIRST   equ 17      ; Search for first matching directory entry
 279:     -	0012'         	BDOS_SEARCH_NEXT    equ 18      ; Search for next matching directory entry
 280:     -	0013'         	BDOS_DELETE_FILE    equ 19      ; Delete File
 281:     -	0014'         	BDOS_READ_SEQ       equ 20      ; Read Sequential
 282:     -	0015'         	BDOS_WRITE_SEQ      equ 21      ; Write Sequential
 283:     -	0016'         	BDOS_MAKE_FILE      equ 22      ; Make File
 284:     -	0017'         	BDOS_RENAME_FILE    equ 23      ; Rename File
 285:     -	0018'         	BDOS_GET_LOGIN_VEC  equ 24      ; Return Login Vector
 286:     -	0019'         	BDOS_GET_CURR_DISK  equ 25      ; Return Current Disk
 287:     -	001A'         	BDOS_SET_DMA_ADDR   equ 26      ; Set DMA Address
 288:     -	001B'         	BDOS_GET_ALLOC_ADDR equ 27      ; Get Addr (Alloc)
 289:     -	001C'         	BDOS_WRITE_PROT     equ 28      ; Write Protect Disk
 290:     -	001D'         	BDOS_GET_RO_VEC     equ 29      ; Get R/O Vector
 291:     -	001E'         	BDOS_SET_FILE_ATTR  equ 30      ; Set File Attributes
 292:     -	001F'         	BDOS_GET_DPB        equ 31      ; Get Addr (Disk Parms)
 293:     -	0020'         	BDOS_GET_SET_USER   equ 32      ; Set/Get User Code
 294:     -	0021'         	BDOS_READ_RANDOM    equ 33      ; Read Random
 295:     -	0022'         	BDOS_WRITE_RANDOM   equ 34      ; Write Random
 296:     -	0023'         	BDOS_GET_FILE_SIZE  equ 35      ; Compute File Size
 297:     -	0024'         	BDOS_SET_RANDOM_REC equ 36      ; Set Random Record
 298:     -	0025'         	BDOS_RESET_DRIVES   equ 37      ; Selectively reset disc drives
 299:     -	0028'         	BDOS_WRITE_RAN_ZFILL equ 40     ; Write Random with Zero Fill
 300:				;
 301:				; Functions 28 and 32 should be avoided in application programs to maintain upward
 302:				; compatibility with CP/M.
 303:				;
 304:				; Direct Console I/O (BDOS_DIRECT_CON_IO) command codes. There are additional
 305:				; codes supported by CP/M 3 (see cpm3.i).
 306:     -	00FF'         	DCONIO_GET_NO_WT    equ 0xff    ; Get character (no echo) else return zero
 307:     -	0000'         	DCONIO_PUT          equ 0x00    ; Put (write) character
 308:				;
 309:				
**** bios.z80 ****
  72:				                include "cpm3.i"        ; Required for CP/M 3 drive A: access
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm3.i ****
   1:				; *******************************************************
   2:				; * ZARC Monitor CP/M 3 Definitions                     *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 26/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Definitions related CP/M running under the monitor programme. It may also
   8:				; be used for CP/M applications.
   9:				;
  10:				; This include file contains defintions specific to CP/M 3. It is not a
  11:				; replacement for cpm.i, but rather an addition to it.
  12:				;
  13:				; Note that ld80 only considers the first six characters of labels significant.
  14:				;
  15:				; The following conditionals are intended to allow the same include file to be
  16:				; used in the defining module and elsewhere as required. Some includes are used
  17:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  18:				; the extern and public statements are not desirable.
  19:				;
  20:     -	0000'         	            ifdef monitor           ; Meaningful for monitor build only
  31:				            endif
  32:				;
  33:				;
  34:				;
  35:				; ****************
  36:				; * Memory Usage *
  37:				; ****************
  38:				;
  39:				;
  40:				; Note: memory banks are allocated by the monitor's initialisation code.
  41:     -	0004'         	MMAP_CP3_BANKS      equ 4               ; Number of CP/M 3 banks
  42:     -	000D'         	MMAP_CP3_PAGES      equ (3 * MMAP_CP3_BANKS) + 1    ; Number of 16 kB pages
  43:     -	0000'         	MMAP_CP3_BK0_ST     equ 0               ; CP/M bank 0 first page
  44:     -	0003'         	MMAP_CP3_BK1_ST     equ 3               ; CP/M bank 1 first page
  45:     -	0006'         	MMAP_CP3_BK2_ST     equ 6               ; CP/M bank 2 first page
  46:     -	0009'         	MMAP_CP3_BK3_ST     equ 9               ; CP/M bank 3 first page
  47:     -	000C'         	MMAP_CP3_COMM_PG    equ 0xc             ; CP/M common bank
  48:				;
  49:				;
  50:				;
  51:				; ***************
  52:				; * Disk System *
  53:				; ***************
  54:				;
  55:				;
  56:     -	0013'         	CPMLDR_START_SEC    equ 19              ; First MMC sector of CPMLDR
  57:				; CPMLDR_MAX_SIZE must be a multiple of MMC_SECTOR_SIZE (512).
  58:     -	2800'         	CPMLDR_MAX_SIZE     equ 10240           ; 10 KB allocation for CPMLDR
  59:     -	0100'         	TPA_START           equ 0x0100          ; Transient Programme Area
  60:     -	0008'         	CP3_NUM_DISKS       equ 8               ; Number of disk drives
  61:     -	0010'         	CP3_NUM_DISKS_MAX   equ 16              ; Maximum number of disk drives
  62:				; CP/M 3 drive A is CP/M 2.2 drive P to allow for initialisation.
  63:     -	0008'         	CP3_DRIVE_A         equ 8               ; Drive A MB offset
  64:     -	0001'         	CP3_DRIVE_B         equ 1               ; Drives B to H MB offset
  65:     -	0019'         	CP3_DPH_SIZE        equ 25              ; Disk Parameter Header size
  66:     -	0023'         	CP3_XDPH_SIZE       equ CP3_DPH_SIZE + 10   ; Extended Disk Parameter Header size
  67:     -	0008'         	DLBLE_NAME_SIZE     equ 8               ; Disk label name size
  68:     -	0003'         	DLBLE_TYP_SIZE      equ 3               ; Disk label type size
  69:     -	0008'         	DIR_PWD_SIZE        equ 8               ; Directory password size
  70:				;
  71:				;
  72:				; CP/M 3 Disk Parameter Block (DPB) structure.
  73:     -	        	                STRUCT
  74:     -	        	                STR_WORD CP3_DPB_SPT        ; Number of 128-byte records per track
  75:     -	        	                STR_BYTE CP3_DPB_BSH        ; Block shift. 3 => 1k, 4 => 2k, 5 => 4k....
  76:     -	        	                STR_BYTE CP3_DPB_BLM        ; Block mask. 7 => 1k, 0Fh => 2k, 1Fh => 4k...
  77:     -	        	                STR_BYTE CP3_DPB_EXM        ; Extent mask
  78:     -	        	                STR_WORD CP3_DPB_DSM        ; Maximum block number
  79:     -	        	                STR_WORD CP3_DPB_DRM        ; Maximum directory entry number
  80:     -	        	                STR_BYTE CP3_DPB_AL0        ; Directory allocation bitmap
  81:     -	        	                STR_BYTE CP3_DPB_AL1
  82:     -	        	                STR_WORD CP3_DPB_CKS        ; Checksum vector size, 0 for a fixed disc
  83:     -	        	                STR_WORD CP3_DPB_OFF        ; Offset, number of reserved tracks
  84:     -	        	                STR_BYTE CP3_DPB_PSH        ; Physical record shift factor
  85:     -	        	                STR_BYTE CP3_DPB_PHM        ; Physical record mask
  86:     -	        	                STR_END CP3_DPB_SIZE
  87:				;
  88:				;
  89:				; Directory date stamp structure.
  90:     -	        	                STRUCT
  91:     -	        	                STR_WORD DSTAMP_DAY         ; Julien day number (1 = 1 Jan 78)
  92:     -	        	                STR_BYTE DSTAMP_HOUR        ; BCD hour
  93:     -	        	                STR_BYTE DSTAMP_MIN         ; BCD minute
  94:     -	        	                STR_END DSTAMP_SIZE 
  95:				;
  96:     -	0001'         	                assert DSTAMP_SIZE = 4
  97:				;
  98:				;
  99:				; Disk label structure.
 100:     -	        	                STRUCT
 101:     -	        	                STR_BYTE DLBLE_USER      ; "User number" (0x20)
 102:     -	        	                STR_BLOCK DLBLE_NAME, DLBLE_NAME_SIZE ; Name
 103:     -	        	                STR_BLOCK DLBLE_TYP, DLBLE_TYP_SIZE   ; Label type
 104:     -	        	                STR_BYTE DLBLE_LB        ; Label byte (flags)
 105:     -	        	                STR_BYTE DLBLE_PB        ; Password decode byte
 106:     -	        	                STR_BYTE DLBLE_RR0       ; Reserved, should be zero
 107:     -	        	                STR_BYTE DLBLE_RR1
 108:     -	        	                STR_BLOCK DLBLE_PWD, DIR_PWD_SIZE    ; Password
 109:     -	        	                STR_BLOCK DLBLE_CREATE_DATE, DSTAMP_SIZE ; Create date stamp
 110:     -	        	                STR_BLOCK DLBLE_UPDATE_DATE, DSTAMP_SIZE ; Update date stamp
 111:     -	        	                STR_END DLBLE_SIZE
 112:				;
 113:     -	0001'         	                assert DLBLE_SIZE = 0x20
 114:				;
 115:				;
 116:				; Date stamp directory entry structure.
 117:     -	        	                STRUCT
 118:     -	        	                STR_BYTE DSTE_USER      ; "User number" (0x21)
 119:     -	        	                STR_BLOCK DSTE_F1_DATE, DSTAMP_SIZE ; File 1 *
 120:     -	        	                STR_BLOCK DSTE_F1_UPD_DATE, DSTAMP_SIZE ; File 1 update date
 121:     -	        	                STR_BYTE DSTE_M1        ; File 1 password mode
 122:     -	        	                STR_BYTE DSTE_R0        ; Reserved, should be zero
 123:     -	        	                STR_BLOCK DSTE_F2_DATE, DSTAMP_SIZE ; File 2 *
 124:     -	        	                STR_BLOCK DSTE_F2_UPD_DATE, DSTAMP_SIZE ; File 2 update date
 125:     -	        	                STR_BYTE DSTE_M2        ; File 2 password mode
 126:     -	        	                STR_BYTE DSTE_R1        ; Reserved, should be zero
 127:     -	        	                STR_BLOCK DSTE_F3_DATE, DSTAMP_SIZE ; File 3 *
 128:     -	        	                STR_BLOCK DSTE_F3_UPD_DATE, DSTAMP_SIZE ; File 3 update date
 129:     -	        	                STR_BYTE DSTE_M3        ; File 3 password mode
 130:     -	        	                STR_BYTE DSTE_R2        ; Reserved, should be zero
 131:     -	        	                STR_BYTE DSTE_R3
 132:     -	        	                STR_END DSTE_SIZE
 133:				;
 134:				; * Create OR access date stamp.
 135:				;
 136:     -	0001'         	                assert DSTE_SIZE = 0x20
 137:				;
 138:				;
 139:				; Password directory entry structure.
 140:     -	        	                STRUCT
 141:     -	        	                STR_BYTE DPWDE_USER     ; User number
 142:     -	        	                STR_BLOCK DPWDE_NAME, FILENAME_SIZE ; Filename
 143:     -	        	                STR_BLOCK DPWDE_TYP, FILEEXT_SIZE   ; File type
 144:     -	        	                STR_BYTE DPWDE_PM       ; Mode byte
 145:     -	        	                STR_BYTE DPWDE_PB       ; Decode byte
 146:     -	        	                STR_BLOCK DPWDE_RESVD1, 2
 147:     -	        	                STR_BLOCK DPWDE_PWD, DIR_PWD_SIZE   ; Password
 148:     -	        	                STR_BLOCK DPWDE_RESVD2, 8
 149:     -	        	                STR_END DPWDE_SIZE
 150:				;
 151:     -	0001'         	                assert DPWDE_SIZE = 0x20
 152:				;
 153:				; DPWDE_PM bits.
 154:     -	        	BITDEF DPWDE_PM_DEL, 5                 ; Password required to delete file
 155:     -	        	BITDEF DPWDE_PM_WRITE, 6               ; Password required to write to file
 156:     -	        	BITDEF DPWDE_PM_READ, 7                ; Password required to read file
 157:				;
 158:				;
 159:				;
 160:				; ********
 161:				; * BIOS *
 162:				; ********
 163:				;
 164:				;
 165:				; PUNCH and READER are replaced by AUXOUT and AUXIN for CP/M 3. This allows the
 166:				; use of either name.
 167:     -	000F'         	BIOS_AUXOUT         equ BIOS_PUNCH
 168:     -	0012'         	BIOS_AUXIN          equ BIOS_READER
 169:				;
 170:				;
 171:				;
 172:				; ********
 173:				; * BDOS *
 174:				; ********
 175:				;
 176:				;
 177:				; Direct Console I/O (BDOS_DIRECT_CON_IO) command codes not supported by CP/M 2.
 178:     -	00FE'         	DCONIO_IN_STAT      equ 0xfe    ; Return console input status. Zero if no character is waiting, nonzero
 179:     -	00FD'         	DCONIO_GET_WT       equ 0xfd    ; Get character (no echo), wait if no key
 180:				;
 181:				;
 182:				;
 183:				; ***************
 184:				; * CMPLDR BIOS *
 185:				; ***************
 186:				;
 187:				;
 188:				; BIOS parameters structure. This is passed from the monitor to the CPMLDR
 189:				; BIOS and the CP/M 3 BIOS.
 190:     -	        	                STRUCT
 191:     -	        	                STR_BYTE BPS_OPTIONS    ; See BIOS_OPT_xxx definitions
 192:     -	        	                STR_BLOCK BPS_PAGES, MMAP_CP3_PAGES ; Memory page list
 193:     -	        	                STR_WORD BPS_PARTITION  ; Pointer to partition table entry
 194:     -	        	                STR_END BPS_SIZE
 195:				;
**** bios.z80 ****
  73:				                include "disks.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/disks.i ****
   1:				; *******************************************
   2:				; * ZARC Monitor Disk Format Include File   *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 13/11/2020                *
   5:				; *******************************************
   6:				;
   7:				; Constants and structures for use when handling disks (memory cards) in the
   8:				; monitor.
   9:				;
  10:				; Master Boot Record (MBR) parameters. This follows the format of the "Structure
  11:				; of a classical generic MBR" at https://en.wikipedia.org/wiki/Master_boot_record#PTE
  12:				; This is consistent what what I found on one of the MMC cards I examined.
  13:     -	AA55'         	DSK_BOOT_SIGN               equ 0xaa55
  14:     -	01FE'         	DSK_BOOT_SIGN_OFFSET        equ 0x01fe
  15:     -	0004'         	DSK_MAX_PARTS               equ 4       ; Maximum allowed in a "classical" MBR
  16:     -	01BE'         	DSK_PART1_OFFSET            equ 0x01be
  17:     -	007F'         	DSK_PART_TYP_EXPER          equ 0x7f    ; Experimental (no CP/M 2.2 type coded)
  18:				;
  19:				;
  20:				; Partition table entry structure.
  21:				; Derived from https://en.wikipedia.org/wiki/Master_boot_record#PTE
  22:     -	        	                STRUCT
  23:     -	        	                STR_BYTE DPART_STATUS
  24:				; CHS of first sector.
  25:     -	        	                STR_BYTE DPART_START_HD     ; Head
  26:     -	        	                STR_BYTE DPART_START_SEC    ; Cylinder MS bits and sector
  27:     -	        	                STR_BYTE DPART_START_CYL    ; Cylinder
  28:     -	        	                STR_BYTE DPART_TYPE
  29:				; CHS of last sector.
  30:     -	        	                STR_BYTE DPART_END_HD
  31:     -	        	                STR_BYTE DPART_END_SEC
  32:     -	        	                STR_BYTE DPART_END_CYL
  33:				; Logical Block Address (LBA) parameters.
  34:     -	        	                STR_LONG DPART_START_LBA    ; Start sector
  35:     -	        	                STR_LONG DPART_SIZE_SECS    ; Size in sectors
  36:     -	        	                STR_END DPART_SIZE
  37:				
**** bios.z80 ****
  74:				                include "mmc.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/mmc.i ****
   1:				; *******************************************
   2:				; * ZARC Monitor Memory Card Include File   *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 7/8/2020                  *
   5:				; *******************************************
   6:				;
   7:				;
   8:				; Note that ld80 only considers the first six characters of labels significant.
   9:				;
  10:				; The following conditionals are intended to allow the same include file to be
  11:				; used in the defining module and elsewhere as required. Some includes are used
  12:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  13:				; the extern and public statements are not desirable.
  14:				;
  15:     -	0000'         	            ifdef monitor           ; Meaningful for monitor build only
  31:				            endif
  32:				;
  33:				;
  34:     -	0200'         	MMC_SECTOR_SIZE             equ 512     ; Sector size
  35:     -	0009'         	MMC_LOG2_SEC_SIZE           equ 9       ; Save number of shifts for above
  36:     -	0040'         	MMC_CMD_START               equ 0x40    ; Command start bits (01b) shifted for
  37:				                                        ; command byte
  38:     -	0001'         	MMC_CMD_STOP                equ 0x01    ; Stop bit (in CRC byte)
  39:				;
  40:				;
  41:				; Card state (mcstat) states.
  42:     -	        	                ENUM_START
  43:     -	        	                ENUM MMC_STAT_IDLE      ; Not initialised
  44:     -	        	                ENUM MMC_STAT_INIT      ; Initialised (can do raw read / writes)
  45:				
  46:     -	        	                ENUM_END MC_STATES  ; Number of states
  47:				;
  48:				;
  49:				; Memory card command structure
  50:     -	        	                STRUCT
  51:     -	        	                STR_BYTE MMC_CMD    ; Command including start bits
  52:     -	        	                STR_BYTE MMC_ARG1   ; Arguments
  53:     -	        	                STR_BYTE MMC_ARG2   ; Arguments
  54:     -	        	                STR_BYTE MMC_ARG3   ; Arguments
  55:     -	        	                STR_BYTE MMC_ARG4   ; Arguments
  56:     -	        	                STR_BYTE MMC_CRC    ; CRC and stop bit
  57:     -	        	                STR_END MMC_SIZE
  58:				;
  59:				;
  60:				; SPI mode commands (CMDn from MMC-System-Spec-v3.31.pdf chapter 4.9).
  61:     -	0000'         	MMC_CMD_GO_IDLE_STATE       equ 0   ; Resets the memory card
  62:     -	0001'         	MMC_CMD_SEND_OP_COND        equ 1   ; Sends host capacity support information and init.
  63:     -	0009'         	MMC_CMD_SEND_CSD            equ 9   ; Read card specific data
  64:     -	000A'         	MMC_CMD_SEND_CID            equ 10  ; Read card identification
  65:     -	000D'         	MMC_CMD_SEND_STATUS         equ 13  ; Read card status register
  66:     -	0010'         	MMC_CMD_SET_BLOCKLEN        equ 16  ; Set block length (in bytes)
  67:     -	0011'         	MMC_CMD_READ_SINGLE_BLOCK   equ 17  ; Reads a block
  68:     -	0018'         	MMC_CMD_WRITE_BLOCK         equ 24  ; Writes a block
  69:     -	0037'         	MMC_CMD_APP_CMD             equ 55  ; Next command is an application specific command
  70:     -	003B'         	MMC_CMD_CRC_ON_OFF          equ 59  ; Turns the CRC option on or off
  71:				;
  72:				; The list describes all the application specific commands supported/reserved by the 
  73:				; memory card. All the following commands shall be preceded with APP_CMD (CMD55).
  74:     -	0029'         	MMC_ACMD_MC_SEND_OP_COND    equ 41  ; Sends host capacity support information and init
  75:				;
  76:				; R1 response bits
  77:     -	        	BITDEF MMC_R1_IDLE, 0           ; In idle state
  78:     -	        	BITDEF MMC_R1_ERA_RST, 1        ; Erase reset
  79:     -	        	BITDEF MMC_R1_ILL_CMD, 2        ; Illegal command
  80:     -	        	BITDEF MMC_R1_CMD_CRC_ERR, 3    ; Command CRC error
  81:     -	        	BITDEF MMC_R1_ERA_SEQ_ERR, 4    ; Erase sequence error
  82:     -	        	BITDEF MMC_R1_ADDR_ERR, 5       ; Address error
  83:     -	        	BITDEF MMC_R1_PAR_ERR, 6        ; Parameter error
  84:     -	        	BITDEF MMC_R1_START, 7          ; Zero identifies an R1 response
  85:				;
  86:				;
  87:     -	0006'         	MMC_CID_PNM_SIZE      equ 6   ; Product name length (bytes)
  88:				;
  89:				; Card IDentification (CID) register (128 bits)
  90:     -	        	                STRUCT
  91:     -	        	                STR_BYTE MMC_CID_MID    ; Manufacturer ID
  92:     -	        	                STR_WORD MMC_CID_OID    ; OEM/Application ID
  93:     -	        	                STR_BLOCK MMC_CID_PNM, MMC_CID_PNM_SIZE ; Product name
  94:     -	        	                STR_BYTE MMC_CID_PRV    ; Product revision
  95:     -	        	                STR_LONG MMC_CID_PSN    ; Product serial number
  96:     -	        	                STR_BYTE MMC_CID_MDT    ; Manufacturing date
  97:     -	        	                STR_BYTE MMC_CID_CRC    ; CRC7 checksum and "1"
  98:     -	        	                STR_END MMC_CID_SIZE
  99:				;
 100:				;
 101:				; Card-Specific Data (CSD) register (128 bits). It contains a number of bit fields
 102:				; that aren't necessarily byte aligned. In these cases, the entries simply identify
 103:				; the bit numbers contained.
 104:     -	        	                STRUCT
 105:     -	        	                STR_BYTE MMC_CSD_VERSION    ; (127-120) CSD version, spec version
 106:     -	        	                STR_BYTE MMC_CSD_TAAC       ; (119-112) data read access-time-1
 107:     -	        	                STR_BYTE MMC_CSD_NSAC       ; (111-104) data read access-time-2
 108:     -	        	                STR_BYTE MMC_CSD_TR_SPD     ; (103-96) max. data transfer rate
 109:     -	        	                STR_BYTE MMC_CSD_95_88      ; Card command classes (MS 8 bits)
 110:     -	        	                STR_BYTE MMC_CSD_87_80      ; CCC (LS bits) and max. read data length
 111:     -	        	                STR_BYTE MMC_CSD_79_72      ; Flags and C_SIZE bits 10 and 11
 112:     -	        	                STR_BYTE MMC_CSD_71_64      ; C_SIZE bits 2 to 9
 113:     -	        	                STR_BYTE MMC_CSD_63_56      ; C_SIZE bits 1 to 0 and some currents
 114:     -	        	                STR_BYTE MMC_CSD_55_48      ; Currents & C_SIZE_MULT (MS 2 bits)
 115:     -	        	                STR_BYTE MMC_CSD_47_40      ; C_SIZE_MULT (LS bit) and erase size (part)
 116:     -	        	                STR_BYTE MMC_CSD_39_32      ; Erase size (part) and WP group size
 117:     -	        	                STR_BYTE MMC_CSD_31_24      ; WP group enable, ECC and write parameters (part)
 118:     -	        	                STR_BYTE MMC_CSD_23_16      ; Write block lenth (part) and reserved
 119:     -	        	                STR_BYTE MMC_CSD_15_8       ; Flags
 120:     -	        	                STR_BYTE MMC_CSD_CRC        ; CRC7 checksum and "1"
 121:     -	        	                STR_END MMC_CSD_SIZE
 122:				
**** bios.z80 ****
  75:				                include "memory.i"      ; Memory page allocation
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/memory.i ****
   1:				; *******************************************
   2:				; * ZARC Memory Include File                *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 24/11/2021                *
   5:				; *******************************************
   6:				;
   7:				;
   8:				; Note that ld80 only considers the first six characters of labels significant.
   9:				;
  10:				; The following conditionals are intended to allow the same include file to be
  11:				; used in the defining module and elsewhere as required. Some includes are used
  12:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  13:				; the extern and public statements are not desirable.
  14:				;
  15:     -	0000'         	            ifdef monitor           ; Meaningful for monitor build only
  26:				            endif
  27:				;
  28:				; Physical memory constants are found in zarc.i
  29:				;
  30:     -	0004'         	MPA_NAME_LEN        equ 4               ; Page owner name length (bytes)
  31:				;
  32:				; Memory map
  33:     -	4000'         	MMAP_PAGE_SIZE      equ 0x4000          ; Memory mapping bank / page size
  34:     -	0004'         	MMAP_BANKS          equ 4               ; Number of 16 kB banks
  35:     -	0040'         	MMAP_PAGES          equ 0x40            ; Number of 16 kB RAM pages
  36:     -	0000'         	MMAP_BANK0_START    equ 0x0000
  37:     -	3FFF'         	MMAP_BANK0_END      equ 0x3fff
  38:     -	4000'         	MMAP_BANK1_START    equ 0x4000
  39:     -	7FFF'         	MMAP_BANK1_END      equ 0x7fff
  40:     -	8000'         	MMAP_BANK2_START    equ 0x8000
  41:     -	BFFF'         	MMAP_BANK2_END      equ 0xbfff
  42:     -	C000'         	MMAP_BANK3_START    equ 0xc000
  43:     -	FFFF'         	MMAP_BANK3_END      equ 0xffff
  44:				;
  45:				;
  46:				;
  47:				; ****************
  48:				; * Memory Usage *
  49:				; ****************
  50:				;
  51:				;
  52:				; Memory banks setup.
  53:				; 0 (0000 - 3FFF): 3f read only, supervisor - monitor program
  54:				; 1 (4000 - 7FFF): 3e writeable - monitor variables, stacks, buffers etc.
  55:				; 2 (8000 - BFFF): (not used)
  56:				; 3 (C000 - FFFF): (mapped as required)
  57:				;
  58:     -	003F'         	MMAP_MON_B0_PAGE    equ 0x3f        ; Page for bank 0
  59:     -	003E'         	MMAP_MON_B1_PAGE    equ 0x3e        ; Page for bank 1
  60:				;
  61:				; This may seem large, but MMC sector writes for example require over 70 bytes
  62:				; of stack!
  63:     -	0080'         	STACKS_SIZE     equ 128             ; Space allocated to normal stacks
  64:				;
  65:     -	7FFF'         	HEAP_TOP        equ MMAP_BANK1_END  ; Top (end) of heap space.
  66:				
**** bios.z80 ****
  76:				                include "bios.i"        ; Local definitions
**** bios.i ****
   1:				; *******************************************************
   2:				; * CP/M 2 BIOS for ZARC Z80 Computer Include File      *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 31/5/2025                             *
   5:				; *******************************************************
   6:				;
   7:				;
   8:				;
   9:				; *************
  10:				; * Constants *
  11:				; *************
  12:				;
  13:				;
  14:     -	0002'         	BIOS_CPM_VER        equ 2               ; Supported CP/M version
  15:				;
  16:				; Version
  17:     -	0001'         	BIOS_MAJ_VER        equ 1
  18:     -	0006'         	BIOS_MIN_VER        equ 6
  19:				;
  20:				; The interrupt stack need only be deep enough to meet the requirements of the
  21:				; interrupt service routines plus a NMI. As the monitor switches to its own
  22:				; stack for NMIs, this is a light requirement.
  23:     -	0010'         	INT_STACK_SIZE      equ 16              ; Interrupt service routine stack size
  24:				;
  25:     -	0100'         	DISK_SPT            equ 256             ; Sectors per track
  26:     -	01FF'         	DISK_DSM            equ 511             ; Maximum block number
  27:				
**** bios.z80 ****
  77:				                include "contran.i"     ; Console translation
**** contran.i ****
   1:				; *******************************************************
   2:				; * CP/M 2 BIOS for ZARC Z80 Computer Include File      *
   3:				; * Console translation definitions                     *
   4:				; * Written by: Merlin Skinner                          *
   5:				; * Date Started: 31/5/2025                             *
   6:				; *******************************************************
   7:				;
   8:				;
   9:				;
  10:				; *************
  11:				; * Constants *
  12:				; *************
  13:				;
  14:				;
  15:     -	0004'         	CIT_BUF_MAX_LEN     equ 4               ; Maximum sequence length
  16:     -	0004'         	COT_BUF_MAX_LEN     equ 4               ; Maximum sequence length
  17:				;
  18:				;
  19:				; Console output translation state machine states (cot_state).
  20:     -	        	                ENUM_START
  21:     -	        	                ENUM COTST_NORM         ; Normal state
  22:     -	        	                ENUM COTST_ESC          ; Escape received
  23:     -	        	                ENUM COTST_LOAD         ; Cursor load sequence
  24:     -	        	                ENUM COTST_Y            ; Cursor load Y received
  25:     -	        	                ENUM_END COTST_STATES   ; Number of states
  26:				;
  27:     -	0001'         	                assert COTST_NORM = 0   ; Code assumes this
  28:				;
  29:				;
  30:				; Console input translation state machine states (cistm).
  31:     -	        	                ENUM_START
  32:     -	        	                ENUM CITST_NORM         ; Normal state
  33:     -	        	                ENUM CITST_REPLAY       ; Replay unrecognised sequence
  34:     -	        	                ENUM_END CITST_STATES   ; Number of states
  35:				;
  36:     -	0001'         	                assert CITST_NORM = 0   ; Code assumes this
  37:				
**** bios.z80 ****
  78:				;
  79:				;
  80:				;
  81:				; *************
  82:				; * Externals *
  83:				; *************
  84:				;
  85:				;
  86:				                public bpanic           ; System error monitor entry
  87:				                public CONST            ; Console status
  88:				                extern btime            ; Build time string
  89:				; To / from contran.z80
  90:				                extern ctinit           ; Initialise console translation
  91:				                extern citr             ; Console translate input
  92:				                public ciraw            ; Console input raw read
  93:				                extern cistm            ; Console input translation state
  94:				                extern cotr             ; Console translate output
  95:				                public coraw            ; Console output raw write
  96:				; Variables
  97:				                extern cittmr           ; Console input translation timer
  98:				;
  99:				;
 100:				;
 101:				; *************
 102:				; * Constants *
 103:				; *************
 104:				;
 105:				;
 106:				; Minimum partition size
 107:     -	0000'         	CPM_MIN_PRT_SIZE    equ CPM_SYS_SIZE + (NUM_DISKS * CPM_DISK_SIZE)  ; In bytes
 108:     -	5000'         	CPM_MIN_PRT_SIZE_MS equ CPM_MIN_PRT_SIZE / MMC_SECTOR_SIZE  ; In MMC sectors
 109:     -	8000'         	CPM_TRACK_SIZE      equ DISK_SPT * CPM_SECTOR_SIZE   ; "Track" size in bytes
 110:     -	0020'         	CPM_SYS_TRACKS      equ CPM_SYS_SIZE / CPM_TRACK_SIZE   ; System area size in tracks
 111:     -	0020'         	CPM_DRIVE_TRACKS    equ CPM_DISK_SIZE / CPM_TRACK_SIZE  ; Drive size in tracks
 112:				;
 113:				;
 114:				;
 115:				; *************
 116:				; * Main Code *
 117:				; *************
 118:				;
 119:				                cseg
 120:				;
 121:				; Linker will load this to BIOS_START.
 122:				;
 123:     -	002C'         	CCP_BDOS_SECTS  equ (BIOS_START-CCP_START) / CPM_SECTOR_SIZE   ; Number of sectors in CCP and BDOS
 124:     -	0010'         	CCP_SECTS       equ (BDOS_START-CCP_START-6) / CPM_SECTOR_SIZE  ; Number of sectors in CCP
 125:				;
 126:				; Jump table.
 127:				; Information from http://www.gaby.de/cpm/manuals/archive/cpm22htm/axb.htm
 128:				; Entries here must match the jump table in cpm.i.
 129:    0+10	0000' C35F01  	                jp BOOT                 ; Cold start routine
 130:   10+10	0003' C3D101  	wboot_entry     jp WBOOT                ; Warm boot
 131:   20+10	0006' C3DC01  	                jp CONST                ; Console status
 132:   30+10	0009' C31602  	                jp CONIN                ; Console input
 133:   40+10	000C' C33702  	                jp CONOUT               ; Console output
 134:   50+10	000F' C35902  	                jp PLIST                ; Printer output
 135:   60+10	0012' C37302  	                jp PUNCH                ; Paper tape punch output
 136:   70+10	0015' C38D02  	                jp READER               ; Paper tape reader input
 137:   80+10	0018' C38703  	                jp HOME                 ; Move disc head to track 0
 138:   90+10	001B' C3AA03  	                jp SELDSK               ; Select disc drive
 139:  100+10	001E' C32504  	                jp SETTRK               ; Set track number
 140:  110+10	0021' C35304  	                jp SETSEC               ; Set sector number
 141:  120+10	0024' C38104  	                jp SETDMA               ; Set DMA address
 142:  130+10	0027' C3AF04  	                jp READ                 ; Read a sector
 143:  140+10	002A' C32805  	                jp WRITE                ; Write a sector
 144:				; CP/M 2 functions.
 145:  150+10	002D' C38E05  	                jp LISTST               ; Status of list device
 146:  160+10	0030' C39005  	                jp SECTRAN              ; Sector translation for skewing
 147:				; CP/M 3 functions (not supported yet). From https://www.seasip.info/Cpm/bios.html
 148:  170+10	0033' C39405  	                jp CONOST               ; Status of console output
 149:  180+10	0036' C3C505  	                jp AUXIST               ; Status of auxiliary input
 150:  190+10	0039' C3DF05  	                jp AUXOST               ; Status of auxiliary output
 151:  200+10	003C' C3F905  	                jp DEVTBL               ; Address of devices table
 152:  210+10	003F' C3FC05  	                jp DEVINI               ; Initialise a device
 153:  220+10	0042' C3FF05  	                jp DRVTBL               ; Address of discs table
 154:  230+10	0045' C30206  	                jp MULTIO               ; Read/write multiple sectors
 155:  240+10	0048' C30506  	                jp FLUSH                ; Flush host buffers
 156:  250+10	004B' C30806  	                jp MOVE                 ; Move a block of memory
 157:  260+10	004E' C30B06  	                jp TIME                 ; Real time clock
 158:  270+10	0051' C30E06  	                jp SELMEM               ; Select memory bank
 159:  280+10	0054' C31106  	                jp SETBNK               ; Select bank for DMA operation
 160:  290+10	0057' C31406  	                jp XMOVE                ; Preload banks for MOVE
 161:  300+10	005A' C31706  	                jp USERF                ; System-depedent functions
 162:  310+10	005D' C31A06  	                jp RESERV1              ; Reserved
 163:  320+10	0060' C31D06  	                jp RESERV2              ; Reserved
 164:				; ZARC-specific items follow.
 165:     -	0063' 5A5243  	                byte "ZRC"              ; ZARC BIOS ID *1
 166:     -	0066' 000106  	                byte 0, BIOS_MAJ_VER, BIOS_MIN_VER  ; BIOS_VER (version)
 167:  330+10	0069' C38100  	                jp startup              ; ZARC CP/M startup entry point
 168:  340+10	006C' C3C906  	                jp mon_call             ; Call monitor function
 169:  350+10	006F' C38C06  	                jp set_super            ; Set supervisor state
 170:  360+10	0072' C3A807  	                jp int_disable          ; Disable interrupt and keep count
 171:  370+10	0075' C39507  	                jp int_enable           ; Enable interrupts if safe.
 172:  380+10	0078' C3B407  	                jp tird                 ; Read time and date
 173:  390+10	007B' C3D507  	                jp set_timer            ; Set elapsed time
 174:  400+10	007E' C3F007  	                jp get_timer            ; Get elapsed timer
