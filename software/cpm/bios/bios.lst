1819:				;
1820:				;
1821:				; Disk Parameter Headers (DPH)
1822:				; From http://www.gaby.de/cpm/manuals/archive/cpm22htm/ch6.htm:
1823:				; Each disk drive has an associated (16-byte) disk parameter header that contains
1824:				; information about the disk drive and provides a scratch pad area for certain
1825:				; BDOS operations. The format of the disk parameter header for each drive is shown
1826:				; in Figure 6-2, where each element is a word (16-bit) value.
1827:				;
1828:				dph_gen         macro d
1829:				                word 0                  ; XLT No sector translation
1830:				                word 0, 0, 0            ; BDOS scratch area
1831:				                word bdos_dirbf         ; DIRBUF BDOS directory scratch area
1832:				                word disk_dpb           ; Pointer to DPB
1833:				                word 0                  ; CSV No check area required for fixed disk
1834:				                word bdos_all_`d        ; ALV Allocation area
1835:				                endm
1836:				;
1837:				; Build DPH list.
1838:     -	08A9'         	disk_dph_base
1839:     -	0000'         	drive           set 0
1840:     -	08A9' 00000000	                rept NUM_DISKS
	              00000000
	              79033909
	              0000A900
	              00000000
