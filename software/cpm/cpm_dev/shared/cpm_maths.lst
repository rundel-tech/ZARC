  61:				; * Code *
  62:				; ********
  63:				;
  64:				;
  65:				                cseg                    ; Code segment
  66:				;
  67:				; 32-bit / 8-bit unsigned divide. Uses restoring algorithm. Derived from code at
  68:				; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Division
  69:				; Call with:
  70:				; DEHL - dividend
  71:				; C - divisor
  72:				; Returns with:
  73:				; DEHL - quotient
  74:				; A - remainder
  75:    0+11	0000' C5      	madlbu          push bc
  76:   11+7	0001' 0620    	                ld b, 32            ; Loop counter
  77:   18+4	0003' AF      	                xor a
  78:   22+11	0004' 29      	dulb_bitloop    add	hl, hl          ; Shift MS bit of dividend into carry
  79:   33+8	0005' CB13    	                rl e
  80:   41+8	0007' CB12    	                rl d
  81:   49+4	0009' 17      	                rla                 ; Collect bit in LS of A
  82:   53+7+5	000A' 3803    	                jr c, dulb_dosub
  83:   60+4	000C' B9      	                cp c
  84:   64+7+5	000D' 3802    	                jr c, dulb_nextbit
  85:   71+4	000F' 91      	dulb_dosub      sub	a, c
  86:   75+4	0010' 2C      	                inc	l
  87:   79+8+5	0011' 10F1    	dulb_nextbit    djnz	 dulb_bitloop
  88:   87+10	0013' C1      	                pop bc
  89:   97+10	0014' C9      	                ret
  90:				;
  91:				;
  92:				; 16-bit / 8-bit unsigned divide. Uses restoring algorithm. Derived from code at
  93:				; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Division
  94:				; Call with:
  95:				; HL - dividend
  96:				; C - divisor
  97:				; Returns with:
  98:				; HL - quotient
  99:				; A - remainder
 100:  107+11	0015' C5      	madwbu          push bc
 101:  118+7	0016' 0610    	                ld b, 16            ; Loop counter
 102:  125+4	0018' AF      	                xor a
 103:  129+11	0019' 29      	duwb_bitloop    add hl, hl          ; Shift MS bit of dividend into carry
 104:  140+4	001A' 17      	                rla                 ; Collect bit in LS of A
 105:  144+7+5	001B' 3803    	                jr c, duwb_dosub
 106:  151+4	001D' B9      	                cp c
 107:  155+7+5	001E' 3802    	                jr c, duwb_nextbit
 108:  162+4	0020' 91      	duwb_dosub      sub	a, c
 109:  166+4	0021' 2C      	                inc	l
 110:  170+8+5	0022' 10F5    	duwb_nextbit    djnz duwb_bitloop
 111:  178+10	0024' C1      	                pop bc
 112:  188+10	0025' C9      	                ret
 113:				;
 114:				;
 115:				; 8-bit / 8-bit unsigned divide. Uses restoring algorithm. Derived from code at
 116:				; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Division
 117:				; Call with:
 118:				; L - dividend
 119:				; C - divisor
 120:				; Returns with:
 121:				; L - quotient
 122:				; A - remainder
 123:  198+11	0026' C5      	madbbu          push bc
 124:  209+7	0027' 0608    	                ld b, 8             ; Loop counter
 125:  216+4	0029' AF      	                xor a
 126:  220+8	002A' CB25    	dubb_bitloop    sla l               ; Shift MS bit of dividend into carry
 127:  228+4	002C' 17      	                rla                 ; Collect bit in LS of A
 128:  232+4	002D' B9      	                cp c
 129:  236+7+5	002E' 3802    	                jr c, dubb_nextbit
 130:  243+4	0030' 91      	dubb_dosub      sub c
 131:  247+4	0031' 2C      	                inc l
 132:  251+8+5	0032' 10F6    	dubb_nextbit    djnz dubb_bitloop
 133:  259+10	0034' C1      	                pop bc
 134:  269+10	0035' C9      	                ret
 135:				;
 136:				;
 137:				; 16-bit * 16-bit unsigned multiply. Uses restoring algorithm. Derived from code at
 138:				; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Multiplication
 139:				; Call with:
 140:				; BC - multiplicand
 141:				; DE - multiplier
 142:				; Returns with:
 143:				; DEHL - result
 144:  279+10	0036' 210000  	mamwwu          ld hl, 0            ; Zero LSW of result
 145:				; Optimised 1st iteration
 146:  289+8	0039' CB23    	                sla	e               ; Shift multiplier
 147:  297+8	003B' CB12    	                rl d
 148:  305+7+5	003D' 3002    	                jr nc, muww_sk_ld
 149:				; Set result to multiplicand if the MS bit of the multiplier was set.
 150:  312+4	003F' 60      	                ld h, b
 151:  316+4	0040' 69      	                ld l, c
 152:  320+7	0041' 3E0F    	muww_sk_ld      ld a, 15
 153:				; A - loop counter
 154:				; BC - multiplicand
 155:				; DE - multiplier (MS bits) and result (LS bits).
 156:				; HL - LSW of result
 157:  327+11	0043' 29      	muww_loop       add hl, hl          ; Shift result (DEHL) left
 158:  338+8	0044' CB13    	                rl e
 159:  346+8	0046' CB12    	                rl d
 160:  354+7+5	0048' 3004    	                jr nc, muww_nc      ; Jump if multiplier bit is zero
 161:  361+11	004A' 09      	                add hl, bc          ; Add multiplicand to result
 162:  372+7+5	004B' 3001    	                jr nc, muww_nc
 163:  379+6	004D' 13      	                inc de              ; Propagate the carry into DE
 164:  385+4	004E' 3D      	muww_nc         dec a
 165:  389+7+5	004F' 20F2    	                jr nz, muww_loop
 166:  396+10	0051' C9      	                ret
 167:				;
 168:				;
 169:				; 32-bit * 8-bit unsigned multiply. Uses restoring algorithm. Derived from mamwwu
 170:				; above.
 171:				; Call with:
 172:				; DEHL - multiplicand
 173:				; C - multiplier
 174:				; Returns with:
 175:				; CDEHL - result
 176:  406+4	0052' 79      	mamlbu          ld a, c
 177:				; Save some registers.
 178:  410+11	0053' C5      	                push bc
 179:  421+4	0054' D9      	                exx
 180:  425+11	0055' C5      	                push bc
 181:  436+11	0056' E5      	                push hl
 182:  447+4	0057' D9      	                exx
 183:				; Setup registers for the multiply.
 184:  451+11	0058' D5      	                push de
 185:  462+11	0059' E5      	                push hl
 186:  473+10	005A' C1      	                pop bc              ; LSW of multiplicand
 187:  483+4	005B' A7      	                and a               ; Reset carry
 188:  487+15	005C' ED62    	                sbc hl, hl          ; Zero LS 32-bits of result
 189:  502+4	005E' D9      	                exx
 190:  506+10	005F' C1      	                pop bc              ; MSW of multiplicand
 191:  516+15	0060' ED62    	                sbc hl, hl          ; Zero MS 32-bits of result
 192:  531+4	0062' D9      	                exx
 193:  535+4	0063' 5F      	                ld e, a             ; Multiplier
 194:				; B'C'BC - multiplicand
 195:				; E - multiplier
 196:				; H'L'HL - result
 197:				; Optimised 1st iteration
 198:  539+8	0064' CB23    	                sla	e		        ; Shift multiplier
 199:  547+7+5	0066' 3006    	                jr nc, mulb_sk_ld
 200:				; Set result to multiplicand if the MS bit of the multiplier was set.
 201:  554+4	0068' 69      	                ld l, c
 202:  558+4	0069' 60      	                ld h, b
 203:  562+4	006A' D9      	                exx
 204:  566+4	006B' 69      	                ld l, c
 205:  570+4	006C' 60      	                ld h, b
 206:  574+4	006D' D9      	                exx
 207:  578+7	006E' 3E07    	mulb_sk_ld      ld a, 7
 208:				; A - loop counter
 209:				; B'C'BC - multiplicand
 210:				; E - multiplier (MS bits) and result (LS bits).
 211:				; H'L'HL - result
 212:  585+11	0070' 29      	mulb_loop       add hl, hl          ; Shift result (CH'L'HL) left
 213:  596+4	0071' D9      	                exx
 214:  600+15	0072' ED6A    	                adc hl, hl
 215:  615+4	0074' D9      	                exx
 216:  619+8	0075' CB13    	                rl e
 217:  627+7+5	0077' 3008    	                jr nc, mulb_nc      ; Jump if multiplier bit is zero
 218:  634+11	0079' 09      	                add hl, bc          ; Add multiplicand to result
 219:  645+4	007A' D9      	                exx
 220:  649+15	007B' ED4A    	                adc hl, bc
 221:  664+4	007D' D9      	                exx
 222:  668+7+5	007E' 3001    	                jr nc, mulb_nc
 223:  675+4	0080' 1C      	                inc e               ; Propagate the carry into result
 224:  679+4	0081' 3D      	mulb_nc         dec a
 225:  683+7+5	0082' 20EC    	                jr nz, mulb_loop
 226:  690+4	0084' 7B      	                ld a, e             ; Top bits of result
 227:  694+4	0085' D9      	                exx
 228:  698+11	0086' E5      	                push hl             ; MSW of result
 229:  709+4	0087' D9      	                exx
 230:  713+10	0088' D1      	                pop de
 231:				; Restore registers
 232:  723+4	0089' D9      	                exx
 233:  727+10	008A' E1      	                pop hl
 234:  737+10	008B' C1      	                pop bc
 235:  747+4	008C' D9      	                exx
 236:  751+10	008D' C1      	                pop bc
 237:  761+4	008E' 4F      	                ld c, a
 238:				; CDEHL - result
 239:  765+10	008F' C9      	                ret
 240:				;
 241:				;
 242:				; Update CRC according to the CRC16 / XMODEM and MultiMediaCard CRC16 algorithm.
 243:				; Adapted from http://regregex.bbcmicro.net/crc-code.htm#crc-code.16.8080
 244:				; Call with:
 245:				; A - byte to be included
 246:				; HL - CRC
 247:				; Returns with:
 248:				; HL - updated CRC;
 249:  775+11	0090' C5      	crc16x          push bc
 250:				;
 251:  786+4	0091' AC      	                xor h
 252:  790+4	0092' 47      	                ld b, a
 253:  794+4	0093' 4D      	                ld c, l
 254:  798+4	0094' 0F      	                rrca
 255:  802+4	0095' 0F      	                rrca
 256:  806+4	0096' 0F      	                rrca
 257:  810+4	0097' 0F      	                rrca
 258:  814+4	0098' 6F      	                ld l, a
 259:  818+7	0099' E60F    	                and 0x0f
 260:  825+4	009B' 67      	                ld h, a
 261:  829+4	009C' A8      	                xor b
 262:  833+4	009D' 47      	                ld b, a
 263:  837+4	009E' AD      	                xor l
 264:  841+7	009F' E6F0    	                and 0xf0
 265:  848+4	00A1' 6F      	                ld l, a
 266:  852+4	00A2' A9      	                xor c
 267:  856+11	00A3' 29      	                add hl, hl
 268:  867+4	00A4' AC      	                xor h
 269:  871+4	00A5' 67      	                ld h, a
 270:  875+4	00A6' 7D      	                ld a, l
 271:  879+4	00A7' A8      	                xor b
 272:  883+4	00A8' 6F      	                ld l, a
 273:				;
 274:  887+10	00A9' C1      	                pop bc
 275:  897+10	00AA' C9      	                ret
 276:				;
 277:				;
 278:				; Adler-32 checksum. See https://en.wikipedia.org/wiki/Adler-32 for details.
 279:				; Call with:
 280:				; DEHL - checksum. Set to 1 for first pass.
 281:				; A - byte to be included
 282:				; Returns with:
 283:				; DEHL - updated checksum
 284:  907+11	00AB' C5      	adler           push bc
 285:				;
 286:				; HL - "A" part
 287:				; DE - "B" part
 288:				; Perform a = (a + data) % MOD_ADLER;
 289:  918+4	00AC' 4F      	                ld c, a
 290:  922+7	00AD' 0600    	                ld b, 0
 291:  929+11	00AF' 09      	                add hl, bc
 292:  940+17	00B0' CDBB00  	                call adl_mod
 293:				;
 294:				; Perform b = (b + a) % MOD_ADLER;
 295:  957+4	00B3' EB      	adl_a_done      ex de, hl
 296:				; DE - "A" part
 297:				; HL - "B" part
 298:  961+11	00B4' 19      	                add hl, de
 299:  972+17	00B5' CDBB00  	                call adl_mod
 300:  989+4	00B8' EB      	                ex de, hl
 301:				;
 302:  993+10	00B9' C1      	                pop bc
 303: 1003+10	00BA' C9      	                ret
 304:				;
 305:				;
 306:				;  Subroutine for use with adler. Performs mod 65521 (0xfff1). Call with:
 307:				; HL - input parameter
 308:				; Carry flag - set as result of previous add operation
 309:				; Returns with:
 310:				; HL - result
 311:				; Note: BC is not preserved.
 312: 1013+7+5	00BB' 380E    	adl_mod         jr c, adlm_over         ; Overflow if > 65535
 313:				; No 16-bit overflow.
 314: 1020+4	00BD' 7C      	                ld a, h
 315: 1024+4	00BE' 3C      	                inc a
 316: 1028+5+6	00BF' C0      	                ret nz                  ; OK if not 0xffxx
 317: 1033+4	00C0' 7D      	                ld a, l
 318: 1037+7	00C1' FEF1    	                cp low 65521
 319: 1044+5+6	00C3' D8      	                ret c                   ; OK if < 0xfff1
 320:				; Adler overflow.
 321: 1049+10	00C4' 01F1FF  	                ld bc, 65521
 322: 1059+4	00C7' A7      	                and a
 323: 1063+15	00C8' ED42    	                sbc hl, bc
 324: 1078+10	00CA' C9      	                ret
 325:				;
 326:				; Result has carried, so is 65536 less than it should be. However, we need to
 327:				; subtract 65521 to perform the modulus operation.
 328: 1088+10	00CB' 010F00  	adlm_over       ld bc, 65536 - 65521
 329: 1098+11	00CE' 09      	                add hl, bc
 330: 1109+10	00CF' C9      	                ret
 331:				;
 332:				;
 333:				; *** 32-bit arithmetic ***
 334:				;
 335:				; Variables are assumed to be little-endian.
 336:				;
 337:				;
 338:				; Clear (zero) the 32-bit variable at (hl).
 339:				; Call with:
 340:				; HL - pointer to first byte of variable.  An incremented pointer is returned to
 341:				; ease processing of arrays.
