1151: 5636+7+5	0457' 200E    	                jr nz, clo_not_brktd    ; Jump if we didn't start with "["
1152:				; Options started with a "[" so must finish with a "]".
1153: 5643+4	0459' A7      	                and a
1154: 5647+7+5	045A' 2835    	                jr z, clo_err
1155: 5654+7	045C' FE20    	                cp " "
