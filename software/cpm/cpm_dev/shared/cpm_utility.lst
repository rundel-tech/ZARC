1102:				;
1103:				;
1104:				; Read command line options. Up to 8 option characters are allowed.
1105:				; Call with:
1106:				; DE - points to a null terminated list of option characters.
1107:				; HL - points to the current position in the command line.
1108:				; Returns with:
1109:				; A - option flags.
1110:				; HL - points to first character after options and any trailing spaces.
1111:				; C flag - set on error (malformed option string)
1112:				; Each bit in A corresponds to one character in the options list. Bit 0 is set
1113:				; of the first character is encountered, bit 1 for the second and so on. Options
1114:				; may begin with "[", "/" or "$", to match all conventions I have found used
1115:				; with CP/M. If no options are included in the command line, A will be set to
1116:				; zero (no options set). Option characters may include any printable character
1117:				; except space or "]". Lower case is not permitted. Duplicates are ignored.
1118: 5497+11	0438' C5      	clopts          push bc
1119:				;
1120: 5508+7	0439' 0E00    	                ld c, 0                 ; Set default options
1121:				; Check for options. These may begin with "[", "/" or "$", to match all
1122:				; conventions I have found used with CP/M.
1123: 5515+17	043B' CD9101  	                call skpspc             ; Skip spaces
1124:				; Options
1125: 5532+7	043E' 7E      	                ld a, (hl)
1126: 5539+4	043F' 47      	                ld b, a                 ; Save for later
1127: 5543+4	0440' A7      	                and a
1128: 5547+7+5	0441' 2851    	                jr z, clo_end_opts      ; Jump if no options 
1129: 5554+7	0443' FE5B    	                cp "["
1130: 5561+7+5	0445' 280B    	                jr z, clo_op_loop
1131: 5568+7	0447' FE2F    	                cp "/"
1132: 5575+7+5	0449' 2807    	                jr z, clo_op_loop
1133: 5582+7	044B' FE24    	                cp "$"
1134: 5589+7+5	044D' 2803    	                jr z, clo_op_loop
1135:				; We have found a character, but it isn't an option introducer. We return with
1136:				; HL pointing to this character we didn't recognise.
1137: 5596+4	044F' A7      	                and a
1138: 5600+12	0450' 1843    	                jr clo_exit             ; Exit with no options
1139:				;
1140:				; Option loop. Attempt to match each option character with the list of options.
1141:				; B - option introducer character
1142:				; C - option flags (initially zero)
1143:				; DE - points to a null terminated list of option characters.
1144:				; HL - pointer to command line
1145: 5612+6	0452' 23      	clo_op_loop     inc hl
1146:				; A terminator or space ends the option string. If the introducer is a "[",
1147:				; a closing "]" is required.
1148: 5618+7	0453' 3E5B    	                ld a, "["
1149: 5625+4	0455' B8      	                cp b
