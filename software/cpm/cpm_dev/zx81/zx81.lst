1186: 6070+10	0513' E1      	                pop hl                  ; Restore the address
1187: 6080+11	0514' F5      	                push af                 ; Save page
1188:				; Find the address as it appears in bank 2.
1189: 6091+4	0515' 7C      	                ld a, h
1190: 6095+7	0516' E63F    	                and (high MMAP_PAGE_SIZE) - 1   ; Clear bank bits
1191: 6102+7	0518' F680    	                or high MMAP_BANK2_START ; Set to bank 3
1192: 6109+4	051A' 67      	                ld h, a
1193: 6113+10	051B' F1      	                pop af                  ; Restore page
1194: 6123+7	051C' E680    	                and MMAP_PROT_MASK
1195: 6130+5+6	051E' C8      	                ret z                   ; Exit with carry clear if R/W
1196: 6135+4	051F' 37      	                scf                     ; Indicate write protection
1197: 6139+10	0520' C9      	                ret                     ; Return with carry clear
1198:				;
1199:				;
1200:				; Load cursor position with optimisation.
1201:				; There is a significant overhead associated with the ANSI load cursor position
1202:				; sequence. This is typically eight characters. We can omit this if the cursor
1203:				; is already at the required position. This speeds up the output considerably
1204:				; compared to loading the cursor position every time.
1205:				; Call with:
1206:				; H - row
1207:				; L - column
1208:				; (0, 0) is the top left-hand corner.
1209: 6149+13	0521' 3AAE00  	load_cursor_pos ld a, (cursor_row)
1210: 6162+4	0524' BC      	                cp h
1211: 6166+7+5	0525' 2006    	                jr nz, lcp_load
1212: 6173+13	0527' 3AAF00  	                ld a, (cursor_col)
1213: 6186+4	052A' BD      	                cp l
1214: 6190+7+5	052B' 280B    	                jr z, lcp_exit          ; Skip load if positions match
1215:				; The cursor is not at the required position, so send the load cursor sequence.
1216: 6197+4	052D' 7C      	lcp_load        ld a, h
1217: 6201+13	052E' 32AE00  	                ld (cursor_row), a      ; Set position for next time
1218: 6214+4	0531' 7D      	                ld a, l
1219: 6218+13	0532' 32AF00  	                ld (cursor_col), a
1220: 6231+17	0535' CD0000  	                call cldcur             ; Load cursor position
1221: 6248+10	0538' C9      	lcp_exit        ret
1222:				;
1223:				;
1224:				; Load cursor position for a diagnostic message and clear the line. Each call
1225:				; loads the cursor with the position of the next row. When at the bottom of the
1226:				; screen, the next message is set to the top. There is no scrolling as this
1227:				; would disturb the emulator display.
1228: 6258+11	0539' E5      	load_diag_pos   push hl
1229: 6269+13	053A' 3AB100  	                ld a, (diag_msg_row)
1230: 6282+4	053D' 67      	                ld h, a
1231: 6286+7	053E' 2E21    	                ld l, 0x21              ; Set position after emulator column
1232: 6293+11	0540' F5      	                push af
1233:				; H - row
1234:				; L - column
1235: 6304+17	0541' CD0000  	                call cldcur             ; Load cursor position
1236: 6321+10	0544' F1      	                pop af
1237: 6331+4	0545' 3C      	                inc a
1238:				; Wrap back to top of display if out of range.
1239: 6335+7	0546' FE18    	                cp VT100_ROWS
1240: 6342+7+5	0548' 3802    	                jr c, ldp_row_ok        ; 1 to 24 is OK
1241: 6349+7	054A' 3E00    	                ld a, 0                 ; Set top row
1242: 6356+13	054C' 32B100  	ldp_row_ok      ld (diag_msg_row), a
1243:				; Set normal video (not reversed).
1244: 6369+4	054F' AF      	                xor a
1245: 6373+17	0550' CD0000  	                call conrev             ; Set normal video
1246: 6390+4	0553' AF      	                xor a                   ; Flag normal video
1247: 6394+13	0554' 32AC00  	                ld (inv_video), a       ; Bit 7 set if inverse video
1248:				; A space separates the emulator display and the messages.
1249: 6407+10	0557' 21FC06  	                ld hl, spc_era_msg      ; Space and erase to end of line
1250: 6417+17	055A' CD0000  	                call conwms             ; Print "$" terminated string to the console
1251:				; Force loading of cursor position when the ZX81 next displays something.
1252: 6434+7	055D' 3EFF    	                ld a, 0xff              ; Set unrealistic value to force load
1253: 6441+13	055F' 32AE00  	                ld (cursor_row), a
1254: 6454+13	0562' 32AF00  	                ld (cursor_col), a
1255: 6467+10	0565' E1      	                pop hl
1256: 6477+10	0566' C9      	                ret
