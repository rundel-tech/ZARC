**** zx81.z80 ****
  36:				;
  37:				;
  38:				;
  39:				; *************
  40:				; * Externals *
  41:				; *************
  42:				;
  43:				;
  44:				; Variables
  45:				                public brkflg   ; Non-zero if break character detected
  46:				;
  47:				                extern btime    ; Build time string
  48:				;
  49:				;
  50:				;
  51:				; *************
  52:				; * Main Code *
  53:				; *************
  54:				;
  55:				;
  56:				; The CP/M transient area start address is set in the linker invocation (see
  57:				; makefile).
