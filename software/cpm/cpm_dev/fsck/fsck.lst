**** fsck.i ****
   1:				; *******************************************************
   2:				; * CP/M File System Checker                            *
   3:				; * Include file                                        *
   4:				; * Written by: Merlin Skinner                          *
   5:				; * Date Started: 16/2/2022                             *
   6:				; *******************************************************
   7:				;
   8:				;
   9:				;
  10:				; *************
  11:				; * Constants *
  12:				; *************
  13:				;
  14:				;
  15:				; DEBUG           equ 1                   ; Define to enable debugging mode
  16:				;
  17:     -	0040'         	STACK_SIZE      equ 64                  ; Stack space allocation
  18:     -	0003'         	BREAK_CHAR      equ 'C' - 0x40
  19:     -	03C0'         	BDIS_CHARS_MAX  equ (VT100_ROWS / 2) * VT100_COLS ; Maximum display area for block usage display
  20:				;
  21:				; Allocation counter and flags
  22:     -	        	BITDEF ALLCF_UNUSED, 7                  ; Set if any allocation is unused
  23:     -	        	BITDEF ALLCF_SPARSE, 6                  ; Set file contains a hole
  24:				; LS bits serve as a counter.
  25:     -	000F'         	ALLCF_COUNT     equ 0x0f                ; Used allocation counter
  26:				;
  27:				; Command line option flags. The order must match clopt_list in fsck.z80.
  28:     -	        	BITDEF CLOPT_SCAN, 0                    ; Enable surface scan
  29:     -	        	BITDEF CLOPT_CPM2_2, 1                  ; Assume CP/M 2.2 disk format
  30:     -	        	BITDEF CLOPT_CPM3, 2                    ; Assume CP/M 3 disk format
  31:				;
  32:				; disk_type_flags.
  33:     -	        	BITDEF DTF_CPM3, 0                      ; CP/M 3 rules apply
  34:				;
  35:				;
  36:				;
  37:				; **************
  38:				; * Structures *
  39:				; **************
  40:				;
  41:				;
  42:				; File information structure. User, name and type must match the directory
  43:				; entry structure (DIRE_xxx).
  44:     -	        	                STRUCT
  45:     -	        	                STR_BYTE FI_USER                    ; User number. 0xe5 if entry unused
  46:     -	        	                STR_BLOCK FI_NAME, FILENAME_SIZE    ; Filename in ASCII upper-case
  47:     -	        	                STR_BLOCK FI_TYP, FILEEXT_SIZE      ; File type
  48:     -	        	                STR_WORD FI_LAST_PEXT               ; Highest physical extent number found
  49:     -	        	                STR_BYTE FI_LAST_RC                 ; RC associated with the extent in FI_LAST_PEXT
  50:     -	        	                STR_BYTE FI_EX_FL_LEN               ; No. of extent flag bytes
  51:     -	        	                STR_BLOCK FI_EX_FLAGS, 0            ; Start of extent flags
  52:     -	        	                STR_END FI_SIZE
  53:				
