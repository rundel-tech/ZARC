  62:				                include "cpm_utility.i" ; CP/M utilities
**** /home/merlin/Technical/ZARC_Z80_Box/git/software/includes/cpm_utility.i ****
   1:				; *******************************************************
   2:				; * Utility Routines for CP/M Applications              *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 16/12/2021                          *
   5:				; *******************************************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant.
   8:				;
   9:     -	0001'         	            ifndef CPMU         ; Inhibit for this module
  10:				; CP/M specific.
  11:				                extern cbdos    ; Call BDOS with some registers saved
  12:				                extern cbios    ; Call BIOS with some registers saved
  13:				                extern panic    ; Fatal application error
  14:				                extern zrcdet   ; Detect ZARC
  15:				                extern z80det   ; Detect Z80 (instead of 8080 / 8085)
  16:				                extern clopts   ; Read command line options
  17:				;
  18:				; Derived from the monitor's utility.z80.
  19:				                extern conwch   ; Write character to console
  20:				                extern conrch   ; Read character from the console
  21:				                extern const    ; Fetch console input status
  22:				                extern cwnwln   ; Write new line characters to console
  23:				                extern conwms   ; Print "$" terminated string to the console
  24:				                extern conwmn   ; Print message <n> in a list
  25:				                extern skpspc   ; Step hl past spaces
  26:				                extern toupca   ; Convert character in A to upper case
  27:				                extern toloca   ; Convert character in A to lower case
  28:				                extern cwvich   ; Print only visible 7-bit characters
  29:				                extern cwpspc   ; Print a space
  30:				                extern mtwdli   ; Match word in a string against list of options
  31:				                extern cwphnb   ; Print least-significant nibble in A in hexadecimal
  32:				                extern cwphby   ; Print A in hexadecimal
  33:				                extern cwphwd   ; Print HL in hexadecimal
  34:				                extern cwpdwd   ; Print HL in decimal. Leading zeros are suppressed
  35:				                extern cwpdby   ; Print A in decimal. Leading zeros are suppressed
  36:				                extern cwpdwd   ; Print HL in decimal. Leading zeros are suppressed
  37:				                extern cwpdlo   ; Print DEHL in decimal. Leading zeros are suppressed
  38:				                extern rdhxwd   ; Read a 16-bit hexadecimal number from a string
  39:				                extern rdduwd   ; Read a 16-bit unsigned decimal number from a string
  40:				                extern rddulo   ; Read a 32-bit unsigned decimal number from a string
  41:				;
  42:				            endif
  43:				;
  44:				;
  45:				; mtwdli (match word in a string against list of options) option bits. Each bit
  46:				; has the described effect if set.
  47:     -	        	BITDEF MTWDLI_ABBREV, 0                 ; Enable "." abbreviation
  48:     -	        	BITDEF MTWDLI_ICASE, 1                  ; Ignore case when matching
  49:     -	        	BITDEF MTWDLI_TERM, 7                   ; Terminator found (internal use only)
  50:				
**** fsck.z80 ****
  63:				                include "cpm_terminal.i"; Terminal control
**** /home/merlin/Technical/ZARC_Z80_Box/git/software/includes/cpm_terminal.i ****
   1:				; *******************************************************
   2:				; * Terminal Control Routines for CP/M Applications     *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 16/12/2021                          *
   5:				; *******************************************************
   6:				;
   7:				; These routines provide more complex control over the terminal than is offered
   8:				; by the simple generic character read / write used by the monitor and CP/M.
   9:				;
  10:				; Note that ld80 only considers the first six characters of labels significant.
  11:				;
  12:				; The following conditionals are intended to allow the same include file to be
  13:				; used in the defining module and elsewhere as required. Some includes are used
  14:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  15:				; the extern and public statements are not desirable.
  16:				;
  17:     -	0001'         	            ifndef cpm_terminal ; Inhibit for this module
  18:				                extern concap   ; Console capabilities (CONCAP_xxx)
  19:				                extern ccinit   ; Determine terminal capabilities
  20:				                extern cldcur   ; Load cursor position
  21:				                extern conuln   ; Set underline
  22:				                extern conrev   ; Set reverse video
  23:				                extern csrvis   ; Show or hide cursor
  24:				                extern ccls     ; Clear screen
  25:				                extern cscrup   ; Scroll screen up
  26:				            endif
  27:				;
  28:				;
  29:     -	0018'         	VT100_ROWS          equ 24
  30:     -	0050'         	VT100_COLS          equ 80
  31:				;
  32:				;
  33:				; The concap (determine terminal capabilities) routine returns a byte
  34:				; indicating various capabilities of the attached terminal. The bits are
  35:				; defined here.
  36:     -	        	BITDEF CONCAP_ZARC, 0           ; ZARC BIOS present
  37:     -	        	BITDEF CONCAP_ANSI, 1           ; ANSI control codes, e.g. VT100
  38:     -	        	BITDEF CONCAP_UNICODE, 2        ; Terminal is capable of Unicode characters
  39:				;
  40:				; Note that Minicom by default emulates a VT102, and is capable of Unicode. If
  41:				; this terminal is detected, both CONCAP_VT100 and CONCAP_UNICODE are set.
  42:				;
  43:				;
  44:				; ANSI graphical rendition (SGR) codes. From https://en.wikipedia.org/wiki/ANSI_escape_code
  45:     -	0000'         	ANSI_SGR_NORMAL     equ 0           ; All attributes off
  46:     -	0001'         	ANSI_SGR_BOLD       equ 1           ; Bold or increased intensity
  47:     -	0002'         	ANSI_SGR_FAINT      equ 2           ; Faint, decreased intensity, or dim
  48:     -	0004'         	ANSI_SGR_ULINE      equ 4           ; Underline
  49:     -	0005'         	ANSI_SGR_SBLINK     equ 5           ; Slow blink
  50:     -	0006'         	ANSI_SGR_RBLINK     equ 6           ; Rapid blink
  51:     -	0007'         	ANSI_SGR_REV        equ 7           ; Reverse video or invert
  52:     -	0009'         	ANSI_SGR_STRIKE     equ 9           ; Characters legible but marked as if for deletion
  53:     -	000A'         	ANSI_SGR_PRI_FONT   equ 10          ; Primary (default) font
  54:     -	000B'         	ANSI_SGR_FONT_1     equ 11          ; Alternative fonts
  55:     -	000C'         	ANSI_SGR_FONT_2     equ 12
  56:     -	000D'         	ANSI_SGR_FONT_3     equ 13
  57:     -	000E'         	ANSI_SGR_FONT_4     equ 14
  58:     -	000F'         	ANSI_SGR_FONT_5     equ 15
  59:     -	0010'         	ANSI_SGR_FONT_6     equ 16
  60:     -	0011'         	ANSI_SGR_FONT_7     equ 17
  61:     -	0012'         	ANSI_SGR_FONT_8     equ 18
  62:     -	0013'         	ANSI_SGR_FONT_9     equ 19
  63:     -	0014'         	ANSI_SGR_GOTHIC     equ 20          ; Fraktur (Gothic) (not widely supported)
  64:     -	0015'         	ANSI_SGR_DULINE     equ 21          ; Doubly underlined *or* not bold
  65:     -	0016'         	ANSI_SGR_NORM_INTEN equ 22          ; Normal intensity
  66:     -	0017'         	ANSI_SGR_ITAL_OFF   equ 23          ; Neither italic, nor blackletter
  67:     -	0018'         	ANSI_SGR_ULINE_OFF  equ 24          ; Underline off
  68:     -	0019'         	ANSI_SGR_BLINK_OFF  equ 25          ; Blinking off
  69:     -	001B'         	ANSI_SGR_REV_OFF    equ 27          ; Reverse image off
  70:     -	001C'         	ANSI_SGR_HIDE_OFF   equ 28          ; Reveal (not concealed)
  71:     -	001D'         	ANSI_SGR_STRIKE_OFF equ 29
  72:				
**** fsck.z80 ****
  64:				                include "cpm_top.i"     ; CP/M dummy top module
**** /home/merlin/Technical/ZARC_Z80_Box/git/software/includes/cpm_top.i ****
   1:				; *******************************************************
   2:				; * Dummy Module to find the Last Location in Use.      *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 16/12/2021                          *
   5:				; *******************************************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant.
   8:				;
   9:				                extern fstfre       ; First location after end of data segment
  10:				
**** fsck.z80 ****
  65:				;
  66:				;
  67:				;
  68:				; *************
  69:				; * Externals *
  70:				; *************
  71:				;
  72:				;
  73:				; Variables
  74:				;                public brkflg   ; Non-zero if break character detected
  75:				;
  76:				;
  77:				;
  78:				; *************
  79:				; * Main Code *
  80:				; *************
  81:				;
  82:				;
  83:				; The CP/M transient area start address is set in the linker invokation (see makefile).
  84:				                cseg                    ; Code segment
  85:				;
  86:				; The default stack space is very small (8 deep), which would almost certainly
  87:				; cause issues, particularly with interrupts running. The initial code should
  88:				; not assume a Z80 so we can exit cleanly if this is run on something else.
  89:    0+20	0000' ED730000	                ld (bdos_sp), sp
  90:   20+10	0004' 317000  	                ld sp, app_stack_top    ; Switch to our stack space
  91:				;
  92:				; Determine CPU type.
  93:   30+17	0007' CD0000  	                call z80det             ; Detect Z80 (instead of 8080 / 8085)
  94:   47+10	000A' D21800  	                jp nc, on_z80           ; Jump if we have a Z80
  95:				;
  96:				; 8080 / 8085 detected. Print message and exit. We can't use conwms as this
  97:				; assumes a Z80.
  98:   57+10	000D' 11ED07  	                ld de, no_z80_msg       ; "Z80 CPU required"
  99:   67+7	0010' 0E09    	                ld c, BDOS_PRINT_STRING ; Print String
 100:   74+17	0012' CD0500  	                call BDOS
 101:   91+10	0015' C30000  	                jp 0                    ; Warm boot
 102:				;
 103:				; Sign on.
 104:  101+10	0018' 21C307  	on_z80          ld hl, signon_msg
 105:  111+17	001B' CD0000  	                call conwms             ; Print $-terminated string to console
 106:				;
 107:				; Examine the command tail, looking for operands. This is stored in the default
 108:				; buffer. "The first byte at 0080H contains the length of the command tall, while
 109:				; the command tail itself begins at 0081H. The command tail is terminated by a
 110:				; byte containing a binary zero value." (http://www.cpm.z80.de/manuals/cpm22-m.pdf
 111:				; appendix H).
 112:  128+10	001E' 218100  	                ld hl, DEF_BUFFER + 1
 113:  138+17	0021' CD0000  	                call skpspc             ; Skip spaces
 114:  155+7	0024' 7E      	                ld a, (hl)              ; This should be a drive letter
 115:  162+6	0025' 23      	                inc hl
 116:     -	0000'         	                ifdef DEBUG
 118:				                endif
 119:  168+7	0026' D641    	                sub "A"                 ; Convert to a number
 120:				; If this carries, the byte is not a letter. It may be the zero terminator, if no
 121:				; operand were supplied.
 122:  175+7+5	0028' 3825    	                jr c, op_error
 123:  182+7	002A' FE10    	                cp NUM_DISKS_MAX
 124:  189+7+5	002C' 3021    	                jr nc, op_error
 125:				; We have a valid drive number.
 126:  196+13	002E' 320200  	                ld (drive), a           ; Save it
 127:				;
 128:				; A following colon is optional.
 129:  209+7	0031' 7E      	                ld a, (hl)
 130:  216+7	0032' FE3A    	                cp ":"
 131:  223+7+5	0034' 2001    	                jr nz, clopt_drive_dn
 132:  230+6	0036' 23      	                inc hl                  ; Step past colon
 133:				;
 134:				; Check for options. These may begin with "[", "/" or "$", to match all
 135:				; conventions I have found used with CP/M.
 136:  236+10	0037' 110008  	clopt_drive_dn  ld de, clopt_list   ; Null-terminated list of options
 137:  246+17	003A' CD0000  	                call clopts             ; Read command line options
 138:  263+7+5	003D' 3810    	                jr c, op_error          ; Error on bad options
 139:  270+13	003F' 320300  	                ld (clopt_flags), a
 140:				; /2 and /3 options are mutually exclusive.
 141:  283+8	0042' CB4F    	                bit CLOPT_CPM2_2_BIT, a
 142:  291+7+5	0044' 2805    	                jr z, clopt_ver_ok
 143:  298+8	0046' CB57    	                bit CLOPT_CPM3_BIT, a
 144:  306+10	0048' C24F00  	                jp nz, op_error         ; Operand error if both specified
 145:				;
 146:				; HL - points to first character after options and any trailing spaces.;
 147:				; The terminator should follow.
 148:  316+7	004B' 7E      	clopt_ver_ok    ld a, (hl)
 149:     -	0000'         	                ifdef DEBUG
 151:				                endif
 152:  323+4	004C' A7      	                and a
 153:  327+7+5	004D' 280C    	                jr z, clopt_term
 154:				;
 155:				; Go here if we don't like the operands supplied.
 156:  334+10	004F' 210408  	op_error        ld hl, op_err_msg
 157:  344+10	0052' C37805  	                jp msg_exit
 158:				;
 159:				; Go here if we don't like the operating system we are running on.
 160:  354+10	0055' 213B08  	os_error        ld hl, unsupp_os_msg
 161:  364+10	0058' C37805  	                jp msg_exit
 162:				;
 163:				; Command line terminator found.
 164:  374+4	005B' AF      	clopt_term      xor a
 165:  378+13	005C' 322F00  	                ld (disk_type_flags), a ; Reset option flags
 166:				;
 167:				; Determine whether we should use CP/M 2.2 or 3 rules.
 168:  391+7	005F' 0E0C    	                ld c, BDOS_VERSION      ; Return BDOS Version Number
 169:  398+17	0061' CD0000  	                call cbdos              ; Call BDOS with some registers saved
 170:				; Returns B=H=system type, A=L=version number.
 171:  415+4	0064' 7C      	                ld a, h                 ; MSN=CPU type, LSN=CP/M type
 172:  419+4	0065' A7      	                and a
 173:  423+7+5	0066' 20ED    	                jr nz, os_error
 174:				; Match version against those supported. It is likely that others are OK too,
 175:				; but I can't test all combinations.
 176:  430+4	0068' 7D      	                ld a, l                 ; OS Version number
 177:  434+7	0069' FE20    	                cp 0x20
 178:  441+7+5	006B' 2812    	                jr z, cver_cpm2
 179:  448+7	006D' FE21    	                cp 0x21
 180:  455+7+5	006F' 280E    	                jr z, cver_cpm2
 181:  462+7	0071' FE22    	                cp 0x22
 182:  469+7+5	0073' 280A    	                jr z, cver_cpm2
 183:  476+7	0075' FE30    	                cp 0x30
 184:  483+7+5	0077' 280F    	                jr z, cver_cpm3
 185:  490+7	0079' FE31    	                cp 0x31
 186:  497+7+5	007B' 280B    	                jr z, cver_cpm3
 187:  504+12	007D' 18D6    	                jr os_error
 188:				;
 189:				; We are running on CP/M 2.x. Enable CP/M 3 features only if "/3" option is
 190:				; specified.
 191:  516+13	007F' 3A0300  	cver_cpm2       ld a, (clopt_flags)     ; Fetch command line options
 192:  529+7	0082' E604    	                and CLOPT_CPM3_MASK
 193:  536+7+5	0084' 2009    	                jr nz, cver_enable3     ; Enable on /3
 194:  543+12	0086' 1812    	                jr cver_done
 195:				;
 196:				; We are running on CP/M 3 or 3.1. Enable CP/M 3 features unless "/2" option is
 197:				; specified.
