;
;
; CP/M 2.2 and 3 file system checker. It is intended for ZARC but avoids using
; any special facilities so should run elsewhere. It reads the DPB to discover
; the organisation of the disk, so it should work for any sensible disk size or
; organisation.
;
; Each directory entry is scanned in turn, and a list (files_info) is
; constructed with one entry per file. This contains a bitmap of physical
; extents encountered, so it is possible to discover "holes" (sparse files)
; as well as duplicated extents.
;
; As files are discovered, files_info will grow by FI_SIZE each time. In
; addition, it will grow by a single byte each time more extent flags are
; required for any file.
;
; Note that there is a difference between logical and physical extents. A
; logical extent always contains 16 KB bytes of data. Each physical extent
; (directory entry) can contain one or more logical extents. (EXM + 1) is the
; number of logical extents per physical one. For ZARC (at least in its present
; form, EXM is zero so both logical and physical extents are 16 KB long. Useful
; reference:
; Ref. https://dflund.se/~pi/cpm/files/ftp.mayn.de/pub/cpm/archive/cpminfo/cpm-dir1.not.txt
;
; From this example:
; BLS = 2K so BSH = 4 and BLM = 15
; It uses 8-bit allocation numbers, so DSM < 256 and EXM = 1
;
; From: https://www.seasip.info/Cpm/format22.html
; (Physical) entry number (PEXTENT) = ((32*S2)+EX) / (EXM+1)
; There are two physical extents shown,
; S2 = 0 and EX = 1, which gives ((32*0)+1) / (2) = 0
; S2 = 0 and EX = 3, which gives ((32*0)+3) / (2) = 1
; So the above equation gives the physical extent number of a given directory
; entry. This is what we want to construct a bitmap of physical extents.
;
; CP/M 3 format information came from https://www.seasip.info/Cpm/format31.html
;
;
                title CP/M File System Checker
;
;
;
; ************
; * Includes *
; ************
;
;
                include "macros.i"
                include "cpm.i"
                include "cpm3.i"
                include "memory.i"
                include "terminal.i"    ; Terminal constants
                include "fsck.i"        ; Project include file
                include "cpm_utility.i" ; CP/M utilities
                include "cpm_terminal.i"; Terminal control
                include "cpm_top.i"     ; CP/M dummy top module
;
;
;
; *************
; * Externals *
; *************
;
;
; Variables
                extern btime    ; Build time string
;
;
;
; *************
; * Main Code *
; *************
;
;
; The CP/M transient area start address is set in the linker invocation (see
; makefile).
                cseg                    ; Code segment
;
; The default stack space is very small (8 deep), which would almost certainly
; cause issues, particularly with interrupts running. The initial code should
; not assume a Z80 so we can exit cleanly if this is run on an 8080, for
; example.
                ld (bdos_sp), sp
                ld sp, app_stack_top    ; Switch to our stack space
;
                call init               ; Common initialisation code
;
; We won't print the sign-on message yet so it can be suppressed by the q
; ("quiet") option.
;
; Clear variables area
                ld hl, clr_start        ; Start address
                ld b, clr_end - clr_start
                xor a
clr_loop        ld (hl), a
                inc hl
                djnz clr_loop
;
; Examine the command tail, looking for operands. This is stored in the default
; buffer. "The first byte at 0080H contains the length of the command tail,
; while the command tail itself begins at 0081H. The command tail is terminated
; by a byte containing a binary zero value."
; (http://www.cpm.z80.de/manuals/cpm22-m.pdf appendix H).
                ld hl, DEF_BUFFER + 1
                call skpspc             ; Skip spaces
; We might have a drive letter, some options, both or neither.
                ld a, (hl)
                and a
                jr z, op_error          ; Error if no operands.
                sub "A"                 ; Convert to a number
; If this carries, the byte is not a letter. It may be options.
                jr c, op_options
                cp NUM_DISKS_MAX
                jr nc, op_options
; We have a valid drive number.
                ld (drive), a           ; Save it
                ld a, (flags)
                or FLG_DRIVE_MASK       ; Set flag
                ld (flags), a
;
; A following colon is optional.
                inc hl
                ld a, (hl)
                cp ":"
                jr nz, op_options
                inc hl                  ; Step past colon
;
; Check for options. These may begin with "[", "/" or "$", to match all
; conventions I have found used with CP/M.
op_options      ld de, clopt_list       ; Null-terminated list of options
                call clopts             ; Read command line options
                jr c, op_error          ; Error on bad options
                ld (clopt_flags), a
;
; HL - points to first character after options and any trailing spaces.
; The terminator should follow.
                ld a, (hl)
                and a
                jr z, clopt_term
;
; Go here if we don't like the operands supplied.
op_error        ld hl, signon_msg       ; Sign on.
                call conwms             ; Print $-terminated string to console
; As above, but with no sign-on.
op_err_no_sign  ld hl, op_err_msg
                jp msg_exit
;
; Command line terminator found. Sign on unless "quiet" is selected.
clopt_term      ld a, (clopt_flags)     ; Fetch command line options
                and CLOPT_QUIET_MASK
                ld hl, signon_msg       ; Sign on.
                call z, conwms          ; Print $-terminated string to console
;
; Show build information if requested, then exit.
; Note that the build time string will be overwritten once the programme starts
; storing data at fstfre, but this is OK as long as we exit after displaying
; the string.
                ld a, (clopt_flags)     ; Fetch command line options
                and CLOPT_BUILD_MASK
                jr z, no_build
;
                ld hl, btime            ; Build time string
                call conwms             ; Print $-terminated string to console
                call cwnwln             ; Write new line characters to console
                jp exit
;
no_build        ld hl, flags
                bit FLG_DRIVE_BIT, (hl)
                jr z, op_err_no_sign    ; We need a drive for anything else
;
; Determine whether we should use CP/M 2.2 or 3 rules.
                ld a, (cpmver)          ; CP/M version (packed BCD)
                cp 0x30
                jr nc, cver_cpm3        ; Jump if running on 3.x or later
;
; We are running on CP/M 2.x. Enable CP/M 3 features only if "/3" option is
; specified.
                ld a, (clopt_flags)     ; Fetch command line options
                and CLOPT_CPM3_MASK
                jr nz, cver_enable3     ; Enable on /3
                jr cver_done
;
; We are running on CP/M 3 or 3.1. Enable CP/M 3 features unless "/2" option is
; specified.
cver_cpm3       ld a, (clopt_flags)     ; Fetch command line options
                and CLOPT_CPM2_2_MASK
                jr nz, cver_done        ; Don't set on /2
; Enable CP/M 3 features.
cver_enable3    ld hl, flags
                set FLG_CPM3_BIT, (hl)
; Skip the message if "quiet" is selected.
                ld hl, clopt_flags      ; Command line option flags
                bit CLOPT_QUIET_BIT, (hl)
                ld hl, cpm3_feat_msg    ; "CP/M 3 features enabled"
                call z, conwms          ; Print $-terminated string to console
cver_done
;
; /2 and /3 options are mutually exclusive.
                ld a, (clopt_flags)
                and CLOPT_CPM2_2_BIT | CLOPT_CPM3_BIT
                cp CLOPT_CPM2_2_BIT | CLOPT_CPM3_BIT
                jp z, op_err_no_sign    ; Operand error if both specified
;
                ld c, BDOS_RESET_DISK_SYS   ; Reset Disk System
                call cbdos              ; Call BDOS with some registers saved
; Both the above reset and the reboot at the end of this application should
; make it safe to test any drive regardless of its logged in status.
;
; Select the drive to analyse.
                ld a, (drive)
                ld c, a
                ld de, 0                ; Treat disk as new to the system
                ld hl, BIOS_SELDSK      ; Select disc drive
                call cbios              ; Call BIOS with some registers saved
; HL - pointer to Disc Parameter Header (DPH) or zero on error. Note from
; https://www.seasip.info/Cpm/bdos.html#50
;   A successful call to function 9 (SELDSK) will return HL pointing to a copy
;   of the Disk Parameter Header in common memory, rather than the original.
;   This copy may be overwritten by subsequent BDOS calls, so grab it while you
;   can.
                ld a, h
                or l
                jr nz, drive_sel_ok
; Can't select drive.
                ld hl, sel_err_msg
                call conwms             ; Print $-terminated string to console
                jp exit
;
