                inc hl
                ld d, (hl)
                ld (dpb), de            ; Save for later
                push de
                pop ix
; IX - pointer to DPB (DPB_xxx)
;
;
; *** Initialise buffers ***
;
; Reserve space for sector buffer. Under CP/M 2, this is fixed at 0x80 bytes.
; CP/M can support larger sizes. The buffer will start at the first location
; after this programme and its variables. Note that this will overwrite the
; build time string, but this should be OK.

; Find sector size, physical sectors per track and number of directory entries
; per sector.
                ld hl, 0x0080           ; CP/M 2 sector size
                ld c, CPM_SECTOR_SIZE / DIRE_SIZE
                ld e, (ix + DPB_SPT)    ; 128-byte records per track
                ld d, (ix + DPB_SPT + 1)
                ld a, (cpmver)          ; CP/M version (packed BCD)
                cp 0x30
                jr c, asb_have_size     ; Jump if running on < 3.0
; We are on CP/M 3 so we need to find the size.
                ld a, (ix + CP3_DPB_PSH)    ; Physical record shift factor
; Physical sector shift, 0 => 128-byte sectors, 1 => 256-byte sectors,
; 2 => 512-byte sectors ...
                and a
asb_size_loop   jr z, asb_have_size
                add hl, hl              ; Double size
                sla c
; A carry here indicates more than 128 directory entries per sector. For 4 KB
; sectors (maximum specified in the system programmer's manual, we have
; 4096 / 32 = 128 entries.
                call c, panic           ; Panic at > 4 KB sectors
                srl d                   ; Halve sectors per track
                rr e
; There should always be a whole number of physical sectors per track so a carry
; here indicates an issue.
                call c, panic           ; Panic at > 4 KB sectors
                dec a
                jr asb_size_loop
; DE - physical sectors per track
; C - directory entries per sector
; HL - sector size
asb_have_size   ld a, c
                ld (ents_per_sec), a    ; Save directory entries per sector
                ld (phys_spt), de       ; Save physical sectors per track 
                ld de, fstfre           ; First location after end of data
                ld (sec_buffer), de
; Find first location after buffer.
                add hl, de
                call chk_mem_lim        ; Check HL is not too high
                jp c, out_of_memory
; HL - first location after buffer
;
; Set start of block flags. These follow the sector buffer.
                ld (blk_flags), hl
;
; Calculate the number of blocks on disk. This will determine blk_flags_size,
; which requires one bit per block.
                ld l, (ix + DPB_DSM)    ; Maximum block number
                ld h, (ix + DPB_DSM + 1)
; Number of bytes required is (DSM / 8) + 1
                ld b, 3
init_blk_div    srl h
                rr l
                djnz init_blk_div
                inc hl
; HL - number of bytes.
                ld (blk_flags_size), hl
;
; Mark all blocks as free.
                ld b, h
                ld c, l
                ld hl, (blk_flags)
bfc_loop        ld a, b
                or c
                jr z, bfc_done          ; Exit if done
                call chk_mem_lim        ; Check HL is not too high
                jp c, out_of_memory
                ld (hl), 0
                inc hl
                dec bc
                jr bfc_loop
;
; Initialise file information area pointers.
; HL - first location after block flags.
bfc_done        call chk_mem_lim        ; Check HL is not too high
                jp c, out_of_memory
                ld (files_info), hl     ; Set start address of FI structures
                ld (free_start), hl     ; No files yet
; As files are discovered, files_info will grow by FI_SIZE each time. In
; addition, it will grow by a single byte each time more physical extent flags
; are required for any file.
;
; The directory starts at the beginning of the first track of the
; data area. There are DRM + 1 directory entries.
; Calculate the number of blocks used by the directory. This is given by
; the number of high bits set in DPB.AL0 and DPB.AL1. Reference:
; http://www.gaby.de/cpm/manuals/archive/cpm22htm/ch6.htm#Figure_6-5
                ld h, (ix + DPB_AL0)    ; Fetch directory allocation bits
                ld l, (ix + DPB_AL1)
; Count the "1" bits.
                ld b, 16                ; Bit counter
                ld c, 0
id_al_loop      bit 7, h                ; Test MS bit
                jr z, id_al_done        ; Exit if "0" found
                inc c                   ; Count 1 bits
                add hl, hl              ; Shift left
                djnz id_al_loop
; We end up here if either all bits are tested or a "0" bit was encountered.
id_al_done      ld a, c
                ld (dir_blocks), a
                and a
                call z, panic           ; Panic if directory has no blocks
;
; Mark the directory blocks as used.
; C - number of directory blocks
                ld hl, 0                ; Directory starts at block 0
                ld b, c
id_mark_used_lp push hl
                call flag_block         ; Mark block used
                call c, panic           ; Panic if already used
                pop hl
                inc hl
                djnz id_mark_used_lp
; 
; IX - pointer to DPB (DPB_xxx)
                ld hl, 0xffff
                ld (loaded_sector), hl  ; Set no sector loaded.
;
; Scan each entry, looking for valid-looking entries.
                ld hl, 0                ; Start at first entry
scan_loop       ld (dir_entry_num), hl  ; Loop counter
                call get_entry
; HL - points to start of entry
                push hl                 ; Move address to IY
                pop iy
                ld (dire), iy           ; Save pointer to directory entry structure
                
;
;
; *** Examine the directory entry ***
; IX - pointer to DPB (DPB_xxx)
; IY - pointer to directory entry structure (DIRE_xxx)
                ld a, (iy + DIRE_USER)
                cp 0xe5
                jp z, sl_unused
;
                ifdef DEBUG
; Display entry if not unused.
                    push af
                    call disp_dir_entry     ; Display directory entry
                    pop af
                endif
;
                cp 0x20
                jp z, sl_label          ; CP/M 3 only
                cp 0x21
                jp z, sl_date_stamp     ; CP/M 3 only
                cp MAX_USER + 1
                jp c, sl_phys_extent    ; Physical extent
                cp 0x10 + MAX_USER + 1  ; 16 + user number (ie 16-31)
                jp c, sl_password       ; CP/M 3 only
                ld de, dire_type_msg    ; "unrecognised directory entry ..."
                call sl_err_cont        ; Report any error and continue
                jp sl_entry_done        ; Entry done
;
;
; Disk label (CP/M 3 only).
sl_label        ld hl, flags
                bit FLG_CPM3_BIT, (hl)
                jr nz, sl_label_cpm3    ; Jump if CP/M 3 features enabled
; CP/M 2 mode. Write "not supported" message if this is the first label we
; found.
                ld hl, (label_count)
                ld a, h
                or l
                ld de, label_msg        ; "labels not supported on CP/M 2.x"
                call z, rpt_error       ; Report any error and continue
                jr sl_label_dn          ; Count and exit
;
; Label found and CP/M 3 features are enabled.
sl_label_cpm3   ld hl, clopt_flags      ; Command line option flags
                bit CLOPT_VERBOSE_BIT, (hl)
                jr z, sl_label_chk      ; Skip display if not verbose
;
; Verbose mode enabled, so display the label.
                ld hl, dis_lbl_msg      ; "Label: 
                call conwms             ; Print $-terminated string to console
                call disp_file          ; Display file or label name
                call cwnwln             ; Write new line characters to console
;
; Check label for illegal characters.
sl_label_chk    call chk_name           ; Check label for illegal characters
; A - attributes corresponding to each character
;   (MSB) F4 F5 F6 F7 F8 T1 T2 T3 (LSB)
;   See https://www.seasip.info/Cpm/fcb.html for descriptions/
; Carry flag - set if one or more illegal characters are encountered
; Report error if one or more issues were found.
                ld de, bad_label_msg    ; "bad disk label"
                call c, sl_err_cont     ; Report any error and continue
;
; Increment label counter.
sl_label_dn     ld hl, (label_count)
                inc hl
                ld (label_count), hl
                jp sl_entry_done        ; Entry done
;
;
; Date stamp (CP/M 3 only). If there are any date stamps, they need to be
; in the correct locations in the directory. No other validation is performed
; as the date stamps are not critical.
sl_date_stamp   ld hl, flags
                bit FLG_CPM3_BIT, (hl)
                jr nz, sl_date_cpm3     ; Jump if CP/M 3 features enabled
; CP/M 2 mode. Write "not supported" message if this is the first date stamp we
; found.
                ld hl, (date_count)
                ld a, h
                or l
                ld de, date_msg         ; "date stamps not supported ..."
                call z, rpt_error       ; Report any error and continue
                jr sl_date_dn           ; Count and exit
;
; Check position in directory. Every fourth directory entry will be a date stamp
; entry, containing stamps for the preceding three entries. Hence the LS two
; bits of the current directory entry should both be 1.
sl_date_cpm3    ld a, (dir_entry_num)   ; LS byte of entry number
                and 3
                cp 3
                jr z, sl_date_dn        ; Jump if as expected
; Increment date stamp entry misplaced counter.
                ld hl, (date_mp_count)
                inc hl
                ld (date_mp_count), hl
;
; Increment date stamp directory entry counter.
sl_date_dn      ld hl, (date_count)
                inc hl
                ld (date_count), hl
                jp sl_entry_done        ; Entry done
;
;
; Password control entry. To set a password for testing, use commands like:
; set f:dump.com [password=wibble]
; set f:[protect=on]
sl_password     ld hl, flags
                bit FLG_CPM3_BIT, (hl)
                jr nz, sl_pwd_cpm3      ; Jump if CP/M 3 features enabled
                ld de, passwd_msg       ; "passwords not supported ..."
                call sl_err_cont        ; Report any error and continue
                jp sl_entry_done        ; Entry done
;
; Display password if verbose flag is selected. This system is extremely simple.
; To decode the password, XOR PB with the 8 bytes of the password and read it
; off backwards.
sl_pwd_cpm3     ld hl, clopt_flags      ; Command line option flags
                bit CLOPT_VERBOSE_BIT, (hl)
                jr z, sl_pwd_dis_done   ; Skip display if not verbose
;
; The password is redundant if none of the valid mode bits are set.
                ld a, (iy + DPWDE_PM)   ; Mode byte
                and DPWDE_PM_DEL_MASK | DPWDE_PM_WRITE_MASK | DPWDE_PM_READ_MASK
                jr z, sl_pwd_dis_done
;
; Display the password.
                call disp_user_file     ; Display user and filename
                ld hl, pwd_msg1         ; " requires password """
                call conwms             ; Print $-terminated string to console
;
; Display the password string itself.
                ld c, (iy + DPWDE_PB)   ; Decode byte
                ld b, DIR_PWD_SIZE      ; Password length
; Find address of last byte.
                push iy
                pop hl
                ld de, DPWDE_PWD + DIR_PWD_SIZE - 1
                add hl, de
sl_pwd_dis_lp   ld a, (hl)
                xor c
                call disp_char_hex      ; Display byte as char or hex
                dec hl
                djnz sl_pwd_dis_lp
                ld hl, pwd_msg2         ; """ to  "
                call conwms             ; Print $-terminated string to console
;
                ld hl, pwd_del_msg      ; "(delete) "
                bit DPWDE_PM_DEL_BIT, (iy + DPWDE_PB)
                call nz, conwms         ; Print $-terminated string to console
;
                ld hl, pwd_write_msg      ; "(write to) "
                bit DPWDE_PM_WRITE_BIT, (iy + DPWDE_PB)
                call nz, conwms         ; Print $-terminated string to console
;
                ld hl, pwd_read_msg      ; "(read from) "
                bit DPWDE_PM_READ_BIT, (iy + DPWDE_PB)
                call nz, conwms         ; Print $-terminated string to console
;
                ld hl, pwd_msg3         ; "the file"
                call conwms             ; Print $-terminated string to console
;
; Password display complete (or skipped). Report error if multiple passwords
; found for the first time for this file. Find file information structure or
; create a new one if it doesn't exist.
sl_pwd_dis_done call find_fi
; IX - pointer to file information structure.
; IY - pointer to directory entry structure (DIRE_xxx)
; A - number of mismatched flags found during file match.
                bit FIF_FFLG_PWD_BIT, (ix + FI_FLAGS)
                set FIF_FFLG_PWD_BIT, (ix + FI_FLAGS)
                jr z, sl_pwd_done       ; Jump if flag was reset
; If there was a previous password, moan.
                ld de, mult_pwds_msg    ; "has multiple passwords!"
                call sl_err_cont        ; Report any error and continue
;
sl_pwd_done     jp sl_entry_done        ; Entry done
;
;
; This is an unused entry.
sl_unused       ld hl, (unused_count)
                inc hl
                ld (unused_count), hl
                jp sl_entry_done        ; Entry done
;
;
; Calculate physical extent. Adapted from
; https://www.seasip.info/Cpm/format22.html:
; An extent is the portion of a file controlled by one directory entry. If a
; file takes up more blocks than can be listed in one directory entry, it is
; given multiple entries, distinguished by their EX and S2 bytes.  A logical
; extent is always 16 KB long, but there can be multiple logical extents in a
; physical extent (directory entry). This is defined by DPB.EXM. The formula
; is: directory number (physical extent) = ((32 * S2) + EX) / (exm + 1) where
; EXM is the extent mask value from the Disc Parameter Block.
sl_phys_extent  ld l, (iy + DIRE_S2)        ; Extent counter, high byte
                ld h, 0
                add hl, hl
                add hl, hl
                add hl, hl
                add hl, hl
                add hl, hl
; HL is (32 * S2)
                ld e, (iy + DIRE_EX)    ; Extent counter, low byte (0-31)
                ld d, 0
                add hl, de
; HL is (32 * S2) + EX
                ld c, (ix + DPB_EXM)    ; Extent mask
; A is 0, 1, 3, 7 or 15. We need to divide by one greater than each of these.
sl_calc_ext_lp  ld a, c
                and a
                jr z, sl_calc_ext_dn
                srl h                   ; Divide by two
                rr l
                srl c                   ; Reduce mask
                jr sl_calc_ext_lp
; HL - physical extent
sl_calc_ext_dn  ld (phys_extent), hl    ; Save calculated extent
;
                ifdef DEBUG
                    ld hl, phys_ext_msg     ; "Physical extent: "
                    call conwms             ; Print $-terminated string to console
                    ld hl, (phys_extent)
                    call cwpdwd             ; Print HL in decimal
                    call cwnwln             ; Write new line characters to console
                endif
;
                call chk_name           ; Check filename for illegal characters
; A - attributes corresponding to each character
;   (MSB) F4 F5 F6 F7 F8 T1 T2 T3 (LSB)
;   See https://www.seasip.info/Cpm/fcb.html for descriptions/
; Carry flag - set if one or more illegal characters are encountered
                push af                 ; Save attributes
; Report error if one or more issues were found.
                ld de, bad_name_msg     ; "bad file name"
                call c, sl_err_cont     ; Report any error and continue
                pop af
; F1 to F4 can be anything (application controlled)
; F5 to F8 should be zero
; T1 - read-only
; T2 - system (hidden)
; T3 - archive. Set if the file has not been changed since it was last copied.
; To complicate things, ZSDOS defines some more:
; F2 - public
; F3 - No access stamp
; F8 - wheel protect
; Doubtless other systems and software use these flags differently. On balance,
; it seems better skip this check rather than generate large number of nuisance
; messages on such systems.
;                and 01111000b
;                ld de, bad_attr_msg     ; "bad file name attributes"
;                call nz, sl_err_cont    ; Report any error and continue
;
; Check extent counter.
                ld de, bad_ex_cnt_msg   ; "bad extent count"
                ld a, (iy + DIRE_EX)    ; Extent counter, low byte (0-31)
                cp 32
                call nc, sl_err_cont    ; Report any error and continue
;
; Check S1.
                ld de, bad_s1_msg       ; "bad S1"
                ld a, (iy + DIRE_S1)    ; Reserved, set to 0
                and a
                call nz, sl_err_cont    ; Report any error and continue
;
; Find file information structure or create a new one if it doesn't exist.
                call find_fi
; IX - pointer to file information structure.
; IY - pointer to directory entry structure (DIRE_xxx)
; A - number of mismatched flags found during file match.
                ld (fie), ix            ; Save pointer to file information structure
;
; Flag that file has at least one physical extent.
                set FIF_FFLG_PEXT_BIT, (ix + FI_FLAGS)
; Set the relevant physical extent flag, expanding the length of the extent
; flags if required.
                ld hl, (phys_extent)    ; Fetch extent number
                call flag_extent        ; Mark block used
                ld de, ext_dup_msg      ; "duplicated physical extent"
                jp c, sl_err_stop       ; Error and stop if already used
;
; Mark the blocks used. Entries may be 8 or 16-bit, depending on the number of
; blocks on the disk.
slf_ext_done    ld ix, (dpb)
                ld c, 0                 ; Reset flags (ALLCF_xxx) and counter
; IX - pointer to DPB (DPB_xxx)
; IY - pointer to directory entry structure (DIRE_xxx)
; C - flags and counter
                ld a, (ix + DPB_DSM + 1)    ; Fetch MS byte of DSM
                and a
                jr z, slf_bytes         ; Jump if < 256 blocks
;
; The maximum block number is >= 256, so the allocation list is in words.
                ld b, 8
slf_wd_alu_lp   ld l, (iy + DIRE_ALLOC) ; Fetch next allocation
                ld h, (iy + DIRE_ALLOC + 1)
                ld a, h
                or l
                jr nz, slf_wd_alu_used
; Unused entry.
                set ALLCF_UNUSED_BIT, c ; Flag unused entry found
                jr slf_wd_alu_dn
; Used entry.
slf_wd_alu_used inc c                   ; Keep count
                call flag_block         ; Mark block used
                jp c, sl_err_stop       ; Error if already used
                bit ALLCF_UNUSED_BIT, c
                jr z, slf_wd_alu_dn     ; Jump if no unused entries encountered
; This used entry is preceded by an unused one. This means we have a holed, or
; "sparse" file.
                set ALLCF_SPARSE_BIT, c ; Hole detected
;
; Allocation entry done.
slf_wd_alu_dn   inc iy
                inc iy
                djnz slf_wd_alu_lp
                jr slf_alu_dn
;
; The maximum block number is < 256, so the allocation list is in bytes.
slf_bytes       ld b, 16
slf_by_alu_lp   ld a, (iy + DIRE_ALLOC) ; Fetch next allocation
                and a
                jr nz, slf_by_alu_used
; Unused entry.
                set ALLCF_UNUSED_BIT, c ; Flag unused entry found
                jr slf_by_alu_dn
; Used entry.
slf_by_alu_used inc c                   ; Keep count
                ld h, 0
                ld l, a
                call flag_block         ; Mark block used
                jp c, sl_err_stop       ; Error if already used
                bit ALLCF_UNUSED_BIT, c
                jr z, slf_by_alu_dn     ; Jump if no unused entries encountered
<<<<<<< HEAD
; This used entry is preceded by an unused one. This means we have a holed, or
=======
; This used entry is preceeded by an unused one. This means we have a holed, or
>>>>>>> refs/remotes/origin/main
; "sparse" file.
                set ALLCF_SPARSE_BIT, c ; Hole detected
;
; Allocation entry done.
slf_by_alu_dn   inc iy
                djnz slf_by_alu_lp
;
; Blocks flagged appropriately.
slf_alu_dn      ld iy, (dire)           ; Restore pointer to directory entry structure
                bit ALLCF_SPARSE_BIT, c
; A sparse file (one with a hole) is not necessarily an error, as discussed in
; http://www.gaby.de/cpm/manuals/archive/cpm22htm/ch5.htm function 35 (description).
                ld de, sparse_msg       ; "is sparse (holed) [warning]"
                call nz, sl_err_cont    ; Error if hole detected
;
; Check for blocks with no allocations at all.
                ld a, c
                and ALLCF_COUNT         ; Isolate count
                ld de, no_alloc_msg     ; "no allocations in physical extent [warning]"
                call z, sl_err_cont     ; Error if no allocations
;
; Checking record count (RC). This should be 0x80 (128 * 128 = 18 KB) for
; anything but the last extent. Note that FI_LAST_PEXT could be derived from
; the bitmap, but it is easier to store it.
; Note: the illegal case PEXT = FI_LAST_PEXT will be picked up in the extent
; flagging code.
                ld ix, (fie)            ; Fetch pointer to file information structure
; IX - pointer to file information structure (FI_xxx)
; IY - pointer to directory entry structure (DIRE_xxx)
                ld hl, (phys_extent)
                ld e, (ix + FI_LAST_PEXT)   ; Last extent
                ld d, (ix + FI_LAST_PEXT + 1)
                and a
                sbc hl, de
                jr nc, slfrc_not_last
; Not the highest extent found so far, so RC should be 0x80.
                ld a, (iy + DIRE_ALLOC)
                cp 0x80
                ld de, bad_rc_msg       ; "RC not 0x80 in intermediate extent"
                call nz, sl_err_cont
                jr slfrc_done
;
; This is the highest extent encountered so far or it is the first extent
; encountered (FI_LAST_PEXT = 0).
slfrc_not_last  ld a, (ix + FI_LAST_PEXT)   ; Last extent
                or (ix + FI_LAST_PEXT + 1)
                jr z, slfrc_update
;
; This isn’t the first extent, so the previous one should have RC = 0x80.
                ld a, (ix + FI_LAST_RC)
                cp 0x80
                ld de, bad_rc_msg       ; "RC not 0x80 in intermediate extent"
                call nz, sl_err_cont
;
; RC checks complete. Update the FI_LAST_PEXT and FI_LAST_RC fields for next
; time.
slfrc_update    ld hl, (phys_extent)    ; Set FI_LAST_PEXT = PEXTENT
                ld (ix + FI_LAST_PEXT), l
                ld (ix + FI_LAST_PEXT + 1), h
                ld a, (iy + DIRE_RC)    ; Set FI_LAST_RC = RC
                ld (ix + FI_LAST_RC), a
slfrc_done
;
; Entry scanned.
sl_entry_done   ld ix, (dpb)
; IX - pointer to DPB (DPB_xxx)
; IY - pointer to directory entry structure (DIRE_xxx)
                ld hl, (dir_entry_num)  ; Loop counter
                ld a, l
                cp (ix + DPB_DRM)       ; Is this the last entry?
                jr nz, sl_do_next
                ld a, h
                cp (ix + DPB_DRM + 1)
                jr z, scan_done
sl_do_next      inc hl                  ; Next entry
                jp scan_loop
;
;
; Error found. Display the entry and an appropriate message, then skip any
; remaining checks. Call with:
; DE - pointer to message
sl_err_stop     call sl_err_cont
                jr sl_entry_done
;
;
; *** All directory entries scanned ***
;
; Examine each file in files_info, performing further checks.
scan_done       ld iy, (files_info)
;
spck_loop       ld de, (free_start)     ; First free location
                push iy
                pop hl
                and a
                sbc hl, de
                jp nc, spck_done        ; Jump if buffer exhausted
; There is an entry to examine.
;
; Check for missing extents. This is different from the previous sparse check,
; as this looks for missing allocations within each physical extent. All entries
; except the last one should be 0xff. The last should consist of zero or more
; "1" bits extending from the LS end with no gaps.
                push iy
                pop hl
                ld de, FI_EX_FLAGS
                add hl, de
; HL - pointer to first extent flag byte.
                ld a, (iy + FI_EX_FL_LEN)
                and a
                jr nz, spck_not_empty
;
                ld de, empty_msg        ; "has no data"
                call spck_error         ; Error if no extents at all
                jp spck_mext_done
;
; File as at least one extent.
spck_not_empty  ld c, a
                ld b, 0                 ; Error flag
;
; B - sparse flag (zero if OK)
; C - length remaining
; HL - pointer to extent flag byte
; IY - pointer to files_info entry (FI_xxx)
spck_byte_loop  ld a, c
                cp 1
                jr z, spck_last_byte
; Not the last byte.
                ld a, (hl)
                cp 0xff
                jr z, spck_byte_ok
; We have encountered a hole.
spck_sp_err     ld b, 1                 ; Flag sparseness
spck_byte_ok    inc hl
                dec c
                jr spck_byte_loop
;
; Process the last byte. This should not be zero, as flag bytes are only
; created when required to flag an extent.
spck_last_byte  ld a, (hl)
                and a
                call z, panic           ; Panic if flag is all zeroes
                ld c, a
; Keep shifting until no "1" bit falls off the end.
spck_bit_loop   srl c                   ; Shift LS bit to carry
                jr c, spck_bit_loop
; The result should be zero.
                jr z, spck_last_ok
                ld b, 1                 ; Flag sparseness
;
; File checks complete.
; B - sparse flag (zero if OK)
spck_last_ok    ld a, b
                and a
                ld de, sparse_msg       ; "is sparse (holed) [warning]"
                call nz, spck_error     ; Error if hole detected
;
; Missing extent checks complete for this entry. 
spck_mext_done  bit FIF_FFLG_PWD_BIT, (iy + FI_FLAGS)
                jr z, spck_opwd_done    ; Jump if no password associated with file
; Count password protected files.
                ld hl, (pwd_count)
                inc hl
                ld (pwd_count), hl
;Check for orphan passwords.
                bit FIF_FFLG_PEXT_BIT, (iy + FI_FLAGS)
                jr nz, spck_opwd_done   ; Jump if physical extent(s) present
; A password entry was found, but no associated physical extents.
                ld de, orp_pwd_msg      ; "orphan password (has no file)"
                call spck_error         ; Error if no extents at all
spck_opwd_done
;
; File checks complete. Advance pointer by the length of this structure. We must
; include the length of the extent flags section (FI_EX_FL_LEN).
                ld e, (iy + FI_EX_FL_LEN)
                ld d, 0
; DE - extent flags length.
                add iy, de              ; Add length to base
                ld de, FI_SIZE
                add iy, de              ; Add structure size
                jr spck_loop
;
;
; *** End of scan checks ***
spck_done       ld ix, (dpb)
; IX - pointer to DPB (DPB_xxx)
;
; Check label count is sensible (0 or 1).
                ld hl, (label_count)
                ld bc, 1 + 1            ; Maximum count is 1
                and a
                sbc hl, bc
                jr c, lbl_ok            ; Jump if OK
; Too many labels (more than 1).
                add hl, bc              ; Restore HL
                call cwpdwd             ; Print HL in decimal
                ld de, mult_labels_msg  ; " labels found!"
                call rpt_error
lbl_ok
;
; Check date stamps count is OK (0 or (DPB.DSM + 1) / 4).
                ld hl, (date_count)
                ld a, h
                or l
                jr z, dsc_done          ; Jump if no date stamps found
; At least one date stamp entry was found.
                ld e, (ix + DPB_DSM)    ; Maximum block number
                ld d, (ix + DPB_DSM + 1)
                inc de
; DE - total number of blocks. This should always be divisible by 4. Now divide
; it by 4 to find the number of entries expected.
                srl d
                rr e
                call c, panic
                srl d
                rr e
                call c, panic
; DE - number of date stamp entries expected.
                and a
                sbc hl, de
                jr z, dsc_done          ; Jump if number matches expectation
                add hl, de              ; Restore HL
; Report error.
                push hl
                push de
                ld hl, date_num_msg1    ; "Date stamp entry count error ..."
                call conwms             ; Print $-terminated string to console
                pop hl
                call cwpdwd             ; Print HL in decimal
                ld hl, date_num_msg2    ; " found "
                call conwms             ; Print $-terminated string to console
                pop hl
                call cwpdwd             ; Print HL in decimal
                call cwnwln             ; Write new line characters to console
                call inc_error_cnt      ; Increment error count
dsc_done
;
; Report of any date stamp entries were misplaced.
                ld hl, (date_mp_count)  ; Date stamp entry misplaced counter
                ld a, h
                or l
                jr z, dsm_done          ; Jump if no misplaced entries found
; Report error.
                call cwpdwd             ; Print HL in decimal
                ld hl, date_mp_msg      ; " date stamp entries incorrectly placed"
                call conwms             ; Print $-terminated string to console
                call cwnwln             ; Write new line characters to console
                call inc_error_cnt      ; Increment error count
dsm_done
;
; All checks complete.
; Skip the summary and block usage map if "quiet" is selected.
                ld hl, clopt_flags      ; Command line option flags
                bit CLOPT_QUIET_BIT, (hl)
                jp nz, surface_scan     ; Skip display if quiet
;
                ld hl, dir_done_msg     ; "Directory checks complete"
                call conwms             ; Print $-terminated string to console
;
                ld hl, errors_msg       ; "Errors and warnings: "
                call conwms             ; Print $-terminated string to console
                ld hl, (error_count)
                call cwpdwd             ; Print HL in decimal
                call cwnwln             ; Write new line characters to console
;
                ld hl, files_msg        ; "Files found: "
                call conwms             ; Print $-terminated string to console
                ld hl, (file_count)
                call cwpdwd             ; Print HL in decimal
                ld hl, files1_msg       ; " including "
                call conwms             ; Print $-terminated string to console
                ld hl, (sys_count)
                call cwpdwd             ; Print HL in decimal
                ld hl, files2_msg       ; " system files and "
                call conwms             ; Print $-terminated string to console
                ld hl, (ro_count)
                call cwpdwd             ; Print HL in decimal
                ld hl, files3_msg       ; " read only files"
                call conwms             ; Print $-terminated string to console
                call cwnwln             ; Write new line characters to console
;
                ld hl, pwd_files_msg    ; "Password protected files: "
                call conwms             ; Print $-terminated string to console
                ld hl, (pwd_count)
                call cwpdwd             ; Print HL in decimal
                call cwnwln             ; Write new line characters to console
;
; Show file counts per user if verbose flag selected.
                ld hl, clopt_flags      ; Command line option flags
                bit CLOPT_VERBOSE_BIT, (hl)
                jr z, duc_done          ; Skip display if not verbose
;
; Also skip if no files were found.
                ld hl, (file_count)
                ld a, h
                or l
                jr z, duc_done          ; Skip display if no files were found
;
                ld hl, files_user_msg   ; "Breakdown of files by user"
                call conwms             ; Print $-terminated string to console
;
                ld b, 0                 ; User count
                ld hl, file_count_user  ; File counts per user
duc_user_loop   ld e, (hl)
                inc hl
                ld d, (hl)
                inc hl
; DE - count
                ld a, d
                or e
                jr z, duc_skip          ; Skip if count is zero
;
; Display the counts
                push hl
                ld hl, user_msg         ; "  User "
                call conwms             ; Print $-terminated string to console
                ld a, b
                call cwpdby             ; Print A in decimal
                ld hl, user_files_msg   ; " files found: "
                call conwms             ; Print $-terminated string to console
                ex de, hl
                call cwpdwd             ; Print HL in decimal
                call cwnwln             ; Write new line characters to console
                pop hl
;
duc_skip        inc b
                ld a, b
                cp (MAX_USER + 1)
                jr c, duc_user_loop
duc_done
;
                ld hl, unused_msg        ; "Unused directory entries: "
                call conwms             ; Print $-terminated string to console
                ld hl, (unused_count)
                call cwpdwd             ; Print HL in decimal
                call cwnwln             ; Write new line characters to console
;
                ld hl, blocks_used_msg  ; "Blocks used: "
                call conwms             ; Print $-terminated string to console
                ld hl, (blocks_used)
                call cwpdwd             ; Print HL in decimal
                ld hl, of_msg           ; " of "
                call conwms             ; Print $-terminated string to console
                ld l, (ix + DPB_DSM)    ; Maximum block number
                ld h, (ix + DPB_DSM + 1)
                inc hl
; HL - total number of blocks
                call cwpdwd             ; Print HL in decimal
                call cwnwln             ; Write new line characters to console
;
; Debugging information.
                ifdef DEBUG
; Dynamic address allocations.
                    ld hl, sec_buffer_msg   ; "Sector buffer: "
                    call conwms             ; Print $-terminated string to console
                    ld hl, (sec_buffer)
                    call cwphwd             ; Print HL in hexadecimal
                    call cwnwln             ; Write new line characters to console
;               
                    ld hl, blk_flags_msg    ; "Block flags: "
                    call conwms             ; Print $-terminated string to console
                    ld hl, (blk_flags)
                    call cwphwd             ; Print HL in hexadecimal
                    call cwnwln             ; Write new line characters to console
;               
                    ld hl, files_info_msg   ; "Files info: "
                    call conwms             ; Print $-terminated string to console
                    ld hl, (files_info)
                    call cwphwd             ; Print HL in hexadecimal
                    call cwnwln             ; Write new line characters to console
;               
                    ld hl, free_start_msg   ; "Free start: "
                    call conwms             ; Print $-terminated string to console
                    ld hl, (free_start)
                    call cwphwd             ; Print HL in hexadecimal
                    call cwnwln             ; Write new line characters to console
                endif
;
;
; *** Display block usage map ***
; Blocks go from 0 to DPB.DSM. Scale this to the display. Scaling will be one
; block per character, unless this won't fit in a reasonable space. In that
; case, the scaling is progressively halved until it does fit.
                ld hl, block_map_msg    ; "Block map ..."
                call conwms             ; Print $-terminated string to console
;
                ld c, 0                 ; Initial shift (scaling)
                ld b, 1                 ; Scale factor
; Scaling loop.
bdis_scale_loop ld l, (ix + DPB_DSM)    ; Maximum block number
                ld h, (ix + DPB_DSM + 1)
                inc hl
; HL - total number of blocks
                push bc
                call rshift_word        ; Shift HL >> C
                pop bc
                ld de, BDIS_CHARS_MAX
                and a
                sbc hl, de
                jr c, bdis_scale_done   ; Jump if scaling OK
; Halve size
                inc c                   ; One more shift
                and a
                rl b                    ; Double scale
                call c, panic           ; Panic on overflow
                jr bdis_scale_loop
;
bdis_scale_done ld a, c
                ld (bdis_shift), a      ; Set shift (scaling)
                ld a, b
                ld (bdis_scale), a      ; Set scale
;;
; Display loop.
                ld hl, 0                ; Start at first block
                xor a
                ld (bdis_s_count), a    ; Scale counter
                ld (bdis_col), a        ; Display column
                ld b, "-"               ; Default character
; B - character
; HL - block number
; Is this a directory block?
bdis_loop       ld a, h
                and a
                jr nz, bdis_not_dir     ; Not a directory block
                ld a, (dir_blocks)      ; Number of blocks used by the directory
                ld e, a
                ld a, l
                cp e
                jr nc, bdis_not_dir     ; Not a directory block
; This is a directory block.
                ld a, "D"
                ld b, a
                jr bdis_blk_done
;
; Not a directory block. Is this block allocated?
bdis_not_dir    push hl                 ; Save block number
                ld de, (blk_flags)      ; Base address of bit map
                call BitAddrMask        ; Find address and mask
; A – bit mask (one bit set)
; HL – address
                ld e, (hl)
                pop hl                  ; Restore block number
                and e
                jr z, bdis_blk_done     ; Jump if unused
;
; This is a file block
                ld a, "F"
                ld b, a
;
; Block processing complete. Have we reached the end of the displayed
; character?
bdis_blk_done   ld a, (bdis_s_count)    ; Scale (block) counter
                inc a
                ld c, a
                ld a, (bdis_scale)      ; Scale (n:1)
                cp c
                jr nz, bdis_entry_done
;
; Display the character.
                ld a, b
                call conwch             ; Write character to console
                ld b, "-"               ; Default character
;
; Update display column and start a newline if required.
                ld a, (bdis_col)
                inc a
                cp VT100_COLS           ; Assume a VT-100 for this purpose
                jr c, bdis_col_done
; We are at the end of the line.
                call cwnwln             ; Write new line characters to console
                xor a
bdis_col_done   ld (bdis_col), a        ; Save updated column
                ld c, 0                 ; Reset scale divider
;
; C - scale (block) counter
; HL - block number
; IX - pointer to DPB (DPB_xxx)
bdis_entry_done ld a, c
                ld (bdis_s_count), a    ; Save updated scale (block) counter
                inc hl                  ; Next block
                ld e, (ix + DPB_DSM)    ; Maximum block number
                ld d, (ix + DPB_DSM + 1)
                inc de
; DE - total number of blocks
                push hl
                and a
                sbc hl, de
                pop hl
                jr c, bdis_loop
                call cwnwln             ; Write new line characters to console
;
;
; *** Surface scan ***
; Read every block to ensure that they are readable. The reserved (system) area
; is not read, as this may have a different geometry to the files area and this
; may cause trouble. Blocks extend from 0 (the beginning of the directory) to
; DPB.DSM. Each block consists of DPB.BLM + 1 records. Alternatively, shifting
; the number of blocks by DPB.BSH gives the number of records.
surface_scan    ld hl, clopt_flags      ; Command line option flags
                bit CLOPT_SCAN_BIT, (hl)
                jr nz, ss_do_it
; Skip the message if "quiet" is selected.
                bit CLOPT_QUIET_BIT, (hl)
                ld hl, no_ss_msg        ; "Surface scan skipped ..."
                jp z, msg_exit
                jp exit                 ; Exit straight away
;
ss_do_it        ld hl, surf_scan_msg    ; "Checking all blocks ..."
                call conwms             ; Print $-terminated string to console
; Find number of records in file system.
                ld e, (ix + DPB_DSM)    ; Maximum block number
                ld d, (ix + DPB_DSM + 1)
                inc de
                ld c, 0                 ; Extend to 24 bits
; CDE - number of blocks
                ld b, (ix + DPB_BSH)    ; Block shift factor
; Valid BSH values are 3 to 7.
ss_find_sec_lp  sla e
                rl d
                rl c
                call c, panic           ; Panic on overflow
                djnz ss_find_sec_lp
; CDE - number of records in file system area (does not include reserved
; (system) area.
                ld a, (cpmver)          ; CP/M version (packed BCD)
                cp 0x30
                jr c, ss_phys_sec       ; No conversion if on CP/M < 3.0
; Convert records to physical sectors.
                ld a, (ix + CP3_DPB_PSH)    ; Physical record shift factor
; Physical sector shift, 0 => 128-byte sectors, 1 => 256-byte sectors,
; 2 => 512-byte sectors ...
                and a
ss_phys_loop    jr z, ss_phys_sec
                srl c                   ; Halve sectors
                rr d
                rr e
; There should always be a whole number of physical sectors per track so a carry
; here indicates an issue.
                call c, panic           ; Panic at > 4 KB sectors
                dec a
                jr ss_phys_loop
; CDE - number of physical sectors in file system area (does not include
; reserved (system) area.
ss_phys_sec     ld hl, total_sectors    ; Number of physical sectors in file system
                ld (hl), e
                inc hl
                ld (hl), d
                inc hl
                ld (hl), c
;
; All blocks are read, including the directory blocks processed earlier. It
; seems easier this way.
                ld hl, 0xffff
                ld (disp_track), hl     ; Force display of first track
                ld de, 0                ; Set initial sector
                ld c, 0
ss_loop         push de                 ; Save sector
                push bc
; CDE - sector number (offset into data area)
                call set_sector
;
; Display the track if it has changed. This is to avoid repeatedly writing the
; same track number, as this slows the scan greatly.
                ld hl, (track)
                ld de, (disp_track)
                ld a, l
                cp e
                jr nz, ss_disp_track    ; Jump on mismatch
                ld a, h
                cp d
                jr z, ss_nodisp         ; Jump match
ss_disp_track   push hl                 ; Save track
                ld a, ASCII_CR
                call conwch             ; Write character to console
                ld hl, track_msg        ; "Track: "
                call conwms             ; Print $-terminated string to console
                pop hl
                ld (disp_track), hl     ; Save for next time
                call cwpdwd             ; Print HL in decimal
;
; Read the sector.
ss_nodisp       ld hl, BIOS_READ        ; Read a sector
                call cbios              ; Call BIOS with some registers saved
                and a
                jr z, ss_sec_done
; I/O error!
                ld hl, sector_msg       ; ", sector: "
                call conwms             ; Print $-terminated string to console
                ld hl, (sector)
                call cwpdwd             ; Print HL in decimal
;
                call cwpspc             ; Print a space
                ld hl, disk_err_msg     ; "Disk I/O error."
                call conwms             ; Print $-terminated string to console
; This message ends in a CR / LF sequence, so it will remain visible.
;
; Sector done. Write a carriage return only, so the next message will overwrite
; the current one except after an error.
ss_sec_done     pop bc
                pop de
; Find next sector (in CDE).
                ld a, e
                add 1
                ld e, a
                ld a, d
                adc 0                   ; Propagate carry
                ld d, a
                ld a, c
                adc 0
                ld c, a
                call c, panic           ; Panic on overflow
;
; Is there more to do?
                ld hl, total_sectors    ; Number of sectors in file system
                ld a, e
                cp (hl)
                jr nz, ss_loop
                inc hl
                ld a, d
                cp (hl)
                jr nz, ss_loop
                inc hl
                ld a, c
                cp (hl)
                jr nz, ss_loop
;
                ld hl, scan_done_msg    ; "Scan complete"
                call conwms             ; Print $-terminated string to console
;
                jr exit
;
out_of_memory   ld hl, memory_msg       ; "Insufficient memory"
;
; Print message pointed to by HL, then exit.
msg_exit        call conwms             ; Print $-terminated string to console
;
; Return to CP/M.
exit            ld sp, (bdos_sp)
; For this application a warm boot is required as we may have overwritten the
; CCP.
;                ret                     ; Return to BDOS
                jp 0                    ; Warm boot
;
;
;
; ***************
; * Subroutines *
; ***************
;
;
; Look for the file in the file information structure buffer. Call with:
; IY - pointer to directory entry structure (DIRE_xxx)
; Returns with:
; A - number of mismatched flags if an existing entry was found.
; IX - pointer to file information structure.
; A, BC, DE, HL and IX registers are not preserved.
find_fi         ld ix, (files_info)     ; Start address of FI structures
; IX - address in files_info structure.
ffi_find_loop   ld de, (free_start)     ; First free location
                push ix
                pop hl
                and a
                sbc hl, de
                jp nc, ffi_no_match     ; Jump if buffer exhausted
; There is an entry to examine.
                push ix
                pop de
                push iy
                pop hl
; DE - pointer to file information structure.
; HL - pointer to directory entry structure.
                call match_file
; A - number of mismatched flags if carry is zero (files match)
; Carry flag set if files don't match.
                jp nc, ffi_found_fi     ; Jump if matching structure found
;
; Advance pointer by the length of this structure. We must include the length
; of the extent flags section (FI_EX_FL_LEN).
                ld e, (ix + FI_EX_FL_LEN)
                ld d, 0
; DE - extent flags length.
                add ix, de              ; Add length to base
                ld de, FI_SIZE
                add ix, de              ; Add structure size
                jr ffi_find_loop
;
; File information structure buffer search complete and no matching entry was
; found. Create a new entry.
ffi_no_match    ld hl, (free_start)     ; Insert point
                ld de, FI_SIZE          ; Number of bytes required
                call fi_make_room       ; Make room in the FI structures store
                jp c, out_of_memory
;
; Copy the relevant fields.
                push hl
                pop ix
                push iy
                pop de
; HL & IX - pointer to file information structure (FI_xxx)
; DE & IY - pointer to directory entry structure (DIRE_xxx)
; Copy user number.
                assert FI_USER = 0
                assert DIRE_USER = 0
                ld a, (de)
                and 0x0f                ; Isolate user number bits
                ld (hl), a
                inc de
                inc hl
;
; Copy filename.
                assert FI_NAME = 1
                assert DIRE_NAME = 1
                ld b, FILENAME_SIZE
ffi_name_loop   ld a, (de)
                ld (hl), a
                inc de
                inc hl
                djnz ffi_name_loop
;
; Copy type.
                assert FI_TYP = 9
                assert DIRE_TYP = 9
                ld b, FILEEXT_SIZE
ffi_typ_loop    ld a, (de)
                ld (hl), a
                inc de
                inc hl
                djnz ffi_typ_loop
;
                ld (ix + FI_FLAGS), 0           ; FIF_xxx flags
                ld (ix + FI_EX_FL_LEN), 0       ; No extent flags initially
                ld (ix + FI_LAST_PEXT), 0       ; Last extent
                ld (ix + FI_LAST_PEXT + 1), 0   ; Last extent
;
                ifdef DEBUG
                    call disp_user_file     ; Display user and filename
                    call cwnwln             ; Write new line characters to console
                endif
;
; Count new files.
                ld hl, (file_count)     ; Overall file count
                inc hl
                ld (file_count), hl
;
; Per user count
                ld a, (iy + DIRE_USER)
                add a, a
                ld e, a
                ld d, 0
                ld hl, file_count_user  ; File counts per user
                add hl, de
; HL - address of counter
                inc (hl)
                jr nz, ffi_uinc_done
                inc hl
                inc (hl)
ffi_uinc_done
;
                ld a, (iy + DIRE_TYP + 1)       ; Fetch file type with T2 bit
                and 0x80
                jr z, ffi_sys_done      ; Jump if not a system file
;
                ld hl, (sys_count)
                inc hl
                ld (sys_count), hl
;
ffi_sys_done    ld a, (iy + DIRE_TYP)   ; Fetch file type with T1 bit
                and 0x80
                jr z, ffi_ro_done       ; Jump if not a read-only file
;
                ld hl, (ro_count)
                inc hl
                ld (ro_count), hl
ffi_ro_done
;
; Debugging information.
                ifdef DEBUG
                    call disp_file          ; Display file or label name
                    call cwnwln             ; Write new line characters to console
                endif
;
                xor a                   ; Set mismatched flags count to zero
                jr ffi_exit
;
; Matching structure found. Set error flag if mismatched file flags (system,
; read-only ...) were found.
ffi_found_fi    and a
                jr z, ffi_exit
; Report error if mismatched file flags found for the first time for this file.
                push af
                bit FIF_FFLG_MMAT_BIT, (ix + FI_FLAGS)
                ld de, bad_flags_msg    ; "inconsistent file flag(s) in directory"
                call z, sl_err_cont     ; Report any error and continue
                set FIF_FFLG_MMAT_BIT, (ix + FI_FLAGS)
                pop af
;
ffi_exit        ret
;
;
; Display a character if it is printable, or the hexadecimal value surrounded
; by "<" and ">" if it is not. Call with:
; A - character (byte) to display
disp_char_hex   cp 0x20
                jr c, dch_hex
                cp 0x7f
                jr nc, dch_hex
                jp conwch               ; Write character to console and exit
;
dch_hex         push af
                ld a, "<"
                call conwch             ; Write character to console
                pop af
                call cwphby             ; Print A in hexadecimal
                ld a, ">"
                jp conwch               ; Write character to console and exit
;
;
; Display directory entry. This is mainly for use when debugging.
; Output for file extents:
;   "Physical extent: U<user> <name>.<type>, EX: xx, S1: xx, S2: xx, RC: xx"
;   "AL: 00 11 22 33 44 55 66 77 88 99 AA BB CC DD EE FF"
;   "CR: xx, Rec: 00 11 22"
; For disk labels:
;   "Label: <name>.<type> 00 11 22 33"
;   "00 11 22 33 44 55 66 77 88 99 AA BB CC DD EE FF"
; For date stamps:
;   "Date: 00 11 22 33 44 55 66 77 88 99 AA BB CC DD EE FF"
;   "00 11 22 33 44 55 66 77 88 99 AA BB CC DD EE FF"
; For passwords:
;   "Password: U<user> <name>.<type> 00 11 22 33"
;   "00 11 22 33 44 55 66 77 88 99 AA BB CC DD EE FF"
; For unused entries:
;   "Unused: 00 11 22 33 44 55 66 77 88 99 AA BB CC DD EE FF"
;   "00 11 22 33 44 55 66 77 88 99 AA BB CC DD EE FF"
; For unrecognised entries:
;   "Unrecognised: 00 11 22 33 44 55 66 77 88 99 AA BB CC DD EE FF"
;   "00 11 22 33 44 55 66 77 88 99 AA BB CC DD EE FF"
; Call with:
; IY - pointer to directory entry
; Returns with:
; IY is preserved.
                ifdef DEBUG
disp_dir_entry      push bc
                    push de
                    push hl
;
                    ld a, (iy + DIRE_USER)
                    ld hl, dde_unused_msg   ; "Unused: "
                    cp 0xe5
                    jp z, dde_hex           ; Display unused entries in hex
                    ld hl, dde_label_msg    ; "Label: "
                    cp 0x20
                    jp z, dde_name_hex      ; CP/M 3 only
                    ld hl, dde_date_msg     ; "Date: "
                    cp 0x21
                    jp z, dde_hex           ; CP/M 3 only
                    cp MAX_USER + 1
                    jp c, dde_phys_ext      ; Physical extent
                    cp 0x10 + MAX_USER + 1  ; 16 + user number (ie 16-31)
                    jp c, dde_password      ; CP/M 3 only
                    ld hl, dde_unrec_msg    ; "Unrecognised: "
;
; Display entry in hex. This is used for date stamps, unused or unrecognised
; entries.
dde_hex             call conwms             ; Print $-terminated string to console
                    push iy
                    pop hl
; HL - pointer to entry
                    ld b, 16
                    call dde_hex_block      ; Display a block of bytes
                    call cwnwln             ; Write new line characters to console
                    ld b, 16
                    call dde_hex_block      ; Display a block of bytes
                    call cwnwln             ; Write new line characters to console
                    jr dde_exit
;
; Display name and hex. This is used for labels. 
dde_name_hex        call conwms             ; Print $-terminated string to console
                    call disp_file          ; Display file or label name
; Display last 20 bytes in hex.
dde_hex_20          push iy
                    pop hl
; HL - pointer to entry.
                    ld de, DIRE_TYP + FILEEXT_SIZE
                    add hl, de              ; Find address after file type
                    ld b, 4
                    call dde_hex_block      ; Display a block of bytes
                    call cwnwln             ; Write new line characters to console
                    ld b, 16
                    call dde_hex_block      ; Display a block of bytes
                    call cwnwln             ; Write new line characters to console
                    jr dde_exit
;
; Password.
dde_password        ld hl, dde_pwd_msg      ; "Password: "
                    call conwms             ; Print $-terminated string to console
                    call disp_user_file     ; Display user and filename
                    jr dde_hex_20           ; Display last 20 bytes in hex
;
; Physical extent.
dde_phys_ext        ld hl, phys_ext_msg     ; "Physical extent: "
                    call conwms             ; Print $-terminated string to console
                    call disp_user_file     ; Display user and filename
                    push iy
                    pop hl
; HL - pointer to entry.
                    ld de, DIRE_TYP + FILEEXT_SIZE
                    add hl, de              ; Find address after file type
                    ld de, dde_msgs         ; Point to text
; DE - pointer to text
; HL - pointer to data in extent
;
; Current extent.
                    scf                     ; Display ", " prefix
                    call dfcb_item          ; EX
                    scf
                    call dfcb_item          ; S1
                    scf
                    call dfcb_item          ; S2
                    scf
                    call dfcb_item          ; RC
;
; Display associated block numbers.
                    push hl
                    ld hl, dde_al_msg       ; 0x0d, 0x0a, "AL:"
                    call conwms             ; Print $-terminated string to console
                    pop hl
;
                    ld b, 16
                    call dde_hex_block      ; Display a block of bytes
                    call cwnwln             ; Write new line characters to console
;
dde_exit            pop hl
                    pop de
                    pop bc
                    ret
;
; Display accompanying text and next byte. Used by dfcb. Call with:
; DE - pointer to text
; HL - pointer to data in FCB
; Carry flag - set to display preceding ", ".
; Returns with DE and HL advanced to next item.
dfcb_item           push bc
;
                    jr nc, dfcb_pref_done   ; Skip prefix if appropriate
                    ld a, ","
                    call conwch             ; Write character to console
                    call cwpspc             ; Print a space
dfcb_pref_done      ex de, hl
                    ld c, "|"               ; Text separator
dfcb_item_loop      ld a, (hl)
                    inc hl
                    cp c
                    jr z, dfcb_name_done
                    call conwch             ; Write character to console
                    jr dfcb_item_loop
dfcb_name_done      ld a, ":"
                    call conwch             ; Write character to console
                    call cwpspc             ; Print a space
                    ex de, hl
;
; Text and separators written. Print the data.
                    ld a, (hl)
                    inc hl
                    call cwphby             ; Print A in hexadecimal
;
                    pop bc
                    ret
;
;
; Display a block of bytes in hex preceded by spaces. Call with:
; B - number of bytes to display
; HL - pointer to data to display
; Returns with HL pointing to byte after the last one displayed.
dde_hex_block       call cwpspc             ; Print a space
                    ld a, (hl)
                    call cwphby             ; Print A in hexadecimal
                    inc hl
                    djnz dde_hex_block
                    ret
;
                endif
;
;
; This is copied directly from cpm_maths.z80. Doing so saves having to include
; the entire library of routines.
; 16-bit / 8-bit unsigned divide. Uses restoring algorithm. Derived from code at
; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Division
; Call with:
; HL - dividend
; C - divisor
; Returns with:
; HL - quotient
; A - remainder
madwbu          push bc
                ld b, 16            ; Loop counter
                xor a
duwb_bitloop    add hl, hl          ; Shift MS bit of dividend into carry
                rla                 ; Collect bit in LS of A
                jr c, duwb_dosub
                cp c
                jr c, duwb_nextbit
duwb_dosub      sub	a, c
                inc	l
duwb_nextbit    djnz duwb_bitloop
                pop bc
                ret
;
;
; Check filename and extension for illegal characters. Returns with:
; A - "top bits" (attributes) of the last 8 characters.
;   (MSB) F4 F5 F6 F7 F8 T1 T2 T3 (LSB)
;   See https://www.seasip.info/Cpm/fcb.html for descriptions. F1 to F3 are not
;   returned.
; Carry flag - set if one or more illegal characters are encountered
chk_name        push bc
                push de
                push hl
;
                push iy
                pop hl
                ld bc, DIRE_NAME
                add hl, bc
; HL - start address of name.
; This code assumes that the type immediately follows the name.
                assert DIRE_TYP = DIRE_NAME + FILENAME_SIZE
                ld b, FILENAME_SIZE + FILEEXT_SIZE
                ld c, 0                 ; Error flag
cn_loop         ld a, (hl)
                rlca
                rl e                    ; Collect attributes in E
                srl a                   ; Restore A with bit 7 = 0
                cp ' '
                call c, set_c_reg       ; < ' ' is a control character
                cp ascii_del
                call nc, set_c_reg      ; >= DEL isn't visible either
;
; Search list of questionable filename characters.
                push hl                 ; Save filename pointer
                ld hl, fn_bad_list
                ld d, a                 ; Save character
cn_chlp         ld a, (hl)
                and a
                jr z, cn_chdn           ; Complete if terminator found
                cp d
                call z, set_c_reg       ; Flag if match
                inc hl
                jr cn_chlp
; Character check done.
cn_chdn         pop hl
                inc hl
                djnz cn_loop            ; Next character or exit
;
; C - error flag (0 or 0xff [error])
; E - attributes
                ld a, e                 ; Move attributes to A
                rr c                    ; Rotate error flag into carry
;
                pop hl
                pop de
                pop bc
                ret
;
;
; Set C to non-zero. This provides a conditional flagging mechanism for use
; when error checking. For example, "call c, set_c_reg".
set_c_reg       ld c, 0xff
                ret
;
;
; Error found during directory scan. Display the entry and an appropriate
; message, then return to continue checking. Call with:
; DE - pointer to message
sl_err_cont     push de
                push hl
                push iy
;
                ld iy, (dire)           ; Pointer to directory entry structure
                call disp_user_file     ; Display user and filename
                ld hl, dash_msg         ; " - "
                call conwms             ; Print $-terminated string to console
                jr rpt_err_entry
;
;
; Error found during files information structure scan. Display the entry and an
; appropriate message, then return to continue checking. Call with:
; DE - pointer to message
; IY - pointer to files_info entry (FI_xxx)
spck_error      push de
                push hl
                push iy
;
                call disp_user_file     ; Display user and filename
                ld hl, dash_msg         ; " - "
                call conwms             ; Print $-terminated string to console
                jr rpt_err_entry
;
;
; Report error and continue. Call with:
; DE - pointer to message
rpt_error       push de
                push hl
                push iy
;
; Entry point used by spck_error and sl_err_cont.
rpt_err_entry   ex de, hl
                call conwms             ; Print $-terminated string to console
                call cwnwln             ; Write new line characters to console
;
                call inc_error_cnt      ; Increment error count
;
                pop iy
                pop hl
                pop de
                ret
;
;
; Increment error count. Limit to 0xffff in case of overflow.
inc_error_cnt   push hl
;
                ld hl, (error_count)
                inc hl
                ld a, h
                or l
                jr z, iec_exit          ; Exit of counter has overflowed
                ld (error_count), hl                
;
iec_exit        pop hl
                ret
;
;
; Find address and mask in a bit mapped array. Call with:
; DE - base address
; HL – bit address
; Returns with:
; A – bit mask (one bit set)
; HL – address
BitAddrMask     push bc
;
; Find bit mask.
                ld a, l
                and 7
                inc a                   ; Make range 1 to 8
                ld b, a
                ld c, 0x80
bam_mask_loop   rlc c
                djnz bam_mask_loop
;
; Find byte offset.
                ld b, 3
bam_div_loop    srl h                   ; Divide by two
                rr l
                djnz bam_div_loop
;
; DE – bit address
; HL - byte offset
; C - bit mask
                add hl, de              ; Add base address
                ld a, c                 ; bit mask
;
                pop bc
                ret
;
;
; Shift a 16-bit value by a number of bits, which can be zero (Shift HL >> C).
; Call with:
; C - displacement
; HL - value
; Returns with:
; HL - displaced value
rshift_word     ld a, c
rshw_loop       and a
                ret z                   ; Return if complete
                srl h                   ; Divide by two
                rr l
                dec a
                jr rshw_loop
;
;
; Mark block as used. Call with:
; HL - block number (0 to DSM).
; IX - pointer to DPB (DPB_xxx)
; Returns with:
; Carry clear if all went well. Carry will be set if there was an error.
; DE - points to an appropriate error message if there was an error.
flag_block      push bc
                push de
;
; Check DE is within range.
                push hl
                ld e, (ix + DPB_DSM)    ; Maximum block number
                ld d, (ix + DPB_DSM + 1)
                inc de
                and a
                sbc hl, de
                pop hl                  ; Restore block number
                ld de, blk_too_big_msg  ; " - block number out of range"
                jr nc, fb_error
;
; Block number is OK. Find bit mask.
                ld de, (blk_flags)      ; Start of blocks used flags
                call BitAddrMask        ; Find address and mask
; A – bit mask (one bit set)
; HL – address
; Is the flag already set?
                ld c, a
                ld a, (hl)
                and c
                ld de, dble_blk_msg     ; " - block not unique"
                jr nz, fb_error
; No duplicate found, so set the bit.
                ld a, (hl)
                or c
                ld (hl), a
;
                ld hl, (blocks_used)    ; Increment count
                inc hl
                ld (blocks_used), hl
;
; Normal exit with carry reset.
                pop de
                pop bc
                and a
                ret
;
; Return with carry set and message pointer in DE.
fb_error        inc sp                  ; Discard DE on stack
                inc sp
                pop bc
                scf
                ret
;
;
; Mark physical extent found in FI structure. The flags space will be extended
; if required. Call with:
; HL - physical extent number (0 to 511).
; IX - pointer to file information structure (FI_xxx)
; Returns with carry set if extent flag was already set.
flag_extent     push bc
                push de
;
                ld de, 0                ; No offset
                call BitAddrMask        ; Find address and mask
                ld c, a
; HL - byte offset
; C - bit mask
; Offset should be < FI_EX_FL_LEN, or we will have to make more space.
                push hl
                ld e, (ix + FI_EX_FL_LEN)
                ld d, 0
                and a
                sbc hl, de
                jr c, fe_have_space
;
; Make room in the FI structures store.
                ex de, hl
                inc de
; DE - number of bytes required
                push ix                 ; Structure base
                pop hl
                push bc                 ; Save bit mask
                ld bc, FI_EX_FLAGS      ; Offset to flags
                add hl, bc              ; Add byte offset
                ld c, (ix + FI_EX_FL_LEN)
                ld b, 0
                add hl, bc              ; Add length
; BC - current length.
; DE - number of bytes required.
; HL - pointer to byte after last FI_EX_FLAGS byte.
                push de
                call fi_make_room
                jp c, out_of_memory
; Adjust length by number of bytes extended.
                pop hl
; BC - current length.
; HL - number of bytes required.
                add hl, bc
                ld (ix + FI_EX_FL_LEN), l
                ld a, h
                and a
                call nz, panic          ; Panic at absurd lengths
                pop bc                  ; Restore bit mask
;
; There is space in the buffer.
; C - bit mask
fe_have_space   pop hl                  ; Fetch byte offset
                ld de, FI_EX_FLAGS      ; Offset to flags
                add hl, de              ; Add byte offset
                push ix
                pop de
                add hl, de              ; Add structure base
; Is the bit already set?
                ld a, (hl)
                and c
                jr nz, fe_dup_err
; No duplicate found, so set the bit.
                ld a, (hl)
                or c
                ld (hl), a
                jr fe_exit              ; Exit with carry reset
;
; Extent flag is already set, so we have a duplicate.
fe_dup_err      scf                     ; Flag error
fe_exit         pop de
                pop bc
                ret
;
;
; Check pointer is lower than the start of BDOS so we don't overwrite CP/M.
; Call with:
; HL - address to be checked.
; Returns with:
; Carry flag set if HL >= start of BDOS.
; HL is preserved.
chk_mem_lim     push hl
                push de
                ld de, (BDOS + 1)       ; Fetch first unusable address
                and a
                sbc hl, de              ; This should carry
                ccf
                pop de
                pop hl
                ret
;
;
; Make room in the FI structures store. The new space is created at HL, and
; everything from this address upwards is copied by DE bytes.
; Call with:
; HL - insert point
; DE - number of bytes required
; Returns with:
; Carry flag set if out of memory.
; HL is preserved.
fi_make_room    push bc
                push de
                push hl
;
; Check the insert point is within the buffer. Panic if not.
                push de
                push hl
                ld de, (free_start)     ; First free location
                inc de
                and a
                sbc hl, de
                call nc, panic          ; Panic if insert > end
                pop hl
;
                push hl
                ld de, (files_info)     ; Start address of FI structures
                and a
                sbc hl, de
                call c, panic           ; Panic if insert < start
                pop hl
                pop de
;
; Find new start of free space if the allocation is successful.
                ld hl, (free_start)     ; First free location
                add hl, de
; HL - adjusted free_start
                call chk_mem_lim        ; Check HL < BDOS start
                jr c, fimr_exit         ; Return with carry set on error
; Find out how much we have to copy (free_start - insert point)
                ex de, hl
; DE - adjusted free_start
                ld hl, (free_start)     ; First free location
                pop bc                  ; Insert point
                push bc
                and a
                sbc hl, bc
                call c, panic
; BC - insert point
; DE - adjusted free_start
; HL - number of bytes required
; Note: there is nothing to copy if we are inserting at the end of the buffer.
                ld a, h
                or l
                jr z, fimr_no_copy
;
; We have data to move.
                ld b, h                 ; Number of bytes required
                ld c, l
                ld hl, (free_start)     ; First free location
                ld (free_start), de     ; Save updated free_start
                dec hl
                dec de
;
; HL = FreeStart - 1 (source)
; DE = adjusted free_start - 1 (destination)
; BC = number of bytes required
                lddr
                and a                   ; Flag success
;
; Clear the newly created space.
fimr_exit       pop hl                  ; Fetch insert point and length
                pop de
                push de
                push hl
;
fimr_clr_loop   ld a, d
                or e
                jr z, fimr_clr_done
                ld (hl), 0
                inc hl
                dec de
                jr fimr_clr_loop
;
fimr_clr_done   pop hl
                pop de
                pop bc
                ret
;
; The insert point is at the end of the buffer, so there is nothing to copy.
fimr_no_copy    ld (free_start), de     ; Save updated free_start
                and a                   ; Flag success
                jr fimr_exit
;
;
; Display user and filename from directory entry OR file information structure.
; Format is:
; U<user> <name>.<type>
; IY - pointer to directory entry structure (DIRE_xxx)
; IY is preserved.
disp_user_file  push bc
                push hl
; Display user.
                ld a, "U"
                call conwch             ; Write character to console
                ld a, (iy + DIRE_USER)  ; User number
                and 0x0f                ; Isolate user bits
                call cwpdby             ; Print A in decimal
                call cwpspc             ; Print a space
;
                jr df_entry
;
;
; Display file or label name from directory entry OR file information structure.
; System and read-only attributes are displayed for directory entries only
; (they are zero in the file information structures).
; Format is:
; <name>.<type>
; IY - pointer to directory entry structure (DIRE_xxx)
; IY is preserved.
disp_file       push bc
                push hl
;
; Ensure the offsets are the same for both structures.
                assert DIRE_USER = FI_USER
                assert DIRE_NAME = FI_NAME
                assert DIRE_TYP = FI_TYP
;
; Display name.
df_entry        push iy
                pop hl
                ld bc, DIRE_NAME
                add hl, bc
; HL - start address of name.
                ld b, FILENAME_SIZE
                ld c, "?"               ; Substitution character
df_name_loop    bit 7, (hl)
                jr z, df_name_hdn
; Indicate that the high bit is set.
                ld a, "^"
                call conwch             ; Write character to console
df_name_hdn     ld a, (hl)
                and 0x7f
                call cwvich             ; Print only visible 7-bit characters
                inc hl
                djnz df_name_loop
;
; Display type.
                ld a, "."
                call conwch             ; Write character to console
                push iy
                pop hl
                ld bc, DIRE_TYP
                add hl, bc
; HL - start address of type.
                ld b, FILEEXT_SIZE
                ld c, "?"               ; Substitution character
df_type_loop    bit 7, (hl)
                jr z, df_type_hdn
; Indicate that the high bit is set.
                ld a, "^"
                call conwch             ; Write character to console
df_type_hdn     ld a, (hl)
                and 0x7f
                call cwvich             ; Print only visible 7-bit characters
                inc hl
                djnz df_type_loop
;
; Display attributes for files only.
                ld a, (iy + DIRE_USER)
                cp MAX_USER + 1
                jr nc, df_attr_done

                ld hl, system_msg       ; " (system)"
                ld a, (iy + DIRE_TYP + 1)       ; Fetch file type with T2 bit
                and 0x80
                call nz, conwms         ; Print $-terminated string to console
;
                ld hl, ro_msg           ; " (read only)"
                ld a, (iy + DIRE_TYP)   ; Fetch file type with T1 bit
                and 0x80
                call nz, conwms         ; Print $-terminated string to console
df_attr_done
;
                pop hl
                pop bc
                ret
;
;
; Compare file in directory entry structure with one in a file information
; structure. The comparison includes the user number, filename and extension.
; Files with different flag settings (e.g. "system") will match, which matches
; what CP/M itself does. The number of mismatched flags is returned (normally
; zero).
; Call with:
; DE - pointer to file information structure.
; HL - pointer to directory entry structure.
; Returns with:
; A - number of mismatched flags if carry is zero (files match)
; Carry flag set if files don't match.
; DE and HL are preserved.
match_file      push bc
                push de
                push hl
;
                ld c, 0                 ; Flag mismatch count
; Compare user number. The directory entry might be that of a password, so match
; only the user number bits.
                assert FI_USER = 0
                assert DIRE_USER = 0
                ex de, hl
                ld a, (de)
                and 0x0f                ; Match only user number bits
                cp (hl)
                ex de, hl
                jr nz, mf_no_match
                inc de
                inc hl
;
; Compare filename. Ignore attributes.
                assert FI_NAME = 1
                assert DIRE_NAME = 1
                ld b, FILENAME_SIZE
mf_name_loop    ld a, (de)
                xor (hl)
                jr z, mf_name_mat_ch    ; Jump if perfect match
                cp 0x80
                jr nz, mf_no_match
; Character matches apart from the flag.
                inc c                   ; Bump mismatch count
mf_name_mat_ch  inc de
                inc hl
                djnz mf_name_loop
;
; Compare type. Ignore read-only, system and archive flags.
                assert FI_TYP = 9
                assert DIRE_TYP = 9
                ld b, FILEEXT_SIZE
mf_typ_loop     ld a, (de)
                xor (hl)
                jr z, mf_typ_mat_ch     ; Jump if perfect match
                cp 0x80
                jr nz, mf_no_match
; Character matches apart from the flag.
                inc c                   ; Bump mismatch count
mf_typ_mat_ch   inc de
                inc hl
                djnz mf_typ_loop
;
; Files match!
                ld a, c                 ; Return with flag mismatch count in A
                and a
;
mf_exit         pop hl
                pop de
                pop bc
                ret
;
; Mismatch.
mf_no_match     scf
                jr mf_exit
;
;
; Read a directory entry from the disk and return a pointer to it.
; Call with:
; HL - required directory entry number
; IX - pointer to Disk Parameter Block (DPB)
; Returns with:
; HL - points to start of entry
get_entry       push bc
                push de
;
                ifdef DEBUG
                    push hl
                    ld hl, entry_msg        ; "Dir Entry: "
                    call conwms             ; Print $-terminated string to console
                    pop hl
                    push hl
                    call cwpdwd             ; Print HL in decimal
                    call cwnwln             ; Write new line characters to console
                    pop hl
                endif
;
                ld a, (ents_per_sec)    ; Directory entries per sector
                ld c, a
; HL - dividend
; C - divisor
                call madwbu             ; 16-bit / 8-bit unsigned divide
; A - entry number within sector
                push af                 ; Save for later
; HL - CP/M (128-byte) sector number (offset into data area)
; Is this already in the buffer?
                ld de, (loaded_sector)
                ld a, h
                cp d
                jr nz, ge_load_reqd
                ld a, l
                cp e
                jr z, ge_have_sec
;
; We need to load the sector containing the required entry.
ge_load_reqd    ld (loaded_sector), hl  ; Save sector number
                ld c, 0
                ex de, hl
; CDE - sector number (offset into data area)
                call set_sector
; Read the sector.
                ld hl, BIOS_READ        ; Read a sector
                call cbios              ; Call BIOS with some registers saved
                and a
                ld hl, disk_err_msg     ; "Disk I/O error."
                jp nz, msg_exit
;
; The required sector is loaded. Find the start address of the directory entry.
ge_have_sec     pop af                  ; Restore entry number within sector
                ld l, a
                ld h, 0
; HL - number of entry within sector.
                add hl, hl              ; Multiply by 32 to find offset
                add hl, hl
                add hl, hl
                add hl, hl
                add hl, hl
                ld de, (sec_buffer)
                add hl, de              ; Add buffer start address
;
                pop de
                pop bc
                ret                     ; Return with address in HL
;
;
; Set track and sector numbers for subsequent read and / or write operations.
; DMA address is set to sec_buffer. The variables track and sector are set
; appropriately.
; Call with:
; CDE - sector number (offset into data area)
; IX - pointer to Disk Parameter Block (DPB)
set_sector      push bc
                push hl
                push iy
;
; Find track number. For this application, the track number is likely to be small
; (normally zero). Hence this crude algorithm is sufficient.
                ld l, (ix + DPB_OFF)    ; Start after reserved tracks
                ld h, (ix + DPB_OFF + 1)
                ld iy, phys_spt         ; Point to physical sectors per track
ss_track_loop   push de                 ; Save LS 16 bits of sector number
; Perform a trial subtraction to see if we have a complete track worth of sectors.
                ld a, e
                sub (iy + 0)            ; Physical sectors per track
                ld e, a
                ld a, d
                sbc (iy + 1)
                ld d, a
                ld a, c
                sbc 0
                ld c, a
                jr c, ss_track_done
; No carry, so we can advance to the next track.
                inc hl
                inc sp                  ; Discard saved sector number
                inc sp
                jr ss_track_loop
;
; There was a carry in the last subtract, so this is the track we want.
; HL - track number
; (stacked) - remainder (sector number)
; Set track.
ss_track_done   ld (track), hl          ; Save track for status reporting
                ifdef DEBUG
                    push hl
                    ld hl, track_msg        ; "Track: "
                    call conwms             ; Print $-terminated string to console
                    pop hl
                    push hl
                    call cwpdwd             ; Print HL in decimal
                    pop hl
                endif
                ld b, h                 ; Move track number to BC
                ld c, l
                ld hl, BIOS_SETTRK      ; Set track number
                call cbios              ; Call BIOS with some registers saved
;
; Set sector.
; The CP/M 3 DPH is significantly different from the CP/M 2 one, but the pointer
; to the translation table is the same in both.
                assert DPH_XLT = CP3_DPH_XLT
                pop bc                  ; Fetch sector
