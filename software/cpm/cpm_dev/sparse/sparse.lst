**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm_top.i ****
   1:				; *******************************************************
   2:				; * Dummy Module to find the Last Location in Use.      *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 16/12/2021                          *
   5:				; *******************************************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant.
   8:				;
   9:				                extern fstfre       ; First location after end of data segment
  10:				
**** sparse.z80 ****
  36:				;
  37:				;
  38:				;
  39:				; *************
  40:				; * Externals *
  41:				; *************
  42:				;
  43:				;
  44:				; Variables
  45:				                extern btime    ; Build time string
  46:				;
  47:				;
  48:				;
  49:				; *************
  50:				; * Main Code *
  51:				; *************
  52:				;
  53:				;
  54:				; The CP/M transient area start address is set in the linker invocation (see
  55:				; makefile).
  56:				                cseg                    ; Code segment
  57:				;
  58:				; The default stack space is very small (8 deep), which would almost certainly
  59:				; cause issues, particularly with interrupts running. The initial code should
  60:				; not assume a Z80 so we can exit cleanly if this is run on an 8080, for
  61:				; example.
  62:    0+20	0000' ED730000	                ld (bdos_sp), sp
  63:   20+10	0004' 318300  	                ld sp, app_stack_top    ; Switch to our stack space
  64:				;
  65:   30+17	0007' CD0000  	                call init               ; Common initialisation code
  66:				;
  67:   47+10	000A' 210001  	                ld hl, signon_msg       ; Sign on.
  68:   57+17	000D' CD0000  	                call conwms             ; Print $-terminated string to console
  69:				;
  70:				; Clear variables area
  71:   74+10	0010' 210200  	                ld hl, clr_start        ; Start address
  72:   84+7	0013' 0601    	                ld b, clr_end - clr_start
  73:   91+4	0015' AF      	                xor a
  74:   95+7	0016' 77      	clr_loop        ld (hl), a
  75:  102+6	0017' 23      	                inc hl
  76:  108+8+5	0018' 10FC    	                djnz clr_loop
  77:				;
  78:				; Examine the command tail, looking for operands. This is stored in the default
  79:				; buffer. "The first byte at 0080H contains the length of the command tail,
  80:				; while the command tail itself begins at 0081H. The command tail is terminated
  81:				; by a byte containing a binary zero value."
  82:				; (http://www.cpm.z80.de/manuals/cpm22-m.pdf appendix H).
  83:  116+10	001A' 218100  	                ld hl, DEF_BUFFER + 1
  84:  126+17	001D' CD0000  	                call skpspc             ; Skip spaces
  85:				;
  86:  143+7	0020' 7E      	                ld a, (hl)
  87:  150+4	0021' A7      	                and a
  88:  154+7+5	0022' 2826    	                jr z, op_error          ; Jump if no operands at all
  89:				; Skip forward there is no filename but we do have options.
  90:  161+7	0024' FE5B    	                cp "["
  91:  168+7+5	0026' 2813    	                jr z, op_options
  92:  175+7	0028' FE2F    	                cp "/"
  93:  182+7+5	002A' 280F    	                jr z, op_options
  94:  189+7	002C' FE24    	                cp "$"
  95:  196+7+5	002E' 280B    	                jr z, op_options
  96:				;
  97:				; We are likely pointing at a filename. If so, skip until we meet a space or the
  98:				; end of the command.
  99:  203+7	0030' 7E      	op_skip_fn      ld a, (hl)
 100:  210+7	0031' FE20    	                cp " "
 101:  217+7+5	0033' 2806    	                jr z, op_options        ; Space separator found
 102:  224+4	0035' A7      	                and a
 103:  228+7+5	0036' 2803    	                jr z, op_options        ; End of line found
 104:  235+6	0038' 23      	                inc hl
 105:  241+12	0039' 18F5    	                jr op_skip_fn
 106:				;
 107:				; Check for options. These may begin with "[", "/" or "$", to match all
 108:				; conventions I have found used with CP/M.
 109:  253+10	003B' 112C01  	op_options      ld de, clopt_list       ; Null-terminated list of options
 110:  263+17	003E' CD0000  	                call clopts             ; Read command line options
 111:  280+7+5	0041' 3807    	                jr c, op_error          ; Error on bad options
 112:  287+13	0043' 320200  	                ld (clopt_flags), a
 113:				;
 114:				; HL - points to first character after options and any trailing spaces.
 115:				; The terminator should follow.
 116:  300+7	0046' 7E      	                ld a, (hl)
 117:  307+4	0047' A7      	                and a
 118:  311+7+5	0048' 2806    	                jr z, clopt_term
 119:				;
 120:				; Go here if we don't like the operands supplied.
 121:  318+10	004A' 212F01  	op_error        ld hl, op_err_msg
 122:  328+10	004D' C3F100  	                jp msg_exit
 123:				;
 124:				; Command line terminator found.
 125:     -	0050'         	clopt_term      
 126:				;
 127:				; Show build information if requested, then exit.
 128:				; Note that the build time string will be overwritten once the programme starts
 129:				; storing data at fstfre, but this is OK as long as we exit after displaying
 130:				; the string.
 131:  338+13	0050' 3A0200  	                ld a, (clopt_flags)     ; Fetch command line options
 132:  351+7	0053' E601    	                and CLOPT_BUILD_MASK
 133:  358+7+5	0055' 280C    	                jr z, no_build
 134:				;
 135:  365+10	0057' 210000  	                ld hl, btime            ; Build time string
 136:  375+17	005A' CD0000  	                call conwms             ; Print $-terminated string to console
 137:  392+17	005D' CD0000  	                call cwnwln             ; Write new line characters to console
 138:  409+10	0060' C3F400  	                jp exit
 139:				;
 140:				; Crude check to see that there is a filename in the command.
 141:  419+10	0063' 215D00  	no_build        ld hl, FCB1 + FCB_NAME  ; Point to name in default FCB
 142:  429+7	0066' 7E      	                ld a, (hl)
 143:  436+17	0067' CDF900  	                call chk_fn_char        ; Check char valid in a filename
 144:  453+7+5	006A' 38DE    	                jr c, op_error
 145:				;
 146:				; Delete any previous file.
 147:  460+10	006C' 115C00  	                ld de, FCB1              ; File Control Block
 148:  470+7	006F' 0E13    	                ld c, BDOS_DELETE_FILE
 149:  477+17	0071' CD0000  	                call cbdos              ; Call BDOS with some registers saved
 150:				;
 151:				; Make output file.
 152:  494+10	0074' 115C00  	                ld de, FCB1              ; File Control Block
 153:  504+7	0077' 0E16    	                ld c, BDOS_MAKE_FILE
 154:  511+17	0079' CD0000  	                call cbdos              ; Call BDOS with some registers saved
 155:  528+10	007C' 218B02  	                ld hl, nodir_msg        ; "No directory space"
 156:  538+4	007F' 3C      	                inc a                   ; 255 becomes 0
 157:  542+10	0080' CAF100  	                jp z, msg_exit          ; done if no dir space
 158:				;
 159:				; Set DMA address to point to test data.
 160:  552+10	0083' 11CF02  	                ld de, test_data
 161:  562+7	0086' 0E1A    	                ld c, BDOS_SET_DMA_ADDR
 162:  569+17	0088' CD0000  	                call cbdos              ; Call BDOS with some registers saved
 163:				;
 164:				; Set record number.
 165:  586+10	008B' 217D00  	                ld hl, FCB1 + FCB_RECORD
 166:  596+10	008E' 3600    	                ld (hl), 0
 167:  606+6	0090' 23      	                inc hl
 168:  612+10	0091' 3600    	                ld (hl), 0
 169:  622+6	0093' 23      	                inc hl
 170:  628+10	0094' 3600    	                ld (hl), 0
 171:				;
 172:				; Write record.
 173:  638+10	0096' 115C00  	                ld de, FCB1              ; File Control Block
 174:  648+7	0099' 0E22    	                ld c, BDOS_WRITE_RANDOM
 175:  655+17	009B' CD0000  	                call cbdos              ; Call BDOS with some registers saved
 176:  672+10	009E' 21AF02  	                ld hl, wr_err_msg       ; "Write record error"
 177:  682+4	00A1' 3C      	                inc a                   ; 255 becomes 0
 178:  686+10	00A2' CAF100  	                jp z, msg_exit          ; done if no dir space
 179:				;
 180:				; The next record depends on whether we are creating a large or small file.
 181:  696+13	00A5' 3A0200  	                ld a, (clopt_flags)     ; Fetch command line options
 182:  709+7	00A8' E602    	                and CLOPT_LARGE_MASK
 183:  716+7+5	00AA' 2013    	                jr nz, large_file
 184:				
 185:				; Set record number for a small file. This means that both records will be in
 186:				; a single physical extent.
 187:  723+10	00AC' 21B001  	                ld hl, small_msg        ; "Creating small file ..."
 188:  733+17	00AF' CD0000  	                call conwms             ; Print $-terminated string to console
 189:  750+10	00B2' 217D00  	                ld hl, FCB1 + FCB_RECORD
 190:  760+10	00B5' 3620    	                ld (hl), 32             ; LS byte
 191:  770+6	00B7' 23      	                inc hl
 192:  776+10	00B8' 3600    	                ld (hl), 0
 193:  786+6	00BA' 23      	                inc hl
 194:  792+10	00BB' 3600    	                ld (hl), 0
 195:  802+12	00BD' 1811    	                jr write_rec2
 196:				
 197:  814+10	00BF' 211D02  	large_file      ld hl, large_msg        ; "Creating large file ..."
 198:  824+17	00C2' CD0000  	                call conwms             ; Print $-terminated string to console
 199:  841+10	00C5' 217D00  	                ld hl, FCB1 + FCB_RECORD
 200:  851+10	00C8' 3600    	                ld (hl), 0              ; LS byte
 201:  861+6	00CA' 23      	                inc hl
 202:  867+10	00CB' 3600    	                ld (hl), 0
 203:  877+6	00CD' 23      	                inc hl
 204:  883+10	00CE' 3601    	                ld (hl), 1
 205:				;
 206:				; Write record.
 207:  893+10	00D0' 115C00  	write_rec2      ld de, FCB1              ; File Control Block
 208:  903+7	00D3' 0E22    	                ld c, BDOS_WRITE_RANDOM
 209:  910+17	00D5' CD0000  	                call cbdos              ; Call BDOS with some registers saved
 210:  927+10	00D8' 21AF02  	                ld hl, wr_err_msg       ; "Write record error"
 211:  937+4	00DB' 3C      	                inc a                   ; 255 becomes 0
 212:  941+10	00DC' CAF100  	                jp z, msg_exit          ; done if no dir space
 213:				;
 214:				; Close file
 215:  951+10	00DF' 115C00  	                ld de, FCB1              ; File Control Block
 216:  961+7	00E2' 0E10    	                ld c, BDOS_CLOSE_FILE
 217:  968+17	00E4' CD0000  	                call cbdos              ; Call BDOS with some registers saved
 218:  985+10	00E7' 219E02  	                ld hl, wrprot_msg       ; "Write protected?"
 219:  995+4	00EA' 3C      	                inc a                   ; 255 becomes 0
 220:  999+10	00EB' CAF100  	                jp z, msg_exit          ; Should not happen
 221:				;
 222:				; Normal exit
 223: 1009+10	00EE' 21C202  	                ld hl, normal_msg       ; "File created"
 224:				;
 225:				; Print message pointed to by HL, then exit.
 226: 1019+17	00F1' CD0000  	msg_exit        call conwms             ; Print $-terminated string to console
 227:				;
 228:				; Return to CP/M.
 229: 1036+20	00F4' ED7B0000	exit            ld sp, (bdos_sp)
 230:				; This is a small programme and we are most unlikely to have overwritten the
 231:				; CCP, so we can just return.
 232: 1056+10	00F8' C9      	                ret                     ; Return to BDOS
 233:				;                jp 0                    ; Warm boot
 234:				;
