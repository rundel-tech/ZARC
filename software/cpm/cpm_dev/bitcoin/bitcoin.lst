  43:				;
  44:				; From sha-256.z80
  45:				                extern sh2ini   ; Initialise sha-256 state
  46:				                extern sh2m     ; Process a message in memory
  47:				                extern sh2dh    ; Display hash value
  48:				;
  49:				;
  50:				;
  51:				; *************
  52:				; * Main Code *
  53:				; *************
  54:				;
  55:				;
  56:				; The CP/M transient area start address is set in the linker invocation (see
  57:				; makefile).
  58:				                cseg                    ; Code segment
  59:				;
  60:				; The default stack space is very small (8 deep), which would almost certainly
  61:				; cause issues, particularly with interrupts running The initial code should
  62:				; not assume a Z80 so we can exit cleanly if this is run on an 8080, for
  63:				; example.
  64:    0+20	0000' ED730000	                ld (bdos_sp), sp
  65:   20+10	0004' 31C701  	                ld sp, app_stack_top    ; Switch to our stack space
  66:				;
  67:   30+17	0007' CD0000  	                call init               ; Common initialisation code
  68:				;
  69:				; Sign on.
  70:   47+10	000A' 219E03  	on_z80          ld hl, signon_msg
  71:   57+17	000D' CD0000  	                call conwms             ; Print $-terminated string to console
  72:				;
  73:				; Clear variables area
  74:   74+10	0010' 210200  	                ld hl, clr_start        ; Start address
  75:   84+7	0013' 06CD    	                ld b, clr_end - clr_start
  76:   91+4	0015' AF      	                xor a
  77:   95+7	0016' 77      	clr_loop        ld (hl), a
  78:  102+6	0017' 23      	                inc hl
  79:  108+8+5	0018' 10FC    	                djnz clr_loop
  80:				;
  81:				; Are we running on a ZARC system?
  82:  116+17	001A' CD0000  	                call zrcdet
  83:				; Carry set if ZARC BIOS not found.
  84:  133+4	001D' 3F      	                ccf
  85:  137+4	001E' 17      	                rla
  86:  141+7	001F' E601    	                and 1
  87:  148+13	0021' 320200  	                ld (zarc_flag), a       ; 0x01 if ZARC, zero otherwise
  88:  161+7+5	0024' 2006    	                jr nz, exam_tail
  89:				;
  90:				; Warn about limited facilities.
  91:  168+10	0026' 21CF03  	                ld hl, no_zarc_msg      ; "ZARC BIOS not detected ..."
  92:  178+17	0029' CD0000  	                call conwms             ; Print $-terminated string to console
  93:				;
  94:				; Examine the command tail, looking for operands. This is stored in the default
  95:				; buffer. "The first byte at 0080H contains the length of the command tall,
  96:				; while the command tail itself begins at 0081H. The command tail is terminated
  97:				; by a byte containing a binary zero value."
  98:				; (http://www.cpm.z80.de/manuals/cpm22-m.pdf appendix H).
  99:  195+10	002C' 218100  	exam_tail       ld hl, DEF_BUFFER + 1
 100:				; No operands (yet).
 101:				; The terminator should follow.
