 141:  486+10+7	006F' D49803  	                call nc, disp_ok        ; Display OK if it was so
 142:				;
 143:				; Test message 2. This will require three chunks, one with message text, another
 144:				; with the rest of the message text (but is just too short to contain the
 145:				; length), and the last with just the length.
 146:  496+10	0072' 21CF04  	                ld hl, test_long_msg    ; "Long message test: "
 147:  506+17	0075' CD0000  	                call conwms             ; Print $-terminated string to console
 148:  523+17	0078' CD0000  	                call sh2ini             ; Initialise sha-256 state
 149:  540+10	007B' 212106  	                ld hl, test2_msg        ; Point to message
 150:  550+10	007E' 017800  	                ld bc, test2_msg_len    ; Overall message length in bytes
 151:  560+17	0081' CD0000  	                call sh2m               ; Process a message in memory
 152:				; HL - pointer to message digest (h0 to h7)
 153:  577+10	0084' 119906  	                ld de, test2_msg_hash
 154:  587+17	0087' CDE102  	                call cmp_hashes         ; Compare hashes and report errors
 155:  604+10+7	008A' D49803  	                call nc, disp_ok        ; Display OK if it was so
 156:				;
 157:				; Test message 3. This is just one byte shorter than the previous message. It
 158:				; will require two chunks, one with message text, another with the rest of the
 159:				; message text and the length. No chunk will contain pad bytes.
 160:  614+10	008D' 21E304  	                ld hl, test_long2_msg   ; "Long message test 2: "
 161:  624+17	0090' CD0000  	                call conwms             ; Print $-terminated string to console
 162:  641+17	0093' CD0000  	                call sh2ini             ; Initialise sha-256 state
 163:  658+10	0096' 212106  	                ld hl, test2_msg        ; Use test2 message (except last byte)
 164:  668+10	0099' 017700  	                ld bc, test3_msg_len    ; Overall message length in bytes
 165:  678+17	009C' CD0000  	                call sh2m               ; Process a message in memory
 166:				; HL - pointer to message digest (h0 to h7)
 167:  695+10	009F' 11B906  	                ld de, test3_msg_hash
 168:  705+17	00A2' CDE102  	                call cmp_hashes         ; Compare hashes and report errors
 169:  722+10+7	00A5' D49803  	                call nc, disp_ok        ; Display OK if it was so
 170:				;
 171:				; Bitcoin genesis block.
 172:  732+10	00A8' 21F904  	                ld hl, genesis_msg      ; "Bitcoin genesis block: "
 173:  742+17	00AB' CD0000  	                call conwms             ; Print $-terminated string to console
 174:  759+17	00AE' CD0000  	                call sh2ini             ; Initialise sha-256 state
