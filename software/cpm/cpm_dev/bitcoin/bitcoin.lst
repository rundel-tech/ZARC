 176:  786+10	00B4' 015000  	                ld bc, BH_SIZE          ; Header size
 177:  796+17	00B7' CD0000  	                call sh2m               ; Process a message in memory
 178:				; HL - pointer to message digest (h0 to h7)
 179:  813+10	00BA' 11AF00  	                ld de, bit_hash_buf     ; Hash digest buffer
 180:  823+11	00BD' D5      	                push de
