**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm_utility.i ****
   1:				; *******************************************************
   2:				; * Utility Routines for CP/M Applications              *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 16/12/2021                          *
   5:				; *******************************************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant.
   8:				;
   9:     -	0001'         	            ifndef CPMU         ; Inhibit for this module
  10:				; CP/M specific.
  11:				                extern init     ; Common initialisation code
  12:				                extern conmod   ; Set console mode (BDOS or BIOS)
  13:				                extern cpmver   ; CP/M version (packed BCD)
  14:				                extern cbdos    ; Call BDOS with some registers saved
  15:				                extern cbios    ; Call BIOS with some registers saved
  16:				                extern panic    ; Fatal application error
  17:				                extern zrcdet   ; Detect ZARC
  18:				                extern z80det   ; Detect Z80 (instead of 8080 / 8085)
  19:				                extern clopts   ; Read command line options
  20:				;
  21:				; Derived from the monitor's utility.z80.
  22:				                extern conwch   ; Write character to console
  23:				                extern conrch   ; Read character from the console
  24:				                extern const    ; Fetch console input status
  25:				                extern cwnwln   ; Write new line characters to console
  26:				                extern conwms   ; Print "$" terminated string to the console
  27:				                extern conwmn   ; Print message <n> in a list
  28:				                extern skpspc   ; Step hl past spaces
  29:				                extern toupca   ; Convert character in A to upper case
  30:				                extern toloca   ; Convert character in A to lower case
  31:				                extern cwvich   ; Print only visible 7-bit characters
  32:				                extern cwpspc   ; Print a space
  33:				                extern mtwdli   ; Match word in a string against list of options
  34:				                extern cwphnb   ; Print least-significant nibble in A in hexadecimal
  35:				                extern cwphby   ; Print A in hexadecimal
  36:				                extern cwphwd   ; Print HL in hexadecimal
  37:				                extern cwpdwd   ; Print HL in decimal. Leading zeros are suppressed
  38:				                extern cwpdby   ; Print A in decimal. Leading zeros are suppressed
  39:				                extern cwpdwd   ; Print HL in decimal. Leading zeros are suppressed
  40:				                extern cwpdlo   ; Print DEHL in decimal. Leading zeros are suppressed
  41:				                extern rdhxwd   ; Read a 16-bit hexadecimal number from a string
  42:				                extern rdduwd   ; Read a 16-bit unsigned decimal number from a string
  43:				                extern rddulo   ; Read a 32-bit unsigned decimal number from a string
  44:				;
  45:				            endif
  46:				;
  47:				;
  48:				; mtwdli (match word in a string against list of options) option bits. Each bit
  49:				; has the described effect if set.
  50:     -	        	BITDEF MTWDLI_ABBREV, 0                 ; Enable "." abbreviation
  51:     -	        	BITDEF MTWDLI_ICASE, 1                  ; Ignore case when matching
  52:     -	        	BITDEF MTWDLI_TERM, 7                   ; Terminator found (internal use only)
  53:				;
  54:				;
  55:				; Console mode (for conmod)
  56:     -	0000'         	CONMOD_BDOS     equ 0x00                ; Use BDOS for console I/O
  57:     -	0001'         	CONMOD_BIOS     equ 0x01                ; Use BIOS for console I/O
  58:				
**** zarc.z80 ****
  52:				;                include "cpm_files.i"   ; CP/M file handling
  53:				;
  54:				;
  55:				;
  56:				; *************
  57:				; * Main Code *
  58:				; *************
  59:				;
  60:				;
  61:				; The CP/M transient area start address is set in the linker invocation (see
  62:				; makefile).
  63:				                cseg                    ; Code segment
  64:				;
  65:				; The default stack space is very small (8 deep), which would almost certainly
  66:				; cause issues, particularly with interrupts running. The initial code should
  67:				; not assume a Z80 so we can exit cleanly if this is run on something else.
  68:    0+20	0000' ED730000	                ld (bdos_sp), sp
  69:   20+10	0004' 318200  	                ld sp, app_stack_top    ; Switch to our stack space
  70:				;
  71:   30+17	0007' CD0000  	                call init               ; Common initialisation code
  72:				;
  73:				; The following code is not 8080 / 8085 safe.
  74:   47+10	000A' 217800  	                ld hl, signon_msg
  75:   57+17	000D' CD0000  	                call conwms             ; Print $-terminated string to the console
  76:				;
  77:				; Are we running on a ZARC system?
  78:   74+17	0010' CD0000  	                call zrcdet
  79:   91+7+5	0013' 3009    	                jr nc, on_zarc          ; Jump if we are on ZARC
  80:				;
  81:   98+10	0015' 21DD00  	                ld hl, no_zarc_msg      ; "ZARC BIOS not detected."
  82:  108+17	0018' CD0000  	                call conwms             ; Print $-terminated string to the console
  83:  125+10	001B' C37300  	                jp exit
  84:				;
  85:				; Examine the command tail, looking for operands. This is stored in the default
  86:				; buffer. "The first byte at 0080H contains the length of the command tall, while
  87:				; the command tail itself begins at 0081H. The command tail is terminated by a
  88:				; byte containing a binary zero value." (http://www.cpm.z80.de/manuals/cpm22-m.pdf
  89:				; appendix H).
  90:  135+10	001E' 218100  	on_zarc         ld hl, DEF_BUFFER + 1
  91:  145+17	0021' CD0000  	                call skpspc             ; Step hl past spaces
  92:				;
  93:				; Attempt to match the operand with an item in the list.
  94:  162+10	0024' 11F700  	                ld de, cmd_list
  95:				; Ignore case and allow abbreviations.
  96:  172+7	0027' 3E03    	                ld a, MTWDLI_ABBREV_MASK | MTWDLI_ICASE_MASK
  97:  179+17	0029' CD0000  	                call mtwdli             ; Match against list of options
  98:  196+4	002C' A7      	                and a
  99:  200+7+5	002D' 2815    	                jr z, op_error
 100:				;
 101:				; Find address of command code
 102:  207+11	002F' E5      	                push hl                 ; Save command buffer pointer
 103:  218+10	0030' 210101  	                ld hl, cmd_vectors
 104:  228+4	0033' 3D      	                dec a                   ; Start index from zero
 105:  232+4	0034' 87      	                add a                   ; Convert index to a word offset
 106:  236+4	0035' 85      	                add l                   ; Add low byte
 107:  240+4	0036' 6F      	                ld l,a
 108:  244+7	0037' 3E00    	                ld a, 0
 109:  251+4	0039' 8C      	                adc a, h                ; Add carry to high byte
 110:  255+4	003A' 67      	                ld h, a
 111:				; HL is cmd_vectors + 2 * index
 112:  259+7	003B' 5E      	                ld e, (hl)              ; Read address
 113:  266+6	003C' 23      	                inc hl
 114:  272+7	003D' 56      	                ld d, (hl)
 115:  279+10	003E' E1      	                pop hl                  ; Restore command buffer pointer
 116:  289+17	003F' CD0000  	                call skpspc             ; Skip any leading spaces
 117:  306+11	0042' D5      	                push de
 118:				; HL points to the separator after the command word or the terminator.
 119:  317+10	0043' C9      	                ret                     ; Go to command routine
 120:				;
 121:				;
 122:				; Go here if we don't like the operands supplied.
 123:  327+10	0044' 21BB00  	op_error        ld hl, op_err_msg
 124:  337+17	0047' CD0000  	                call conwms             ; Print $-terminated string to the console
 125:  354+10	004A' C37300  	                jp exit
 126:				;
 127:				;
 128:				; Print terse help text.
 129:  364+10	004D' 210501  	cmd_help        ld hl, help_msg
 130:  374+17	0050' CD0000  	                call conwms             ; Print message
 131:  391+10	0053' C37300  	                jp exit
 132:				;
 133:				;
 134:				; Exit CP/M and return to monitor.
 135:  401+4	0056' AF      	cmd_exit        xor a
 136:  405+7	0057' BE      	                cp (hl)
 137:  412+10	0058' C24400  	                jp nz, op_error         ; Error if text follows
 138:				;
 139:  422+10	005B' 213901  	                ld hl, exit_msg
 140:  432+17	005E' CD0000  	                call conwms             ; Print message
 141:				;
 142:				; Call monitor via BIOS to flush the MMC sector cache.
 143:  449+10	0061' 11F000  	                ld de, MCALL_CAFLUS     ; Flush cache (write dirty buffers)
 144:  459+10	0064' 216900  	                ld hl, BIOS_MON_CALL    ; Call monitor function
 145:				; No parameters required (would be in alternate register set).
 146:  469+17	0067' CD0000  	                call cbios              ; Call BIOS
 147:				;
 148:				; Enter the monitor.
 149:  486+10	006A' 116900  	                ld de, MCALL_MON_ENTRY  ; Normal monitor entry
 150:  496+10	006D' 216900  	                ld hl, BIOS_MON_CALL    ; Call monitor function
 151:				; No parameters required (would be in alternate register set).
 152:  506+17	0070' CD0000  	                call cbios              ; Call BIOS
 153:				;
 154:				;
 155:				; Return to CP/M. Going here is always safe as it does not rely on the stack
 156:				; state.
 157:  523+20	0073' ED7B0000	exit            ld sp, (bdos_sp)
 158:  543+10	0077' C9      	                ret                     ; Return to BDOS
 159:				;               jp 0                    ; Warm boot
 160:				;
