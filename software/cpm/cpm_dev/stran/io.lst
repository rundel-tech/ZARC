 583: 2875+10	0222' C1      	                pop bc
 584: 2885+10	0223' C9      	                ret
 585:				;
 586:				; Check console port for break character.
 587:				; Returns with:
 588:				; Carry flag - set if break detected.
 589: 2895+10	0224' 210300  	rdc_con_break   ld hl, BIOS_CONST       ; Console status
 590: 2905+17	0227' CD0000  	                call cbios
 591: 2922+4	022A' A7      	                and a
