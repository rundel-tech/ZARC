   1:				; *******************************************************
   2:				; * I/O Routines for STran                              *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 22/3/2021                           *
   5:				; *******************************************************
   6:				;
   7:				                title STran I/O
   8:				;
   9:				;
  10:				;
