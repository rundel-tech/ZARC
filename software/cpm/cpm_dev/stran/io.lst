**** io.z80 ****
  18:				                include "stran.i"       ; Project include file
**** stran.i ****
   1:				; *******************************************************
   2:				; * Serial File Transfer for ZARC Z80 Computer (STran)  *
   3:				; * Include file                                        *
   4:				; * Written by: Merlin Skinner                          *
   5:				; * Date Started: 22/3/2021                             *
   6:				; *******************************************************
   7:				;
   8:				;
   9:				;
  10:				; *************
  11:				; * Constants *
  12:				; *************
  13:				;
  14:				;
  15:				; Version
  16:     -	0002'         	MAJ_VER         equ 2
  17:     -	0000'         	MIN_VER         equ 0
  18:				;
  19:				; DEBUG           equ 1                   ; Define to enable debug messages
  20:				;
  21:     -	0080'         	STACK_SIZE      equ 0x80                ; Stack space allocation
  22:     -	0003'         	BREAK_CHAR      equ 'C' - 0x40
  23:     -	0200'         	BLKLEN          equ 512                 ; Maximum data block size
  24:     -	8000'         	FLUSH_TIMER     equ 0x8000              ; Receive buffer flush time
  25:     -	000B'         	DIR_ENTRY_SIZE  equ FILENAME_SIZE + FILEEXT_SIZE    ; Size of each entry in packet
  26:				;
  27:				;
  28:				; Receive error codes.
  29:     -	        	                ENUM_START
  30:     -	        	                ENUM RXERR_OK           ; No error
  31:     -	        	                ENUM RXERR_BREAK        ; Break detected
  32:     -	        	                ENUM RXERR_ENC          ; 3 to 4 coding error
  33:     -	        	                ENUM RXERR_CRC          ; CRC error
  34:     -	        	                ENUM_END RXERR_NUM      ; Number of possible values
  35:				;
  36:				; Command line option flags. The order must match clopt_list in stran.z80.
  37:     -	        	BITDEF CLOPT_BUILD, 0                   ; Show build time
  38:     -	        	BITDEF CLOPT_VERBOSE, 1                 ; Enable debugging messages
  39:     -	        	BITDEF CLOPT_CON, 2                     ; Use CON: for data transfer
  40:     -	        	BITDEF CLOPT_AUX, 3                     ; Use AUX: for data transfer
  41:     -	        	BITDEF CLOPT_FORCE, 4                   ; Transfer even if identical
  42:				;
  43:				; Assorted flags.
  44:     -	        	BITDEF FLG_ZARC, 0                      ; Set if on a ZARC system
  45:     -	        	BITDEF FLG_CPM3, 1                      ; Set if running on CP/M 3.x
  46:     -	        	BITDEF FLG_AUXST, 2                     ; Set if AUX: status is available
  47:     -	        	BITDEF FLG_BREAK, 3                     ; Set if break character detected
  48:     -	        	BITDEF FLG_AUX, 4                       ; Set if using AUX: instead of CON:
  49:     -	        	BITDEF FLG_AUTO, 5                      ; Set if in auto-port mode
  50:     -	        	BITDEF FLG_TXB_VALID, 6                 ; Set if tx_packet_buf contains data
  51:     -	        	BITDEF FLG_DIR_END, 7                   ; Set if end of directory
  52:				;
  53:				;
  54:				; **************
  55:				; * Structures *
  56:				; **************
  57:				;
  58:				;
  59:				; Packet format (header).
  60:     -	        	                STRUCT
  61:				; Start of packet "*" is hard coded, and not stored in the structure.
  62:     -	        	                STR_BYTE PKT_TYPE       ; Packet type
  63:     -	        	                STR_WORD PKT_PSN        ; Packet Sequence Number
  64:     -	        	                STR_WORD PKT_LENGTH     ; Data length (0 to BLKLEN).
  65:     -	        	                STR_BLOCK PKT_DATA, BLKLEN  ; Data (PKT_LENGTH bytes)
  66:				; 1 or 2 bytes of padding to align to 3-byte boundary.
  67:				; 16-bit CRC
  68:				; 1 byte pad to align to 3-byte boundary.
  69:     -	        	                STR_END PKT_SIZE
  70:				;
  71:				; File descriptor block (for Tx and Rx file command packets).
  72:     -	        	                STRUCT
  73:     -	        	                STR_BYTE FDESC_DRIVE    ; Drive letter
  74:     -	        	                STR_BLOCK FDESC_NAME, 8 ; File name
  75:     -	        	                STR_BLOCK FDESC_EXT, 3  ; File extension
  76:     -	        	                STR_BLOCK FDESC_LEN, 4  ; File length (bytes)
  77:     -	        	                STR_BLOCK FDESC_ADLER, 4    ; Adler-32 checksum of entire file
  78:     -	        	                STR_BLOCK FDESC_CRC16, 2    ; CRC-16 (XMODEM) of entire file
  79:     -	        	                STR_END FDESC_SIZE
  80:				;
  81:				; PKT_TYPE can have any of the following values:
  82:     -	        	                ENUM_START
  83:     -	        	                ENUM PKTYP_NULL         ; Skip zero
  84:     -	        	                ENUM PKTYP_ACK          ; Positive acknowledgement
  85:     -	        	                ENUM PKTYP_NAK          ; Negative acknowledgement
  86:     -	        	                ENUM PKTYP_EXIT         ; Exit CP/M stran and return to CP/M
  87:     -	        	                ENUM PKTYP_TX           ; Transmit file (PC to CP/M)
  88:     -	        	                ENUM PKTYP_RX           ; Receive file (CP/M to PC)
  89:     -	        	                ENUM PKTYP_END          ; Normal end of transfer
  90:     -	        	                ENUM PKTYP_RESET        ; Reset (aborts any transfer)
  91:     -	        	                ENUM PKTYP_DIR          ; Read directory
  92:     -	        	                ENUM PKTYP_DATA         ; File data block
  93:     -	        	                ENUM PKTYP_DREQ         ; Request data block
  94:     -	        	                ENUM_END PKTYP_NUM      ; Number of possible values
  95:				; Zero is skipped to avoid a completely null packet appearing valid. This would
  96:				; have a zero checksum, so a string of nulls could cause confusion.
  97:				; Entries must match dh_types_msg in stran.z80.
  98:				;
  99:				; NAK reason codes:
 100:     -	        	                ENUM_START
 101:     -	        	                ENUM NAK_CRC            ; CRC error
 102:     -	        	                ENUM NAK_CMD            ; Unexpected command
 103:     -	        	                ENUM NAK_OPEN           ; Can’t open file
 104:     -	        	                ENUM NAK_RW_ERR         ; BDOS file read / write error
 105:     -	        	                ENUM NAK_BAD_DRIVE      ; Bad drive letter
 106:     -	        	                ENUM_END NAK_NUM        ; Number of possible values
 107:				;
 108:				; TX or TX command acknowledge packet codes are sent in the data field of the
 109:				; corresponding ACK. These determine whether or no a transfer is actually 
 110:				; required.
 111:     -	        	                ENUM_START
 112:     -	        	                ENUM TRA_IDENTICAL      ; Files are identical (skip transfer)
 113:     -	        	                ENUM TRA_FORCED         ; Forced (/f command line option)
 114:     -	        	                ENUM TRA_BAD_LEN        ; Bad file length
 115:     -	        	                ENUM TRA_LEN_MISMATCH   ; File lengths differ
 116:     -	        	                ENUM TRA_SUMS_ERROR     ; Error calculating checksums
 117:     -	        	                ENUM TRA_CRC_MISMATCH   ; CRC does not match
 118:     -	        	                ENUM TRA_ADL_MISMATCH   ; Adler-32 does not match
 119:     -	        	                ENUM_END TRA_NUM        ; Number of possible values
 120:				
**** io.z80 ****
  19:				                include "cpm_utility.i" ; CP/M utilities
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm_utility.i ****
   1:				; *******************************************************
   2:				; * Utility Routines for CP/M Applications              *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 16/12/2021                          *
   5:				; *******************************************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant.
   8:				;
   9:     -	0001'         	            ifndef CPMU         ; Inhibit for this module
  10:				; CP/M specific.
  11:				                extern init     ; Common initialisation code
  12:				                extern conmod   ; Set console mode (BDOS or BIOS)
  13:				                extern cpmver   ; CP/M version (packed BCD)
  14:				                extern cbdos    ; Call BDOS with some registers saved
  15:				                extern cbios    ; Call BIOS with some registers saved
  16:				                extern panic    ; Fatal application error
  17:				                extern zrcdet   ; Detect ZARC
  18:				                extern z80det   ; Detect Z80 (instead of 8080 / 8085)
  19:				                extern clopts   ; Read command line options
  20:				;
  21:				; Derived from the monitor's utility.z80.
  22:				                extern conwch   ; Write character to console
  23:				                extern conrch   ; Read character from the console
  24:				                extern const    ; Fetch console input status
  25:				                extern cwnwln   ; Write new line characters to console
  26:				                extern conwms   ; Print "$" terminated string to the console
  27:				                extern conwmn   ; Print message <n> in a list
  28:				                extern skpspc   ; Step hl past spaces
  29:				                extern toupca   ; Convert character in A to upper case
  30:				                extern toloca   ; Convert character in A to lower case
  31:				                extern cwvich   ; Print only visible 7-bit characters
  32:				                extern cwpspc   ; Print a space
  33:				                extern mtwdli   ; Match word in a string against list of options
  34:				                extern cwphnb   ; Print least-significant nibble in A in hexadecimal
  35:				                extern cwphby   ; Print A in hexadecimal
  36:				                extern cwphwd   ; Print HL in hexadecimal
  37:				                extern cwpdwd   ; Print HL in decimal. Leading zeros are suppressed
  38:				                extern cwpdby   ; Print A in decimal. Leading zeros are suppressed
  39:				                extern cwpdwd   ; Print HL in decimal. Leading zeros are suppressed
  40:				                extern cwpdlo   ; Print DEHL in decimal. Leading zeros are suppressed
  41:				                extern rdhxwd   ; Read a 16-bit hexadecimal number from a string
  42:				                extern rdduwd   ; Read a 16-bit unsigned decimal number from a string
  43:				                extern rddulo   ; Read a 32-bit unsigned decimal number from a string
  44:				;
  45:				            endif
  46:				;
  47:				;
  48:				; mtwdli (match word in a string against list of options) option bits. Each bit
  49:				; has the described effect if set.
  50:     -	        	BITDEF MTWDLI_ABBREV, 0                 ; Enable "." abbreviation
  51:     -	        	BITDEF MTWDLI_ICASE, 1                  ; Ignore case when matching
  52:     -	        	BITDEF MTWDLI_TERM, 7                   ; Terminator found (internal use only)
  53:				;
  54:				;
  55:				; Console mode (for conmod)
  56:     -	0000'         	CONMOD_BDOS     equ 0x00                ; Use BDOS for console I/O
  57:     -	0001'         	CONMOD_BIOS     equ 0x01                ; Use BIOS for console I/O
  58:				
**** io.z80 ****
  20:				                include "cpm_maths.i"   ; Integer mathematics
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm_maths.i ****
   1:				; *******************************************************
   2:				; * Mathematical Routines for CP/M Applications         *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 10/9/2022                           *
   5:				; *******************************************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant.
   8:				;
   9:     -	0001'         	            ifndef CPMM         ; Inhibit for this module
  10:				; CP/M specific.
  11:				; 32-bit arithmetic.
  12:				                extern mclr32       ; 32-bit clear (zero)
  13:				                extern mcop32       ; 32-bit copy from (hl) to (de)
  14:				                extern minc32       ; 32-bit increment
  15:				                extern mcp32        ; 32-bit compare (hl) - (de)
  16:				                extern madd32       ; 32-bit add (hl) <- (hl) + (de)
  17:				                extern msub32       ; 32-bit sub (hl) <- (hl) - (de)
  18:				;
  19:				; Derived from the monitor's maths.z80.
  20:				                extern madlbu       ; 32-bit / 8-bit unsigned divide
  21:				                extern madwbu       ; 16-bit / 8-bit unsigned divide
  22:				                extern madbbu       ; 8-bit / 8-bit unsigned divide
  23:				                extern mamwwu       ; 16-bit * 16-bit unsigned multiply
  24:				                extern mamlbu       ; 32-bit * 8-bit unsigned multiply
  25:				                extern crc16x       ; Software CRC-16 (XMODEM)
  26:				                extern adler        ; Adler-32 checksum
  27:				;
  28:				            endif
  29:				;
**** io.z80 ****
  21:				;
  22:				;
  23:				;
  24:				; *************
  25:				; * Externals *
  26:				; *************
  27:				;
  28:				;
  29:				; Variables
  30:				                extern flags    ; Flags. See FLG_xxx in stran.i
  31:				;
  32:				; Functions
  33:				                public flush    ; Flush data port receive buffer
  34:				                public rxpkt    ; Receive a packet
  35:				                public txpkt    ; Transmit a packet
  36:				                public txdch    ; Transmit a character to the data port
  37:				                public rxdch    ; Read a character from the data port
  38:				;
  39:				;
  40:				                cseg                    ; Code segment
  41:				;
  42:				;
  43:				;
  44:				; ************
  45:				; * Transmit *
  46:				; ************
  47:				;
  48:				;
  49:				; Transmit a packet. The packet is assumed to be fully built, with all fields
  50:				; populated except the CRC. The FLG_TXB_VALID flag is set to indicate that the
  51:				; transmit buffer contains valid data.
  52:				; Call with:
  53:				; IY - pointer to packet buffer
  54:    0+11	0000' C5      	txpkt           push bc
  55:   11+11	0001' D5      	                push de
  56:   22+11	0002' E5      	                push hl
  57:				;
  58:   33+15	0003' FDE5    	                push iy
  59:   48+10	0005' E1      	                pop hl
  60:				;
  61:				; Send start of packet character ("*" - not encoded)
  62:   58+7	0006' 3E2A    	                ld a, "*"
  63:   65+17	0008' CD8F00  	                call txdch
  64:				;
  65:				; Calculate total number of unencoded bytes to send.
  66:   82+4	000B' EB      	                ex de, hl
  67:   86+10	000C' 210500  	                ld hl, PKT_DATA         ; Number of header bytes to send
  68:   96+19	000F' FD4604  	                ld b, (iy + PKT_LENGTH + 1) ; Fetch data length in bytes
  69:  115+19	0012' FD4E03  	                ld c, (iy + PKT_LENGTH)
  70:  134+11	0015' 09      	                add hl, bc
  71:  145+11	0016' E5      	                push hl                 ; Copy length to BC
  72:  156+10	0017' C1      	                pop bc
  73:  166+4	0018' EB      	                ex de, hl
  74:  170+10	0019' 110000  	                ld de, 0                ; Set initial CRC
  75:				; BC - total bytes of header + data.
  76:				; DE - CRC
  77:				; HL - pointer to next byte to send (PSN).
  78:  180+11	001C' C5      	txp_send_loop   push bc                 ; Save byte counter
  79:  191+11	001D' D5      	                push de                 ; Save CRC
  80:				;
  81:				; Send data
  82:  202+7	001E' 4E      	                ld c, (hl)
  83:  209+6	001F' 23      	                inc hl
  84:  215+7	0020' 56      	                ld d, (hl)
  85:  222+6	0021' 23      	                inc hl
  86:  228+7	0022' 5E      	                ld e, (hl)
  87:  235+17	0023' CD5400  	                call tx_data_enc        ; Send 3 to 4 bytes encoded data
  88:  252+10	0026' D1      	                pop de                  ; Restore CRC
  89:				;
  90:				; Update CRC.
  91:  262+6	0027' 2B      	                dec hl
  92:  268+6	0028' 2B      	                dec hl
  93:  274+4	0029' EB      	                ex de, hl
  94:				
  95:				; DE - pointer to next byte to send (PSN).
  96:				; HL - CRC
  97:  278+7	002A' 1A      	                ld a, (de)              ; Fetch byte 0
  98:  285+17	002B' CD0000  	                call crc16x             ; Add to CRC
  99:  302+6	002E' 13      	                inc de
 100:				;
 101:  308+7	002F' 1A      	                ld a, (de)              ; Fetch byte 1
 102:  315+17	0030' CD0000  	                call crc16x             ; Add to CRC
 103:  332+6	0033' 13      	                inc de
 104:				;
 105:  338+7	0034' 1A      	                ld a, (de)              ; Fetch byte 2
 106:  345+17	0035' CD0000  	                call crc16x             ; Add to CRC
 107:  362+6	0038' 13      	                inc de
 108:				;
 109:  368+4	0039' EB      	                ex de, hl
 110:  372+10	003A' C1      	                pop bc
 111:				; BC - total bytes of header + data.
 112:				; DE - CRC
 113:				; HL - pointer to next byte to send (PSN).
 114:  382+6	003B' 0B      	                dec bc                  ; Update byte counter
 115:  388+6	003C' 0B      	                dec bc
 116:  394+6	003D' 0B      	                dec bc
 117:				; If BC is zero or negative there is no more data to send.
 118:  400+6	003E' 0B      	                dec bc
 119:				; Now we can look for negative in all cases.
 120:  406+4	003F' 78      	                ld a, b
 121:  410+6	0040' 03      	                inc bc                  ; Restore decrement by 3 result
 122:  416+4	0041' A7      	                and a
 123:  420+10	0042' F21C00  	                jp p, txp_send_loop     
 124:				; Data sent, complete with padding (if required) to align to a 3-byte boundary.
 125:				;
 126:				; Send CRC
 127:  430+4	0045' 4B      	                ld c, e
 128:  434+7	0046' 1E00    	                ld e, 0                 ; Pad byte
 129:  441+17	0048' CD5400  	                call tx_data_enc        ; Send 3 to 4 bytes encoded data
 130:				;
 131:				; Flag tx_packet_buf contains valid data.
 132:  458+10	004B' 210000  	                ld hl, flags
 133:  468+15	004E' CBF6    	                set FLG_TXB_VALID_BIT, (hl)
 134:				;
 135:  483+10	0050' E1      	                pop hl
 136:  493+10	0051' D1      	                pop de
 137:  503+10	0052' C1      	                pop bc
 138:  513+10	0053' C9      	                ret
 139:				;
 140:				;
 141:				; Transmit 3 bytes using the 3 to 4 bytes encoding scheme.
 142:				; Call with:
 143:				; CDE - data to transmit (C first)
 144:  523+11	0054' C5      	tx_data_enc     push bc
 145:  534+4	0055' 79      	                ld a, c
 146:  538+8	0056' CB3F    	                srl a
 147:  546+8	0058' CB3F    	                srl a
 148:  554+7	005A' C63F    	                add 0x3f
 149:				; A - <0, 1> <byte 0 bits 7 to 2>
 150:  561+17	005C' CD8F00  	                call txdch
 151:  578+4	005F' 79      	                ld a, c
 152:  582+4	0060' 07      	                rlca
 153:  586+4	0061' 07      	                rlca
 154:  590+4	0062' 07      	                rlca
 155:  594+4	0063' 07      	                rlca
 156:  598+7	0064' E630    	                and 0x30                ; Isolate byte 0 bits 1 to 0
 157:  605+4	0066' 47      	                ld b, a
 158:  609+4	0067' 7A      	                ld a, d
