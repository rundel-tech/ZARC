 599:				;
 600: 2988+4	0239' 37      	rdcb_break      scf                     ; Flag break detected
 601: 2992+10	023A' C9      	                ret
 602:				;
 603:				;
 604:				; Flush data port receive buffer. This works when the console port is the
 605:				; data port and / or when running on a CP/M 3.x or ZARC system. This code keeps
 606:				; reading and discarding data until no data is received for a reasonable period,
 607:				; defined by FLUSH_TIMER. This behaviour allows for delays caused by additional
 608:				; upstream buffers, such as those in a RS-232 to USB adaptor.
 609:     -	023B'         	flush
 610:				; If not FLG_AUTO and FLG_AUX and not FLG_AUXST then we are attempting to flush
 611:				; without being able to check the status, which won't work. We don't need to
 612:				; worry about auto-port mode as this is trapped elsewhere.
 613: 3002+13	023B' 3A0000  	                ld a, (flags)
 614: 3015+7	023E' E634    	                and FLG_AUTO_MASK | FLG_AUX_MASK | FLG_AUXST_MASK
 615: 3022+7	0240' FE10    	                cp FLG_AUX_MASK
 616: 3029+5+6	0242' C8      	                ret z
 617:				;
 618: 3034+11	0243' C5      	                push bc
 619: 3045+11	0244' D5      	                push de
 620: 3056+11	0245' E5      	                push hl
 621:				;
 622: 3067+10	0246' 219902  	                ld hl, flushing_msg     ; "Flushing serial port receive buffer"
 623: 3077+17	0249' CD0000  	                call conwms             ; Print $-terminated string to the console
 624:				;
 625:				; The timer is crude in that it really only sets the number of checks made
 626:				; before declaring the buffer empty. The actual time will depend on processor
 627:				; speed.
 628: 3094+10	024C' 010080  	flu_reset       ld bc, FLUSH_TIMER
 629:				; Check the port status. This will determine whether we use CONST or AUXIST
 630:				; to check whether or not there is a character to read.
 631: 3104+13	024F' 3A0000  	flu_loop        ld a, (flags)
 632: 3117+8	0252' CB6F    	                bit FLG_AUTO_BIT, a
 633: 3125+7+5	0254' 200C    	                jr nz, flu_auto
 634:				; Not auto mode, so work out which port to do.
 635: 3132+8	0256' CB67    	                bit FLG_AUX_BIT, a
 636: 3140+11	0258' F5      	                push af                 ; Save zero flag
 637: 3151+10+7	0259' CC7102  	                call z, flu_con         ; Flush CON: if selected
 638: 3161+10	025C' F1      	                pop af
 639: 3171+10+7	025D' C48502  	                call nz, flu_aux        ; Flush AUX: if selected
 640: 3181+12	0260' 1806    	                jr flu_pass_done
 641:				;
 642:				; Auto-port mode, so flush both.
 643: 3193+17	0262' CD7102  	flu_auto        call flu_con            ; Flush CON:
 644: 3210+17	0265' CD8502  	                call flu_aux            ; Flush AUX:
 645:     -	0268'         	flu_pass_done     
 646:				;
 647:				; Keep going unless timer has expired.
 648: 3227+6	0268' 0B      	                dec bc                  ; Adjust timer
 649: 3233+4	0269' 78      	                ld a, b
 650: 3237+4	026A' B1      	                or c
 651: 3241+7+5	026B' 20E2    	                jr nz, flu_loop
 652:				;
 653:				; Best effort flushing complete.
 654: 3248+10	026D' E1      	flu_done        pop hl
 655: 3258+10	026E' D1      	                pop de
 656: 3268+10	026F' C1      	                pop bc
 657: 3278+10	0270' C9      	                ret
 658:				;
 659:				; Read one character from CON: if there is one and modify timer in BC
 660:				; appropriately. Used by flush only.
 661: 3288+11	0271' C5      	flu_con         push bc
 662: 3299+10	0272' 210300  	                ld hl, BIOS_CONST       ; Console status
 663:				; Check the port status using the appropriate function.
 664: 3309+17	0275' CD0000  	                call cbios
 665: 3326+10	0278' C1      	                pop bc
 666: 3336+4	0279' A7      	                and a
 667: 3340+5+6	027A' C8      	                ret z                   ; Exit if no character awaits
 668:				; There is a character awaiting, so read it and return.
 669: 3345+10	027B' 210600  	                ld hl, BIOS_CONIN       ; Reader input
 670: 3355+17	027E' CD0000  	                call cbios
 671: 3372+10	0281' 010080  	                ld bc, FLUSH_TIMER      ; Reset timer
 672: 3382+10	0284' C9      	                ret
 673:				;
 674:				; Read one character from AUX: if there is one and modify timer in BC
 675:				; appropriately. Used by flush only.
 676: 3392+11	0285' C5      	flu_aux         push bc
 677: 3403+10	0286' 213300  	                ld hl, BIOS_AUXIST      ; Status of auxiliary input
 678:				; Check the port status using the appropriate function.
 679: 3413+17	0289' CD0000  	                call cbios
 680: 3430+10	028C' C1      	                pop bc
 681: 3440+4	028D' A7      	                and a
 682: 3444+5+6	028E' C8      	                ret z                   ; Exit if no character awaits
 683:				; There is a character awaiting, so read it and return.
 684: 3449+10	028F' 211200  	                ld hl, BIOS_READER      ; Reader input
 685: 3459+17	0292' CD0000  	                call cbios
