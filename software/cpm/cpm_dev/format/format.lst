   1:				; *******************************************************
   2:				; * MMC Drive Format for ZARC Z80 Computer              *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 27/12/2020                          *
   5:				; *******************************************************
   6:				;
   7:				; This programme is intended to run under CP/M 2.2. It formats a "drive" on the
   8:				; MMC card ready for use by the filing system. Unlike formatters for physical
   9:				; disks, the sectors are already prepared so most of the work is done. All that
  10:				; is required it so mark the directory entries as unused.
  11:				;
  12:				; Running under CP/M 3.x would be possible after some modifications, mainly due
  13:				; to the variable sector size possible under that system. This change would
  14:				; offer no advantage under my ZARC system as CP/M 2.2 is required to setup the
  15:				; CP/M 3.1 system. All CP/M 3.1 drives are accessible and can be formatted under
  16:				; CP/M 2.2.
  17:				;
  18:				; This programme reads the DPB to discover the organisation of the disk, so it
  19:				; should work for any sensible disk size or organisation. It is intended for ZARC
  20:				; systems only, and is unlikely to be useful on a system with physical floppy
  21:				; disk drives as it knows nothing about formatting sectors.
  22:				;
  23:				; V1.1 (14/12/2025) - updated to prevent accidental running under CP/M 3.x
  24:				;
  25:				                title ZARC CP/M Format
  26:				;
  27:				;
  28:				;
  29:				; ************
  30:				; * Includes *
  31:				; ************
  32:				;
  33:				;
  34:				                include "macros.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/macros.i ****
   1:				; ***********************************
   2:				; * ZARC Macro Definitions          *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 30/7/2020         *
   5:				; ***********************************
   6:				;
   7:				;
   8:				;
   9:				; **********
  10:				; * Macros *
  11:				; **********
  12:				;
  13:				;
  14:				; Initialise enumeration.
  15:				; The absolute segment is used so the offsets are not marked as relocatable. This
  16:				; avoids "Not relocatable" errors.
  17:				ENUM_START      macro
  18:				                .aseg
  19:				enum_counter    set 0
  20:				                endm
  21:				;
  22:				; Invoke for each item.
  23:				ENUM            macro x
  24:				x               equ enum_counter
  25:				enum_counter    set enum_counter + 1
  26:				                endm
  27:				;
  28:				ENUM_END        macro x
  29:				x               set enum_counter    ; Set label to count of items
  30:				                .cseg
  31:				                endm
  32:				;
  33:				;
  34:				; Initialise a structure. This is used to generate offsets for data structures.
  35:				; The absolute segment is used so the offsets are not marked as relocatable. This
  36:				; avoids "Not relocatable" errors.
  37:				STRUCT          macro
  38:				                .aseg
  39:				str_offset      set 0
  40:				                endm
  41:				;
  42:				; Add a byte entry.
  43:				STR_BYTE        macro x
  44:				x               equ str_offset
  45:				str_offset      set str_offset + 1
  46:				                endm
  47:				;
  48:				; Add a word (16-bit) entry.
  49:				STR_WORD        macro x
  50:				x               equ str_offset
  51:				str_offset      set str_offset + 2
  52:				                endm
  53:				;
  54:				; Add a 3 byte (24-bit) entry.
  55:				STR_24BIT       macro x
  56:				x               equ str_offset
  57:				str_offset      set str_offset + 3
  58:				                endm
  59:				;
  60:				; Add a long (32-bit) entry.
  61:				STR_LONG        macro x
  62:				x               equ str_offset
  63:				str_offset      set str_offset + 4
  64:				                endm
  65:				;
  66:				; Add an arbitrary length entry.
  67:				STR_BLOCK       macro x, size   ; <name>, <size>
  68:				x               equ str_offset
  69:				str_offset      set str_offset + size
  70:				                endm
  71:				;
  72:				; End of structure (used to set size)
  73:				STR_END         macro x
  74:				x               equ str_offset
  75:				                .cseg
  76:				                endm
  77:				;
  78:				;
  79:				; Allocate space. This is used to generate variable addresses, affectively
  80:				; providing a new variables segment. Allocated size is kept track of separately
  81:				; to the address as the latter may overflow in certain error cases.
  82:				ALLOC           macro x
  83:				                .aseg
  84:				all_addr        set x
  85:				all_size        set 0
  86:				                endm
  87:				;
  88:				; Add a byte entry.
  89:				ALL_BYTE        macro x
  90:				x               equ all_addr
  91:				all_addr        set all_addr + 1
  92:				all_size        set all_size + 1
  93:				                endm
  94:				;
  95:				; Add a word (16-bit) entry.
  96:				ALL_WORD        macro x
  97:				x               equ all_addr
  98:				all_addr        set all_addr + 2
  99:				all_size        set all_size + 2
 100:				                endm
 101:				;
 102:				; Add a 3 byte (24-bit) entry.
 103:				ALL_24BIT       macro x
 104:				x               equ all_addr
 105:				all_addr        set all_addr + 3
 106:				all_size        set all_size + 3
 107:				                endm
 108:				;
 109:				; Add a long (32-bit) entry.
 110:				ALL_LONG        macro x
 111:				x               equ all_addr
 112:				all_addr        set all_addr + 4
 113:				all_size        set all_size + 4
 114:				                endm
 115:				;
 116:				; Add an arbitrary length entry.
 117:				ALL_BLOCK       macro x, size   ; <name>, <size>
 118:				x               equ all_addr
 119:				all_addr        set all_addr + size
 120:				all_size        set all_size + size
 121:				                endm
 122:				;
 123:				; End of allocated space. Returns size of block.
 124:				ALL_END         macro x
 125:				x               equ all_size
 126:				                .cseg
 127:				                endm
 128:				;
 129:				;
 130:				; Calculate offsets into jump tables.
 131:				; The absolute segment is used so the offsets are not marked as relocatable. This
 132:				; avoids "Not relocatable" errors.
 133:				JPTBL_START     macro x
 134:				                .aseg
 135:				jptbl_addr      set x               ; Set start address
 136:				                endm
 137:				;
 138:				; Invoke for each item.
 139:				JPTBL_ENTRY     macro x
 140:				x               equ jptbl_addr
 141:				jptbl_addr      set jptbl_addr + 3
 142:				                endm
 143:				;
 144:				; Invoke for a data block in the jump table
 145:				JPTBL_BLOCK     macro x, size   ; <name>, <size>
 146:				x               equ jptbl_addr
 147:				jptbl_addr      set jptbl_addr + size
 148:				                endm
 149:				;
 150:				JPTBL_END       macro x
 151:				x               set jptbl_addr      ; Set label to next address
 152:				                .cseg
 153:				                endm
 154:				;
 155:				;
 156:				; Define bits and masks. This is inspired by the Commodore Amiga BITDEF mechanism.
 157:				; Given:
 158:				; BITDEF I2C_CSR_STOP, 2
 159:				; Yields:
 160:				; I2C_CSR_STOP_BIT  EQU 2       ; Bit number
 161:				; I2C_CSR_STOP_MASK EQU 1<<2    ; Bit mask
 162:				BITDEF          macro n, b      ; <Name>, <bit>
 163:				n`_BIT          equ b
 164:				n`_MASK         equ 1 << b
 165:				                endm
 166:				;
 167:				;
 168:				; Force alignment. This asserts an appropriate number of zero bytes to achieve
 169:				; the required alignment. Note that these macros cannot work for relocatable
 170:				; files.
 171:				; 16-bit
 172:				ALIGN_WORD      macro
 173:				                if $ and 1
 174:				                    byte 0
 175:				                endif
 176:				                endm
 177:				;
 178:				; 32-bit
 179:				ALIGN_LONG      macro
 180:				                ALIGN_WORD
 181:				                if $ and 2
 182:				                    byte 0, 0
 183:				                endif
 184:				                endm
 185:				;
 186:				;
 187:				; Write message to console (short for "call conwms").
 188:				CON_WR_MSG      macro
 189:				                rst 08
 190:				                endm
 191:				;
 192:				;
 193:				; Write character to console (short for "call conwch").
 194:				CON_WR_CHAR     macro
 195:				                rst 16
 196:				                endm
 197:				
**** format.z80 ****
  35:				                include "cpm.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm.i ****
   1:				; *******************************************************
   2:				; * ZARC Monitor CP/M 2.2 Definitions                   *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 26/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Definitions related to CP/M running under the monitor programme. It may also
   8:				; be used for CP/M applications.
   9:				;
  10:				; Note that ld80 only considers the first six characters of labels significant.
  11:				;
  12:				; The following conditionals are intended to allow the same include file to be
  13:				; used in the defining module and elsewhere as required. Some includes are used
  14:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  15:				; the extern and public statements are not desirable.
  16:				;
  17:     -	0000'         	            ifdef monitor           ; Meaningful for monitor build only
  30:				            endif
  31:				;
  32:				;
  33:				;
  34:				; ****************
  35:				; * Memory Usage *
  36:				; ****************
  37:				;
  38:				;
  39:				; Note: memory banks are allocated by the monitor's initialisation code.
  40:     -	0004'         	MMAP_CPM_PAGES      equ 4               ; Number of 16 kB pages
  41:				;
  42:				; The MS byte of INT_VEC_TABLE comes from the Z80 I register, and the LS byte
  43:				; from the FPGA. The 0xe0 offset is chosen to allow the table to reside at the
  44:				; top of memory (0xffe0 to 0xffff).
  45:     -	FFE0'         	INT_VEC_TABLE   equ 0xffe0              ; Interrupt mode 2 vector table
  46:				;
  47:				; Copied from CP/M manual appendix A.
  48:				; MSIZE             equ 64              ; CP/M version memory size in kilobytes
  49:				;
  50:				; "BIAS" is the address offset from 0x3400 for memory systems other than 16 K.
  51:				;BIAS               equ (MSIZE-20) * 1024
  52:     -	A200'         	CPM_BIAS            equ 0xa200          ; For CompuPro64K_CPM
  53:     -	D600'         	CCP_START           equ 0x3400 + CPM_BIAS   ; Base of CCP
  54:     -	DE06'         	BDOS_START          equ CCP_START + 0x0806  ; Base of BDOS
  55:     -	EC00'         	BIOS_START          equ CCP_START + 0x1600  ; Base of BIOS
  56:     -	002C'         	BIOS_CPM_START_SEC  equ 44              ; First CP/M sector of BIOS
  57:     -	1000'         	BIOS_MAX_SIZE       equ 4096            ; 2 KB allocation for BIOS stored on MMC (ZARC)
  58:     -	0100'         	TPA_START           equ 0x0100          ; Transient Programme Area
  59:				;
  60:				; Page zero.
  61:     -	0003'         	IOBYTE              equ 0x0003          ; Intel I/O byte
  62:     -	0004'         	CDISK               equ 0x0004          ; Current disk (0="A") & user no. (in high nibble)
  63:     -	005C'         	FCB1                equ 0x005c          ; Default FCB 1
  64:     -	006C'         	FCB2                equ 0x006c          ; Default FCB 2 (overwritten if FCB 1 is opened)
  65:				; Default 128-byte disk buffer, also filled with the command line when a transient
  66:				; is loaded under the CCP.
  67:     -	0080'         	DEF_BUFFER          equ 0x80
  68:     -	0080'         	DEF_BUFFER_SIZE     equ 0x80
  69:				;
  70:				; IOBYTE bit definitions.
  71:     -	0003'         	IOB_CON_MASK        equ 0x03
  72:     -	000C'         	IOB_RDR_MASK        equ 0x0c
  73:     -	0030'         	IOB_PUN_MASK        equ 0x30
  74:     -	00C0'         	IOB_LST_MASK        equ 0xc0
  75:				;
  76:				; BIOS option bits.
  77:     -	        	BITDEF BIOS_OPT_DEBUG, 0                ; Enable BIOS debugging messages
  78:     -	        	BITDEF BIOS_OPT_NOINTS, 1               ; Disables interrupts (use basic I/O mode)
  79:     -	        	BITDEF BIOS_OPT_RAWCON, 2               ; Disables ADM-3A to VT-100 translation
  80:				;
  81:				;
  82:				;
  83:				; ***************
  84:				; * Disk System *
  85:				; ***************
  86:				;
  87:				;
  88:				; Note: NUM_DISKS reduced to 9 from 16 in preparation for adding CP/M 3 support.
  89:     -	0080'         	CPM_SECTOR_SIZE     equ 128             ; CP/M disk sector size
  90:     -	0009'         	NUM_DISKS           equ 9               ; Number of disk drives
  91:     -	0010'         	NUM_DISKS_MAX       equ 16              ; Maximum number of disk drives
  92:     -	0000'         	CPM_SYS_SIZE        equ 1024 * 1024     ; System area size (bytes)
  93:     -	0000'         	CPM_DISK_SIZE       equ 1024 * 1024     ; Disk size (bytes)
  94:     -	0800'         	CPM_BLOCK_SIZE      equ 2048            ; Allocation block size (bytes)
  95:     -	0200'         	CPM_DIR_ENTRIES     equ 512             ; Number of directory entries
  96:     -	0008'         	FILENAME_SIZE       equ 8               ; Filename size
  97:     -	0003'         	FILEEXT_SIZE        equ 3               ; File extension size
  98:     -	001A'         	FILE_EOF            equ 0x1a            ; End of file (^Z)
  99:     -	000F'         	MAX_USER            equ 15              ; Maximum user number
 100:				;
 101:     -	0001'         	BDOS_READ_SEQ_EOF   equ 1               ; Sequential read EOF error code
 102:				;
 103:				; CP/M 2.2 Disk Parameter Header (DPH) structure.
 104:     -	        	                STRUCT
 105:     -	        	                STR_WORD DPH_XLT        ; Address of sector translation table
 106:     -	        	                STR_WORD DPH_SCRATCH0   ; BDOS scratch area
 107:     -	        	                STR_WORD DPH_SCRATCH1
 108:     -	        	                STR_WORD DPH_SCRATCH2
 109:     -	        	                STR_WORD DPH_DIRBF      ; BDOS directory scratch area
 110:     -	        	                STR_WORD DPH_DPB        ; Pointer to DPB
 111:     -	        	                STR_WORD DPH_CSV        ; Pointer to the directory checksum vector
 112:     -	        	                STR_WORD DPH_ALV        ; Pointer to the allocation vector
 113:     -	        	                STR_END DPH_SIZE
 114:				;
 115:				;
 116:				; CP/M 2.2 Disk Parameter Block (DPB) structure.
 117:     -	        	                STRUCT
 118:     -	        	                STR_WORD DPB_SPT        ; Number of 128-byte records per track
 119:     -	        	                STR_BYTE DPB_BSH        ; Block shift. 3 => 1k, 4 => 2k, 5 => 4k....
 120:     -	        	                STR_BYTE DPB_BLM        ; Block mask. 7 => 1k, 0Fh => 2k, 1Fh => 4k...
 121:     -	        	                STR_BYTE DPB_EXM        ; Extent mask
 122:     -	        	                STR_WORD DPB_DSM        ; Maximum block number
 123:     -	        	                STR_WORD DPB_DRM        ; Maximum directory entry number
 124:     -	        	                STR_BYTE DPB_AL0        ; Directory allocation bitmap
 125:     -	        	                STR_BYTE DPB_AL1
 126:     -	        	                STR_WORD DPB_CKS        ; Checksum vector size, 0 for a fixed disc
 127:     -	        	                STR_WORD DPB_OFF        ; Offset, number of reserved tracks
 128:     -	        	                STR_END DPB_SIZE
 129:				;
 130:				;
 131:				; Directory entry structure.
 132:     -	        	                STRUCT
 133:     -	        	                STR_BYTE DIRE_USER      ; User number. 0xe5 if entry unused
 134:     -	        	                STR_BLOCK DIRE_NAME, FILENAME_SIZE  ; Filename
 135:     -	        	                STR_BLOCK DIRE_TYP, FILEEXT_SIZE    ; File type
 136:     -	        	                STR_BYTE DIRE_EX        ; Extent counter, low byte (0-31)
 137:     -	        	                STR_BYTE DIRE_S1        ; Reserved, set to 0
 138:     -	        	                STR_BYTE DIRE_S2        ; Extent counter, high byte
 139:     -	        	                STR_BYTE DIRE_RC        ; Record count (low byte)
 140:     -	        	                STR_BLOCK DIRE_ALLOC, 16 ; Associated block numbers
 141:     -	        	                STR_END DIRE_SIZE
 142:				;
 143:     -	0001'         	                assert DIRE_SIZE = 0x20
 144:				;
 145:				;
 146:				; File Control Block (FCB) structure.
 147:     -	        	                STRUCT
 148:     -	        	                STR_BYTE FCB_DRIVE      ; Drive. 0 for default, 1-16 for A-P
 149:     -	        	                STR_BLOCK FCB_NAME, FILENAME_SIZE   ; Filename in ASCII upper-case
 150:     -	        	                STR_BLOCK FCB_TYP, FILEEXT_SIZE     ; File type
 151:     -	        	                STR_BYTE FCB_EX         ; Current extent (*)
 152:     -	        	                STR_BYTE FCB_S1         ; Reserved (*)
 153:     -	        	                STR_BYTE FCB_S2         ; Extent high byte (*)
 154:     -	        	                STR_BYTE FCB_RC         ; Record count (*)
 155:     -	        	                STR_BLOCK FCB_ALLOC, 16 ; Associated block numbers
 156:     -	        	                STR_BYTE FCB_CR         ; Current record within extent
 157:     -	        	                STR_BLOCK FCB_RECORD, 3 ; Record number (low byte first)
 158:     -	        	                STR_END FCB_SIZE
 159:				;
 160:				; * - Set this to 0 when opening a file and then leave it to CP/M. You can
 161:				; rewind a file by setting EX, RC, S2 and CR to 0.
 162:				;
 163:				;
 164:				;
 165:				; **************
 166:				; * BIOS Calls *
 167:				; **************
 168:				;
 169:				;
 170:				; Calculate offsets into jump tables. Entries here must match the jump table in
 171:				; the BIOS. The base address of the BIOS must be added to these addresses. A
 172:				; call routine might look like:
 173:				;
 174:				; Call BIOS, allowing for its unknown base address.
 175:				; Call with:
 176:				; BC - operand (depends on BIOS function called)
 177:				; DE - operand (depends on BIOS function called)
 178:				; HL - offset for the routine (e.g. BIOS_CONIN)
 179:				; call_bios       push de
 180:				;                 ex de, hl
 181:				;                 ld hl, (1)              ; Find WBOOT (warm boot) address
 182:				;                 add hl, de              ; Add offset
 183:				;                 pop de
 184:				;                 jp (hl)                 ; Jump to BIOS then return to caller
 185:				;
 186:				; The above method is a bit clumsy, but then application code shouldn't normally
 187:				; call the BIOS directly.
 188:				;
 189:     -	        	    JPTBL_START 0                   ; Generate offsets as BIOS_START isn't always known
 190:				;
 191:				; Note - cold start routine omitted to align with use of address at (1) to find BIOS.
 192:     -	        	    JPTBL_ENTRY BIOS_WBOOT          ; Warm boot - reload command processor
 193:     -	        	    JPTBL_ENTRY BIOS_CONST          ; Console status
 194:     -	        	    JPTBL_ENTRY BIOS_CONIN          ; Console input
 195:     -	        	    JPTBL_ENTRY BIOS_CONOUT         ; Console output
 196:     -	        	    JPTBL_ENTRY BIOS_PLIST          ; Printer output
 197:     -	        	    JPTBL_ENTRY BIOS_PUNCH          ; Paper tape punch output
 198:     -	        	    JPTBL_ENTRY BIOS_READER         ; Paper tape reader input
 199:     -	        	    JPTBL_ENTRY BIOS_HOME           ; Move disc head to track 0
 200:     -	        	    JPTBL_ENTRY BIOS_SELDSK         ; Select disc drive
 201:     -	        	    JPTBL_ENTRY BIOS_SETTRK         ; Set track number
 202:     -	        	    JPTBL_ENTRY BIOS_SETSEC         ; Set sector number
 203:     -	        	    JPTBL_ENTRY BIOS_SETDMA         ; Set DMA address
 204:     -	        	    JPTBL_ENTRY BIOS_READ           ; Read a sector
 205:     -	        	    JPTBL_ENTRY BIOS_WRITE          ; Write a sector
 206:				; CP/M 2 functions.
 207:     -	        	    JPTBL_ENTRY BIOS_LISTST         ; Status of list device
 208:     -	        	    JPTBL_ENTRY BIOS_SECTRAN        ; Sector translation for skewing
 209:				; CP/M 3 functions. From https://www.seasip.info/Cpm/bios.html
 210:     -	        	    JPTBL_ENTRY BIOS_CONOST         ; Status of console output
 211:     -	        	    JPTBL_ENTRY BIOS_AUXIST         ; Status of auxiliary input
 212:     -	        	    JPTBL_ENTRY BIOS_AUXOST         ; Status of auxiliary output
 213:     -	        	    JPTBL_ENTRY BIOS_DEVTBL         ; Address of devices table
 214:     -	        	    JPTBL_ENTRY BIOS_DEVINI         ; Initialise a device
 215:     -	        	    JPTBL_ENTRY BIOS_DRVTBL         ; Address of discs table
 216:     -	        	    JPTBL_ENTRY BIOS_MULTIO         ; Read/write multiple sectors
 217:     -	        	    JPTBL_ENTRY BIOS_FLUSH          ; Flush host buffers
 218:     -	        	    JPTBL_ENTRY BIOS_MOVE           ; Move a block of memory
 219:     -	        	    JPTBL_ENTRY BIOS_TIME           ; Real time clock
 220:     -	        	    JPTBL_ENTRY BIOS_SELMEM         ; Select memory bank
 221:     -	        	    JPTBL_ENTRY BIOS_SETBNK         ; Select bank for DMA operation
 222:     -	        	    JPTBL_ENTRY BIOS_XMOVE          ; Preload banks for MOVE
 223:     -	        	    JPTBL_ENTRY BIOS_USERF          ; System-depedent functions
 224:     -	        	    JPTBL_ENTRY BIOS_RESERV1        ; Reserved
 225:     -	        	    JPTBL_ENTRY BIOS_RESERV2        ; Reserved
 226:				; ZARC-specific items.
 227:     -	        	    JPTBL_BLOCK BIOS_ID, 3          ; BIOS ID ("ZRC")
 228:     -	        	    JPTBL_BLOCK BIOS_VER, 3         ; Version (see below)
 229:     -	        	    JPTBL_ENTRY BIOS_STARTUP        ; CP/M startup entry point
 230:     -	        	    JPTBL_ENTRY BIOS_MON_CALL       ; Call monitor function
 231:     -	        	    JPTBL_ENTRY BIOS_SUPER          ; Set supervisor state
 232:     -	        	    JPTBL_ENTRY BIOS_INT_DISABLE    ; Disable interrupts and keep count
 233:     -	        	    JPTBL_ENTRY BIOS_INT_ENABLE     ; Enable interrupts if safe
 234:     -	        	    JPTBL_ENTRY BIOS_TIRD           ; Read time and date (ZARC format)
 235:     -	        	    JPTBL_ENTRY BIOS_SET_TIMER      ; Set timer
 236:     -	        	    JPTBL_ENTRY BIOS_GET_TIMER      ; Get timer
 237:				;
 238:     -	        	    JPTBL_END BIOS_JPTBL_NEXT
 239:				;
 240:				; BIOS_VER is <reserved (zero)>, <major version>, <minor version>. The reserved
 241:				; byte may flag capabilities at some point.
 242:				;
 243:				;
 244:				;
 245:				; **************
 246:				; * BDOS Calls *
 247:				; **************
 248:				;
 249:				;
 250:				; From http://www.gaby.de/cpm/manuals/archive/cpm22htm/ch5.htm#Section_5.2
 251:				; In general, the function number is passed in register C with the information
 252:				; address in the double byte pair DE. Single byte values are returned in register
 253:				; A, with double byte values returned in HL. A zero value is returned when the
 254:				; function number is out of range. For reasons of compatibility, register A = L
 255:				; and register B = H upon return in all cases. Example call:
 256:				;   ld c, BDOS_CONIN    ; Read next character
 257:				;   call BDOS           ; Return character in A
 258:				;
 259:     -	0005'         	BDOS        equ 5               ; BDOS entry point
 260:				;
 261:     -	0000'         	BDOS_SYS_RST        equ 0       ; System Reset
 262:     -	0001'         	BDOS_CON_IN         equ 1       ; Console Input
 263:     -	0002'         	BDOS_CON_OUT        equ 2       ; Console Output
 264:     -	0003'         	BDOS_RDR_IN         equ 3       ; Reader Input
 265:     -	0004'         	BDOS_PUN_OUT        equ 4       ; Punch Output
 266:     -	0005'         	BDOS_LST_OUT        equ 5       ; List Output
 267:     -	0006'         	BDOS_DIRECT_CON_IO  equ 6       ; Direct Console I/O
 268:     -	0007'         	BDOS_GET_IO_BYTE    equ 7       ; Get I/O Byte
 269:     -	0008'         	BDOS_SET_IO_BYTE    equ 8       ; Set I/O Byte
 270:     -	0009'         	BDOS_PRINT_STRING   equ 9       ; Print String
 271:     -	000A'         	BDOS_READ_CON_BUFF  equ 10      ; Read Console Buffer
 272:     -	000B'         	BDOS_GET_CON_STAT   equ 11      ; Get Console Status
 273:     -	000C'         	BDOS_VERSION        equ 12      ; Return Version Number
 274:     -	000D'         	BDOS_RESET_DISK_SYS equ 13      ; Reset Disk System
 275:     -	000E'         	BDOS_SEL_DISK       equ 14      ; Select Disk
 276:     -	000F'         	BDOS_OPEN_FILE      equ 15      ; Open File
 277:     -	0010'         	BDOS_CLOSE_FILE     equ 16      ; Close File
 278:     -	0011'         	BDOS_SEARCH_FIRST   equ 17      ; Search for first matching directory entry
 279:     -	0012'         	BDOS_SEARCH_NEXT    equ 18      ; Search for next matching directory entry
 280:     -	0013'         	BDOS_DELETE_FILE    equ 19      ; Delete File
 281:     -	0014'         	BDOS_READ_SEQ       equ 20      ; Read Sequential
 282:     -	0015'         	BDOS_WRITE_SEQ      equ 21      ; Write Sequential
 283:     -	0016'         	BDOS_MAKE_FILE      equ 22      ; Make File
 284:     -	0017'         	BDOS_RENAME_FILE    equ 23      ; Rename File
 285:     -	0018'         	BDOS_GET_LOGIN_VEC  equ 24      ; Return Login Vector
 286:     -	0019'         	BDOS_GET_CURR_DISK  equ 25      ; Return Current Disk
 287:     -	001A'         	BDOS_SET_DMA_ADDR   equ 26      ; Set DMA Address
 288:     -	001B'         	BDOS_GET_ALLOC_ADDR equ 27      ; Get Addr (Alloc)
 289:     -	001C'         	BDOS_WRITE_PROT     equ 28      ; Write Protect Disk
 290:     -	001D'         	BDOS_GET_RO_VEC     equ 29      ; Get R/O Vector
 291:     -	001E'         	BDOS_SET_FILE_ATTR  equ 30      ; Set File Attributes
 292:     -	001F'         	BDOS_GET_DPB        equ 31      ; Get Addr (Disk Parms)
 293:     -	0020'         	BDOS_GET_SET_USER   equ 32      ; Set/Get User Code
 294:     -	0021'         	BDOS_READ_RANDOM    equ 33      ; Read Random
 295:     -	0022'         	BDOS_WRITE_RANDOM   equ 34      ; Write Random
 296:     -	0023'         	BDOS_GET_FILE_SIZE  equ 35      ; Compute File Size
 297:     -	0024'         	BDOS_SET_RANDOM_REC equ 36      ; Set Random Record
 298:     -	0025'         	BDOS_RESET_DRIVES   equ 37      ; Selectively reset disc drives
 299:     -	0028'         	BDOS_WR_RND_ZFILL   equ 40      ; Write Random with Zero Fill
 300:     -	002C'         	BDOS_F_MULTISEC     equ 44      ; Set number of records to read/write at once
 301:     -	0031'         	BDOS_S_SYSVAR       equ 49      ; Access the System Control Block
 302:     -	0032'         	BDOS_S_BIOS         equ 50      ; Use the BIOS
 303:     -	003B'         	BDOS_P_LOAD         equ 59      ; Load overlay
 304:     -	003C'         	BDOS_CALL_RSX       equ 60      ; Call to RSX
 305:     -	0062'         	BDOS_DISK_CLEAN     equ 98      ; Clean up disc
 306:     -	0063'         	BDOS_F_TRUNCATE     equ 99      ; Truncate file
 307:     -	0068'         	BDOS_T_SET          equ 104     ; Set date and time
 308:     -	006C'         	BDOS_P_CODE         equ 108     ; Get/put program return code
 309:     -	006D'         	BDOS_C_MODE         equ 109     ; Set or get console mode
 310:     -	006E'         	BDOS_C_DELIMIT      equ 110     ; Get/set string delimiter
 311:     -	006F'         	BDOS_C_WRITEBLK     equ 111     ; Send block of text to console
 312:     -	0070'         	BDOS_L_WRITEBLK     equ 112     ; Send block of text to printer
 313:     -	0098'         	BDOS_F_PARSE        equ 152     ; Parse filename
 314:				;
 315:				; Functions 28 and 32 should be avoided in application programs to maintain upward
 316:				; compatibility with CP/M.
 317:				;
 318:				; Direct Console I/O (BDOS_DIRECT_CON_IO) command codes. There are additional
 319:				; codes supported by CP/M 3 (see cpm3.i).
 320:     -	00FF'         	DCONIO_GET_NO_WT    equ 0xff    ; Get character (no echo) else return zero
 321:     -	0000'         	DCONIO_PUT          equ 0x00    ; Put (write) character
 322:				;
 323:				; BDOS_S_BIOS (function 50) parameter block.
 324:     -	        	                STRUCT
 325:     -	        	                STR_BYTE SBM_FUNC       ; BIOS function (0-32)
 326:     -	        	                STR_BYTE SBM_A
 327:     -	        	                STR_BYTE SBM_C
 328:     -	        	                STR_BYTE SBM_B
 329:     -	        	                STR_BYTE SBM_E
 330:     -	        	                STR_BYTE SBM_D
 331:     -	        	                STR_BYTE SBM_L
 332:     -	        	                STR_BYTE SBM_H
 333:     -	        	                STR_END SBM_SIZE
 334:				;
 335:				;
 336:				
**** format.z80 ****
  36:				                include "memory.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/memory.i ****
   1:				; *******************************************
   2:				; * ZARC Memory Include File                *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 24/11/2021                *
   5:				; *******************************************
   6:				;
   7:				;
   8:				; Note that ld80 only considers the first six characters of labels significant.
   9:				;
  10:				; The following conditionals are intended to allow the same include file to be
  11:				; used in the defining module and elsewhere as required. Some includes are used
  12:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  13:				; the extern and public statements are not desirable.
  14:				;
  15:     -	0000'         	            ifdef monitor           ; Meaningful for monitor build only
  26:				            endif
  27:				;
  28:				; Physical memory constants are found in zarc.i
  29:				;
  30:     -	0004'         	MPA_NAME_LEN        equ 4               ; Page owner name length (bytes)
  31:				;
  32:				; Memory map
  33:     -	4000'         	MMAP_PAGE_SIZE      equ 0x4000          ; Memory mapping bank / page size
  34:     -	0004'         	MMAP_BANKS          equ 4               ; Number of 16 kB banks
  35:     -	0040'         	MMAP_PAGES          equ 0x40            ; Number of 16 kB RAM pages
  36:     -	0000'         	MMAP_BANK0_START    equ 0x0000
  37:     -	3FFF'         	MMAP_BANK0_END      equ 0x3fff
  38:     -	4000'         	MMAP_BANK1_START    equ 0x4000
  39:     -	7FFF'         	MMAP_BANK1_END      equ 0x7fff
  40:     -	8000'         	MMAP_BANK2_START    equ 0x8000
  41:     -	BFFF'         	MMAP_BANK2_END      equ 0xbfff
  42:     -	C000'         	MMAP_BANK3_START    equ 0xc000
  43:     -	FFFF'         	MMAP_BANK3_END      equ 0xffff
  44:				;
  45:				;
  46:				;
  47:				; ****************
  48:				; * Memory Usage *
  49:				; ****************
  50:				;
  51:				;
  52:				; Memory banks setup.
  53:				; 0 (0000 - 3FFF): 3f read only, supervisor - monitor program
  54:				; 1 (4000 - 7FFF): 3e writeable - monitor variables, stacks, buffers etc.
  55:				; 2 (8000 - BFFF): (not used)
  56:				; 3 (C000 - FFFF): (mapped as required)
  57:				;
  58:     -	003F'         	MMAP_MON_B0_PAGE    equ 0x3f        ; Page for bank 0
  59:     -	003E'         	MMAP_MON_B1_PAGE    equ 0x3e        ; Page for bank 1
  60:				;
  61:				; This may seem large, but MMC sector writes for example require over 70 bytes
  62:				; of stack!
  63:     -	0080'         	STACKS_SIZE     equ 128             ; Space allocated to normal stacks
  64:				;
  65:     -	7FFF'         	HEAP_TOP        equ MMAP_BANK1_END  ; Top (end) of heap space.
  66:				
**** format.z80 ****
  37:				                include "cpm_utility.i" ; CP/M utilities
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm_utility.i ****
   1:				; *******************************************************
   2:				; * Utility Routines for CP/M Applications              *
   3:				; * Version: V1.0                                       *
   4:				; * Merlin Skinner, 16/12/2021                          *
   5:				; *******************************************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant.
   8:				;
   9:     -	0001'         	            ifndef CPMU         ; Inhibit for this module
  10:				; CP/M specific.
  11:				                extern init     ; Common initialisation code
  12:				                extern conmod   ; Set console mode (BDOS or BIOS)
  13:				                extern cpmver   ; CP/M version (packed BCD)
  14:				                extern cbdos    ; Call BDOS with some registers saved
  15:				                extern cbios    ; Call BIOS with some registers saved
  16:				                extern panic    ; Fatal application error
  17:				                extern zrcdet   ; Detect ZARC
  18:				                extern z80det   ; Detect Z80 (instead of 8080 / 8085)
  19:				                extern clopts   ; Read command line options
  20:				;
  21:				; Derived from the monitor's utility.z80.
  22:				                extern conwch   ; Write character to console
  23:				                extern conrch   ; Read character from the console
  24:				                extern const    ; Fetch console input status
  25:				                extern cwnwln   ; Write new line characters to console
  26:				                extern conwms   ; Print "$" terminated string to the console
  27:				                extern conwmn   ; Print message <n> in a list
  28:				                extern skpspc   ; Step hl past spaces
  29:				                extern toupca   ; Convert character in A to upper case
  30:				                extern toloca   ; Convert character in A to lower case
  31:				                extern cwvich   ; Print only visible 7-bit characters
  32:				                extern cwpspc   ; Print a space
  33:				                extern mtwdli   ; Match word in a string against list of options
  34:				                extern cwphnb   ; Print least-significant nibble in A in hexadecimal
  35:				                extern cwphby   ; Print A in hexadecimal
  36:				                extern cwphwd   ; Print HL in hexadecimal
  37:				                extern cwpdwd   ; Print HL in decimal. Leading zeros are suppressed
  38:				                extern cwpdby   ; Print A in decimal. Leading zeros are suppressed
  39:				                extern cwpdwd   ; Print HL in decimal. Leading zeros are suppressed
  40:				                extern cwpdlo   ; Print DEHL in decimal. Leading zeros are suppressed
  41:				                extern rdhxwd   ; Read a 16-bit hexadecimal number from a string
  42:				                extern rdduwd   ; Read a 16-bit unsigned decimal number from a string
  43:				                extern rddulo   ; Read a 32-bit unsigned decimal number from a string
  44:				;
  45:				            endif
  46:				;
  47:				;
  48:				; mtwdli (match word in a string against list of options) option bits. Each bit
  49:				; has the described effect if set.
  50:     -	        	BITDEF MTWDLI_ABBREV, 0                 ; Enable "." abbreviation
  51:     -	        	BITDEF MTWDLI_ICASE, 1                  ; Ignore case when matching
  52:     -	        	BITDEF MTWDLI_TERM, 7                   ; Terminator found (internal use only)
  53:				;
  54:				;
  55:				; Console mode (for conmod)
  56:     -	0000'         	CONMOD_BDOS     equ 0x00                ; Use BDOS for console I/O
  57:     -	0001'         	CONMOD_BIOS     equ 0x01                ; Use BIOS for console I/O
  58:				
**** format.z80 ****
  38:				;
  39:				;
  40:				;
  41:				; *************
  42:				; * Constants *
  43:				; *************
  44:				;
  45:				;
  46:				; None
  47:				;
  48:				;
  49:				;
  50:				; *************
  51:				; * Main Code *
  52:				; *************
  53:				;
  54:				;
  55:				; The CP/M transient area start address is set in the linker invocation (see
  56:				; makefile).
  57:				                cseg                    ; Code segment
  58:				;
  59:				; The default stack space is very small (8 deep), which would almost certainly
  60:				; cause issues, particularly with interrupts running. The initial code should
  61:				; not assume a Z80 so we can exit cleanly if this is run on an 8080, for
  62:				; example.
  63:    0+20	0000' ED730000	                ld (bdos_sp), sp
  64:   20+10	0004' 318900  	                ld sp, app_stack_top    ; Switch to our stack space
  65:				;
  66:   30+17	0007' CD0000  	                call init               ; Common initialisation code
  67:				;
  68:   47+10	000A' 21EB01  	                ld hl, signon_msg
  69:   57+17	000D' CD0000  	                call conwms             ; Print "$" terminated string to the console
  70:				;
  71:				; Clear variables area
  72:   74+10	0010' 210200  	                ld hl, clr_start        ; Start address
  73:   84+7	0013' 0607    	                ld b, clr_end - clr_start
  74:   91+4	0015' AF      	                xor a
  75:   95+7	0016' 77      	clr_loop        ld (hl), a
  76:  102+6	0017' 23      	                inc hl
  77:  108+8+5	0018' 10FC    	                djnz clr_loop
  78:				;
  79:				; Examine the command tail, looking for operands. This is stored in the default
  80:				; buffer. "The first byte at 0080H contains the length of the command tail, while
  81:				; the command tail itself begins at 0081H. The command tail is terminated by a
  82:				; byte containing a binary zero value." (http://www.cpm.z80.de/manuals/cpm22-m.pdf
  83:				; appendix H).
  84:  116+10	001A' 218100  	                ld hl, DEF_BUFFER + 1
  85:  126+17	001D' CD0000  	                call skpspc             ; Skip spaces
  86:  143+7	0020' 7E      	                ld a, (hl)              ; This should be a drive letter
  87:  150+7	0021' D641    	                sub "A"                 ; Convert to a number
  88:				; If this carries, the byte is not a letter. It may be the zero terminator, if no
  89:				; operand were supplied.
  90:  157+7+5	0023' 3815    	                jr c, op_error
  91:  164+7	0025' FE10    	                cp NUM_DISKS_MAX
  92:  171+7+5	0027' 3011    	                jr nc, op_error
  93:				; We have a valid drive number.
  94:  178+13	0029' 320200  	                ld (drive), a           ; Save it
  95:				;
  96:				; A following colon is optional.
  97:  191+6	002C' 23      	                inc hl
  98:  197+7	002D' 7E      	                ld a, (hl)
  99:  204+7	002E' FE3A    	                cp ":"
 100:  211+7+5	0030' 2001    	                jr nz, op_check_term
 101:  218+6	0032' 23      	                inc hl                  ; Step past colon
 102:				;
 103:				; The terminator should follow.
 104:  224+17	0033' CD0000  	op_check_term   call skpspc             ; Skip spaces
 105:  241+7	0036' 7E      	                ld a, (hl)
 106:  248+4	0037' A7      	                and a
 107:  252+7+5	0038' 2809    	                jr z, operands_ok
 108:				;
 109:				; Go here if we don't like the operands supplied.
 110:  259+10	003A' 210E02  	op_error        ld hl, op_err_msg
 111:  269+17	003D' CD0000  	                call conwms             ; Print "$" terminated string to the console
 112:  286+10	0040' C36701  	                jp exit
 113:				;
 114:				; Operand processing complete. We can't run under CP/M 3 so stop if someonetries
 115:				; this.
 116:  296+13	0043' 3A0000  	operands_ok     ld a, (cpmver)          ; CP/M version (packed BCD)
 117:  309+7	0046' FE30    	                cp 0x30
 118:  316+7+5	0048' 3809    	                jr c, cver_cpm2         ; Jump on earlier and 3.0
 119:				;
 120:				; We are running on CP/M 3.x.
 121:  323+10	004A' 21C002  	                ld hl, os_err_msg       ; "CP/M 2.x required"
 122:  333+17	004D' CD0000  	                call conwms             ; Print "$" terminated string to the console
 123:  350+10	0050' C36701  	                jp exit
 124:				;
 125:				; We are running on CP/M 3 or 3.1. Enable CP/M 3 features unless "/2" option is
 126:				; specified.
 127:  360+7	0053' 0E0D    	cver_cpm2       ld c, BDOS_RESET_DISK_SYS   ; Reset Disk System
 128:  367+17	0055' CD0000  	                call cbdos              ; Call BDOS with some registers saved
 129:				; Both the above reset and the reboot at the end of this application should
 130:				; make it safe to format any drive regardless of its logged in status.
 131:				;
 132:				; Note that the BDOS function BDOS_GET_DPB is not useful here as it works only
 133:				; on the current drive.
 134:				;
 135:				; Select the drive to format.
 136:  384+13	0058' 3A0200  	                ld a, (drive)
 137:  397+4	005B' 4F      	                ld c, a
 138:  401+10	005C' 110000  	                ld de, 0                ; Treat disk as new to the system
 139:  411+10	005F' 211800  	                ld hl, BIOS_SELDSK      ; Select disc drive
 140:  421+17	0062' CD0000  	                call cbios
 141:				;HL - pointer to Disc Parameter Header (DPH) or zero on error.
 142:  438+4	0065' 7C      	                ld a, h
 143:  442+4	0066' B5      	                or l
 144:  446+7+5	0067' 2009    	                jr nz, drive_sel_ok
 145:				; Can't select drive.
 146:  453+10	0069' 213C02  	                ld hl, sel_err_msg
 147:  463+17	006C' CD0000  	                call conwms             ; Print "$" terminated string to the console
 148:  480+10	006F' C36701  	                jp exit
 149:     -	0072'         	drive_sel_ok
 150:				;
 151:				; Find address of DPB.
 152:  490+10	0072' 110A00  	                ld de, DPH_DPB          ; Offset to pointer to DPB
 153:  500+11	0075' 19      	                add hl, de
 154:  511+7	0076' 5E      	                ld e, (hl)              ; Fetch pointer
 155:  518+6	0077' 23      	                inc hl
 156:  524+7	0078' 56      	                ld d, (hl)
 157:  531+11	0079' D5      	                push de
 158:  542+14	007A' DDE1    	                pop ix
 159:				;
 160:				; We know that the directory starts at the beginning of the first track of the
 161:				; data area. There are DRM + 1 directory entries.
 162:				; 
 163:				; IX - pointer to DPB
 164:				; Scan each entry, looking for valid-looking entries.
 165:  556+10	007C' 010000  	                ld bc, 0                ; Directory entry number
 166:  566+20	007F' ED430500	                ld (file_count), bc     ; Reset counts
 167:  586+20	0083' ED430700	                ld (unused_count), bc
 168:				; Set no sector loaded.
 169:  606+10	0087' 21FFFF  	                ld hl, 0xffff
 170:  616+16	008A' 220300  	                ld (loaded_sector), hl
 171:				;
 172:  632+4	008D' 60      	scan_loop       ld h, b
 173:  636+4	008E' 69      	                ld l, c
 174:  640+17	008F' CD7301  	                call get_entry
 175:				; HL - points to start of entry
 176:  657+11	0092' E5      	                push hl                 ; Move address to IY
 177:  668+14	0093' FDE1    	                pop iy
 178:				;
 179:				; Check the entry.
 180:  682+19	0095' FD7E00  	                ld a, (iy + DIRE_USER)
 181:  701+7	0098' FEE5    	                cp 0xe5
 182:  708+7+5	009A' 2009    	                jr nz, sl_not_unused
 183:				; This is an unused entry.
 184:  715+16	009C' 2A0700  	                ld hl, (unused_count)
 185:  731+6	009F' 23      	                inc hl
 186:  737+16	00A0' 220700  	                ld (unused_count), hl
 187:  753+12	00A3' 183C    	                jr sl_entry_done        ; Entry done
 188:				;
 189:				; Does the filename look credible?
 190:  765+15	00A5' FDE5    	sl_not_unused   push iy
 191:  780+10	00A7' E1      	                pop hl
 192:  790+6	00A8' 23      	                inc hl
 193:				; HL - points to start of filename
 194:  796+11	00A9' C5      	                push bc                 ; Save entry number
 195:  807+7	00AA' 0608    	                ld b, 8                 ; Number of characters to check
 196:  814+7	00AC' 0E00    	                ld c, 0                 ; Oddity count
 197:  821+7	00AE' 7E      	sl_fn_check     ld a, (hl)
 198:  828+7	00AF' FE20    	                cp 0x20
 199:  835+7+5	00B1' 3804    	                jr c, sl_fn_ch_bad
 200:  842+7	00B3' FE80    	                cp 0x80
 201:  849+7+5	00B5' 3801    	                jr c, sl_fn_ch_ok
 202:  856+4	00B7' 0C      	sl_fn_ch_bad    inc c                   ; Flag oddity
 203:  860+6	00B8' 23      	sl_fn_ch_ok     inc hl
 204:  866+8+5	00B9' 10F3    	                djnz sl_fn_check
 205:				;
 206:				; Check the extension, which follows directly.
 207:  874+7	00BB' 0603    	                ld b, 3                 ; Number of characters to check
 208:  881+7	00BD' 7E      	sl_typ_check    ld a, (hl)
 209:  888+7	00BE' E67F    	                and 0x7f                ; Remove top bit (flag)
 210:  895+7	00C0' FE20    	                cp 0x20
 211:  902+7+5	00C2' 3001    	                jr nc, sl_typ_ch_ok
 212:  909+4	00C4' 0C      	                inc c                   ; Flag oddity
 213:  913+6	00C5' 23      	sl_typ_ch_ok    inc hl
 214:  919+8+5	00C6' 10F5    	                djnz sl_typ_check
 215:				;
 216:				; Examine the results
 217:  927+4	00C8' 79      	                ld a, c
 218:  931+10	00C9' C1      	                pop bc                  ; Restore entry number
 219:  941+4	00CA' A7      	                and a
 220:  945+7+5	00CB' 2014    	                jr nz, sl_entry_done    ; Complete if any oddities found
 221:				;
 222:				; Extent counter (low byte) should be 0 to 31.
 223:  952+19	00CD' FD7E0C  	                ld a, (iy + DIRE_EX)
 224:  971+7	00D0' FE20    	                cp 32
 225:  978+7+5	00D2' 300D    	                jr nc, sl_entry_done
 226:				;
 227:				; S1 should be 0.
 228:  985+19	00D4' FD7E0D  	                ld a, (iy + DIRE_S1)
 229: 1004+4	00D7' A7      	                and a
 230: 1008+7+5	00D8' 2007    	                jr nz, sl_entry_done
 231:				;
 232:				; If we get this far, the entry looks credible. It would be possible to check the
 233:				; allocation list, but there seems little value in doing this given the context.
 234: 1015+16	00DA' 2A0500  	                ld hl, (file_count)
 235: 1031+6	00DD' 23      	                inc hl
