 363: 1858+4	0184' 7C      	                ld a, h
 364: 1862+4	0185' BA      	                cp d
 365: 1866+7+5	0186' 2004    	                jr nz, ge_load_reqd
 366: 1873+4	0188' 7D      	                ld a, l
 367: 1877+4	0189' BB      	                cp e
