 342:				;
 343:				;
 344:				; Read a directory entry from the disk and return a pointer to it.
 345:				; Call with:
 346:				; HL - required directory entry number
 347:				; IX - pointer to Disk Parameter Block (DPB)
 348:				; Returns with:
 349:				; HL - points to start of entry
 350: 1765+11	0173' C5      	get_entry       push bc
 351: 1776+11	0174' D5      	                push de
 352: 1787+11	0175' E5      	                push hl                 ; Save entry number
 353:				; Divide by four to find the sector number.
 354: 1798+4	0176' A7      	                and a
 355: 1802+8	0177' CB1C    	                rr h
 356: 1810+8	0179' CB1D    	                rr l
 357: 1818+4	017B' A7      	                and a
 358: 1822+8	017C' CB1C    	                rr h
 359: 1830+8	017E' CB1D    	                rr l
 360:				; HL - CP/M (128-byte) sector number (offset into data area)
 361:				; Is this already in the buffer?
