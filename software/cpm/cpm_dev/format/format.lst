 400:				;
 401:				;
 402:				; Set track and sector numbers for subsequent read and / or write operations. DMA
 403:				; address is set to the default area (0x80).
 404:				; Call with:
 405:				; CDE - CP/M (128-byte) sector number (offset into data area)
 406:				; IX - pointer to Disk Parameter Block (DPB)
 407: 2111+11	01B2' C5      	set_sector      push bc
 408: 2122+11	01B3' E5      	                push hl
 409:				; Find track number. For this application, the track number is likely to be small
 410:				; (normally zero). Hence this crude algorithm is sufficient.
 411: 2133+19	01B4' DD6E0D  	                ld l, (ix + DPB_OFF)    ; Start after reserved tracks
 412: 2152+19	01B7' DD660E  	                ld h, (ix + DPB_OFF + 1)
 413: 2171+11	01BA' D5      	ss_track_loop   push de                 ; Save LS 16 bits of sector number
 414:				; Perform a trial subtraction to see if we have a complete track worth of sectors.
