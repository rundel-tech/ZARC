**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/mmc.i ****
   1:				; *******************************************
   2:				; * ZARC Monitor Memory Card Include File   *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 7/8/2020                  *
   5:				; *******************************************
   6:				;
   7:				;
   8:				; Note that ld80 only considers the first six characters of labels significant.
   9:				;
  10:				; The following conditionals are intended to allow the same include file to be
  11:				; used in the defining module and elsewhere as required. Some includes are used
  12:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  13:				; the extern and public statements are not desirable.
  14:				;
  15:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  16:     -	0001'         	                ifndef mmc          ; Inhibit for this module
  17:				; Functions
  18:				                extern mccold       ; Cold start initialisation
  19:				                extern mcinit       ; Initialise memory card
  20:				                extern mcprer       ; Print memory card error text
  21:				                extern mcrvrs       ; Raw read / verify sector
  22:				                extern mcrws        ; Raw write sector
  23:				; Variables
  24:				                extern mcstat       ; Card state (MC_STAT_xxx)
  25:				                extern mcstat       ; Card state (MMC_STAT_xxx)
  26:				                extern mcprc        ; Physical read sector counter
  27:				                extern mcpwc        ; Physical write sector counter
  28:				                extern mcuwsc       ; Unchanged sector writes skipped
  29:				;
  30:				                endif
  31:				            endif
  32:				;
  33:				;
  34:     -	0200'         	MMC_SECTOR_SIZE             equ 512     ; Sector size
  35:     -	0009'         	MMC_LOG2_SEC_SIZE           equ 9       ; Save number of shifts for above
  36:     -	0040'         	MMC_CMD_START               equ 0x40    ; Command start bits (01b) shifted for
  37:				                                        ; command byte
  38:     -	0001'         	MMC_CMD_STOP                equ 0x01    ; Stop bit (in CRC byte)
  39:				;
  40:				;
  41:				; Card state (mcstat) states.
  42:     -	        	                ENUM_START
  43:     -	        	                ENUM MMC_STAT_IDLE      ; Not initialised
  44:     -	        	                ENUM MMC_STAT_INIT      ; Initialised (can do raw read / writes)
  45:				
  46:     -	        	                ENUM_END MC_STATES  ; Number of states
  47:				;
  48:				;
  49:				; Memory card command structure
  50:     -	        	                STRUCT
  51:     -	        	                STR_BYTE MMC_CMD    ; Command including start bits
  52:     -	        	                STR_BYTE MMC_ARG1   ; Arguments
  53:     -	        	                STR_BYTE MMC_ARG2   ; Arguments
  54:     -	        	                STR_BYTE MMC_ARG3   ; Arguments
  55:     -	        	                STR_BYTE MMC_ARG4   ; Arguments
  56:     -	        	                STR_BYTE MMC_CRC    ; CRC and stop bit
  57:     -	        	                STR_END MMC_SIZE
  58:				;
  59:				;
  60:				; SPI mode commands (CMDn from MMC-System-Spec-v3.31.pdf chapter 4.9).
  61:     -	0000'         	MMC_CMD_GO_IDLE_STATE       equ 0   ; Resets the memory card
  62:     -	0001'         	MMC_CMD_SEND_OP_COND        equ 1   ; Sends host capacity support information and init.
  63:     -	0009'         	MMC_CMD_SEND_CSD            equ 9   ; Read card specific data
  64:     -	000A'         	MMC_CMD_SEND_CID            equ 10  ; Read card identification
  65:     -	000D'         	MMC_CMD_SEND_STATUS         equ 13  ; Read card status register
  66:     -	0010'         	MMC_CMD_SET_BLOCKLEN        equ 16  ; Set block length (in bytes)
  67:     -	0011'         	MMC_CMD_READ_SINGLE_BLOCK   equ 17  ; Reads a block
  68:     -	0018'         	MMC_CMD_WRITE_BLOCK         equ 24  ; Writes a block
  69:     -	0037'         	MMC_CMD_APP_CMD             equ 55  ; Next command is an application specific command
  70:     -	003B'         	MMC_CMD_CRC_ON_OFF          equ 59  ; Turns the CRC option on or off
  71:				;
  72:				; The list describes all the application specific commands supported/reserved by the 
  73:				; memory card. All the following commands shall be preceded with APP_CMD (CMD55).
  74:     -	0029'         	MMC_ACMD_MC_SEND_OP_COND    equ 41  ; Sends host capacity support information and init
  75:				;
  76:				; R1 response bits
  77:     -	        	BITDEF MMC_R1_IDLE, 0           ; In idle state
  78:     -	        	BITDEF MMC_R1_ERA_RST, 1        ; Erase reset
  79:     -	        	BITDEF MMC_R1_ILL_CMD, 2        ; Illegal command
  80:     -	        	BITDEF MMC_R1_CMD_CRC_ERR, 3    ; Command CRC error
  81:     -	        	BITDEF MMC_R1_ERA_SEQ_ERR, 4    ; Erase sequence error
  82:     -	        	BITDEF MMC_R1_ADDR_ERR, 5       ; Address error
  83:     -	        	BITDEF MMC_R1_PAR_ERR, 6        ; Parameter error
  84:     -	        	BITDEF MMC_R1_START, 7          ; Zero identifies an R1 response
  85:				;
  86:				;
  87:     -	0006'         	MMC_CID_PNM_SIZE      equ 6   ; Product name length (bytes)
  88:				;
  89:				; Card IDentification (CID) register (128 bits)
  90:     -	        	                STRUCT
  91:     -	        	                STR_BYTE MMC_CID_MID    ; Manufacturer ID
  92:     -	        	                STR_WORD MMC_CID_OID    ; OEM/Application ID
  93:     -	        	                STR_BLOCK MMC_CID_PNM, MMC_CID_PNM_SIZE ; Product name
  94:     -	        	                STR_BYTE MMC_CID_PRV    ; Product revision
  95:     -	        	                STR_LONG MMC_CID_PSN    ; Product serial number
  96:     -	        	                STR_BYTE MMC_CID_MDT    ; Manufacturing date
  97:     -	        	                STR_BYTE MMC_CID_CRC    ; CRC7 checksum and "1"
  98:     -	        	                STR_END MMC_CID_SIZE
  99:				;
 100:				;
 101:				; Card-Specific Data (CSD) register (128 bits). It contains a number of bit fields
 102:				; that aren't necessarily byte aligned. In these cases, the entries simply identify
 103:				; the bit numbers contained.
 104:     -	        	                STRUCT
 105:     -	        	                STR_BYTE MMC_CSD_VERSION    ; (127-120) CSD version, spec version
 106:     -	        	                STR_BYTE MMC_CSD_TAAC       ; (119-112) data read access-time-1
 107:     -	        	                STR_BYTE MMC_CSD_NSAC       ; (111-104) data read access-time-2
 108:     -	        	                STR_BYTE MMC_CSD_TR_SPD     ; (103-96) max. data transfer rate
 109:     -	        	                STR_BYTE MMC_CSD_95_88      ; Card command classes (MS 8 bits)
 110:     -	        	                STR_BYTE MMC_CSD_87_80      ; CCC (LS bits) and max. read data length
 111:     -	        	                STR_BYTE MMC_CSD_79_72      ; Flags and C_SIZE bits 10 and 11
 112:     -	        	                STR_BYTE MMC_CSD_71_64      ; C_SIZE bits 2 to 9
 113:     -	        	                STR_BYTE MMC_CSD_63_56      ; C_SIZE bits 1 to 0 and some currents
 114:     -	        	                STR_BYTE MMC_CSD_55_48      ; Currents & C_SIZE_MULT (MS 2 bits)
 115:     -	        	                STR_BYTE MMC_CSD_47_40      ; C_SIZE_MULT (LS bit) and erase size (part)
 116:     -	        	                STR_BYTE MMC_CSD_39_32      ; Erase size (part) and WP group size
 117:     -	        	                STR_BYTE MMC_CSD_31_24      ; WP group enable, ECC and write parameters (part)
 118:     -	        	                STR_BYTE MMC_CSD_23_16      ; Write block lenth (part) and reserved
 119:     -	        	                STR_BYTE MMC_CSD_15_8       ; Flags
 120:     -	        	                STR_BYTE MMC_CSD_CRC        ; CRC7 checksum and "1"
 121:     -	        	                STR_END MMC_CSD_SIZE
 122:				
**** diags.z80 ****
  33:				                include "cache.i"       ; MMC sector cache
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cache.i ****
   1:				; ***********************************************
   2:				; * ZARC Monitor Memory Card Cache Include File *
   3:				; * Written by: Merlin Skinner                  *
   4:				; * Date Started: 23/11/2020                    *
   5:				; ***********************************************
   6:				;
   7:				; Constants and structures associated with the MMC memory card sector cache.
   8:				;
   9:				; "Dirty" in this case indicates sector data that is in the cache, but has not yet
  10:				; been written to the MMC.
  11:				;
  12:				;
  13:				; The following conditionals are intended to allow the same include file to be
  14:				; used in the defining module and elsewhere as required. Some includes are used
  15:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  16:				; the extern and public statements are not desirable.
  17:				;
  18:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  19:     -	0001'         	                ifndef cache        ; Inhibit for this module
  20:				; Functions
  21:				                extern cacold       ; Reset cache (cold start)
  22:				                extern cawarm       ; Initialise cache (warm start)
  23:				                extern carpt        ; Report status
  24:				                extern caflus       ; Flush cache
  25:				                extern cars         ; Read sector
  26:				                extern caws         ; Write sector
  27:				                extern cacrs        ; Read CP/M sector
  28:				                extern cacws        ; Write CP/M sector
  29:				; Variables
  30:				; Counters
  31:				                extern cntrs        ; Read MMC sector counter
  32:				                extern cntws        ; Write MMC sector counter
  33:				                extern cntcrs       ; Read CP/M sector counter
  34:				                extern cntcws       ; Write CP/M sector counter
  35:				                endif
  36:				            endif
  37:				;
  38:				;
  39:     -	0008'         	MCCA_PAGES          equ 8               ; RAM (16 KB) pages used for cache
  40:     -	0020'         	MCCA_BUFS_PER_PAGE  equ MMAP_PAGE_SIZE / MMC_SECTOR_SIZE
  41:     -	0100'         	MCCA_BUFFERS        equ MCCA_PAGES * MCCA_BUFS_PER_PAGE ; No. of sector buffers
  42:     -	0080'         	MCCA_DIRT_THRES     equ MCCA_BUFFERS / 2    ; Target no. of dirty buffers
  43:     -	0004'         	MMAP_CP3_BANKS      equ 4               ; Number of CP/M 3 banks
  44:				;
  45:				;
  46:				; Sector cache structure. This contains the data associated with a single cached
  47:				; sector.
  48:     -	        	                STRUCT
  49:     -	        	                STR_BYTE MCCAS_STATUS       ; Status byte
  50:     -	        	                STR_24BIT MCCAS_SECTOR      ; 24-bit sector number
  51:     -	        	                STR_WORD MCCAS_CSUM         ; Checksum of data
  52:     -	        	                STR_WORD MCCAS_ADDR         ; Address of data *1
  53:     -	        	                STR_BYTE MCCAS_PAGE         ; Page containing data
  54:     -	        	                STR_END MCCAS_SIZE
  55:				;
  56:				; *1 Address is in the range 0x8000 to 0xbfff to allow direct use when the page
  57:				; in MCCAS_PAGE is mapped to bank 2.
  58:				;
  59:				;
  60:				; MCCAS_STATUS byte is defined as follows:
  61:				; Bits 0 to 3 - set if the corresponding CP/M sector in this MMC sector is dirty.
  62:     -	        	BITDEF MCCAS_STAT_CPM0, 0       ; CP/M sector 0 (0 to 0x7f)
  63:     -	        	BITDEF MCCAS_STAT_CPM1, 1       ; CP/M sector 1 (0x80 to 0x0ff)
  64:     -	        	BITDEF MCCAS_STAT_CPM2, 2       ; CP/M sector 2 (0x100 to 0x17f)
  65:     -	        	BITDEF MCCAS_STAT_CPM3, 3       ; CP/M sector 3 (0x180 to 0x1ff)
  66:     -	        	BITDEF MCCAS_STAT_VALID, 4      ; Buffer contains valid data
  67:				;
  68:     -	000F'         	MCCAS_STAT_DIRT_MASK    equ MCCAS_STAT_CPM0_MASK + MCCAS_STAT_CPM1_MASK + MCCAS_STAT_CPM2_MASK + MCCAS_STAT_CPM3_MASK
  69:				
**** diags.z80 ****
  34:				;
  35:				;
  36:				; *************
  37:				; * Externals *
  38:				; *************
  39:				;
  40:				                public cpuspd   ; Measure approximate CPU clock speed
  41:				                public memtst   ; Test an area of memory with a range of patterns
  42:				                public memtal   ; Test entire memory
  43:				;
  44:				;
  45:				; *************
  46:				; * Constants *
  47:				; *************
  48:				;
  49:				; None
  50:				;
  51:				;
  52:				; *************
  53:				; * Main Code *
  54:				; *************
  55:				;
  56:				                cseg                ; Code segment
  57:				;
  58:				; Measure approximate CPU clock speed. This is intended by use during initialisation
  59:				; before interrupts are enabled. The tick interrupt mechanism is used as a timing
  60:				; reference (polling the relevant "pending" bit).
  61:				; Returns with:
  62:				; BC - CPU clock in KHz.
  63:    0+11	0000' D5      	cpuspd          push de
  64:   11+11	0001' E5      	                push hl
  65:   22+10	0002' 010000  	                ld bc, 0            ; Reset counter for later
  66:   32+7	0005' 2610    	                ld h, INT_TICK_MASK ; Cache value for later
  67:   39+10	0007' 110000  	                ld de, 0            ; Set timeout
  68:				; Synchronise to the tick interrupt
  69:   49+4	000A' 7C      	                ld a, h
  70:   53+11	000B' D30A    	                out (IOA_INT_PEND), a   ; Clear any pending tick interrupt
  71:     -	0000'         	                sett 0              ; Reset assembler cycle count
  72:				; Wait loop
  73:    0+11	000D' DB0A    	cspd_waittick   in IOA_INT_PEND     ; [11]
  74:   11+4	000F' A4      	                and h               ; [4]
  75:   15+7+5	0010' 2009    	                jr nz, cspd_tick    ; [7 - not taken] Jump if tick interrupt found                
  76:   22+6	0012' 13      	                inc de              ; [6]
  77:   28+4	0013' 7A      	                ld a, d             ; [4]
  78:   32+4	0014' B3      	                or e                ; [4]
  79:   36+10	0015' C20D00  	                jp nz, cspd_waittick    ; [10]
  80:				; Timed out after 0.41 s (8 MHz) or 105 s (31.25 Khz)
  81:   46+17	0018' CD0000  	                call panic          ; System panic if no tick found
  82:				;
  83:   63+4	001B' 7C      	cspd_tick       ld a, h
  84:   67+11	001C' D30A    	                out (IOA_INT_PEND), a   ; Clear pending tick interrupt
  85:     -	0000'         	                sett 0              ; Reset assembler cycle count
  86:				; The ideal period of the timing loop is 50 cycles for easy conversion  of the resulting
  87:				; count into KHz. The instructions below total 46, but allowing for I/O wait cycles then
  88:				; we are close.
  89:    0+11	001E' DB0A    	cspd_timloop    in IOA_INT_PEND     ; [11]
  90:   11+4	0020' A4      	                and h               ; [4]
  91:   15+7+5	0021' 2009    	                jr nz, cspd_tick1   ; [7 - not taken] Jump if tick interrupt found
  92:   22+6	0023' 03      	                inc bc              ; [6]
  93:   28+4	0024' 78      	                ld a, b             ; [4]
  94:   32+4	0025' B1      	                or c                ; [4]
  95:   36+10	0026' C21E00  	                jp nz, cspd_timloop ; [10]
  96:				; Timed out after 0.41 s (8 MHz) or 105 s (31.25 Khz)
  97:   46+17	0029' CD0000  	                call panic          ; System panic if no tick found
  98:				; Tick interrupt found, so we can stop counting.
  99:				; BC - count
 100:				; We need to divide by approximately 2.141.
 101:   63+10	002C' 118D77  	cspd_tick1      ld de, 30605        ; Multiplier
 102:   73+17	002F' CD0000  	                call mamwwu         ; 16-bit * 16-bit unsigned multiply
 103:				; DEHL - result
 104:				; Now divide by 65536.
 105:   90+4	0032' 42      	                ld b, d             ; Copy MSW to BC
 106:   94+4	0033' 4B      	                ld c, e
 107:   98+10	0034' E1      	                pop hl
 108:  108+10	0035' D1      	                pop de
 109:  118+10	0036' C9      	                ret
 110:				;
 111:				;
 112:				; Test an area of memory with a range of patterns. This tests memory as it is
 113:				; currently mapped.
 114:				; Call with:
 115:				; HL - start address
 116:				; BC - length
 117:				; Returns with:
 118:				; A - 0 if all went well.
 119:  128+11	0037' D5      	memtst          push de
 120:  139+4	0038' AF      	                xor a
 121:  143+13	0039' 320000  	                ld (mt_err_flag), a ; Reset error flag
 122:  156+11	003C' E5      	                push hl
 123:  167+11	003D' C5      	                push bc
 124:  178+17	003E' CDCA00  	                call mt_test_patt   ; All zeros
 125:  195+10	0041' C1      	                pop bc
 126:  205+10	0042' E1      	                pop hl
 127:  215+11	0043' E5      	                push hl
 128:  226+11	0044' C5      	                push bc
 129:  237+7	0045' 3EFF    	                ld a, 0xff
 130:  244+17	0047' CDCA00  	                call mt_test_patt   ; All ones
 131:  261+10	004A' C1      	                pop bc
 132:  271+10	004B' E1      	                pop hl
 133:				; Walking ones
 134:  281+7	004C' 1601    	                ld d, 1             ; Initial pattern
 135:  288+4	004E' 7A      	mt_walk1_lp     ld a, d
 136:  292+11	004F' E5      	                push hl
 137:  303+11	0050' C5      	                push bc
 138:  314+17	0051' CDCA00  	                call mt_test_patt   ; All ones
 139:  331+10	0054' C1      	                pop bc
 140:  341+10	0055' E1      	                pop hl
 141:  351+8	0056' CB02    	                rlc d
 142:				; Keep going unless the bit has fallen off
 143:  359+7+5	0058' 30F4    	                jr nc, mt_walk1_lp
 144:				; Walking zeroes
 145:  366+7	005A' 16FE    	                ld d, 0xfe          ; Initial pattern
 146:  373+4	005C' 7A      	mt_walk0_lp     ld a, d
 147:  377+11	005D' E5      	                push hl
 148:  388+11	005E' C5      	                push bc
 149:  399+17	005F' CDCA00  	                call mt_test_patt   ; All ones
 150:  416+10	0062' C1      	                pop bc
 151:  426+10	0063' E1      	                pop hl
 152:  436+8	0064' CB02    	                rlc d
 153:				; Keep going unless the bit has fallen off
 154:  444+7+5	0066' 38F4    	                jr c, mt_walk0_lp
 155:				; Addressing test. Write a repeating pattern of three bytes (1, 2 and 3)
 156:				; and verify it. No multiple of three is a power of two, so all address
 157:				; bits are tested.
 158:  451+7	0068' 1E01    	                ld e, 1             ; Initial pattern
 159:  458+11	006A' E5      	                push hl             ; Save address
 160:  469+11	006B' C5      	                push bc             ; Save length
 161:  480+10	006C' 218401  	                ld hl, mt_addr_msg
 162:  490+11	006F' CF      	                CON_WR_MSG   ; Print "Addressing test" message
 163:				; Restore address and length but leave a copy on the stack.
 164:  501+10	0070' C1      	                pop bc
 165:  511+10	0071' E1      	                pop hl
 166:  521+11	0072' E5      	                push hl
 167:  532+11	0073' C5      	                push bc
 168:				; Write the pattern.
 169:  543+4	0074' 78      	mt_wra_lp       ld a, b
 170:  547+4	0075' B1      	                or c
 171:  551+7+5	0076' 280D    	                jr z, mt_wra_dn     ; Exit if finished
 172:  558+7	0078' 73      	                ld (hl), e
 173:				; Adjust pattern
 174:  565+4	0079' 1C      	                inc e
 175:  569+7	007A' 3E03    	                ld a, 3
 176:  576+4	007C' BB      	                cp e
 177:  580+7+5	007D' 3002    	                jr nc, mt_wra_pok
 178:  587+7	007F' 1E01    	                ld e, 1
 179:  594+6	0081' 23      	mt_wra_pok      inc hl
 180:  600+6	0082' 0B      	                dec bc
 181:  606+12	0083' 18EF    	                jr mt_wra_lp
 182:				; Restore address and length.
 183:  618+10	0085' C1      	mt_wra_dn       pop bc
 184:  628+10	0086' E1      	                pop hl
 185:				; Verify the pattern.
 186:  638+7	0087' 1E01    	                ld e, 1             ; Initial pattern
 187:  645+4	0089' 78      	mt_vea_lp       ld a, b
 188:  649+4	008A' B1      	                or c
 189:  653+7+5	008B' 282C    	                jr z, mt_done       ; Exit if finished
 190:  660+7	008D' 7E      	                ld a, (hl)
 191:  667+4	008E' BB      	                cp e
 192:  671+7+5	008F' 281C    	                jr z, mt_vea_byte_dn ; Jump if OK
 193:				; Mismatch
 194:  678+11	0091' F5      	                push af             ; Save data read
 195:  689+11	0092' E5      	                push hl             ; Save address
 196:  700+10	0093' 219F01  	                ld hl, mt_err1_msg
 197:  710+11	0096' CF      	                CON_WR_MSG         ; Print "Error at " message
 198:  721+10	0097' E1      	                pop hl
 199:  731+11	0098' E5      	                push hl
 200:  742+17	0099' CD0000  	                call cwphwd         ; Print address in hex
 201:  759+10	009C' 21A901  	                ld hl, mt_err2_msg
 202:  769+11	009F' CF      	                CON_WR_MSG         ; Print ", read " message
 203:  780+10	00A0' E1      	                pop hl
 204:  790+10	00A1' F1      	                pop af
 205:  800+17	00A2' CD0000  	                call cwphby         ; Print data read in hex
 206:  817+17	00A5' CD0000  	                call cwnwln         ; Write new line characters to console
 207:				; Set error flag
 208:  834+7	00A8' 3E01    	                ld a, 1
 209:  841+13	00AA' 320000  	                ld (mt_err_flag), a
 210:				; Adjust pattern
 211:  854+4	00AD' 1C      	mt_vea_byte_dn  inc e
 212:  858+7	00AE' 3E03    	                ld a, 3
 213:  865+4	00B0' BB      	                cp e
 214:  869+7+5	00B1' 3002    	                jr nc, mt_vea_pok
 215:  876+7	00B3' 1E01    	                ld e, 1
 216:  883+6	00B5' 23      	mt_vea_pok      inc hl
 217:  889+6	00B6' 0B      	                dec bc
 218:  895+12	00B7' 18D0    	                jr mt_vea_lp
 219:				;
 220:  907+10	00B9' D1      	mt_done         pop de
 221:				                
 222:				; Report pass / fail state.
 223:  917+13	00BA' 3A0000  	mt_test_dn      ld a, (mt_err_flag) ; Return with error flag in A
 224:  930+4	00BD' A7      	                and a
 225:  934+7+5	00BE' 2005    	                jr nz, mt_errs
 226:				; No errors
 227:  941+10	00C0' 21CF01  	                ld hl, mt_pass_msg
 228:  951+11	00C3' CF      	                CON_WR_MSG         ; Print "Passed" message
 229:  962+10	00C4' C9      	                ret
 230:				; One or more errors occurred.
 231:  972+10	00C5' 21D801  	mt_errs         ld hl, mt_fail_msg
 232:  982+11	00C8' CF      	                CON_WR_MSG         ; Print "Failed" message
 233:  993+10	00C9' C9      	                ret 
 234:				;
 235:				; Test an area of memory with the pattern specified. This is used by memtst.
 236:				; Call with:
 237:				; A - pattern
 238:				; HL - start address
 239:				; BC - length
 240:				; mt_err_flag is set to 1 if an error is encountered.
 241:				; Note: E is not preserved.
 242: 1003+11	00CA' E5      	mt_test_patt    push hl             ; Save address
 243: 1014+11	00CB' C5      	                push bc             ; Save length
 244: 1025+4	00CC' 5F      	                ld e, a             ; Save pattern
 245: 1029+10	00CD' 219601  	                ld hl, mt_patt_msg
 246: 1039+11	00D0' CF      	                CON_WR_MSG         ; Print "Pattern " message
 247: 1050+4	00D1' 7B      	                ld a, e
 248: 1054+17	00D2' CD0000  	                call cwphby         ; Print in hex
 249: 1071+17	00D5' CD0000  	                call cwnwln         ; Write new line characters to console
 250:				; Restore address and length but leave a copy on the stack.
 251: 1088+10	00D8' C1      	                pop bc
 252: 1098+10	00D9' E1      	                pop hl
 253: 1108+11	00DA' E5      	                push hl
 254: 1119+11	00DB' C5      	                push bc
 255:				; Write the pattern.
 256: 1130+4	00DC' 78      	mt_wr_patt_lp   ld a, b
 257: 1134+4	00DD' B1      	                or c
 258: 1138+7+5	00DE' 2805    	                jr z, mt_wr_patt_dn ; Exit if finished
 259: 1145+7	00E0' 73      	                ld (hl), e
 260: 1152+6	00E1' 23      	                inc hl
 261: 1158+6	00E2' 0B      	                dec bc
 262: 1164+12	00E3' 18F7    	                jr mt_wr_patt_lp
 263:				; Now check it.
 264:				; Restore address and length.
 265: 1176+10	00E5' C1      	mt_wr_patt_dn   pop bc
 266: 1186+10	00E6' E1      	                pop hl
 267:				; Verify the pattern.
 268: 1196+4	00E7' 78      	mt_ve_patt_lp   ld a, b
 269: 1200+4	00E8' B1      	                or c
 270: 1204+5+6	00E9' C8      	                ret z               ; Exit if finished
 271: 1209+7	00EA' 7E      	                ld a, (hl)
 272: 1216+4	00EB' BB      	                cp e
 273: 1220+7+5	00EC' 281C    	                jr z, mt_ve_byte_dn ; Jump if OK
 274:				; Mismatch
 275: 1227+11	00EE' F5      	                push af             ; Save data read
 276: 1238+11	00EF' E5      	                push hl             ; Save address
 277: 1249+10	00F0' 219F01  	                ld hl, mt_err1_msg
