 306: 1472+7	0118' FE3F    	                cp MMAP_MON_B0_PAGE
 307: 1479+7+5	011A' 2826    	                jr z, mta_next_page ; Skip pages used by monitor
 308: 1486+7	011C' FE3E    	                cp MMAP_MON_B1_PAGE
 309: 1493+7+5	011E' 2822    	                jr z, mta_next_page
 310:				; Print the current page
 311: 1500+10	0120' 21BB01  	                ld hl, mta_page_msg
 312: 1510+11	0123' CF      	                CON_WR_MSG         ; Print "Page" message
 313: 1521+4	0124' 79      	                ld a, c
