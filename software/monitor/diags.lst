 327: 1644+13	013C' 320000  	                ld (mt_err_flag), a ; Set error flag on error
 328: 1657+10	013F' E1      	mta_pageok      pop hl
 329: 1667+10	0140' C1      	                pop bc
 330: 1677+7	0141' 71      	                ld (hl), c          ; Write page number into first byte
