 315: 1542+17	0128' CD0000  	                call cwnwln         ; Write new line characters to console
 316: 1559+4	012B' 79      	                ld a, c
 317:				; Set bank 3 (0xc000 to 0xffff) to the required page.
 318:				; Super and prot are not set so we can write, and there is no need for I/O.
 319: 1563+11	012C' D307    	                out (IOA_MMAP_3), a
 320: 1574+11	012E' C5      	                push bc             ; Save page
 321: 1585+10	012F' 2100C0  	                ld hl, MMAP_BANK3_START ; Start address
 322: 1595+11	0132' E5      	                push hl             ; Save address
 323: 1606+10	0133' 010040  	                ld bc, MMAP_PAGE_SIZE   ; Length
 324: 1616+17	0136' CD3700  	                call memtst
