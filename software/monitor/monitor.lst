1560:     -	0056"         	xpt_id          defs 1              ; Exception ID
1561:     -	0057"         	mcspd           defs 2              ; Approximate CPU speed in KHz
1562:     -	0059"         	trace_mode      defs 1              ; Trace mode (TRM_xxx)
1563:     -	005A"         	trace_addr      defs 2              ; Trace to address
1564:     -	005C"         	dr_inst_add_buf defs 2 * DIS_PRE_INSTRS ; Instruction start address buffer
1565:     -	0060"         	rst_flag        defs 1              ; Reset flag
1566:     -	0061"         	run_ctrl        defs 1              ; Pre-calculated CONTROL register value
