**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/heap.i ****
   1:				; *******************************************
   2:				; * ZARC Monitor Heap Incude File           *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 7/8/2020                  *
   5:				; *******************************************
   6:				;
   7:				;
   8:				; Note that ld80 only considers the first six characters of labels significant.
   9:				;
  10:				; The following conditionals are intended to allow the same include file to be
  11:				; used in the defining module and elsewhere as required. Some includes are used
  12:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  13:				; the extern and public statements are not desirable.
  14:				;
  15:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  16:     -	0001'         	                ifndef heap         ; Inhibit for this module
  17:				;
  18:				                extern hinit        ; Initialise
  19:				                extern halloc       ; Allocate memory
  20:				;
  21:				                endif
  22:				            endif
  23:				
**** monitor.z80 ****
  90:				                include "cache.i"       ; MMC sector cache
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cache.i ****
   1:				; ***********************************************
   2:				; * ZARC Monitor Memory Card Cache Include File *
   3:				; * Written by: Merlin Skinner                  *
   4:				; * Date Started: 23/11/2020                    *
   5:				; ***********************************************
   6:				;
   7:				; Constants and structures associated with the MMC memory card sector cache.
   8:				;
   9:				; "Dirty" in this case indicates sector data that is in the cache, but has not yet
  10:				; been written to the MMC.
  11:				;
  12:				;
  13:				; The following conditionals are intended to allow the same include file to be
  14:				; used in the defining module and elsewhere as required. Some includes are used
  15:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  16:				; the extern and public statements are not desirable.
  17:				;
  18:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  19:     -	0001'         	                ifndef cache        ; Inhibit for this module
  20:				; Functions
  21:				                extern cacold       ; Reset cache (cold start)
  22:				                extern cawarm       ; Initialise cache (warm start)
  23:				                extern carpt        ; Report status
  24:				                extern caflus       ; Flush cache
  25:				                extern cars         ; Read sector
  26:				                extern caws         ; Write sector
  27:				                extern cacrs        ; Read CP/M sector
  28:				                extern cacws        ; Write CP/M sector
  29:				; Variables
  30:				; Counters
  31:				                extern cntrs        ; Read MMC sector counter
  32:				                extern cntws        ; Write MMC sector counter
  33:				                extern cntcrs       ; Read CP/M sector counter
  34:				                extern cntcws       ; Write CP/M sector counter
  35:				                endif
  36:				            endif
  37:				;
  38:				;
  39:     -	0008'         	MCCA_PAGES          equ 8               ; RAM (16 KB) pages used for cache
  40:     -	0020'         	MCCA_BUFS_PER_PAGE  equ MMAP_PAGE_SIZE / MMC_SECTOR_SIZE
  41:     -	0100'         	MCCA_BUFFERS        equ MCCA_PAGES * MCCA_BUFS_PER_PAGE ; No. of sector buffers
  42:     -	0080'         	MCCA_DIRT_THRES     equ MCCA_BUFFERS / 2    ; Target no. of dirty buffers
  43:     -	0004'         	MMAP_CP3_BANKS      equ 4               ; Number of CP/M 3 banks
  44:				;
  45:				;
  46:				; Sector cache structure. This contains the data associated with a single cached
  47:				; sector.
  48:     -	        	                STRUCT
  49:     -	        	                STR_BYTE MCCAS_STATUS       ; Status byte
  50:     -	        	                STR_24BIT MCCAS_SECTOR      ; 24-bit sector number
  51:     -	        	                STR_WORD MCCAS_CSUM         ; Checksum of data
  52:     -	        	                STR_WORD MCCAS_ADDR         ; Address of data *1
  53:     -	        	                STR_BYTE MCCAS_PAGE         ; Page containing data
  54:     -	        	                STR_END MCCAS_SIZE
  55:				;
  56:				; *1 Address is in the range 0x8000 to 0xbfff to allow direct use when the page
  57:				; in MCCAS_PAGE is mapped to bank 2.
  58:				;
  59:				;
  60:				; MCCAS_STATUS byte is defined as follows:
  61:				; Bits 0 to 3 - set if the corresponding CP/M sector in this MMC sector is dirty.
  62:     -	        	BITDEF MCCAS_STAT_CPM0, 0       ; CP/M sector 0 (0 to 0x7f)
  63:     -	        	BITDEF MCCAS_STAT_CPM1, 1       ; CP/M sector 1 (0x80 to 0x0ff)
  64:     -	        	BITDEF MCCAS_STAT_CPM2, 2       ; CP/M sector 2 (0x100 to 0x17f)
  65:     -	        	BITDEF MCCAS_STAT_CPM3, 3       ; CP/M sector 3 (0x180 to 0x1ff)
  66:     -	        	BITDEF MCCAS_STAT_VALID, 4      ; Buffer contains valid data
  67:				;
  68:     -	000F'         	MCCAS_STAT_DIRT_MASK    equ MCCAS_STAT_CPM0_MASK + MCCAS_STAT_CPM1_MASK + MCCAS_STAT_CPM2_MASK + MCCAS_STAT_CPM3_MASK
  69:				
**** monitor.z80 ****
  91:				                include "memory.i"      ; Memory page allocation
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/memory.i ****
   1:				; *******************************************
   2:				; * ZARC Memory Include File                *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 24/11/2021                *
   5:				; *******************************************
   6:				;
   7:				;
   8:				; Note that ld80 only considers the first six characters of labels significant.
   9:				;
  10:				; The following conditionals are intended to allow the same include file to be
  11:				; used in the defining module and elsewhere as required. Some includes are used
  12:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  13:				; the extern and public statements are not desirable.
  14:				;
  15:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  16:     -	0001'         	                ifndef memory       ; Inhibit for this module
  17:				;
  18:				                extern mpinit       ; Initialise
  19:				                extern mprpt        ; Report status to console
  20:				                extern mpall        ; Allocate new page
  21:				                extern mpfree       ; Free allocated page
  22:				                extern mpstat       ; Allocation status
  23:				                extern mppnam       ; Print entry name
  24:				;
  25:				                endif
  26:				            endif
  27:				;
  28:				; Physical memory constants are found in zarc.i
  29:				;
  30:     -	0004'         	MPA_NAME_LEN        equ 4               ; Page owner name length (bytes)
  31:				;
  32:				; Memory map
  33:     -	4000'         	MMAP_PAGE_SIZE      equ 0x4000          ; Memory mapping bank / page size
  34:     -	0004'         	MMAP_BANKS          equ 4               ; Number of 16 kB banks
  35:     -	0040'         	MMAP_PAGES          equ 0x40            ; Number of 16 kB RAM pages
  36:     -	0000'         	MMAP_BANK0_START    equ 0x0000
  37:     -	3FFF'         	MMAP_BANK0_END      equ 0x3fff
  38:     -	4000'         	MMAP_BANK1_START    equ 0x4000
  39:     -	7FFF'         	MMAP_BANK1_END      equ 0x7fff
  40:     -	8000'         	MMAP_BANK2_START    equ 0x8000
  41:     -	BFFF'         	MMAP_BANK2_END      equ 0xbfff
  42:     -	C000'         	MMAP_BANK3_START    equ 0xc000
  43:     -	FFFF'         	MMAP_BANK3_END      equ 0xffff
  44:				;
  45:				;
  46:				;
  47:				; ****************
  48:				; * Memory Usage *
  49:				; ****************
  50:				;
  51:				;
  52:				; Memory banks setup.
  53:				; 0 (0000 - 3FFF): 3f read only, supervisor - monitor program
  54:				; 1 (4000 - 7FFF): 3e writeable - monitor variables, stacks, buffers etc.
  55:				; 2 (8000 - BFFF): (not used)
  56:				; 3 (C000 - FFFF): (mapped as required)
  57:				;
  58:     -	003F'         	MMAP_MON_B0_PAGE    equ 0x3f        ; Page for bank 0
  59:     -	003E'         	MMAP_MON_B1_PAGE    equ 0x3e        ; Page for bank 1
  60:				;
  61:     -	0040'         	STACKS_SIZE     equ 64              ; Space allocated to normal stacks
  62:				;
  63:     -	7FFF'         	HEAP_TOP        equ MMAP_BANK1_END  ; Top (end) of heap space.
  64:				
**** monitor.z80 ****
  92:				;
  93:				;
  94:				;
  95:				; *************
  96:				; * Externals *
  97:				; *************
  98:				;
  99:				; Routines
 100:				                public panic            ; System error exception
 101:				                public rusby            ; Read byte from user space
 102:				                public ruswd            ; Read 16-bit word from user space
 103:				                public wusby            ; Write byte to user space
 104:				                public wuswd            ; Write 16-bit word to user space
 105:				                extern prpnam           ; Print memory page name
 106:				                public mcrun            ; Switch context to user code
 107:				                public mdisrg           ; Display registers
 108:				;
 109:				; Variables
 110:				                public mscnt            ; Monitor start count
 111:				                public mcspd            ; Approximate CPU speed in KHz
 112:				                public mstate           ; Machine state structure
 113:				                public warm1            ; Warm start marker 1
 114:				                extern warm2            ; Warm start marker 2
 115:				;
 116:				;
 117:				; *************
 118:				; * Constants *
 119:				; *************
 120:				;
 121:     -	0100'         	CMD_HIST_SIZE   equ 256                 ; Command history size
 122:     -	0050'         	CMD_BUF_SIZE    equ 80                  ; Command buffer length
 123:     -	0055'         	WARM_MAGIC_1    equ 0x55                ; Warm start magic numbers
 124:     -	00AA'         	WARM_MAGIC_2    equ 0xaa
 125:     -	0002'         	DIS_PRE_INSTRS  equ 2                   ; Number of instructions to show before PC
 126:     -	0002'         	DIS_POST_INSTRS equ 2                   ; Number of instructions to show after PC
 127:				;
 128:				; Exception types.
 129:     -	        	                ENUM_START
 130:     -	        	                ENUM XPTT_MON_ENT
 131:     -	        	                ENUM XPTT_RST08
 132:     -	        	                ENUM XPTT_RST10
 133:     -	        	                ENUM XPTT_RST18
 134:     -	        	                ENUM XPTT_RST20
 135:     -	        	                ENUM XPTT_RST28
 136:     -	        	                ENUM XPTT_RST30
 137:     -	        	                ENUM XPTT_RST38
 138:     -	        	                ENUM XPTT_NMI
 139:     -	        	                ENUM XPTT_PANIC
 140:     -	        	                ENUM_END XPTT_CNT       ; Number of types
 141:				;
 142:				;
 143:				;
 144:				; *************
 145:				; * Main Code *
 146:				; *************
 147:				;
 148:				                cseg                    ; Code segment
 149:				;
 150:				; Linker -P option sets start address (0x0000). Do not attempt to write to RAM
 151:				; until the memory mapping has been set up.
 152:    0+4	0000' F3      	reset           di
 153:    4+7	0001' 0EFF    	                ld c, 0xff
 154:   11+10	0003' C3FC00  	                jp init
 155:				;
 156:				; Some vectors are used as aliases for commonly-used functions in the monitor.
 157:				; See macros.i for definitions.
 158:				; RST 08 handler.
 159:     -	0006'         	                defs 2                  ; Align following vector
 160:   21+10	0008' C30000  	                jp conwms               ; Print null-terminated string to the console
 161:				;
 162:				; RST 10 handler.
 163:     -	000B'         	                defs 5                  ; Align following vector
 164:   31+10	0010' C30000  	                jp conwch               ; Write character to the console
 165:				;
 166:				; RST 18 handler.
 167:     -	0013'         	                defs 5                  ; Align following vector
 168:   41+10	0018' C3F403  	                jp default_rst18
 169:				;
 170:				; RST 20 handler.
 171:     -	001B'         	                defs 5                  ; Align following vector
 172:   51+10	0020' C30504  	                jp default_rst20
 173:				;
 174:				; RST 28 handler.
 175:     -	0023'         	                defs 5                  ; Align following vector
 176:   61+10	0028' C31504  	                jp default_rst28
 177:				;
 178:				; RST 30 handler.
 179:     -	002B'         	                defs 5                  ; Align following vector
 180:   71+10	0030' C32604  	                jp default_rst30
 181:				;
 182:				; RST 38 handler.
 183:     -	0033'         	                defs 5                  ; Align following vector
 184:   81+10	0038' C33704  	                jp default_rst38
 185:				;
 186:				; NMI service routine.
 187:     -	003B'         	                defs 0x2b               ; Align following vector
 188:   91+10	0066' C35904  	                jp default_nmi
 189:				;
 190:				; Functions made externally available have fixed entry points in the same manner
 191:				; CP/M uses. This allows changes to the monitor without having to recompile
 192:				; other modules.
 193:				; The jump vector table begins at NMI vector plus space for a jump instruction.
 194:				; Entries here must match the jump table in monitor.i.
 195:     -	0001'         	                assert ($ - reset) = (Z80_NMI_VEC + 3)  ; Verify start
 196:				; From monitor.z80
 197:  101+10	0069' C3C303  	                jp mon_entry    ; Normal monitor entry
 198:  111+10	006C' C34804  	                jp panic        ; System error monitor entry
 199:				; From io.z80
 200:  121+10	006F' C30000  	                jp conwch       ; Write character to the console
 201:  131+10	0072' C30000  	                jp conrch       ; Read character from the console
 202:  141+10	0075' C30000  	                jp consta       ; Fetch console port status
 203:  151+10	0078' C30000  	                jp s1wch        ; Write character to serial port 1
 204:  161+10	007B' C30000  	                jp s1rch        ; Read character from serial port 1
 205:  171+10	007E' C30000  	                jp s1sta        ; Fetch serial port 1 status
 206:  181+10	0081' C30000  	                jp s2wch        ; Write character to serial port 2
 207:  191+10	0084' C30000  	                jp s2rch        ; Read character from serial port 2
 208:  201+10	0087' C30000  	                jp s2sta        ; Fetch serial port 2 status
 209:				; From utility.z80
 210:  211+10	008A' C30000  	                jp cwnwln       ; Write new line characters to console
 211:  221+10	008D' C30000  	                jp conwms       ; Print null-terminated string to the console
 212:  231+10	0090' C30000  	                jp conwmn       ; Print message <n> in a list
 213:  241+10	0093' C30000  	                jp skpspc       ; Step hl past spaces
 214:  251+10	0096' C30000  	                jp toupca       ; Convert character in A to upper case
 215:  261+10	0099' C30000  	                jp toloca       ; Convert character in A to lower case
 216:  271+10	009C' C30000  	                jp cwvich       ; Print only visible 7-bit characters
 217:  281+10	009F' C30000  	                jp cwpspc       ; Print a space
 218:  291+10	00A2' C30000  	                jp mtwdli       ; Match word in a string against list of options
 219:  301+10	00A5' C30000  	                jp cwphnb       ; Print least-significant nibble in A in hexadecimal
 220:  311+10	00A8' C30000  	                jp cwphby       ; Print A in hexadecimal
 221:  321+10	00AB' C30000  	                jp cwphwd       ; Print HL in hexadecimal
 222:  331+10	00AE' C30000  	                jp cwpdby       ; Print A in decimal. Leading zeros are suppressed.
