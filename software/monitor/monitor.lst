   1:				; *******************************************************
   2:				; * Monitor for ZARC Z80 Computer                       *
   3:				; * (Serial boot version).                              *
   4:				; * Version: V1.1                                       *
   5:				; * Merlin Skinner, 14/5/2020                           *
   6:				; *******************************************************
   7:				;
   8:				;
   9:				; V1.0, 14/5/2020 - initial version.
  10:				; V1.1, 9/12/2022 - added CP/M 3 support
  11:				;
  12:				;
  13:				; This code will be loaded from the console serial port by the stage 1 bootloader.
  14:				; This is entered manually from the front panel:
  15:				;
  16:				; 3FE0                          .ORG   0x3fe0   ; Use top of page
  17:				; 3FE0   3E 7F                  LD   a,0x7f     ; Page 0x3f, SUPER=1 and PROT=0
  18:				; 3FE2   D3 04                  OUT   0x04,a    ; Page and prot. 0x0000-0x3fff
  19:				; 3FE4   3E 02                  LD   a,0x02
  20:				; 3FE6   D3 02                  OUT   0x02,a    ; Enable memory mapping
  21:				; 3FE8   0E 11                  LD   c,0x11     ; Select console input port
  22:				; 3FEA   21 00 00               LD   hl,0x0000  ; Start address 
  23:				; 3FED                LOOP:     
  24:				; 3FED   ED A2                  INI
  25:				; 3FEF   18 FC                  JR   loop       ; Load data until reset
  26:				;
  27:				; The above was assembled with the online assembler at:
  28:				; https://www.asm80.com/onepage/asmz80.html
  29:				;
  30:				; This loads raw binary data from the serial port into memory starting at location
  31:				; zero. Press reset to stop the loader and run the newly downloaded code.
  32:				;
  33:				;
  34:				; Memory Map (Monitor Mode)
  35:				; 
  36:				; 0 (0000 - 3FFF): 3f read only, supervisor - monitor program
  37:				; 1 (4000 - 7FFF): 3e writable - monitor variables, stacks, buffers etc.
  38:				; 2 (8000 - BFFF): set by the monitor as required
  39:				; 3 (C000 - FFFF): (mapped as required)
  40:				;
  41:				; This is the default map used by the monitor, and is selected when the monitor is
  42:				; active either for user commands or when its support routines are called. Pages
  43:				; are mapped into banks 2 and 3 as required to support this. Page 0x3f is
  44:				; selected in hardware when memory mapping is not active, so on reset the monitor
  45:				; (page 0x3f at address 0) is entered.
  46:				;
  47:				; A special memory mapping mode is enabled when NMI is serviced. In this mode,
  48:				; the memory mapping system is disabled except for write operations. As a result,
  49:				; handling code in page 0x3f is executed and writes proceed to the previously
  50:				; selected bank.
  51:				;
  52:				; Memory Map (CP/M Mode)
  53:				; 
  54:				; 0 (0000 - 3FFF): 00 writable
  55:				; 1 (4000 - 7FFF): 01 writable
  56:				; 2 (8000 - BFFF): 02 writable
  57:				; 3 (C000 - FFFF): 03 writable
  58:				;
  59:				; When running CP/M, memory is mapped as shown above.
  60:				;
  61:				;
  62:				                title ZARC Monitor
  63:				;
  64:     -	0001'         	monitor         equ 1                   ; Flag part of monitor build
  65:     -	0001'         	main            equ 1                   ; Flag module for includes
  66:				;
  67:				;
  68:				;
  69:				; ************
  70:				; * Includes *
  71:				; ************
  72:				;
  73:				                include "macros.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/macros.i ****
   1:				; ***********************************
   2:				; * ZARC Macro Definitions          *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 30/7/2020         *
   5:				; ***********************************
   6:				;
   7:				;
   8:				;
   9:				; **********
  10:				; * Macros *
  11:				; **********
  12:				;
  13:				;
  14:				; Initialise enumeration.
  15:				; The absolute segment is used so the offsets are not marked as relocatable. This
  16:				; avoids "Not relocatable" errors.
  17:				ENUM_START      macro
  18:				                .aseg
  19:				enum_counter    set 0
  20:				                endm
  21:				;
  22:				; Invoke for each item.
  23:				ENUM            macro x
  24:				x               equ enum_counter
  25:				enum_counter    set enum_counter + 1
  26:				                endm
  27:				;
  28:				ENUM_END        macro x
  29:				x               set enum_counter    ; Set label to count of items
  30:				                .cseg
  31:				                endm
  32:				;
  33:				;
  34:				; Initialise a structure. This is used to generate offsets for data structures.
  35:				; The absolute segment is used so the offsets are not marked as relocatable. This
  36:				; avoids "Not relocatable" errors.
  37:				STRUCT          macro
  38:				                .aseg
  39:				str_offset      set 0
  40:				                endm
  41:				;
  42:				; Add a byte entry.
  43:				STR_BYTE        macro x
  44:				x               equ str_offset
  45:				str_offset      set str_offset + 1
  46:				                endm
  47:				;
  48:				; Add a word (16-bit) entry.
  49:				STR_WORD        macro x
  50:				x               equ str_offset
  51:				str_offset      set str_offset + 2
  52:				                endm
  53:				;
  54:				; Add a 3 byte (24-bit) entry.
  55:				STR_24BIT       macro x
  56:				x               equ str_offset
  57:				str_offset      set str_offset + 3
  58:				                endm
  59:				;
  60:				; Add a long (32-bit) entry.
  61:				STR_LONG        macro x
  62:				x               equ str_offset
  63:				str_offset      set str_offset + 4
  64:				                endm
  65:				;
  66:				; Add an arbitrary length entry.
  67:				STR_BLOCK       macro x, size   ; <name>, <size>
  68:				x               equ str_offset
  69:				str_offset      set str_offset + size
  70:				                endm
  71:				;
  72:				; End of structure (used to set size)
  73:				STR_END         macro x
  74:				x               equ str_offset
  75:				                .cseg
  76:				                endm
  77:				;
  78:				;
  79:				; Allocate space. This is used to generate variable addresses, affectively
  80:				; providing a new variables segment. Allocated size is kept track of separately
  81:				; to the address as the latter may overflow in certain error cases.
  82:				ALLOC           macro x
  83:				                .aseg
  84:				all_addr        set x
  85:				all_size        set 0
  86:				                endm
  87:				;
  88:				; Add a byte entry.
  89:				ALL_BYTE        macro x
  90:				x               equ all_addr
  91:				all_addr        set all_addr + 1
  92:				all_size        set all_size + 1
  93:				                endm
  94:				;
  95:				; Add a word (16-bit) entry.
  96:				ALL_WORD        macro x
  97:				x               equ all_addr
  98:				all_addr        set all_addr + 2
  99:				all_size        set all_size + 2
 100:				                endm
 101:				;
 102:				; Add a 3 byte (24-bit) entry.
 103:				ALL_24BIT       macro x
 104:				x               equ all_addr
 105:				all_addr        set all_addr + 3
 106:				all_size        set all_size + 3
 107:				                endm
 108:				;
 109:				; Add a long (32-bit) entry.
 110:				ALL_LONG        macro x
 111:				x               equ all_addr
 112:				all_addr        set all_addr + 4
 113:				all_size        set all_size + 4
 114:				                endm
 115:				;
 116:				; Add an arbitrary length entry.
 117:				ALL_BLOCK       macro x, size   ; <name>, <size>
 118:				x               equ all_addr
 119:				all_addr        set all_addr + size
 120:				all_size        set all_size + size
 121:				                endm
 122:				;
 123:				; End of allocated space. Returns size of block.
 124:				ALL_END         macro x
 125:				x               equ all_size
 126:				                .cseg
 127:				                endm
 128:				;
 129:				;
 130:				; Calculate offsets into jump tables.
 131:				; The absolute segment is used so the offsets are not marked as relocatable. This
 132:				; avoids "Not relocatable" errors.
 133:				JPTBL_START     macro x
 134:				                .aseg
 135:				jptbl_addr      set x               ; Set start address
 136:				                endm
 137:				;
 138:				; Invoke for each item.
 139:				JPTBL_ENTRY     macro x
 140:				x               equ jptbl_addr
 141:				jptbl_addr      set jptbl_addr + 3
 142:				                endm
 143:				;
 144:				; Invoke for a data block in the jump table
 145:				JPTBL_BLOCK     macro x, size   ; <name>, <size>
 146:				x               equ jptbl_addr
 147:				jptbl_addr      set jptbl_addr + size
 148:				                endm
 149:				;
 150:				JPTBL_END       macro x
 151:				x               set jptbl_addr      ; Set label to next address
 152:				                .cseg
 153:				                endm
 154:				;
 155:				;
 156:				; Define bits and masks. This is inspired by the Commodore Amiga BITDEF mechanism.
 157:				; Given:
 158:				; BITDEF I2C_CSR_STOP, 2
 159:				; Yields:
 160:				; I2C_CSR_STOP_BIT  EQU 2       ; Bit number
 161:				; I2C_CSR_STOP_MASK EQU 1<<2    ; Bit mask
 162:				BITDEF          macro n, b      ; <Name>, <bit>
 163:				n`_BIT          equ b
 164:				n`_MASK         equ 1 << b
 165:				                endm
 166:				;
 167:				;
 168:				; Force alignment. This asserts an appropriate number of zero bytes to achieve
 169:				; the required alignment. Note that these macros cannot work for relocatable
 170:				; files.
 171:				; 16-bit
 172:				ALIGN_WORD      macro
 173:				                if $ and 1
 174:				                    byte 0
 175:				                endif
 176:				                endm
 177:				;
 178:				; 32-bit
 179:				ALIGN_LONG      macro
 180:				                ALIGN_WORD
 181:				                if $ and 2
 182:				                    byte 0, 0
 183:				                endif
 184:				                endm
 185:				;
 186:				;
 187:				; Write message to console (short for "call conwms").
 188:				CON_WR_MSG      macro
 189:				                rst 08
 190:				                endm
 191:				;
 192:				;
 193:				; Write character to console (short for "call conwch").
 194:				CON_WR_CHAR     macro
 195:				                rst 16
 196:				                endm
 197:				
