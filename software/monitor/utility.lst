**** utility.z80 ****
  32:				;
  33:				;
  34:				; *************
  35:				; * Externals *
  36:				; *************
  37:				;
  38:				                public cwnwln   ; Write new line characters to console
  39:				                public conwms   ; Print null-terminated string to the console
  40:				                public conwmn   ; Print message <n> in a list
  41:				                public skpspc   ; Step hl past spaces
  42:				                public toupca   ; Convert character in A to upper case
  43:				                public toloca   ; Convert character in A to lower case
  44:				                public cwvich   ; Print only visible 7-bit characters
  45:				                public cwpspc   ; Print a space
  46:				                public mtwdli   ; Match word in a string against list of options
  47:				                public cwphnb   ; Print least-significant nibble in A in hexadecimal
  48:				                public cwphby   ; Print A in hexadecimal
  49:				                public cwphwd   ; Print HL in hexadecimal
  50:				                public cwpdby   ; Print A in decimal. Leading zeros are suppressed
  51:				                public cwpdwd   ; Print HL in decimal. Leading zeros are suppressed
  52:				                public cwpdlo   ; Print DEHL in decimal. Leading zeros are suppressed
  53:				                public rdhxwd   ; Read a 16-bit hexadecimal number from a string
  54:				                public rdduwd   ; Read a 16-bit unsigned decimal number from a string
  55:				                public rddulo   ; Read a 32-bit unsigned decimal number from a string
  56:				;
  57:				;
  58:				;
  59:				; *************
  60:				; * Constants *
  61:				; *************
  62:				;
  63:				; None
  64:				;
  65:				;
  66:				;
  67:				; *************
  68:				; * Main Code *
  69:				; *************
  70:				;
  71:				                cseg                ; Code segment
  72:				;
  73:				; Write new line characters to console.
  74:    0+7	0000' 3E0D    	cwnwln          ld a, ascii_cr
  75:    7+11	0002' D7      	                CON_WR_CHAR
  76:   18+7	0003' 3E0A    	                ld a, ascii_lf
  77:   25+10	0005' C30000  	                jp conwch
  78:				;
  79:				;
  80:				; Print null-terminated string to the console.
  81:				; Call with:
  82:				; HL - pointer to start of message
  83:				; Returns with:
  84:				; HL - points to the terminator.
  85:   35+7	0008' 7E      	conwms          ld a, (hl)
  86:   42+4	0009' A7      	                and a
  87:   46+5+6	000A' C8      	                ret z                   ; Return if terminator found
  88:   51+11	000B' D7      	                CON_WR_CHAR             ; Write character to console
  89:   62+6	000C' 23      	                inc hl                  ; Increment character pointer
  90:   68+12	000D' 18F9    	                jr conwms               ; Transmit next character
  91:				;
  92:				;
  93:				; Print message <n> in a null terminated list. Nothing is printed if the
  94:				; terminator is encountered before message <n> is found.
  95:				; Call with:
  96:				; A - number of message to print (first is zero)
  97:				; C - message separator
  98:				; HL - pointer to start of message
  99:				; Returns with:
 100:				; HL - points to the separator at the end of the message printed, or the
 101:				; terminator (zero).
 102:				; Carry flag is set if the message was not found (terminator encountered).
 103:   80+11	000F' C5      	conwmn          push bc
 104:   91+4	0010' 47      	                ld b, a                 ; Message number
 105:   95+4	0011' 78      	pmn_msg_lp      ld a, b
 106:   99+4	0012' A7      	                and a
 107:  103+7+5	0013' 280B    	                jr z, pmn_found         ; Jump if this is the one
 108:				; Skip to next message.
 109:  110+7	0015' 7E      	pmn_sk_lp       ld a, (hl)
 110:  117+4	0016' A7      	                and a
 111:  121+7+5	0017' 2815    	                jr z, pmn_error         ; Error if terminator
 112:  128+6	0019' 23      	                inc hl
 113:  134+4	001A' B9      	                cp c
 114:  138+7+5	001B' 20F8    	                jr nz, pmn_sk_lp        ; Keep going if not separator or terminator
 115:				; Separator found
 116:  145+4	001D' 05      	                dec b
 117:  149+12	001E' 18F1    	                jr pmn_msg_lp
 118:				; HL now points to the requied message. Print it until the separator or
 119:				; terminator is encountered.
 120:  161+7	0020' 7E      	pmn_found       ld a, (hl)
 121:  168+4	0021' A7      	                and a
 122:  172+7+5	0022' 2807    	                jr z, pmn_done          ; Exit if terminator found
 123:  179+4	0024' B9      	                cp c
 124:  183+7+5	0025' 2804    	                jr z, pmn_done          ; Exit if separator found
 125:  190+11	0027' D7      	                CON_WR_CHAR             ; Write character to console
 126:  201+6	0028' 23      	                inc hl                  ; Increment character pointer
 127:  207+12	0029' 18F5    	                jr pmn_found            ; Transmit next character
 128:				; Successful completion.
 129:  219+10	002B' C1      	pmn_done        pop bc
 130:  229+4	002C' A7      	                and a
 131:  233+10	002D' C9      	                ret                     ; Return with carry reset (no error)
 132:				; Terminator encountered before the message was found
 133:  243+10	002E' C1      	pmn_error       pop bc                  ; Restore registers
 134:  253+4	002F' 37      	                scf
 135:  257+10	0030' C9      	                ret                     ; Return with carry set (error)
 136:				;
 137:				;
 138:				; Step HL past any spaces.
 139:				; Returns with:
 140:				; HL - points to the first non-space character
 141:  267+7	0031' 3E20    	skpspc          ld a, ' '
 142:  274+7	0033' BE      	sks_loop        cp (hl)
 143:  281+5+6	0034' C0      	                ret nz                  ; Return if non-space found
 144:  286+6	0035' 23      	                inc hl
 145:  292+12	0036' 18FB    	                jr sks_loop
 146:				;
 147:				;
 148:				; Convert character in A to upper case.
 149:  304+7	0038' FE61    	toupca          cp 'a'
 150:  311+5+6	003A' D8      	                ret c                   ; Nothing to do if < 'a'
 151:  316+7	003B' FE7B    	                cp 'z' + 1
 152:  323+5+6	003D' D0      	                ret nc                  ; Nothing to do if > 'z'
 153:  328+7	003E' D620    	                sub 'a' - 'A'
 154:  335+10	0040' C9      	                ret
 155:				;
 156:				;
 157:				; Convert character in A to lower case.
 158:  345+7	0041' FE41    	toloca          cp 'A'
 159:  352+5+6	0043' D8      	                ret c                   ; Nothing to do if < 'A'
 160:  357+7	0044' FE5B    	                cp 'Z' + 1
 161:  364+5+6	0046' D0      	                ret nc                  ; Nothing to do if > 'Z'
 162:  369+7	0047' C620    	                add 'a' - 'A'
 163:  376+10	0049' C9      	                ret
 164:				;
 165:				;
 166:				; Print a space.
 167:  386+7	004A' 3E20    	cwpspc          ld a, ' '
 168:  393+10	004C' C30000  	                jp conwch
 169:				;
 170:				;
 171:				; Print only visible 7-bit characters. Non-visible ones are substituted by
 172:				; the character in C.
 173:  403+7	004F' FE20    	cwvich          cp ' '
 174:  410+7+5	0051' 3807    	                jr c, prv_do_subs       ; < ' ' is a control character
 175:  417+7	0053' FE7F    	                cp ascii_del
 176:  424+7+5	0055' 3003    	                jr nc, prv_do_subs      ; >= DEL isn't visible either
 177:  431+10	0057' C30000  	                jp conwch               ; Print visible character
