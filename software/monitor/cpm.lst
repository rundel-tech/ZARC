  67:				;
  68:				;
  69:				;
  70:				; *************
  71:				; * Main Code *
  72:				; *************
  73:				;
  74:				                cseg                    ; Code segment
  75:				;
  76:				;
  77:				; Load and start CP/M. No registers are saved. No return is anticipated unless an
  78:				; error occurs.
  79:				; A - options. See BIOS_OPT_xxx definitions in cpm.i.
  80:    0+13	0000' 320202  	cpinit          ld (options), a
  81:   13+13	0003' 3A0000  	                ld a, (mcstat)          ; Fetch card state (MMC_STAT_xxx)
  82:   26+7	0006' FE01    	                cp MMC_STAT_INIT
  83:   33+7+5	0008' 2806    	                jr z, in_mmc_ok
  84:				; MMC not initialised.
  85:   40+10	000A' 212501  	                ld hl, no_mmc_msg       ; "MMC not initialised"
  86:   50+10	000D' C39E00  	                jp in_error
  87:				;
  88:   60+17	0010' CDD900  	in_mmc_ok       call cpprt              ; Find CP/M partition
  89:   77+5+6	0013' D8      	                ret c                   ; Give up on error
  90:   82+20	0014' DD220000	                ld (cpm_part_entry), ix
  91:				;
  92:				; Allocate memory pages.
  93:  102+10	0018' 210302  	                ld hl, cppags           ; Store for page numbers
  94:  112+7	001B' 3E04    	                ld a, MMAP_CPM_PAGES    ; Number of pages required
  95:  119+17	001D' CDA300  	                call cpmem              ; Allocate CP/M pages
  96:  136+5+6	0020' D8      	                ret c                   ; Give up on error
  97:				; Set the supervisor bit for the upper bank so the BIOS can access I/O.
  98:  141+10	0021' 210602  	                ld hl, cppags + 3
  99:  151+15	0024' CBF6    	                set MMAP_SUPER_BIT, (hl)
 100:				;
 101:				; Load BIOS into memory. Map the relevant page.
 102:  166+13	0026' 3A0602  	                ld a, (cppags + 3)
 103:  179+11	0029' D307    	                out (IOA_MMAP_3), a     ; Map C000 - FFFF to the relevant page
 104:				;
 105:  190+7	002B' 0620    	                ld b, BIOS_SECTS        ; Sector count
