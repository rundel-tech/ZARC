   1:				; *******************************************************
   2:				; * CP/M 3 Launcher and Support for ZARC Z80 Computer   *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 21/11/2020                            *
   5:				; *******************************************************
   6:				;
   7:				; Configures the system and loads CPMLDR.COM from the MMC. The first partition
   8:				; of an appropriate type is made available to the CP/M 3 sub-system by means of
   9:				; sector read and write functions. These are located in cache.z80 (cars and
  10:				; caws). There operate with MMC (512-byte) sectors, unlike CP/M 2.2.
  11:				;
  12:				;
  13:     -	0001'         	monitor         equ 1                   ; Flag part of monitor build
  14:     -	0001'         	cpm3            equ 1                   ; Flag module for includes
  15:				;
  16:				;
  17:				;
  18:				; ************
  19:				; * Includes *
  20:				; ************
  21:				;
  22:				                include "macros.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/macros.i ****
   1:				; ***********************************
   2:				; * ZARC Macro Definitions          *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 30/7/2020         *
   5:				; ***********************************
   6:				;
   7:				;
   8:				;
   9:				; **********
  10:				; * Macros *
  11:				; **********
  12:				;
  13:				;
  14:				; Initialise enumeration.
  15:				; The absolute segment is used so the offsets are not marked as relocatable. This
  16:				; avoids "Not relocatable" errors.
  17:				ENUM_START      macro
  18:				                .aseg
  19:				enum_counter    set 0
  20:				                endm
  21:				;
  22:				; Invoke for each item.
  23:				ENUM            macro x
  24:				x               equ enum_counter
  25:				enum_counter    set enum_counter + 1
  26:				                endm
  27:				;
  28:				ENUM_END        macro x
  29:				x               set enum_counter    ; Set label to count of items
  30:				                .cseg
  31:				                endm
  32:				;
  33:				;
  34:				; Initialise a structure. This is used to generate offsets for data structures.
  35:				; The absolute segment is used so the offsets are not marked as relocatable. This
  36:				; avoids "Not relocatable" errors.
  37:				STRUCT          macro
  38:				                .aseg
  39:				str_offset      set 0
  40:				                endm
  41:				;
  42:				; Add a byte entry.
  43:				STR_BYTE        macro x
  44:				x               equ str_offset
  45:				str_offset      set str_offset + 1
  46:				                endm
  47:				;
  48:				; Add a word (16-bit) entry.
  49:				STR_WORD        macro x
  50:				x               equ str_offset
  51:				str_offset      set str_offset + 2
  52:				                endm
  53:				;
  54:				; Add a 3 byte (24-bit) entry.
  55:				STR_24BIT       macro x
  56:				x               equ str_offset
  57:				str_offset      set str_offset + 3
  58:				                endm
  59:				;
  60:				; Add a long (32-bit) entry.
  61:				STR_LONG        macro x
  62:				x               equ str_offset
  63:				str_offset      set str_offset + 4
  64:				                endm
  65:				;
  66:				; Add an arbitrary length entry.
  67:				STR_BLOCK       macro x, size   ; <name>, <size>
  68:				x               equ str_offset
  69:				str_offset      set str_offset + size
  70:				                endm
  71:				;
  72:				; End of structure (used to set size)
  73:				STR_END         macro x
  74:				x               equ str_offset
  75:				                .cseg
  76:				                endm
  77:				;
  78:				;
  79:				; Allocate space. This is used to generate variable addresses, affectively
  80:				; providing a new variables segment. Allocated size is kept track of separately
  81:				; to the address as the latter may overflow in certain error cases.
  82:				ALLOC           macro x
  83:				                .aseg
  84:				all_addr        set x
  85:				all_size        set 0
  86:				                endm
  87:				;
  88:				; Add a byte entry.
  89:				ALL_BYTE        macro x
  90:				x               equ all_addr
  91:				all_addr        set all_addr + 1
  92:				all_size        set all_size + 1
  93:				                endm
  94:				;
  95:				; Add a word (16-bit) entry.
  96:				ALL_WORD        macro x
  97:				x               equ all_addr
  98:				all_addr        set all_addr + 2
  99:				all_size        set all_size + 2
 100:				                endm
 101:				;
 102:				; Add a 3 byte (24-bit) entry.
 103:				ALL_24BIT       macro x
 104:				x               equ all_addr
 105:				all_addr        set all_addr + 3
 106:				all_size        set all_size + 3
 107:				                endm
 108:				;
 109:				; Add a long (32-bit) entry.
 110:				ALL_LONG        macro x
 111:				x               equ all_addr
 112:				all_addr        set all_addr + 4
 113:				all_size        set all_size + 4
 114:				                endm
 115:				;
 116:				; Add an arbitrary length entry.
 117:				ALL_BLOCK       macro x, size   ; <name>, <size>
 118:				x               equ all_addr
 119:				all_addr        set all_addr + size
 120:				all_size        set all_size + size
 121:				                endm
 122:				;
 123:				; End of allocated space. Returns size of block.
 124:				ALL_END         macro x
 125:				x               equ all_size
 126:				                .cseg
 127:				                endm
 128:				;
 129:				;
 130:				; Calculate offsets into jump tables.
 131:				; The absolute segment is used so the offsets are not marked as relocatable. This
 132:				; avoids "Not relocatable" errors.
 133:				JPTBL_START     macro x
 134:				                .aseg
 135:				jptbl_addr      set x               ; Set start address
 136:				                endm
 137:				;
 138:				; Invoke for each item.
 139:				JPTBL_ENTRY     macro x
 140:				x               equ jptbl_addr
 141:				jptbl_addr      set jptbl_addr + 3
 142:				                endm
 143:				;
 144:				; Invoke for a data block in the jump table
 145:				JPTBL_BLOCK     macro x, size   ; <name>, <size>
 146:				x               equ jptbl_addr
 147:				jptbl_addr      set jptbl_addr + size
 148:				                endm
 149:				;
 150:				JPTBL_END       macro x
 151:				x               set jptbl_addr      ; Set label to next address
 152:				                .cseg
 153:				                endm
 154:				;
 155:				;
 156:				; Define bits and masks. This is inspired by the Commodore Amiga BITDEF mechanism.
 157:				; Given:
 158:				; BITDEF I2C_CSR_STOP, 2
 159:				; Yields:
 160:				; I2C_CSR_STOP_BIT  EQU 2       ; Bit number
 161:				; I2C_CSR_STOP_MASK EQU 1<<2    ; Bit mask
 162:				BITDEF          macro n, b      ; <Name>, <bit>
 163:				n`_BIT          equ b
 164:				n`_MASK         equ 1 << b
 165:				                endm
 166:				;
 167:				;
 168:				; Force alignment. This asserts an appropriate number of zero bytes to achieve
 169:				; the required alignment. Note that these macros cannot work for relocatable
 170:				; files.
 171:				; 16-bit
 172:				ALIGN_WORD      macro
 173:				                if $ and 1
 174:				                    byte 0
 175:				                endif
 176:				                endm
 177:				;
 178:				; 32-bit
 179:				ALIGN_LONG      macro
 180:				                ALIGN_WORD
 181:				                if $ and 2
 182:				                    byte 0, 0
 183:				                endif
 184:				                endm
 185:				;
 186:				;
 187:				; Write message to console (short for "call conwms").
 188:				CON_WR_MSG      macro
 189:				                rst 08
 190:				                endm
 191:				;
 192:				;
 193:				; Write character to console (short for "call conwch").
 194:				CON_WR_CHAR     macro
 195:				                rst 16
 196:				                endm
 197:				
**** cpm3.z80 ****
  23:				                include "z80.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/z80.i ****
   1:				; ***********************************
   2:				; * ZARC Z80 Definitions            *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 28/5/2020         *
   5:				; ***********************************
   6:				;
   7:				; Definitions related to the Z80 itself.
   8:				;
   9:				; Z80 Vectors
  10:     -	0000'         	Z80_RST00_VEC   equ 0x0000      ; RST instruction vectors
  11:     -	0008'         	Z80_RST08_VEC   equ 0x0008
  12:     -	0010'         	Z80_RST10_VEC   equ 0x0010
  13:     -	0018'         	Z80_RST18_VEC   equ 0x0018
  14:     -	0020'         	Z80_RST20_VEC   equ 0x0020
  15:     -	0028'         	Z80_RST28_VEC   equ 0x0028
  16:     -	0030'         	Z80_RST30_VEC   equ 0x0030
  17:     -	0038'         	Z80_RST38_VEC   equ 0x0038
  18:     -	0066'         	Z80_NMI_VEC     equ 0x0066      ; NMI vectors
  19:				
**** cpm3.z80 ****
  24:				                include "zarc.i"        ; Hardware definitions
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/zarc.i ****
   1:				; ***********************************
   2:				; * ZARC Definitions                *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 26/5/2020         *
   5:				; ***********************************
   6:				;
   7:				; Definitions related to the ZARC system.
   8:				;
   9:				;
  10:				; ************
  11:				; * Hardware *
  12:				; ************
  13:				;
  14:				; Interrupt vector numbers in INT_VEC_TABLE.
  15:				; Address is INT_VEC_TABLE + 2 * vector number).
  16:     -	0000'         	INT_SER1_TX_VEC     equ INT_SER1_TX_BIT ; Serial port 1 transmitter buffer is half full or less
  17:     -	0001'         	INT_SER1_RX_VEC     equ INT_SER1_RX_BIT ; Serial port 1 receiver has data
  18:     -	0002'         	INT_SER2_TX_VEC     equ INT_SER2_TX_BIT ; Serial port 2 transmitter buffer is half full or less
  19:     -	0003'         	INT_SER2_RX_VEC     equ INT_SER2_RX_BIT ; Serial port 2 receiver has data
  20:     -	0004'         	INT_TICK_VEC        equ INT_TICK_BIT    ; Regular timekeeping
  21:				;
  22:     -	0064'         	MS_PER_TICK         equ 100             ; ms per tick
  23:     -	000A'         	TICK_FREQ           equ 10              ; Tick rate in Hz
  24:				;
  25:				
**** cpm3.z80 ****
  25:				                include "monitor.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/monitor.i ****
   1:				; *******************************************************
   2:				; * ZARC Monitor Definitions                            *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 26/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Definitions related to the monitor programme.
   8:				;
   9:				; Note that ld80 only considers the first six characters of labels significant.
  10:				;
  11:				;
  12:				; The following conditionals are intended to allow the same include file to be
  13:				; used in the defining module and elsewhere as required. Some includes are used
  14:				; for other applications than the monitor, such as the CP/M BIOS. In these
  15:				; cases, the extern and public statements are not desirable.
  16:				;
  17:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  18:     -	0001'         	                ifndef main         ; Inhibit for this module
  19:				; Constants
  20:				;
  21:				; Variables
  22:				                extern mscnt            ; Monitor start count
  23:				                extern mcspd            ; Approximate CPU speed in KHz
  24:				                extern mstate           ; Machine state structure
  25:				;
  26:				; Functions
  27:				                extern panic            ; System error exception
  28:				                extern rusby            ; Read byte from user space
  29:				                extern ruswd            ; Read 16-bit word from user space
  30:				                extern wusby            ; Write byte to user space
  31:				                extern wuswd            ; Write 16-bit word to user space
  32:				                extern mcrun            ; Switch context to user code
  33:				                extern mdisrg           ; Display registers
  34:				;
  35:				                endif
  36:				            endif
  37:				;
  38:				;
  39:				;
  40:				; *****************
  41:				; * Monitor Calls *
  42:				; *****************
  43:				;
  44:				;
  45:				; Calculate offsets into jump tables. Entries here must match the jump table in
  46:				; monitor.z80.
  47:     -	        	    JPTBL_START %(Z80_NMI_VEC + 3)   ; Start after NMI vector
  48:				;
  49:				; From monitor.z80
  50:     -	        	    JPTBL_ENTRY MCALL_MON_ENTRY     ; Normal monitor entry
  51:     -	        	    JPTBL_ENTRY MCALL_PANIC         ; System error monitor entry
  52:				; From io.z80
  53:     -	        	    JPTBL_ENTRY MCALL_CONWCH        ; Write character to the console port
  54:     -	        	    JPTBL_ENTRY MCALL_CONRCH        ; Read character from the console port
  55:     -	        	    JPTBL_ENTRY MCALL_CONSTA        ; Fetch console port status
  56:     -	        	    JPTBL_ENTRY MCALL_S1WCH         ; Write character to serial port 1
  57:     -	        	    JPTBL_ENTRY MCALL_S1RCH         ; Read character from serial port 1
  58:     -	        	    JPTBL_ENTRY MCALL_S1STA         ; Fetch serial port 1 status
  59:     -	        	    JPTBL_ENTRY MCALL_S2WCH         ; Write character to serial port 2
  60:     -	        	    JPTBL_ENTRY MCALL_S2RCH         ; Read character from serial port 2
  61:     -	        	    JPTBL_ENTRY MCALL_S2STA         ; Fetch serial port 2 status
  62:				; From utility.z80
  63:     -	        	    JPTBL_ENTRY MCALL_CWNWLN        ; Write new line characters to console
  64:     -	        	    JPTBL_ENTRY MCALL_CONWMS        ; Print null-terminated string to the console
  65:     -	        	    JPTBL_ENTRY MCALL_CONWMN        ; Print message <n> in a list
  66:     -	        	    JPTBL_ENTRY MCALL_SKPSPC        ; Step hl past spaces
  67:     -	        	    JPTBL_ENTRY MCALL_TOUPCA        ; Convert character in A to upper case
  68:     -	        	    JPTBL_ENTRY MCALL_TOLOCA        ; Convert character in A to lower case
  69:     -	        	    JPTBL_ENTRY MCALL_CWVICH        ; Print only visible 7-bit characters
  70:     -	        	    JPTBL_ENTRY MCALL_CWPSPC        ; Print a space
  71:     -	        	    JPTBL_ENTRY MCALL_MTWDLI        ; Match word in a string against list of options
  72:     -	        	    JPTBL_ENTRY MCALL_CWPHNB        ; Print least-significant nibble in A in hexadecimal
  73:     -	        	    JPTBL_ENTRY MCALL_CWPHBY        ; Print A in hexadecimal
  74:     -	        	    JPTBL_ENTRY MCALL_CWPHWD        ; Print HL in hexadecimal
  75:     -	        	    JPTBL_ENTRY MCALL_CWPDBY        ; Print A in decimal. Leading zeros are suppressed.
  76:     -	        	    JPTBL_ENTRY MCALL_CWPDWD        ; Print HL in decimal. Leading zeros are suppressed.
  77:     -	        	    JPTBL_ENTRY MCALL_CWPDLO        ; Print DEHL in decimal. Leading zeros are suppressed
  78:     -	        	    JPTBL_ENTRY MCALL_RDHXWD        ; Read a 16-bit hexadecimal number from a string
  79:     -	        	    JPTBL_ENTRY MCALL_RDDUWD        ; Read a 16-bit unsigned decimal number from a string
  80:     -	        	    JPTBL_ENTRY MCALL_RDDULO        ; Read a 32-bit unsigned decimal number from a string
  81:				; From maths.z80
  82:     -	        	    JPTBL_ENTRY MCALL_MADLBU        ; 32-bit / 8-bit unsigned divide
  83:     -	        	    JPTBL_ENTRY MCALL_MADWBU        ; 16-bit / 8-bit unsigned divide
  84:     -	        	    JPTBL_ENTRY MCALL_MADBBU        ; 8-bit / 8-bit unsigned divide
  85:     -	        	    JPTBL_ENTRY MCALL_MAMWWU        ; 16-bit * 16-bit unsigned multiply
  86:     -	        	    JPTBL_ENTRY MCALL_MAMLBU        ; 32-bit * 8-bit unsigned multiply
  87:     -	        	    JPTBL_ENTRY MCALL_CRC16X        ; CRC-16 (XMODEM)
  88:				; From time.z80
  89:     -	        	    JPTBL_ENTRY MCALL_TIRD          ; Read current time and date
  90:     -	        	    JPTBL_ENTRY MCALL_TIWR          ; Set time and date
  91:     -	        	    JPTBL_ENTRY MCALL_TIITOS        ; Convert integer time to structure
  92:     -	        	    JPTBL_ENTRY MCALL_TISTOI        ; Convert structure time to integer
  93:     -	        	    JPTBL_ENTRY MCALL_CWPTM         ; Print time structure to console
  94:				; From mmc.z80
  95:     -	        	    JPTBL_ENTRY MCALL_MCPRER        ; Print memory card error text
  96:				; From cache.z80
  97:     -	        	    JPTBL_ENTRY MCALL_CACRS         ; CP/M read sector
  98:     -	        	    JPTBL_ENTRY MCALL_CACWS         ; CP/M write sector
  99:     -	        	    JPTBL_ENTRY MCALL_CARS          ; MMC read sector
 100:     -	        	    JPTBL_ENTRY MCALL_CAWS          ; MMC write sector
 101:     -	        	    JPTBL_ENTRY MCALL_CAFLUS        ; Flush cache (write dirty buffers)
 102:				; From memory.z80
 103:     -	        	    JPTBL_ENTRY MCALL_MPALL         ; Allocate new page
 104:     -	        	    JPTBL_ENTRY MCALL_MPFREE        ; Free allocated page
 105:     -	        	    JPTBL_ENTRY MCALL_MPSTAT        ; Allocation status
 106:				;
 107:     -	        	    JPTBL_END MCALL_JPTBL_NEXT
 108:				;
 109:				;
 110:				;
 111:				; **************
 112:				; * Structures *
 113:				; **************
 114:				;
 115:				;
 116:				; Machine state structure.
 117:     -	        	                STRUCT
 118:     -	        	                STR_BYTE MST_IEN        ; Non-zero if interrupts enabled
 119:     -	        	                STR_BYTE MST_MMAP_EN    ; Non-zero if memory mapping enabled
 120:     -	        	                STR_BYTE MST_MMAP0      ; Memory mapping registers
 121:     -	        	                STR_BYTE MST_MMAP1
 122:     -	        	                STR_BYTE MST_MMAP2
 123:     -	        	                STR_BYTE MST_MMAP3
 124:     -	        	                STR_WORD MST_SP
 125:     -	        	                STR_WORD MST_PC
 126:				; The sequence of the following entries must match those in the state save and
 127:				; load routines.
 128:     -	        	                STR_WORD MST_IY
 129:     -	        	                STR_WORD MST_IX
 130:     -	        	                STR_WORD MST_HL_P
 131:     -	        	                STR_WORD MST_DE_P
 132:     -	        	                STR_WORD MST_BC_P
 133:     -	        	                STR_WORD MST_AF_P       ; Alternate ("prime") registers
 134:     -	        	                STR_WORD MST_HL
 135:     -	        	                STR_WORD MST_DE
 136:     -	        	                STR_WORD MST_BC
 137:     -	        	                STR_WORD MST_AF
 138:				; End of sequence critical entries.
 139:     -	        	                STR_BYTE MST_I
 140:     -	        	                STR_BYTE MST_R
 141:     -	        	                STR_END MST_SIZE
 142:				;
 143:				;
 144:				;
 145:				; *************
 146:				; * Constants *
 147:				; *************
 148:				;
 149:				;
 150:				; Trace mode states for trace_mode.
 151:     -	        	                ENUM_START
 152:     -	        	                ENUM TRM_NONE
 153:     -	        	                ENUM TRM_SINGLE
 154:     -	        	                ENUM TRM_TO_ADDR        ; Trace to address
 155:     -	        	                ENUM TRM_XPT            ; Exception - start running normally
 156:     -	        	                ENUM_END TRM_STATES     ; Number of states
 157:				
**** cpm3.z80 ****
  26:				                include "io_map.i"      ; I/O addresses mapping
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/io_map.i ****
   1:				; ***********************************
   2:				; * ZARC I/O Definitions            *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 3/9/2019          *
   5:				; ***********************************
   6:				
   7:				; *** I/O register address mapping ***
   8:				
   9:				; This should be kept in sync with the Definitions.vhd package file.
  10:     -	0000'         	IOA_FPGA_MAJREV equ 0x00        ; FPGA major revision
  11:     -	0001'         	IOA_FPGA_MINREV equ 0x01        ; FPGA minor revision
  12:     -	0002'         	IOA_CONTROL     equ 0x02        ; System control register
  13:     -	0003'         	IOA_FP_SW       equ 0x03        ; Front panel data switches
  14:				
  15:				; Paging
  16:     -	0004'         	IOA_MMAP_0      equ 0x04        ; Page, supervisor and protection for bank 0 (0x0000 to 0x3fff)
  17:     -	0005'         	IOA_MMAP_1      equ 0x05        ; Page, supervisor and protection for bank 1 (0x4000 to 0x7fff)
  18:     -	0006'         	IOA_MMAP_2      equ 0x06        ; Page, supervisor and protection for bank 2 (0x8000 to 0xbfff)
  19:     -	0007'         	IOA_MMAP_3      equ 0x07        ; Page, supervisor and protection for bank 3 (0xc000 to 0xffff)
  20:				
  21:				; Interrupts
  22:				; Note: Up to eight interrupts are supported. IM 2 is anticipated, and the
  23:				; fixed vector associated with each interrupt is supplied when the interrupt
  24:				; is serviced. Routine address is “I*256+databus”. Vector supplied is
  25:				; 0xe0 + 2 * interrupt number (0 to 7).
  26:				; Note: addresses 0x09 and 0x0b reserved for use if more than eight interrupt
  27:				; sources are required.
  28:     -	0008'         	IOA_INT_EN      equ 0x08        ; Enables
  29:     -	000A'         	IOA_INT_PEND    equ 0x0a        ; Pending interrupts
  30:				;
  31:				;NMI
  32:     -	000C'         	IOA_NMI_REASONS equ 0x0c        ; NMI reasons flags
  33:				;
  34:				; Serial.
  35:     -	0010'         	IOA_SER1_CSR    equ 0x10        ; Port 1 control / status
  36:     -	0011'         	IOA_SER1_DATA   equ 0x11        ; Port 1 data
  37:     -	0012'         	IOA_SER2_CSR    equ 0x12        ; Port 2 serial control / status
  38:     -	0013'         	IOA_SER2_DATA   equ 0x13        ; Port 2 serial data
  39:				
  40:				; RTC (DS1672)
  41:				; I2C, implemented using a byte interface to the CPU. Writing to the data port
  42:				; shifts out a byte. Input puts are shifted into the “other end” of the same
  43:				; register.
  44:     -	0018'         	IOA_I2C_CSR     equ 0x18        ; Control
  45:     -	0019'         	IOA_I2C_DATA    equ 0x19        ; Data
  46:				;
  47:				; SD Card
  48:				; Uses SPI mode, with a generally similar interface to that of the I2C.
  49:     -	0020'         	IOA_SPI_CSR     equ 0x20        ; Control
  50:     -	0021'         	IOA_SPI_DATA    equ 0x21        ; Data
  51:				
  52:				; CRC16 / XMODEM and MultiMediaCard CRC16
  53:				; Write to the CRC register to set the initial value. Writing to the input
  54:				; data register updates the CRC.
  55:     -	0024'         	IOA_CRC_0       equ 0x24        ; CRC register (low)
  56:     -	0025'         	IOA_CRC_1       equ 0x25        ; CRC register (high)
  57:     -	0026'         	IOA_CRC_DATA    equ 0x26        ; Input data
  58:				
  59:				; *** Proposed features ***
  60:				; Video
  61:				;IOA_VID_CTRL    equ 0x30;       ; Control (cursor on/off ...)
  62:				;IOA_VID_DATA    equ 0x31;       ; Data
  63:				;IOA_VID_CUR_X   equ 0x32;       ; Cursor X (0 to 127)
  64:				;IOA_VID_CUR_Y   equ 0x33;       ; Cursor Y (0 to 63)
  65:				;IOA_VID_START_L equ 0x34        ; Display start address (low byte)
  66:				;IOA_VID_START_H equ 0x35        ; Display start address (high byte)
  67:				
  68:				; Video palette
  69:				; Each entry consists of 6 bits of colour data. Foreground and background
  70:				; colour pairs are selected from the above palette using eight of the 22
  71:				; control codes in the display character set. This leaves codes for
  72:				; double-height, double-width etc.
  73:				;IOA_VID_PALBG0  equ 0x40        ; Background colour 0
  74:				;IOA_VID_PALFG0  equ 0x41        ; Foreground colour 0
  75:				;IOA_VID_PALBG1  equ 0x42        ; Background colour 1
  76:				;IOA_VID_PALFG1  equ 0x43        ; Foreground colour 1
  77:				;IOA_VID_PALBG2  equ 0x44        ; Background colour 2
  78:				;IOA_VID_PALFG2  equ 0x45        ; Foreground colour 2
  79:				;IOA_VID_PALBG3  equ 0x46        ; Background colour 3
  80:				;IOA_VID_PALFG3  equ 0x47        ; Foreground colour 3
  81:				;IOA_VID_PALBG4  equ 0x48        ; Background colour 4
  82:				;IOA_VID_PALFG4  equ 0x49        ; Foreground colour 4
  83:				;IOA_VID_PALBG5  equ 0x4a        ; Background colour 5
  84:				;IOA_VID_PALFG5  equ 0x4b        ; Foreground colour 5
  85:				;IOA_VID_PALBG6  equ 0x4c        ; Background colour 6
  86:				;IOA_VID_PALFG6  equ 0x4d        ; Foreground colour 6
  87:				;IOA_VID_PALBG7  equ 0x4e        ; Background colour 7
  88:				;IOA_VID_PALFG7  equ 0x4f        ; Foreground colour 7
  89:				
  90:				; Arithmetic
  91:				; Multiply, divide … based on 68000 DIV, DIVU, MUL, MULU.
  92:				; Multiply does A[16] * B[16] => C[32].
  93:				; Divide does A[32] / B[16] => C[32] (16-bit remainder [high bits] and
  94:				; 16-bit quotient [low bits]).
  95:				; Status bits include “complete” and “overflow”.
  96:				;IOA_ARITH_A_L   equ 0x50        ; A register (low)
  97:				;IOA_ARITH_A_H   equ 0x51        ; A register (high)
  98:				;IOA_ARITH_B_L   equ 0x54        ; B register (low)
  99:				;IOA_ARITH_B_H   equ 0x57        ; B register (high)
 100:				;IOA_ARITH_C_0   equ 0x58        ; C register (low)
 101:				;IOA_ARITH_C_1   equ 0x59 
 102:				;IOA_ARITH_C_2   equ 0x5a
 103:				;IOA_ARITH_C_3   equ 0x5b        ; C register (high)
 104:				;IOA_ARITH_CSR   equ 0x5c        ; Command / status
 105:				
 106:				
 107:				; *** Register bits allocation ***
 108:				
 109:				; IOA_CONTROL register
 110:     -	        	BITDEF SYSCTRL_TRARM, 0         ; 1 arms the trace interrupt
 111:     -	        	BITDEF SYSCTRL_MMAP, 1          ; 1 enables memory mapping
 112:     -	        	BITDEF SYSCTRL_NMCLR, 2         ; NMI mapping clear
 113:     -	        	BITDEF SYSCTRL_MAPARM, 3        ; NMI out arm
 114:     -	        	BITDEF SYSCTRL_MMAPN, 4         ; State of MMAP when an NMI occurred
 115:     -	        	BITDEF SYSCTRL_TRPRE0, 5        ; Number of prefixes for trace
 116:     -	        	BITDEF SYSCTRL_TRPRE1, 6
 117:     -	        	BITDEF SYSCTRL_RESERVED, 7      ; Unused bit
 118:				;
 119:				; MMAP page registers
 120:     -	        	BITDEF MMAP_PROT, 7             ; Write protection
 121:     -	        	BITDEF MMAP_SUPER, 6            ; I/O enable
 122:     -	003F'         	MMAP_PAGE_MASK  equ 0x3f        ; RAM page number bits
 123:				;
 124:				; IOA_INT_EN and IOA_INT_PEND registers.
 125:     -	0008'         	INTS_NUM        equ 8           ; Number of possible interrupt sources
 126:     -	        	BITDEF INT_SER1_TX, 0           ; Serial port 1 transmitter buffer is half full or less
 127:     -	        	BITDEF INT_SER1_RX, 1           ; Serial port 1 receiver has data
 128:     -	        	BITDEF INT_SER2_TX, 2           ; Serial port 2 transmitter buffer is half full or less
 129:     -	        	BITDEF INT_SER2_RX, 3           ; Serial port 2 receiver has data
 130:     -	        	BITDEF INT_TICK, 4              ; Regular timekeeping
 131:				;
 132:				; IOA_NMI_REASONS register.
 133:     -	0004'         	NMI_REASONS_NUM equ 4           ; Number of reasons for an NMI
 134:     -	        	BITDEF NMI_SWITCH, 0;           ; Front panel switch
 135:     -	        	BITDEF NMI_PROT_VIOL, 1;        ; Write protection violation
 136:     -	        	BITDEF NMI_SUPER_VIOL, 2;       ; Supervisor violation
 137:     -	        	BITDEF NMI_TRACE, 3;            ; Debugger trace (single step)
 138:     -	000F'         	NMI_REASONS_ALL equ NMI_SWITCH_MASK + NMI_PROT_VIOL_MASK + NMI_SUPER_VIOL_MASK + NMI_TRACE_MASK
 139:				;
 140:				; Serial CSRs (IOA_SER1_CSR and IOA_SER2_CSR).
 141:     -	        	BITDEF SER_CSR_RX_EMPTY, 0      ; Receiver buffer is empty
 142:     -	        	BITDEF SER_CSR_RX_ALHALF, 1     ; Receiver buffer is at least half full
 143:     -	        	BITDEF SER_CSR_RX_FULL, 2       ; Receiver buffer is full
 144:     -	        	BITDEF SER_CSR_FRAME_ERR, 3     ; Framing error in last character
 145:     -	        	BITDEF SER_CSR_TX_EMPTY, 4      ; Transmitter buffer is empty
 146:     -	        	BITDEF SER_CSR_TX_ALHALF, 5     ; Transmitter buffer is at least half full
 147:     -	        	BITDEF SER_CSR_TX_FULL, 6       ; Transmitter buffer is full
 148:				; Bit 7 is not used.
 149:				;
 150:				; I2C (Inter-Integrated Circuit) master interface. Used for RTC (DS1672).
 151:				; Bits in IOA_I2C_CSR
 152:     -	        	BITDEF I2C_CSR_ACKN, 0          ; (Read / write) acknowledge from receiving device
 153:     -	        	BITDEF I2C_CSR_START, 1         ; (Write only) trigger start sequence
 154:     -	        	BITDEF I2C_CSR_STOP, 2          ; (Write only) trigger stop sequence
 155:     -	        	BITDEF I2C_CSR_BUSY, 7          ; (Read only) transceiver busy
 156:				;
 157:				; SPI (Serial Peripheral Interface) master interface. Used for memory card.
 158:				; Bits in IOA_SPI_CSR
 159:     -	        	BITDEF SPI_CSR_FAST, 0          ; (Read / write) SPI speed select
 160:     -	        	BITDEF SPI_CSR_MC_SS, 1         ; (Read / write) memory card slave select
 161:     -	        	BITDEF SPI_CSR_BUSY, 7          ; (Read only) transceiver busy
 162:				
**** cpm3.z80 ****
  27:				                include "mmc.i"         ; Memory card
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/mmc.i ****
   1:				; *******************************************
   2:				; * ZARC Monitor Memory Card Include File   *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 7/8/2020                  *
   5:				; *******************************************
   6:				;
   7:				;
   8:				; Note that ld80 only considers the first six characters of labels significant.
   9:				;
  10:				; The following conditionals are intended to allow the same include file to be
  11:				; used in the defining module and elsewhere as required. Some includes are used
  12:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  13:				; the extern and public statements are not desirable.
  14:				;
  15:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  16:     -	0001'         	                ifndef mmc          ; Inhibit for this module
  17:				; Functions
  18:				                extern mccold       ; Cold start initialisation
  19:				                extern mcinit       ; Initialise memory card
  20:				                extern mcprer       ; Print memory card error text
  21:				                extern mcrvrs       ; Raw read / verify sector
  22:				                extern mcrws        ; Raw write sector
  23:				; Variables
  24:				                extern mcstat       ; Card state (MC_STAT_xxx)
  25:				                extern mcstat       ; Card state (MMC_STAT_xxx)
  26:				                extern mcprc        ; Physical read sector counter
  27:				                extern mcpwc        ; Physical write sector counter
  28:				                extern mcuwsc       ; Unchanged sector writes skipped
  29:				;
  30:				                endif
  31:				            endif
  32:				;
  33:				;
  34:     -	0200'         	MMC_SECTOR_SIZE             equ 512     ; Sector size
  35:     -	0009'         	MMC_LOG2_SEC_SIZE           equ 9       ; Save number of shifts for above
  36:     -	0040'         	MMC_CMD_START               equ 0x40    ; Command start bits (01b) shifted for
  37:				                                        ; command byte
  38:     -	0001'         	MMC_CMD_STOP                equ 0x01    ; Stop bit (in CRC byte)
  39:				;
  40:				;
  41:				; Card state (mcstat) states.
  42:     -	        	                ENUM_START
  43:     -	        	                ENUM MMC_STAT_IDLE      ; Not initialised
  44:     -	        	                ENUM MMC_STAT_INIT      ; Initialised (can do raw read / writes)
  45:				
  46:     -	        	                ENUM_END MC_STATES  ; Number of states
  47:				;
  48:				;
  49:				; Memory card command structure
  50:     -	        	                STRUCT
  51:     -	        	                STR_BYTE MMC_CMD    ; Command including start bits
  52:     -	        	                STR_BYTE MMC_ARG1   ; Arguments
  53:     -	        	                STR_BYTE MMC_ARG2   ; Arguments
  54:     -	        	                STR_BYTE MMC_ARG3   ; Arguments
  55:     -	        	                STR_BYTE MMC_ARG4   ; Arguments
  56:     -	        	                STR_BYTE MMC_CRC    ; CRC and stop bit
  57:     -	        	                STR_END MMC_SIZE
  58:				;
  59:				;
  60:				; SPI mode commands (CMDn from MMC-System-Spec-v3.31.pdf chapter 4.9).
  61:     -	0000'         	MMC_CMD_GO_IDLE_STATE       equ 0   ; Resets the memory card
  62:     -	0001'         	MMC_CMD_SEND_OP_COND        equ 1   ; Sends host capacity support information and init.
  63:     -	0009'         	MMC_CMD_SEND_CSD            equ 9   ; Read card specific data
  64:     -	000A'         	MMC_CMD_SEND_CID            equ 10  ; Read card identification
  65:     -	000D'         	MMC_CMD_SEND_STATUS         equ 13  ; Read card status register
  66:     -	0010'         	MMC_CMD_SET_BLOCKLEN        equ 16  ; Set block length (in bytes)
  67:     -	0011'         	MMC_CMD_READ_SINGLE_BLOCK   equ 17  ; Reads a block
  68:     -	0018'         	MMC_CMD_WRITE_BLOCK         equ 24  ; Writes a block
  69:     -	0037'         	MMC_CMD_APP_CMD             equ 55  ; Next command is an application specific command
  70:     -	003B'         	MMC_CMD_CRC_ON_OFF          equ 59  ; Turns the CRC option on or off
  71:				;
  72:				; The list describes all the application specific commands supported/reserved by the 
  73:				; memory card. All the following commands shall be preceded with APP_CMD (CMD55).
  74:     -	0029'         	MMC_ACMD_MC_SEND_OP_COND    equ 41  ; Sends host capacity support information and init
  75:				;
  76:				; R1 response bits
  77:     -	        	BITDEF MMC_R1_IDLE, 0           ; In idle state
  78:     -	        	BITDEF MMC_R1_ERA_RST, 1        ; Erase reset
  79:     -	        	BITDEF MMC_R1_ILL_CMD, 2        ; Illegal command
  80:     -	        	BITDEF MMC_R1_CMD_CRC_ERR, 3    ; Command CRC error
  81:     -	        	BITDEF MMC_R1_ERA_SEQ_ERR, 4    ; Erase sequence error
  82:     -	        	BITDEF MMC_R1_ADDR_ERR, 5       ; Address error
  83:     -	        	BITDEF MMC_R1_PAR_ERR, 6        ; Parameter error
  84:     -	        	BITDEF MMC_R1_START, 7          ; Zero identifies an R1 response
  85:				;
  86:				;
  87:     -	0006'         	MMC_CID_PNM_SIZE      equ 6   ; Product name length (bytes)
  88:				;
  89:				; Card IDentification (CID) register (128 bits)
  90:     -	        	                STRUCT
  91:     -	        	                STR_BYTE MMC_CID_MID    ; Manufacturer ID
  92:     -	        	                STR_WORD MMC_CID_OID    ; OEM/Application ID
  93:     -	        	                STR_BLOCK MMC_CID_PNM, MMC_CID_PNM_SIZE ; Product name
  94:     -	        	                STR_BYTE MMC_CID_PRV    ; Product revision
  95:     -	        	                STR_LONG MMC_CID_PSN    ; Product serial number
  96:     -	        	                STR_BYTE MMC_CID_MDT    ; Manufacturing date
  97:     -	        	                STR_BYTE MMC_CID_CRC    ; CRC7 checksum and "1"
  98:     -	        	                STR_END MMC_CID_SIZE
  99:				;
 100:				;
 101:				; Card-Specific Data (CSD) register (128 bits). It contains a number of bit fields
 102:				; that aren't necessarily byte aligned. In these cases, the entries simply identify
 103:				; the bit numbers contained.
 104:     -	        	                STRUCT
 105:     -	        	                STR_BYTE MMC_CSD_VERSION    ; (127-120) CSD version, spec version
 106:     -	        	                STR_BYTE MMC_CSD_TAAC       ; (119-112) data read access-time-1
 107:     -	        	                STR_BYTE MMC_CSD_NSAC       ; (111-104) data read access-time-2
 108:     -	        	                STR_BYTE MMC_CSD_TR_SPD     ; (103-96) max. data transfer rate
 109:     -	        	                STR_BYTE MMC_CSD_95_88      ; Card command classes (MS 8 bits)
 110:     -	        	                STR_BYTE MMC_CSD_87_80      ; CCC (LS bits) and max. read data length
 111:     -	        	                STR_BYTE MMC_CSD_79_72      ; Flags and C_SIZE bits 10 and 11
 112:     -	        	                STR_BYTE MMC_CSD_71_64      ; C_SIZE bits 2 to 9
 113:     -	        	                STR_BYTE MMC_CSD_63_56      ; C_SIZE bits 1 to 0 and some currents
 114:     -	        	                STR_BYTE MMC_CSD_55_48      ; Currents & C_SIZE_MULT (MS 2 bits)
 115:     -	        	                STR_BYTE MMC_CSD_47_40      ; C_SIZE_MULT (LS bit) and erase size (part)
 116:     -	        	                STR_BYTE MMC_CSD_39_32      ; Erase size (part) and WP group size
 117:     -	        	                STR_BYTE MMC_CSD_31_24      ; WP group enable, ECC and write parameters (part)
 118:     -	        	                STR_BYTE MMC_CSD_23_16      ; Write block lenth (part) and reserved
 119:     -	        	                STR_BYTE MMC_CSD_15_8       ; Flags
 120:     -	        	                STR_BYTE MMC_CSD_CRC        ; CRC7 checksum and "1"
 121:     -	        	                STR_END MMC_CSD_SIZE
 122:				
**** cpm3.z80 ****
  28:				                include "disks.i"       ; Disk parameters
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/disks.i ****
   1:				; *******************************************
   2:				; * ZARC Monitor Disk Format Include File   *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 13/11/2020                *
   5:				; *******************************************
   6:				;
   7:				; Constants and structures for use when handling disks (memory cards) in the
   8:				; monitor.
   9:				;
  10:				; Master Boot Record (MBR) parameters. This follows the format of the "Structure
  11:				; of a classical generic MBR" at https://en.wikipedia.org/wiki/Master_boot_record#PTE
  12:				; This is consistent what what I found on one of the MMC cards I examined.
  13:     -	AA55'         	DSK_BOOT_SIGN               equ 0xaa55
  14:     -	01FE'         	DSK_BOOT_SIGN_OFFSET        equ 0x01fe
  15:     -	0004'         	DSK_MAX_PARTS               equ 4       ; Maximum allowed in a "classical" MBR
  16:     -	01BE'         	DSK_PART1_OFFSET            equ 0x01be
  17:     -	007F'         	DSK_PART_TYP_EXPER          equ 0x7f    ; Experimental (no CP/M 2.2 type coded)
  18:				;
  19:				;
  20:				; Partition table entry structure.
  21:				; Derived from https://en.wikipedia.org/wiki/Master_boot_record#PTE
  22:     -	        	                STRUCT
  23:     -	        	                STR_BYTE DPART_STATUS
  24:				; CHS of first sector.
  25:     -	        	                STR_BYTE DPART_START_HD     ; Head
  26:     -	        	                STR_BYTE DPART_START_SEC    ; Cylinder MS bits and sector
  27:     -	        	                STR_BYTE DPART_START_CYL    ; Cylinder
  28:     -	        	                STR_BYTE DPART_TYPE
  29:				; CHS of last sector.
  30:     -	        	                STR_BYTE DPART_END_HD
  31:     -	        	                STR_BYTE DPART_END_SEC
  32:     -	        	                STR_BYTE DPART_END_CYL
  33:				; Logical Block Address (LBA) parameters.
  34:     -	        	                STR_LONG DPART_START_LBA    ; Start sector
  35:     -	        	                STR_LONG DPART_SIZE_SECS    ; Size in sectors
  36:     -	        	                STR_END DPART_SIZE
  37:				
**** cpm3.z80 ****
  29:				                include "interrupts.i"  ; Interrupts
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/interrupts.i ****
   1:				; ***********************************
   2:				; * ZARC Interrupts Routines        *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 30/5/2020         *
   5:				; ***********************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant.
   8:				;
   9:				; The following conditionals are intended to allow the same include file to be
  10:				; used in the defining module and elsewhere as required. Some includes are used
  11:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  12:				; the extern and public statements are not desirable.
  13:				;
  14:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  15:     -	0001'         	                ifndef interrupts   ; Inhibit for this module
  16:				; Variables 
  17:				                extern itenfl   ; Int. enable flag (0 = basic, 1 = normal I/O mode)
  18:				                extern itdsct   ; DI nest count
  19:				; Functions
  20:				                extern itinit   ; Initialise interrupt variables and set basic I/O mode
  21:				                extern itstrt   ; Start monitor interrupts
  22:				                extern itena    ; Enable interrupts if safe
  23:				                extern itdis    ; Disable interrupts and keep count
  24:				                extern itsvec   ; Set interrupt vector to point to a new service routine
  25:				;
  26:				                endif
  27:				            endif
  28:				
**** cpm3.z80 ****
  30:				                include "cache.i"       ; MMC sector cache
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cache.i ****
   1:				; ***********************************************
   2:				; * ZARC Monitor Memory Card Cache Include File *
   3:				; * Written by: Merlin Skinner                  *
   4:				; * Date Started: 23/11/2020                    *
   5:				; ***********************************************
   6:				;
   7:				; Constants and structures associated with the MMC memory card sector cache.
   8:				;
   9:				; "Dirty" in this case indicates sector data that is in the cache, but has not yet
  10:				; been written to the MMC.
  11:				;
  12:				;
  13:				; The following conditionals are intended to allow the same include file to be
  14:				; used in the defining module and elsewhere as required. Some includes are used
  15:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  16:				; the extern and public statements are not desirable.
  17:				;
  18:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  19:     -	0001'         	                ifndef cache        ; Inhibit for this module
  20:				; Functions
  21:				                extern cacold       ; Reset cache (cold start)
  22:				                extern cawarm       ; Initialise cache (warm start)
  23:				                extern carpt        ; Report status
  24:				                extern caflus       ; Flush cache
  25:				                extern cars         ; Read sector
  26:				                extern caws         ; Write sector
  27:				                extern cacrs        ; Read CP/M sector
  28:				                extern cacws        ; Write CP/M sector
  29:				; Variables
  30:				; Counters
  31:				                extern cntrs        ; Read MMC sector counter
  32:				                extern cntws        ; Write MMC sector counter
  33:				                extern cntcrs       ; Read CP/M sector counter
  34:				                extern cntcws       ; Write CP/M sector counter
  35:				                endif
  36:				            endif
  37:				;
  38:				;
  39:     -	0008'         	MCCA_PAGES          equ 8               ; RAM (16 KB) pages used for cache
  40:     -	0020'         	MCCA_BUFS_PER_PAGE  equ MMAP_PAGE_SIZE / MMC_SECTOR_SIZE
  41:     -	0100'         	MCCA_BUFFERS        equ MCCA_PAGES * MCCA_BUFS_PER_PAGE ; No. of sector buffers
  42:     -	0080'         	MCCA_DIRT_THRES     equ MCCA_BUFFERS / 2    ; Target no. of dirty buffers
  43:     -	0004'         	MMAP_CP3_BANKS      equ 4               ; Number of CP/M 3 banks
  44:				;
  45:				;
  46:				; Sector cache structure. This contains the data associated with a single cached
  47:				; sector.
  48:     -	        	                STRUCT
  49:     -	        	                STR_BYTE MCCAS_STATUS       ; Status byte
  50:     -	        	                STR_24BIT MCCAS_SECTOR      ; 24-bit sector number
  51:     -	        	                STR_WORD MCCAS_CSUM         ; Checksum of data
  52:     -	        	                STR_WORD MCCAS_ADDR         ; Address of data *1
  53:     -	        	                STR_BYTE MCCAS_PAGE         ; Page containing data
  54:     -	        	                STR_END MCCAS_SIZE
  55:				;
  56:				; *1 Address is in the range 0x8000 to 0xbfff to allow direct use when the page
  57:				; in MCCAS_PAGE is mapped to bank 2.
  58:				;
  59:				;
  60:				; MCCAS_STATUS byte is defined as follows:
  61:				; Bits 0 to 3 - set if the corresponding CP/M sector in this MMC sector is dirty.
  62:     -	        	BITDEF MCCAS_STAT_CPM0, 0       ; CP/M sector 0 (0 to 0x7f)
  63:     -	        	BITDEF MCCAS_STAT_CPM1, 1       ; CP/M sector 1 (0x80 to 0x0ff)
  64:     -	        	BITDEF MCCAS_STAT_CPM2, 2       ; CP/M sector 2 (0x100 to 0x17f)
  65:     -	        	BITDEF MCCAS_STAT_CPM3, 3       ; CP/M sector 3 (0x180 to 0x1ff)
  66:     -	        	BITDEF MCCAS_STAT_VALID, 4      ; Buffer contains valid data
  67:				;
  68:     -	000F'         	MCCAS_STAT_DIRT_MASK    equ MCCAS_STAT_CPM0_MASK + MCCAS_STAT_CPM1_MASK + MCCAS_STAT_CPM2_MASK + MCCAS_STAT_CPM3_MASK
  69:				
**** cpm3.z80 ****
  31:				                include "utility.i"     ; Utility functions
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/utility.i ****
   1:				; ***********************************
   2:				; * ZARC Monitor Utility Routines   *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 16/5/2020         *
   5:				; ***********************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant
   8:				;
   9:				; The following conditionals are intended to allow the same include file to be
  10:				; used in the defining module and elsewhere as required. Some includes are used
  11:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  12:				; the extern and public statements are not desirable.
  13:				;
  14:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  15:     -	0001'         	                ifndef utility      ; Inhibit for this module
  16:				;
  17:				                extern cwnwln       ; Write new line characters to console.
  18:				                extern conwms       ; Print null-terminated string to the console
  19:				                extern conwmn       ; Print message <n> in a list
  20:				                extern skpspc       ; Step hl past spaces
  21:				                extern toupca       ; Convert character in A to upper case
  22:				                extern toloca       ; Convert character in A to lower case
  23:				                extern cwvich       ; Print only visible 7-bit characters
  24:				                extern cwpspc       ; Print a space
  25:				                extern mtwdli       ; Match word in a string against list of options
  26:				                extern cwphnb       ; Print least-significant nibble in A in hexadecimal
  27:				                extern cwphby       ; Print A in hexadecimal
  28:				                extern cwphwd       ; Print HL in hexadecimal
  29:				                extern cwpdby       ; Print A in decimal. Leading zeros are suppressed
  30:				                extern cwpdwd       ; Print HL in decimal. Leading zeros are suppressed
  31:				                extern cwpdlo       ; Print DEHL in decimal. Leading zeros are suppressed
  32:				                extern rdhxwd       ; Read a 16-bit hexadecimal number from a string
  33:				                extern rdduwd       ; Read a 16-bit unsigned decimal number from a string
  34:				                extern rddulo       ; Read a 32-bit unsigned decimal number from a string
  35:				;
  36:				                endif
  37:				            endif
  38:				;
  39:				;
  40:				; mtwdli (match word in a string against list of options) option bits. Each bit
  41:				; has the described effect if set.
  42:     -	        	BITDEF MTWDLI_ABBREV, 0                 ; Enable "." abbreviation
  43:     -	        	BITDEF MTWDLI_ICASE, 1                  ; Ignore case when matching
  44:     -	        	BITDEF MTWDLI_TERM, 7                   ; Terminator found (internal use only)
  45:				
**** cpm3.z80 ****
  32:				                include "time.i"        ; Routines associated with time
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/time.i ****
   1:				; ***********************************
   2:				; * ZARC Monitor Time Routines      *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 30/7/2020         *
   5:				; ***********************************
   6:				;
   7:				; The system keeps track of time as a Unix-style 32-bit number. Unlike Unix, this
   8:				; is treated as an unsigned integer and so will not suffer from the Year 2038 problem
   9:				; as it doubles the allowable postive time. It does, however, mean that it is not
  10:				; possible to represent dates before 1970.
  11:				
  12:				; Note that ld80 only considers the first six characters of labels significant.
  13:				;
  14:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  15:     -	0001'         	                ifndef time         ; Inhibit for this module
  16:				;
  17:				                extern tird         ; Read current time and date
  18:				                extern tiwr         ; Set time and date
  19:				                extern tiitos       ; Convert integer time to structure
  20:				                extern tistoi       ; Convert structure time to integer
  21:				                extern cwptm        ; Print time structure to console
  22:				;
  23:				                endif
  24:				            endif
  25:				;
  26:				;
  27:     -	0046'         	TIM_EPOCH_YEAR  equ 70              ; Epoch year byte
  28:				;
  29:				; The following structure is used to store dates and times in human units. It is based
  30:				; on the Unix time.h tm structure.
  31:     -	        	                STRUCT
  32:     -	        	                STR_BYTE TM_SECS    ; Seconds [0,59]
  33:     -	        	                STR_BYTE TM_MINS    ; Minutes [0,59]
  34:     -	        	                STR_BYTE TM_HOURS   ; Hours [0,23]
  35:     -	        	                STR_BYTE TM_MDAY    ; Day of month [1,31]
  36:     -	        	                STR_BYTE TM_MON     ; Month of year [1,12]
  37:     -	        	                STR_BYTE TM_YEAR    ; Years since 1900 [70,255]
  38:     -	        	                STR_BYTE TM_WDAY    ; Day of week [0,6] (Sunday = 0)
  39:     -	        	                STR_WORD TM_YDAY    ; Day of year [0,365]
  40:     -	        	                STR_BYTE TM_DST     ; Daylight savings status
  41:     -	        	                STR_END TM_SIZE
  42:				
  43:				; TM_DST can have any of the following values:
  44:     -	        	                ENUM_START
  45:     -	        	                ENUM TMDST_UNKNOWN
  46:     -	        	                ENUM TMDST_GMT      ; The time is GMT
  47:     -	        	                ENUM TMDST_DST      ; The time has DST applied (is one hour advanced)
  48:     -	        	                ENUM_END TMDST_NUM  ; Number of possible values
  49:				
**** cpm3.z80 ****
  33:				                include "cpm.i"         ; CP/M support
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm.i ****
   1:				; *******************************************************
   2:				; * ZARC Monitor CP/M 2.2 Definitions                   *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 26/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Definitions related to CP/M running under the monitor programme. It may also
   8:				; be used for CP/M applications.
   9:				;
  10:				; Note that ld80 only considers the first six characters of labels significant.
  11:				;
  12:				; The following conditionals are intended to allow the same include file to be
  13:				; used in the defining module and elsewhere as required. Some includes are used
  14:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  15:				; the extern and public statements are not desirable.
  16:				;
  17:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  18:     -	0001'         	                ifndef cpm          ; Inhibit for this module
  19:				; Constants
  20:				;
  21:				; Variables 
  22:				                extern cppags       ; CP/M page allocations
  23:				;
  24:				; Functions
  25:				                extern cpinit       ; Load and start CP/M
  26:				                extern cpmem        ; Allocate CP/M pages
  27:				                extern cpprt        ; Find CP/M partition
  28:				;
  29:				                endif
  30:				            endif
  31:				;
  32:				;
  33:				;
  34:				; ****************
  35:				; * Memory Usage *
  36:				; ****************
  37:				;
  38:				;
  39:				; Note: memory banks are allocated by the monitor's initialisation code.
  40:     -	0004'         	MMAP_CPM_PAGES      equ 4               ; Number of 16 kB pages
  41:				;
  42:				; The MS byte of INT_VEC_TABLE comes from the Z80 I register, and the LS byte
  43:				; from the FPGA. The 0xe0 offset is chosen to allow the table to reside at the
  44:				; top of memory (0xffe0 to 0xffff).
  45:     -	FFE0'         	INT_VEC_TABLE   equ 0xffe0              ; Interrupt mode 2 vector table
  46:				;
  47:				; Copied from CP/M manual appendix A.
  48:				; MSIZE             equ 64              ; CP/M version memory size in kilobytes
  49:				;
  50:				; "BIAS" is the address offset from 0x3400 for memory systems other than 16 K.
  51:				;BIAS               equ (MSIZE-20) * 1024
  52:     -	A200'         	CPM_BIAS            equ 0xa200          ; For CompuPro64K_CPM
  53:     -	D600'         	CCP_START           equ 0x3400 + CPM_BIAS   ; Base of CCP
  54:     -	DE06'         	BDOS_START          equ CCP_START + 0x0806  ; Base of BDOS
  55:     -	EC00'         	BIOS_START          equ CCP_START + 0x1600  ; Base of BIOS
  56:     -	002C'         	BIOS_CPM_START_SEC  equ 44              ; First CP/M sector of BIOS
  57:     -	1000'         	BIOS_MAX_SIZE       equ 4096            ; 2 KB allocation for BIOS stored on MMC (ZARC)
  58:     -	0100'         	TPA_START           equ 0x0100          ; Transient Programme Area
  59:				;
  60:				; Page zero.
  61:     -	0003'         	IOBYTE              equ 0x0003          ; Intel I/O byte
  62:     -	0004'         	CDISK               equ 0x0004          ; Current disk (0="A") & user no. (in high nibble)
  63:     -	005C'         	FCB1                equ 0x005c          ; Default FCB 1
  64:     -	006C'         	FCB2                equ 0x006c          ; Default FCB 2 (overwritten if FCB 1 is opened)
  65:				; Default 128-byte disk buffer, also filled with the command line when a transient
  66:				; is loaded under the CCP.
  67:     -	0080'         	DEF_BUFFER          equ 0x80
  68:     -	0080'         	DEF_BUFFER_SIZE     equ 0x80
  69:				;
  70:				; IOBYTE bit definitions.
  71:     -	0003'         	IOB_CON_MASK        equ 0x03
  72:     -	000C'         	IOB_RDR_MASK        equ 0x0c
  73:     -	0030'         	IOB_PUN_MASK        equ 0x30
  74:     -	00C0'         	IOB_LST_MASK        equ 0xc0
  75:				;
  76:				; BIOS option bits.
  77:     -	        	BITDEF BIOS_OPT_DEBUG, 0                ; Enable BIOS debugging messages
  78:     -	        	BITDEF BIOS_OPT_NOINTS, 1               ; Disables interrupts (use basic I/O mode)
  79:     -	        	BITDEF BIOS_OPT_RAWCON, 2               ; Disables ADM-3A to VT-100 translation
  80:				;
  81:				;
  82:				;
  83:				; ***************
  84:				; * Disk System *
  85:				; ***************
  86:				;
  87:				;
  88:				; Note: NUM_DISKS reduced to 9 from 16 in preparation for adding CP/M 3 support.
  89:     -	0080'         	CPM_SECTOR_SIZE     equ 128             ; CP/M disk sector size
  90:     -	0009'         	NUM_DISKS           equ 9               ; Number of disk drives
  91:     -	0010'         	NUM_DISKS_MAX       equ 16              ; Maximum number of disk drives
  92:     -	0000'         	CPM_SYS_SIZE        equ 1024 * 1024     ; System area size (bytes)
  93:     -	0000'         	CPM_DISK_SIZE       equ 1024 * 1024     ; Disk size (bytes)
  94:     -	0800'         	CPM_BLOCK_SIZE      equ 2048            ; Allocation block size (bytes)
  95:     -	0200'         	CPM_DIR_ENTRIES     equ 512             ; Number of directory entries
  96:     -	0008'         	FILENAME_SIZE       equ 8               ; Filename size
  97:     -	0003'         	FILEEXT_SIZE        equ 3               ; File extension size
  98:     -	001A'         	FILE_EOF            equ 0x1a            ; End of file (^Z)
  99:     -	000F'         	MAX_USER            equ 15              ; Maximum user number
 100:				;
 101:     -	0001'         	BDOS_READ_SEQ_EOF   equ 1               ; Sequential read EOF error code
 102:				;
 103:				; CP/M 2.2 Disk Parameter Header (DPH) structure.
 104:     -	        	                STRUCT
 105:     -	        	                STR_WORD DPH_XLT        ; Address of sector translation table
 106:     -	        	                STR_WORD DPH_SCRATCH0   ; BDOS scratch area
 107:     -	        	                STR_WORD DPH_SCRATCH1
 108:     -	        	                STR_WORD DPH_SCRATCH2
 109:     -	        	                STR_WORD DPH_DIRBF      ; BDOS directory scratch area
 110:     -	        	                STR_WORD DPH_DPB        ; Pointer to DPB
 111:     -	        	                STR_WORD DPH_CSV        ; Pointer to the directory checksum vector
 112:     -	        	                STR_WORD DPH_ALV        ; Pointer to the allocation vector
 113:     -	        	                STR_END DPH_SIZE
 114:				;
 115:				;
 116:				; CP/M 2.2 Disk Parameter Block (DPB) structure.
 117:     -	        	                STRUCT
 118:     -	        	                STR_WORD DPB_SPT        ; Number of 128-byte records per track
 119:     -	        	                STR_BYTE DPB_BSH        ; Block shift. 3 => 1k, 4 => 2k, 5 => 4k....
 120:     -	        	                STR_BYTE DPB_BLM        ; Block mask. 7 => 1k, 0Fh => 2k, 1Fh => 4k...
 121:     -	        	                STR_BYTE DPB_EXM        ; Extent mask
 122:     -	        	                STR_WORD DPB_DSM        ; Maximum block number
 123:     -	        	                STR_WORD DPB_DRM        ; Maximum directory entry number
 124:     -	        	                STR_BYTE DPB_AL0        ; Directory allocation bitmap
 125:     -	        	                STR_BYTE DPB_AL1
 126:     -	        	                STR_WORD DPB_CKS        ; Checksum vector size, 0 for a fixed disc
 127:     -	        	                STR_WORD DPB_OFF        ; Offset, number of reserved tracks
 128:     -	        	                STR_END DPB_SIZE
 129:				;
 130:				;
 131:				; Directory entry structure.
 132:     -	        	                STRUCT
 133:     -	        	                STR_BYTE DIRE_USER      ; User number. 0xe5 if entry unused
 134:     -	        	                STR_BLOCK DIRE_NAME, FILENAME_SIZE  ; Filename
 135:     -	        	                STR_BLOCK DIRE_TYP, FILEEXT_SIZE    ; File type
 136:     -	        	                STR_BYTE DIRE_EX        ; Extent counter, low byte (0-31)
 137:     -	        	                STR_BYTE DIRE_S1        ; Reserved, set to 0
 138:     -	        	                STR_BYTE DIRE_S2        ; Extent counter, high byte
 139:     -	        	                STR_BYTE DIRE_RC        ; Record count (low byte)
 140:     -	        	                STR_BLOCK DIRE_ALLOC, 16 ; Associated block numbers
 141:     -	        	                STR_END DIRE_SIZE
 142:				;
 143:     -	0001'         	                assert DIRE_SIZE = 0x20
 144:				;
 145:				;
 146:				; File Control Block (FCB) structure.
 147:     -	        	                STRUCT
 148:     -	        	                STR_BYTE FCB_DRIVE      ; Drive. 0 for default, 1-16 for A-P
 149:     -	        	                STR_BLOCK FCB_NAME, FILENAME_SIZE   ; Filename in ASCII upper-case
 150:     -	        	                STR_BLOCK FCB_TYP, FILEEXT_SIZE     ; File type
 151:     -	        	                STR_BYTE FCB_EX         ; Current extent (*)
 152:     -	        	                STR_BYTE FCB_S1         ; Reserved (*)
 153:     -	        	                STR_BYTE FCB_S2         ; Extent high byte (*)
 154:     -	        	                STR_BYTE FCB_RC         ; Record count (*)
 155:     -	        	                STR_BLOCK FCB_ALLOC, 16 ; Associated block numbers
 156:     -	        	                STR_BYTE FCB_CR         ; Current record within extent
 157:     -	        	                STR_BLOCK FCB_RECORD, 3 ; Record number (low byte first)
 158:     -	        	                STR_END FCB_SIZE
 159:				;
 160:				; * - Set this to 0 when opening a file and then leave it to CP/M. You can
 161:				; rewind a file by setting EX, RC, S2 and CR to 0.
 162:				;
 163:				;
 164:				;
 165:				; **************
 166:				; * BIOS Calls *
 167:				; **************
 168:				;
 169:				;
 170:				; Calculate offsets into jump tables. Entries here must match the jump table in
 171:				; the BIOS. The base address of the BIOS must be added to these addresses. A
 172:				; call routine might look like:
 173:				;
 174:				; Call BIOS, allowing for its unknown base address.
 175:				; Call with:
 176:				; BC - operand (depends on BIOS function called)
 177:				; DE - operand (depends on BIOS function called)
 178:				; HL - offset for the routine (e.g. BIOS_CONIN)
 179:				; call_bios       push de
 180:				;                 ex de, hl
 181:				;                 ld hl, (1)              ; Find WBOOT (warm boot) address
 182:				;                 add hl, de              ; Add offset
 183:				;                 pop de
 184:				;                 jp (hl)                 ; Jump to BIOS then return to caller
 185:				;
 186:				; The above method is a bit clumsy, but then application code shouldn't normally
 187:				; call the BIOS directly.
 188:				;
 189:     -	        	    JPTBL_START 0                   ; Generate offsets as BIOS_START isn't always known
 190:				;
 191:				; Note - cold start routine omitted to align with use of address at (1) to find BIOS.
 192:     -	        	    JPTBL_ENTRY BIOS_WBOOT          ; Warm boot - reload command processor
 193:     -	        	    JPTBL_ENTRY BIOS_CONST          ; Console status
 194:     -	        	    JPTBL_ENTRY BIOS_CONIN          ; Console input
 195:     -	        	    JPTBL_ENTRY BIOS_CONOUT         ; Console output
 196:     -	        	    JPTBL_ENTRY BIOS_PLIST          ; Printer output
 197:     -	        	    JPTBL_ENTRY BIOS_PUNCH          ; Paper tape punch output
 198:     -	        	    JPTBL_ENTRY BIOS_READER         ; Paper tape reader input
 199:     -	        	    JPTBL_ENTRY BIOS_HOME           ; Move disc head to track 0
 200:     -	        	    JPTBL_ENTRY BIOS_SELDSK         ; Select disc drive
 201:     -	        	    JPTBL_ENTRY BIOS_SETTRK         ; Set track number
 202:     -	        	    JPTBL_ENTRY BIOS_SETSEC         ; Set sector number
 203:     -	        	    JPTBL_ENTRY BIOS_SETDMA         ; Set DMA address
 204:     -	        	    JPTBL_ENTRY BIOS_READ           ; Read a sector
 205:     -	        	    JPTBL_ENTRY BIOS_WRITE          ; Write a sector
 206:				; CP/M 2 functions.
 207:     -	        	    JPTBL_ENTRY BIOS_LISTST         ; Status of list device
 208:     -	        	    JPTBL_ENTRY BIOS_SECTRAN        ; Sector translation for skewing
 209:				; CP/M 3 functions (not supported yet). From https://www.seasip.info/Cpm/bios.html
 210:     -	        	    JPTBL_ENTRY BIOS_CONOST         ; Status of console output
 211:     -	        	    JPTBL_ENTRY BIOS_AUXIST         ; Status of auxiliary input
 212:     -	        	    JPTBL_ENTRY BIOS_AUXOST         ; Status of auxiliary output
 213:     -	        	    JPTBL_ENTRY BIOS_DEVTBL         ; Address of devices table
 214:     -	        	    JPTBL_ENTRY BIOS_DEVINI         ; Initialise a device
 215:     -	        	    JPTBL_ENTRY BIOS_DRVTBL         ; Address of discs table
 216:     -	        	    JPTBL_ENTRY BIOS_MULTIO         ; Read/write multiple sectors
 217:     -	        	    JPTBL_ENTRY BIOS_FLUSH          ; Flush host buffers
 218:     -	        	    JPTBL_ENTRY BIOS_MOVE           ; Move a block of memory
 219:     -	        	    JPTBL_ENTRY BIOS_TIME           ; Real time clock
 220:     -	        	    JPTBL_ENTRY BIOS_SELMEM         ; Select memory bank
 221:     -	        	    JPTBL_ENTRY BIOS_SETBNK         ; Select bank for DMA operation
 222:     -	        	    JPTBL_ENTRY BIOS_XMOVE          ; Preload banks for MOVE
 223:     -	        	    JPTBL_ENTRY BIOS_USERF          ; System-depedent functions
 224:     -	        	    JPTBL_ENTRY BIOS_RESERV1        ; Reserved
 225:     -	        	    JPTBL_ENTRY BIOS_RESERV2        ; Reserved
 226:				; ZARC-specific items.
 227:     -	        	    JPTBL_BLOCK BIOS_ID, 3          ; BIOS ID ("ZRC")
 228:     -	        	    JPTBL_BLOCK BIOS_VER, 3         ; Version (see below)
 229:     -	        	    JPTBL_ENTRY BIOS_STARTUP        ; CP/M startup entry point
 230:     -	        	    JPTBL_ENTRY BIOS_MON_CALL       ; Call monitor function
 231:     -	        	    JPTBL_ENTRY BIOS_SUPER          ; Set supervisor state
 232:     -	        	    JPTBL_ENTRY BIOS_INT_DISABLE    ; Disable interrupts and keep count
 233:     -	        	    JPTBL_ENTRY BIOS_INT_ENABLE     ; Enable interrupts if safe
 234:     -	        	    JPTBL_ENTRY BIOS_TIRD           ; Read time and date (ZARC format)
 235:     -	        	    JPTBL_ENTRY BIOS_SET_TIMER      ; Set timer
 236:     -	        	    JPTBL_ENTRY BIOS_GET_TIMER      ; Get timer
 237:				;
 238:     -	        	    JPTBL_END BIOS_JPTBL_NEXT
 239:				;
 240:				; BIOS_VER is <reserved (zero)>, <major version>, <minor version>. The reserved
 241:				; byte may flag capabilities at some point.
 242:				;
 243:				;
 244:				;
 245:				; **************
 246:				; * BDOS Calls *
 247:				; **************
 248:				;
 249:				;
 250:				; From http://www.gaby.de/cpm/manuals/archive/cpm22htm/ch5.htm#Section_5.2
 251:				; In general, the function number is passed in register C with the information
 252:				; address in the double byte pair DE. Single byte values are returned in register
 253:				; A, with double byte values returned in HL. A zero value is returned when the
 254:				; function number is out of range. For reasons of compatibility, register A = L
 255:				; and register B = H upon return in all cases. Example call:
 256:				;   ld c, BDOS_CONIN    ; Read next character
 257:				;   call BDOS           ; Return character in A
 258:				;
 259:     -	0005'         	BDOS        equ 5               ; BDOS entry point
 260:				;
 261:     -	0000'         	BDOS_SYS_RST        equ 0       ; System Reset
 262:     -	0001'         	BDOS_CON_IN         equ 1       ; Console Input
 263:     -	0002'         	BDOS_CON_OUT        equ 2       ; Console Output
 264:     -	0003'         	BDOS_RDR_IN         equ 3       ; Reader Input
 265:     -	0004'         	BDOS_PUN_OUT        equ 4       ; Punch Output
 266:     -	0005'         	BDOS_LST_OUT        equ 5       ; List Output
 267:     -	0006'         	BDOS_DIRECT_CON_IO  equ 6       ; Direct Console I/O
 268:     -	0007'         	BDOS_GET_IO_BYTE    equ 7       ; Get I/O Byte
 269:     -	0008'         	BDOS_SET_IO_BYTE    equ 8       ; Set I/O Byte
 270:     -	0009'         	BDOS_PRINT_STRING   equ 9       ; Print String
 271:     -	000A'         	BDOS_READ_CON_BUFF  equ 10      ; Read Console Buffer
 272:     -	000B'         	BDOS_GET_CON_STAT   equ 11      ; Get Console Status
 273:     -	000C'         	BDOS_VERSION        equ 12      ; Return Version Number
 274:     -	000D'         	BDOS_RESET_DISK_SYS equ 13      ; Reset Disk System
 275:     -	000E'         	BDOS_SEL_DISK       equ 14      ; Select Disk
 276:     -	000F'         	BDOS_OPEN_FILE      equ 15      ; Open File
 277:     -	0010'         	BDOS_CLOSE_FILE     equ 16      ; Close File
 278:     -	0011'         	BDOS_SEARCH_FIRST   equ 17      ; Search for first matching directory entry
 279:     -	0012'         	BDOS_SEARCH_NEXT    equ 18      ; Search for next matching directory entry
 280:     -	0013'         	BDOS_DELETE_FILE    equ 19      ; Delete File
 281:     -	0014'         	BDOS_READ_SEQ       equ 20      ; Read Sequential
 282:     -	0015'         	BDOS_WRITE_SEQ      equ 21      ; Write Sequential
 283:     -	0016'         	BDOS_MAKE_FILE      equ 22      ; Make File
 284:     -	0017'         	BDOS_RENAME_FILE    equ 23      ; Rename File
 285:     -	0018'         	BDOS_GET_LOGIN_VEC  equ 24      ; Return Login Vector
 286:     -	0019'         	BDOS_GET_CURR_DISK  equ 25      ; Return Current Disk
 287:     -	001A'         	BDOS_SET_DMA_ADDR   equ 26      ; Set DMA Address
 288:     -	001B'         	BDOS_GET_ALLOC_ADDR equ 27      ; Get Addr (Alloc)
 289:     -	001C'         	BDOS_WRITE_PROT     equ 28      ; Write Protect Disk
 290:     -	001D'         	BDOS_GET_RO_VEC     equ 29      ; Get R/O Vector
 291:     -	001E'         	BDOS_SET_FILE_ATTR  equ 30      ; Set File Attributes
 292:     -	001F'         	BDOS_GET_DPB        equ 31      ; Get Addr (Disk Parms)
 293:     -	0020'         	BDOS_GET_SET_USER   equ 32      ; Set/Get User Code
 294:     -	0021'         	BDOS_READ_RANDOM    equ 33      ; Read Random
 295:     -	0022'         	BDOS_WRITE_RANDOM   equ 34      ; Write Random
 296:     -	0023'         	BDOS_GET_FILE_SIZE  equ 35      ; Compute File Size
 297:     -	0024'         	BDOS_SET_RANDOM_REC equ 36      ; Set Random Record
 298:     -	0025'         	BDOS_RESET_DRIVES   equ 37      ; Selectively reset disc drives
 299:     -	0028'         	BDOS_WRITE_RAN_ZFILL equ 40     ; Write Random with Zero Fill
 300:				;
 301:				; Functions 28 and 32 should be avoided in application programs to maintain upward
 302:				; compatibility with CP/M.
 303:				;
 304:				; Direct Console I/O (BDOS_DIRECT_CON_IO) command codes. There are additional
 305:				; codes supported by CP/M 3 (see cpm3.i).
 306:     -	00FF'         	DCONIO_GET_NO_WT    equ 0xff    ; Get character (no echo) else return zero
 307:     -	0000'         	DCONIO_PUT          equ 0x00    ; Put (write) character
 308:				;
 309:				
**** cpm3.z80 ****
  34:				                include "cpm3.i"        ; CP/M 3 support
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/cpm3.i ****
   1:				; *******************************************************
   2:				; * ZARC Monitor CP/M 3 Definitions                     *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 26/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Definitions related CP/M running under the monitor programme. It may also
   8:				; be used for CP/M applications.
   9:				;
  10:				; This include file contains defintions specific to CP/M 3. It is not a
  11:				; replacement for cpm.i, but rather an addition to it.
  12:				;
  13:				; Note that ld80 only considers the first six characters of labels significant.
  14:				;
  15:				; The following conditionals are intended to allow the same include file to be
  16:				; used in the defining module and elsewhere as required. Some includes are used
  17:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  18:				; the extern and public statements are not desirable.
  19:				;
  20:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  21:     -	0000'         	                ifndef cpm3         ; Inhibit for this module
  30:				                endif
  31:				            endif
  32:				;
  33:				;
  34:				;
  35:				; ****************
  36:				; * Memory Usage *
  37:				; ****************
  38:				;
  39:				;
  40:				; Note: memory banks are allocated by the monitor's initialisation code.
  41:     -	0004'         	MMAP_CP3_BANKS      equ 4               ; Number of CP/M 3 banks
  42:     -	000D'         	MMAP_CP3_PAGES      equ (3 * MMAP_CP3_BANKS) + 1    ; Number of 16 kB pages
  43:     -	0000'         	MMAP_CP3_BK0_ST     equ 0               ; CP/M bank 0 first page
  44:     -	0003'         	MMAP_CP3_BK1_ST     equ 3               ; CP/M bank 1 first page
  45:     -	0006'         	MMAP_CP3_BK2_ST     equ 6               ; CP/M bank 2 first page
  46:     -	0009'         	MMAP_CP3_BK3_ST     equ 9               ; CP/M bank 3 first page
  47:     -	000C'         	MMAP_CP3_COMM_PG    equ 0xc             ; CP/M common bank
  48:				;
  49:				;
  50:				;
  51:				; ***************
  52:				; * Disk System *
  53:				; ***************
  54:				;
  55:				;
  56:     -	0013'         	CPMLDR_START_SEC    equ 19              ; First MMC sector of CPMLDR
  57:				; CPMLDR_MAX_SIZE must be a multiple of MMC_SECTOR_SIZE (512).
  58:     -	2800'         	CPMLDR_MAX_SIZE     equ 10240           ; 10 KB allocation for CPMLDR
  59:     -	0100'         	TPA_START           equ 0x0100          ; Transient Programme Area
  60:     -	0008'         	CP3_NUM_DISKS       equ 8               ; Number of disk drives
  61:     -	0010'         	CP3_NUM_DISKS_MAX   equ 16              ; Maximum number of disk drives
  62:				; CP/M 3 drive A is CP/M 2.2 drive P to allow for initialisation.
  63:     -	0008'         	CP3_DRIVE_A         equ 8               ; Drive A MB offset
  64:     -	0001'         	CP3_DRIVE_B         equ 1               ; Drives B to H MB offset
  65:     -	0019'         	CP3_DPH_SIZE        equ 25              ; Disk Parameter Header size
  66:     -	0023'         	CP3_XDPH_SIZE       equ CP3_DPH_SIZE + 10   ; Extended Disk Parameter Header size
  67:     -	0008'         	DLBLE_NAME_SIZE     equ 8               ; Disk label name size
  68:     -	0003'         	DLBLE_TYP_SIZE      equ 3               ; Disk label type size
  69:     -	0008'         	DIR_PWD_SIZE        equ 8               ; Directory password size
  70:				;
  71:				;
  72:				; CP/M 3 Disk Parameter Block (DPB) structure.
  73:     -	        	                STRUCT
  74:     -	        	                STR_WORD CP3_DPB_SPT        ; Number of 128-byte records per track
  75:     -	        	                STR_BYTE CP3_DPB_BSH        ; Block shift. 3 => 1k, 4 => 2k, 5 => 4k....
  76:     -	        	                STR_BYTE CP3_DPB_BLM        ; Block mask. 7 => 1k, 0Fh => 2k, 1Fh => 4k...
  77:     -	        	                STR_BYTE CP3_DPB_EXM        ; Extent mask
  78:     -	        	                STR_WORD CP3_DPB_DSM        ; Maximum block number
  79:     -	        	                STR_WORD CP3_DPB_DRM        ; Maximum directory entry number
  80:     -	        	                STR_BYTE CP3_DPB_AL0        ; Directory allocation bitmap
  81:     -	        	                STR_BYTE CP3_DPB_AL1
  82:     -	        	                STR_WORD CP3_DPB_CKS        ; Checksum vector size, 0 for a fixed disc
  83:     -	        	                STR_WORD CP3_DPB_OFF        ; Offset, number of reserved tracks
  84:     -	        	                STR_BYTE CP3_DPB_PSH        ; Physical record shift factor
  85:     -	        	                STR_BYTE CP3_DPB_PHM        ; Physical record mask
  86:     -	        	                STR_END CP3_DPB_SIZE
  87:				;
  88:				;
  89:				; Directory date stamp structure.
  90:     -	        	                STRUCT
  91:     -	        	                STR_WORD DSTAMP_DAY         ; Julien day number (1 = 1 Jan 78)
  92:     -	        	                STR_BYTE DSTAMP_HOUR        ; BCD hour
  93:     -	        	                STR_BYTE DSTAMP_MIN         ; BCD minute
  94:     -	        	                STR_END DSTAMP_SIZE 
  95:				;
  96:     -	0001'         	                assert DSTAMP_SIZE = 4
  97:				;
  98:				;
  99:				; Disk label structure.
 100:     -	        	                STRUCT
 101:     -	        	                STR_BYTE DLBLE_USER      ; "User number" (0x20)
 102:     -	        	                STR_BLOCK DLBLE_NAME, DLBLE_NAME_SIZE ; Name
 103:     -	        	                STR_BLOCK DLBLE_TYP, DLBLE_TYP_SIZE   ; Label type
 104:     -	        	                STR_BYTE DLBLE_LB        ; Label byte (flags)
 105:     -	        	                STR_BYTE DLBLE_PB        ; Password decode byte
 106:     -	        	                STR_BYTE DLBLE_RR0       ; Reserved, should be zero
 107:     -	        	                STR_BYTE DLBLE_RR1
 108:     -	        	                STR_BLOCK DLBLE_PWD, DIR_PWD_SIZE    ; Password
 109:     -	        	                STR_BLOCK DLBLE_CREATE_DATE, DSTAMP_SIZE ; Create date stamp
 110:     -	        	                STR_BLOCK DLBLE_UPDATE_DATE, DSTAMP_SIZE ; Update date stamp
 111:     -	        	                STR_END DLBLE_SIZE
 112:				;
 113:     -	0001'         	                assert DLBLE_SIZE = 0x20
 114:				;
 115:				;
 116:				; Date stamp directory entry structure.
 117:     -	        	                STRUCT
 118:     -	        	                STR_BYTE DSTE_USER      ; "User number" (0x21)
 119:     -	        	                STR_BLOCK DSTE_F1_DATE, DSTAMP_SIZE ; File 1 *
 120:     -	        	                STR_BLOCK DSTE_F1_UPD_DATE, DSTAMP_SIZE ; File 1 update date
 121:     -	        	                STR_BYTE DSTE_M1        ; File 1 password mode
 122:     -	        	                STR_BYTE DSTE_R0        ; Reserved, should be zero
 123:     -	        	                STR_BLOCK DSTE_F2_DATE, DSTAMP_SIZE ; File 2 *
 124:     -	        	                STR_BLOCK DSTE_F2_UPD_DATE, DSTAMP_SIZE ; File 2 update date
 125:     -	        	                STR_BYTE DSTE_M2        ; File 2 password mode
 126:     -	        	                STR_BYTE DSTE_R1        ; Reserved, should be zero
 127:     -	        	                STR_BLOCK DSTE_F3_DATE, DSTAMP_SIZE ; File 3 *
 128:     -	        	                STR_BLOCK DSTE_F3_UPD_DATE, DSTAMP_SIZE ; File 3 update date
 129:     -	        	                STR_BYTE DSTE_M3        ; File 3 password mode
 130:     -	        	                STR_BYTE DSTE_R2        ; Reserved, should be zero
 131:     -	        	                STR_BYTE DSTE_R3
 132:     -	        	                STR_END DSTE_SIZE
 133:				;
 134:				; * Create OR access date stamp.
 135:				;
 136:     -	0001'         	                assert DSTE_SIZE = 0x20
 137:				;
 138:				;
 139:				; Password directory entry structure.
 140:     -	        	                STRUCT
 141:     -	        	                STR_BYTE DPWDE_USER     ; User number
 142:     -	        	                STR_BLOCK DPWDE_NAME, FILENAME_SIZE ; Filename
 143:     -	        	                STR_BLOCK DPWDE_TYP, FILEEXT_SIZE   ; File type
 144:     -	        	                STR_BYTE DPWDE_PM       ; Mode byte
 145:     -	        	                STR_BYTE DPWDE_PB       ; Decode byte
 146:     -	        	                STR_BLOCK DPWDE_RESVD1, 2
 147:     -	        	                STR_BLOCK DPWDE_PWD, DIR_PWD_SIZE   ; Password
 148:     -	        	                STR_BLOCK DPWDE_RESVD2, 8
 149:     -	        	                STR_END DPWDE_SIZE
 150:				;
 151:     -	0001'         	                assert DPWDE_SIZE = 0x20
 152:				;
 153:				; DPWDE_PM bits.
 154:     -	        	BITDEF DPWDE_PM_DEL, 5                 ; Password required to delete file
 155:     -	        	BITDEF DPWDE_PM_WRITE, 6               ; Password required to write to file
 156:     -	        	BITDEF DPWDE_PM_READ, 7                ; Password required to read file
 157:				;
 158:				;
 159:				;
 160:				; ********
 161:				; * BIOS *
 162:				; ********
 163:				;
 164:				;
 165:				; PUNCH and READER are replaced by AUXOUT and AUXIN for CP/M 3. This allows the
 166:				; use of either name.
 167:     -	000F'         	BIOS_AUXOUT         equ BIOS_PUNCH
 168:     -	0012'         	BIOS_AUXIN          equ BIOS_READER
 169:				;
 170:				;
 171:				;
 172:				; ********
 173:				; * BDOS *
 174:				; ********
 175:				;
 176:				;
 177:				; Direct Console I/O (BDOS_DIRECT_CON_IO) command codes not supported by CP/M 2.
 178:     -	00FE'         	DCONIO_IN_STAT      equ 0xfe    ; Return console input status. Zero if no character is waiting, nonzero
 179:     -	00FD'         	DCONIO_GET_WT       equ 0xfd    ; Get character (no echo), wait if no key
 180:				;
 181:				;
 182:				;
 183:				; ***************
 184:				; * CMPLDR BIOS *
 185:				; ***************
 186:				;
 187:				;
 188:				; BIOS parameters structure. This is passed from the monitor to the CPMLDR
 189:				; BIOS and the CP/M 3 BIOS.
 190:     -	        	                STRUCT
 191:     -	        	                STR_BYTE BPS_OPTIONS    ; See BIOS_OPT_xxx definitions
 192:     -	        	                STR_BLOCK BPS_PAGES, MMAP_CP3_PAGES ; Memory page list
 193:     -	        	                STR_WORD BPS_PARTITION  ; Pointer to partition table entry
 194:     -	        	                STR_END BPS_SIZE
 195:				;
**** cpm3.z80 ****
  35:				                include "maths.i"       ; Mathematical functions
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/maths.i ****
   1:				; *******************************************************
   2:				; * Mathematical Routines for ZARC Z80 Computer         *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 29/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant.
   8:				;
   9:				; The following conditionals are intended to allow the same include file to be
  10:				; used in the defining module and elsewhere as required. Some includes are used
  11:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  12:				; the extern and public statements are not desirable.
  13:				;
  14:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  15:     -	0001'         	                ifndef maths        ; Inhibit for this module
  16:				;
  17:				                extern madlbu       ; 32-bit / 8-bit unsigned divide
  18:				                extern madwbu       ; 16-bit / 8-bit unsigned divide
  19:				                extern madbbu       ; 8-bit / 8-bit unsigned divide
  20:				                extern mamwwu       ; 16-bit * 16-bit unsigned multiply
  21:				                extern mamlbu       ; 32-bit * 8-bit unsigned multiply
  22:				                extern crc16x       ; Software CRC-16 (XMODEM)
  23:				;                extern malclr       ; 32-bit clear (HL)
  24:				                extern malinc       ; 32-bit increment (HL)
  25:				                extern mapcnt       ; Calculate percentage of two 32-bit values
  26:				                extern malld	    ; Load 32-bit number from memory
  27:				                extern malst        ; Store 32-bit number to memory
  28:				                extern maladd       ; 32-bit add
  29:				;
  30:				                endif
  31:				            endif
  32:				
**** cpm3.z80 ****
  36:				                include "memory.i"      ; Memory page allocation
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/memory.i ****
   1:				; *******************************************
   2:				; * ZARC Memory Include File                *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 24/11/2021                *
   5:				; *******************************************
   6:				;
   7:				;
   8:				; Note that ld80 only considers the first six characters of labels significant.
   9:				;
  10:				; The following conditionals are intended to allow the same include file to be
  11:				; used in the defining module and elsewhere as required. Some includes are used
  12:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  13:				; the extern and public statements are not desirable.
  14:				;
  15:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  16:     -	0001'         	                ifndef memory       ; Inhibit for this module
  17:				;
  18:				                extern mpinit       ; Initialise
  19:				                extern mprpt        ; Report status to console
  20:				                extern mpall        ; Allocate new page
  21:				                extern mpfree       ; Free allocated page
  22:				                extern mpstat       ; Allocation status
  23:				                extern mppnam       ; Print entry name
  24:				;
  25:				                endif
  26:				            endif
  27:				;
  28:				; Physical memory constants are found in zarc.i
  29:				;
  30:     -	0004'         	MPA_NAME_LEN        equ 4               ; Page owner name length (bytes)
  31:				;
  32:				; Memory map
  33:     -	4000'         	MMAP_PAGE_SIZE      equ 0x4000          ; Memory mapping bank / page size
  34:     -	0004'         	MMAP_BANKS          equ 4               ; Number of 16 kB banks
  35:     -	0040'         	MMAP_PAGES          equ 0x40            ; Number of 16 kB RAM pages
  36:     -	0000'         	MMAP_BANK0_START    equ 0x0000
  37:     -	3FFF'         	MMAP_BANK0_END      equ 0x3fff
  38:     -	4000'         	MMAP_BANK1_START    equ 0x4000
  39:     -	7FFF'         	MMAP_BANK1_END      equ 0x7fff
  40:     -	8000'         	MMAP_BANK2_START    equ 0x8000
  41:     -	BFFF'         	MMAP_BANK2_END      equ 0xbfff
  42:     -	C000'         	MMAP_BANK3_START    equ 0xc000
  43:     -	FFFF'         	MMAP_BANK3_END      equ 0xffff
  44:				;
  45:				;
  46:				;
  47:				; ****************
  48:				; * Memory Usage *
  49:				; ****************
  50:				;
  51:				;
  52:				; Memory banks setup.
  53:				; 0 (0000 - 3FFF): 3f read only, supervisor - monitor program
  54:				; 1 (4000 - 7FFF): 3e writeable - monitor variables, stacks, buffers etc.
  55:				; 2 (8000 - BFFF): (not used)
  56:				; 3 (C000 - FFFF): (mapped as required)
  57:				;
  58:     -	003F'         	MMAP_MON_B0_PAGE    equ 0x3f        ; Page for bank 0
  59:     -	003E'         	MMAP_MON_B1_PAGE    equ 0x3e        ; Page for bank 1
  60:				;
  61:     -	0040'         	STACKS_SIZE     equ 64              ; Space allocated to normal stacks
  62:				;
  63:     -	7FFF'         	HEAP_TOP        equ MMAP_BANK1_END  ; Top (end) of heap space.
  64:				
**** cpm3.z80 ****
  37:				;
  38:				;
  39:				;
  40:				; *************
  41:				; * Externals *
  42:				; *************
  43:				;
  44:				; Routines
  45:				                public cp3ini           ; Load and start CP/M 3
  46:				;
  47:				; Variables
  48:				;                public cp3pgs           ; CP/M page allocations
  49:				;
  50:				;
  51:				;
  52:				; *************
  53:				; * Constants *
  54:				; *************
  55:				;
  56:				;
  57:     -	0014'         	CPMLDR_SECTS    equ CPMLDR_MAX_SIZE / MMC_SECTOR_SIZE
  58:				;
  59:				;
  60:				;
  61:				; *************
  62:				; * Main Code *
  63:				; *************
  64:				;
  65:				                cseg                    ; Code segment
  66:				;
  67:				;
  68:				; Load and start CP/M. No registers are saved. No return is anticipated unless an
  69:				; error occurs.
  70:				; A - options. See BIOS_OPT_xxx definitions in cpm.i.
  71:    0+13	0000' 320000  	cp3ini          ld (options), a
  72:   13+10	0003' 210101  	                ld hl, no_noints_msg    ; "noints not supported"
  73:   23+7	0006' E602    	                and BIOS_OPT_NOINTS_MASK
  74:   30+10	0008' C2CB00  	                jp nz, in_error
  75:   40+13	000B' 3A0000  	                ld a, (mcstat)          ; Fetch card state (MMC_STAT_xxx)
  76:   53+7	000E' FE01    	                cp MMC_STAT_INIT
  77:   60+7+5	0010' 2806    	                jr z, in_mmc_ok
  78:				; MMC not initialised.
  79:   67+10	0012' 21D000  	                ld hl, no_mmc_msg       ; "MMC not initialised"
  80:   77+10	0015' C3CB00  	                jp in_error
  81:				;
  82:   87+17	0018' CD0000  	in_mmc_ok       call cpprt              ; Find CP/M partition
  83:  104+5+6	001B' D8      	                ret c                   ; Give up on error
  84:  109+20	001C' DD220E00	                ld (cpm_part_entry), ix
  85:				;
  86:				; Allocate memory pages.
  87:  129+10	0020' 210100  	                ld hl, cp3pgs           ; Store for page numbers
  88:  139+7	0023' 3E0D    	                ld a, MMAP_CP3_PAGES    ; Number of pages required
  89:  146+17	0025' CD0000  	                call cpmem              ; Use CP/M 2.2 routine
  90:  163+5+6	0028' D8      	                ret c                   ; Give up on error
  91:				; Set the supervisor bit for the common bank so the BIOS can access I/O.
  92:  168+10	0029' 210D00  	                ld hl, cp3pgs + MMAP_CP3_COMM_PG
  93:  178+15	002C' CBF6    	                set MMAP_SUPER_BIT, (hl)
  94:				; CP/M puts the banked part of the BIOS into the upper part of bank 0 (transient
  95:				; programmes run in bank 1). We need to allow I/O access for the banked BIOS
  96:				; too.
  97:  193+10	002E' 210300  	                ld hl, cp3pgs + MMAP_CP3_BK0_ST + 2 ; 0x8000 to 0xbfff
  98:  203+15	0031' CBF6    	                set MMAP_SUPER_BIT, (hl)
  99:				;
 100:				; Load CPMLDR into memory at 0x100 in the initial CP/M space (CP/M bank 0).
 101:				; Map the relevant page. The maximum size allocated to CPMLDR is 10 KB, which
 102:				; fits within a single 16 KB page.
 103:     -	0001'         	                assert (CPMLDR_MAX_SIZE + TPA_START) <= MMAP_PAGE_SIZE
 104:  218+13	0033' 3A0100  	                ld a, (cp3pgs + MMAP_CP3_BK0_ST)
 105:  231+11	0036' D307    	                out (IOA_MMAP_3), a     ; Map C000 - FFFF to the relevant page
 106:				;
 107:  242+7	0038' 0614    	                ld b, CPMLDR_SECTS      ; Sector count
 108:  249+20	003A' DD2A0E00	                ld ix, (cpm_part_entry) ; Point to partition table entry
 109:  269+7	003E' 0E00    	                ld c, 0                 ; Starting sector
 110:  276+10	0040' 111300  	                ld de, CPMLDR_START_SEC
 111:  286+10	0043' 2100C1  	                ld hl, MMAP_BANK3_START + TPA_START ; Destination address
 112:  296+11	0046' C5      	in_load_loop    push bc
 113:  307+11	0047' D5      	                push de
 114:				; CDE - MMC (512 byte) sector number (offset into partition)
 115:				; HL - destination address
 116:				; IX - pointer to partition table entry structure
 117:  318+17	0048' CD0000  	                call cars               ; Read MMC sector
 118:				; A - zero (OK) or error code (SPI_ERR_xxx)
 119:				; HL - updated pointer to buffer (points to location after last written)
 120:  335+10	004B' D1      	                pop de
 121:  345+10	004C' C1      	                pop bc
 122:  355+4	004D' A7      	                and a
 123:				; Print memory card error text and return on error.
 124:  359+10	004E' C20000  	                jp nz, mcprer
 125:				; Increment sector.
 126:  369+6	0051' 13      	                inc de
 127:  375+4	0052' 7A      	                ld a, d
 128:  379+4	0053' B3      	                or e
 129:  383+7+5	0054' 2001    	                jr nz, in_ldlp_nc
 130:  390+4	0056' 0C      	                inc c                   ; Increment if carry occurred
 131:  394+8+5	0057' 10ED    	in_ldlp_nc      djnz in_load_loop
 132:				;
 133:				; Calculate and display CRC if debugging is enabled.
 134:  402+13	0059' 3A0000  	                ld a, (options)         ; See BIOS_OPT_xxx definitions.
 135:  415+7	005C' E601    	                and BIOS_OPT_DEBUG_MASK
 136:  422+7+5	005E' 281D    	                jr z, in_debug_done
 137:				;
 138:				; Debugging messages.
 139:  429+10	0060' 21F400  	                ld hl, ldr_crc_msg      ; "CPMLDR CRC: "
 140:  439+11	0063' CF      	                CON_WR_MSG             ; Print message
 141:				; Generate CRC.
 142:  450+10	0064' 1100C1  	                ld de, MMAP_BANK3_START + TPA_START ; Start of CPMLDR
 143:  460+10	0067' 010028  	                ld bc, CPMLDR_MAX_SIZE  ; Length
 144:  470+10	006A' 210000  	                ld hl, 0                ; Initial CRC
 145:  480+7	006D' 1A      	in_crc_loop     ld a, (de)
 146:  487+17	006E' CD0000  	                call crc16x             ; CRC-16 (XMODEM)
 147:  504+6	0071' 13      	                inc de
 148:  510+6	0072' 0B      	                dec bc
 149:  516+4	0073' 78      	                ld a, b
 150:  520+4	0074' B1      	                or c
 151:  524+7+5	0075' 20F6    	                jr nz, in_crc_loop
 152:				; HL - required CRC.
 153:  531+17	0077' CD0000  	                call cwphwd             ; Print HL in hexadecimal
 154:  548+17	007A' CD0000  	                call cwnwln             ; Write new line characters to console
 155:				;
 156:				; Check that this looks like a CPMLDR. The first instruction is a ld sp, xxxx,
 157:				; so we can check for this.
 158:  565+10	007D' 2100C1  	in_debug_done   ld hl, MMAP_BANK3_START + TPA_START ; Start of CPMLDR
 159:  575+7	0080' 7E      	                ld a, (hl)
 160:  582+7	0081' FE31    	                cp 0x31                 ; ld sp, xxxx
 161:  589+10	0083' C2C800  	                jp nz, in_no_ldr        ; Jump if not plausible
 162:				;
 163:				; Given that CPMLDR is essentially a self-contained CP/M programme, we should
 164:				; switch to the CP/M context before running it. The monitor's context switching
 165:				; mechanism is used. Set the machine state accordingly. The memory map is set
 166:				; to CP/M bank 0 complete with the common area.
 167:  599+14	0086' DD210000	                ld ix, mstate           ; Machine state structure
 168:  613+19	008A' DD360000	                ld (ix + MST_IEN), 0    ; Interrupts disabled
 169:  632+19	008E' DD360101	                ld (ix + MST_MMAP_EN), 1    ; Memory mapping enabled
 170:  651+13	0092' 3A0100  	                ld a, (cp3pgs + MMAP_CP3_BK0_ST)
 171:  664+19	0095' DD7702  	                ld (ix + MST_MMAP0), a  ; Memory mapping registers
 172:  683+13	0098' 3A0200  	                ld a, (cp3pgs + MMAP_CP3_BK0_ST + 1)
 173:  696+19	009B' DD7703  	                ld (ix + MST_MMAP1), a
 174:  715+13	009E' 3A0300  	                ld a, (cp3pgs + MMAP_CP3_BK0_ST + 2)
 175:  728+19	00A1' DD7704  	                ld (ix + MST_MMAP2), a
 176:  747+13	00A4' 3A0D00  	                ld a, (cp3pgs + MMAP_CP3_COMM_PG)
 177:  760+19	00A7' DD7705  	                ld (ix + MST_MMAP3), a
 178:				; Set stack just below the interrupt vector table.
 179:  779+19	00AA' DD3606E0	                ld (ix + MST_SP), low INT_VEC_TABLE
 180:  798+19	00AE' DD3607FF	                ld (ix + MST_SP + 1), high INT_VEC_TABLE
 181:  817+19	00B2' DD360800	                ld (ix + MST_PC), low TPA_START
 182:  836+19	00B6' DD360901	                ld (ix + MST_PC + 1), high TPA_START
 183:				; Set pointer to parameters in IX.
 184:  855+10	00BA' 210000  	                ld hl, bios_params      ; Point to structure
 185:  865+19	00BD' DD750C  	                ld (ix + MST_IX), l
 186:  884+19	00C0' DD740D  	                ld (ix + MST_IX + 1), h
 187:				;
 188:  903+7	00C3' 3E00    	                ld a, TRM_NONE          ; Flag normal run (not trace)
 189:  910+10	00C5' C30000  	                jp mcrun                ; Switch to user context
 190:				;
 191:				; No plausible CPMLDR loaded.
 192:  920+10	00C8' 21E400  	in_no_ldr       ld hl, no_ldr_msg      ; "CPMLDR not loaded"
 193:				;
 194:				; Go here to exit.
 195:				; HL - pointer to error message.
 196:  930+11	00CB' CF      	in_error        CON_WR_MSG             ; Print message
 197:  941+17	00CC' CD0000  	                call cwnwln             ; Write new line characters to console
 198:  958+10	00CF' C9      	                ret
