**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/spi.i ****
   1:				; ***********************************
   2:				; * ZARC SPI Definitions            *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 7/8/2020          *
   5:				; ***********************************
   6:				;
   7:				; Definitions associated with the SPI (Inter-Integrated Circuit) master interface.
   8:				; Used for the memory card initially, but it may turn out to have other uses.
   9:				;
  10:				;
  11:				; Memory card command structure
  12:     -	        	                STRUCT
  13:     -	        	                STR_BYTE MMC_CMD    ; Command including start bits
  14:     -	        	                STR_BYTE MMC_ARG1   ; Arguments
  15:     -	        	                STR_BYTE MMC_ARG2   ; Arguments
  16:     -	        	                STR_BYTE MMC_ARG3   ; Arguments
  17:     -	        	                STR_BYTE MMC_ARG4   ; Arguments
  18:     -	        	                STR_BYTE MMC_CRC    ; CRC and stop bit
  19:     -	        	                STR_END MMC_SIZE
  20:				
  21:				; SPI-related error codes. This should be maintained in sync with err_msgs in
  22:				; mmc_card.z80.
  23:     -	        	                ENUM_START
  24:     -	        	                ENUM SPI_ERR_OK         ; No error
  25:     -	        	                ENUM SPI_ERR_BUSY       ; Master interface stuck busy
  26:				; Memory card error codes.
  27:     -	        	                ENUM SPI_ERR_NORESP     ; No response received from card
  28:     -	        	                ENUM SPI_ERR_BADINIT    ; Initialisation failed
  29:     -	        	                ENUM SPI_ERR_BADCRC     ; CRC error
  30:     -	        	                ENUM SPI_ERR_BADSEC     ; Bad sector size
  31:     -	        	                ENUM SPI_ERR_RANGE      ; Parameter out of range
  32:     -	        	                ENUM SPI_ERR_DATAERR    ; Data error token received
  33:     -	        	                ENUM SPI_ERR_BAD_R1     ; Card reported error in R1 response
  34:     -	        	                ENUM SPI_ERR_BAD_R2     ; Card reported error in R2 response
  35:     -	        	                ENUM SPI_ERR_HEAP       ; Out of heap space
  36:     -	        	                ENUM SPI_ERR_TIMEOUT    ; Busy timeout
  37:     -	        	                ENUM SPI_ERR_WRITE      ; Write error
  38:     -	        	                ENUM SPI_ERR_UNKN       ; Unknown error
  39:     -	        	                ENUM SPI_ERR_PART       ; Sector is outside the partition
  40:     -	        	                ENUM_END SPI_ERR_NUM    ; Number of errors
  41:				
**** mmc.z80 ****
  39:				                include "mmc.i"         ; Memory card
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/mmc.i ****
   1:				; *******************************************
   2:				; * ZARC Monitor Memory Card Include File   *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 7/8/2020                  *
   5:				; *******************************************
   6:				;
   7:				;
   8:				; Note that ld80 only considers the first six characters of labels significant.
   9:				;
  10:				; The following conditionals are intended to allow the same include file to be
  11:				; used in the defining module and elsewhere as required. Some includes are used
  12:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  13:				; the extern and public statements are not desirable.
  14:				;
  15:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  16:     -	0000'         	                ifndef mmc          ; Inhibit for this module
  30:				                endif
  31:				            endif
  32:				;
  33:				;
  34:     -	0200'         	MMC_SECTOR_SIZE             equ 512     ; Sector size
  35:     -	0009'         	MMC_LOG2_SEC_SIZE           equ 9       ; Save number of shifts for above
  36:     -	0040'         	MMC_CMD_START               equ 0x40    ; Command start bits (01b) shifted for
  37:				                                        ; command byte
  38:     -	0001'         	MMC_CMD_STOP                equ 0x01    ; Stop bit (in CRC byte)
  39:				;
  40:				;
  41:				; Card state (mcstat) states.
  42:     -	        	                ENUM_START
  43:     -	        	                ENUM MMC_STAT_IDLE      ; Not initialised
  44:     -	        	                ENUM MMC_STAT_INIT      ; Initialised (can do raw read / writes)
  45:				
  46:     -	        	                ENUM_END MC_STATES  ; Number of states
  47:				;
  48:				;
  49:				; Memory card command structure
  50:     -	        	                STRUCT
  51:     -	        	                STR_BYTE MMC_CMD    ; Command including start bits
  52:     -	        	                STR_BYTE MMC_ARG1   ; Arguments
  53:     -	        	                STR_BYTE MMC_ARG2   ; Arguments
  54:     -	        	                STR_BYTE MMC_ARG3   ; Arguments
  55:     -	        	                STR_BYTE MMC_ARG4   ; Arguments
  56:     -	        	                STR_BYTE MMC_CRC    ; CRC and stop bit
  57:     -	        	                STR_END MMC_SIZE
  58:				;
  59:				;
  60:				; SPI mode commands (CMDn from MMC-System-Spec-v3.31.pdf chapter 4.9).
  61:     -	0000'         	MMC_CMD_GO_IDLE_STATE       equ 0   ; Resets the memory card
  62:     -	0001'         	MMC_CMD_SEND_OP_COND        equ 1   ; Sends host capacity support information and init.
  63:     -	0009'         	MMC_CMD_SEND_CSD            equ 9   ; Read card specific data
  64:     -	000A'         	MMC_CMD_SEND_CID            equ 10  ; Read card identification
  65:     -	000D'         	MMC_CMD_SEND_STATUS         equ 13  ; Read card status register
  66:     -	0010'         	MMC_CMD_SET_BLOCKLEN        equ 16  ; Set block length (in bytes)
  67:     -	0011'         	MMC_CMD_READ_SINGLE_BLOCK   equ 17  ; Reads a block
  68:     -	0018'         	MMC_CMD_WRITE_BLOCK         equ 24  ; Writes a block
  69:     -	0037'         	MMC_CMD_APP_CMD             equ 55  ; Next command is an application specific command
  70:     -	003B'         	MMC_CMD_CRC_ON_OFF          equ 59  ; Turns the CRC option on or off
  71:				;
  72:				; The list describes all the application specific commands supported/reserved by the 
  73:				; memory card. All the following commands shall be preceded with APP_CMD (CMD55).
  74:     -	0029'         	MMC_ACMD_MC_SEND_OP_COND    equ 41  ; Sends host capacity support information and init
  75:				;
  76:				; R1 response bits
  77:     -	        	BITDEF MMC_R1_IDLE, 0           ; In idle state
  78:     -	        	BITDEF MMC_R1_ERA_RST, 1        ; Erase reset
  79:     -	        	BITDEF MMC_R1_ILL_CMD, 2        ; Illegal command
  80:     -	        	BITDEF MMC_R1_CMD_CRC_ERR, 3    ; Command CRC error
  81:     -	        	BITDEF MMC_R1_ERA_SEQ_ERR, 4    ; Erase sequence error
  82:     -	        	BITDEF MMC_R1_ADDR_ERR, 5       ; Address error
  83:     -	        	BITDEF MMC_R1_PAR_ERR, 6        ; Parameter error
  84:     -	        	BITDEF MMC_R1_START, 7          ; Zero identifies an R1 response
  85:				;
  86:				;
  87:     -	0006'         	MMC_CID_PNM_SIZE      equ 6   ; Product name length (bytes)
  88:				;
  89:				; Card IDentification (CID) register (128 bits)
  90:     -	        	                STRUCT
  91:     -	        	                STR_BYTE MMC_CID_MID    ; Manufacturer ID
  92:     -	        	                STR_WORD MMC_CID_OID    ; OEM/Application ID
  93:     -	        	                STR_BLOCK MMC_CID_PNM, MMC_CID_PNM_SIZE ; Product name
  94:     -	        	                STR_BYTE MMC_CID_PRV    ; Product revision
  95:     -	        	                STR_LONG MMC_CID_PSN    ; Product serial number
  96:     -	        	                STR_BYTE MMC_CID_MDT    ; Manufacturing date
  97:     -	        	                STR_BYTE MMC_CID_CRC    ; CRC7 checksum and "1"
  98:     -	        	                STR_END MMC_CID_SIZE
  99:				;
 100:				;
 101:				; Card-Specific Data (CSD) register (128 bits). It contains a number of bit fields
 102:				; that aren't necessarily byte aligned. In these cases, the entries simply identify
 103:				; the bit numbers contained.
 104:     -	        	                STRUCT
 105:     -	        	                STR_BYTE MMC_CSD_VERSION    ; (127-120) CSD version, spec version
 106:     -	        	                STR_BYTE MMC_CSD_TAAC       ; (119-112) data read access-time-1
 107:     -	        	                STR_BYTE MMC_CSD_NSAC       ; (111-104) data read access-time-2
 108:     -	        	                STR_BYTE MMC_CSD_TR_SPD     ; (103-96) max. data transfer rate
 109:     -	        	                STR_BYTE MMC_CSD_95_88      ; Card command classes (MS 8 bits)
 110:     -	        	                STR_BYTE MMC_CSD_87_80      ; CCC (LS bits) and max. read data length
 111:     -	        	                STR_BYTE MMC_CSD_79_72      ; Flags and C_SIZE bits 10 and 11
 112:     -	        	                STR_BYTE MMC_CSD_71_64      ; C_SIZE bits 2 to 9
 113:     -	        	                STR_BYTE MMC_CSD_63_56      ; C_SIZE bits 1 to 0 and some currents
 114:     -	        	                STR_BYTE MMC_CSD_55_48      ; Currents & C_SIZE_MULT (MS 2 bits)
 115:     -	        	                STR_BYTE MMC_CSD_47_40      ; C_SIZE_MULT (LS bit) and erase size (part)
 116:     -	        	                STR_BYTE MMC_CSD_39_32      ; Erase size (part) and WP group size
 117:     -	        	                STR_BYTE MMC_CSD_31_24      ; WP group enable, ECC and write parameters (part)
 118:     -	        	                STR_BYTE MMC_CSD_23_16      ; Write block lenth (part) and reserved
 119:     -	        	                STR_BYTE MMC_CSD_15_8       ; Flags
 120:     -	        	                STR_BYTE MMC_CSD_CRC        ; CRC7 checksum and "1"
 121:     -	        	                STR_END MMC_CSD_SIZE
 122:				
**** mmc.z80 ****
  40:				                include "heap.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/heap.i ****
   1:				; *******************************************
   2:				; * ZARC Monitor Heap Incude File           *
   3:				; * Written by: Merlin Skinner              *
   4:				; * Date Started: 7/8/2020                  *
   5:				; *******************************************
   6:				;
   7:				;
   8:				; Note that ld80 only considers the first six characters of labels significant.
   9:				;
  10:				; The following conditionals are intended to allow the same include file to be
  11:				; used in the defining module and elsewhere as required. Some includes are used
  12:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  13:				; the extern and public statements are not desirable.
  14:				;
  15:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  16:     -	0001'         	                ifndef heap         ; Inhibit for this module
  17:				;
  18:				                extern hinit        ; Initialise
  19:				                extern halloc       ; Allocate memory
  20:				;
  21:				                endif
  22:				            endif
  23:				
**** mmc.z80 ****
  41:				                include "utility.i"     ; Utility functions
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/utility.i ****
   1:				; ***********************************
   2:				; * ZARC Monitor Utility Routines   *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 16/5/2020         *
   5:				; ***********************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant
   8:				;
   9:				; The following conditionals are intended to allow the same include file to be
  10:				; used in the defining module and elsewhere as required. Some includes are used
  11:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  12:				; the extern and public statements are not desirable.
  13:				;
  14:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  15:     -	0001'         	                ifndef utility      ; Inhibit for this module
  16:				;
  17:				                extern cwnwln       ; Write new line characters to console.
  18:				                extern conwms       ; Print null-terminated string to the console
  19:				                extern conwmn       ; Print message <n> in a list
  20:				                extern skpspc       ; Step hl past spaces
  21:				                extern toupca       ; Convert character in A to upper case
  22:				                extern toloca       ; Convert character in A to lower case
  23:				                extern cwvich       ; Print only visible 7-bit characters
  24:				                extern cwpspc       ; Print a space
  25:				                extern mtwdli       ; Match word in a string against list of options
  26:				                extern cwphnb       ; Print least-significant nibble in A in hexadecimal
  27:				                extern cwphby       ; Print A in hexadecimal
  28:				                extern cwphwd       ; Print HL in hexadecimal
  29:				                extern cwpdby       ; Print A in decimal. Leading zeros are suppressed
  30:				                extern cwpdwd       ; Print HL in decimal. Leading zeros are suppressed
  31:				                extern cwpdlo       ; Print DEHL in decimal. Leading zeros are suppressed
  32:				                extern rdhxwd       ; Read a 16-bit hexadecimal number from a string
  33:				                extern rdduwd       ; Read a 16-bit unsigned decimal number from a string
  34:				                extern rddulo       ; Read a 32-bit unsigned decimal number from a string
  35:				;
  36:				                endif
  37:				            endif
  38:				;
  39:				;
  40:				; mtwdli (match word in a string against list of options) option bits. Each bit
  41:				; has the described effect if set.
  42:     -	        	BITDEF MTWDLI_ABBREV, 0                 ; Enable "." abbreviation
  43:     -	        	BITDEF MTWDLI_ICASE, 1                  ; Ignore case when matching
  44:     -	        	BITDEF MTWDLI_TERM, 7                   ; Terminator found (internal use only)
  45:				
**** mmc.z80 ****
  42:				;
  43:				;
  44:				; *************
  45:				; * Externals *
  46:				; *************
  47:				;
  48:				; Routines
  49:				                public mccold       ; Cold start initialisation
  50:				                public mcinit       ; Initialise memory card
  51:				                public mcprer       ; Print memory card error text
  52:				                public mcrvrs       ; Raw read / verify sector
  53:				                public mcrws        ; Raw write sector
  54:				;
  55:				; Variables
  56:				;
  57:				                public mcstat       ; Card state (MMC_STAT_xxx)
  58:				                public mcprc        ; Physical read sector counter
  59:				                public mcpwc        ; Physical write sector counter
  60:				                public mcuwsc       ; Unchanged sector writes skipped
  61:				;
  62:				;
  63:				; *************
  64:				; * Constants *
  65:				; *************
  66:				;
  67:				; (None)
  68:				;
  69:				;
  70:				; *************
  71:				; * Main Code *
  72:				; *************
  73:				;
  74:				                cseg                    ; Code segment
  75:				;
  76:				; Cold start initialisation.
  77:				; Counters will all be zero due to variables RAM clear.
  78:    0+10	0000' C9      	mccold          ret
  79:				;
  80:				;
  81:				; Initialise card.
  82:				; Returns with:
  83:				; A - zero (OK) or SPI error code (SPI_ERR_xxx)
  84:   10+11	0001' C5      	mcinit          push bc
  85:   21+11	0002' D5      	                push de
  86:   32+11	0003' E5      	                push hl
  87:   43+10	0004' 21D505  	                ld hl, init_msg
  88:   53+11	0007' CF      	                CON_WR_MSG       ; Print message
  89:				; Clock speed is limited to 400 KHz in Identification Mode.
  90:				; At least 74 clocks must be issued (with SS inactive) by the master before any
  91:				; attempt is made to communicate with the card (reference 1 section 6.4.1.1).
  92:   64+4	0008' AF      	                xor a                   ; Set slow mode
  93:   68+17	0009' CD0000  	                call spiini             ; Initialise SPI interface and set speed
  94:   85+7	000C' 060A    	                ld b, 10                ; 10 bytes generate 80 clocks
  95:   92+7	000E' 3EFF    	init_clk_loop   ld a, 0xff
  96:   99+17	0010' CD0000  	                call spitr              ; Send / receive byte
  97:  116+4	0013' A7      	                and a
  98:  120+10	0014' C28D02  	                jp nz, init_exit        ; Jump on error
  99:  130+8+5	0017' 10F5    	                djnz init_clk_loop
 100:				;
 101:  138+17	0019' CD1505  	                call select             ; Set slave select
 102:				; Send a reset command (CMD0)
 103:  155+14	001C' DD210000	                ld ix, cmd_buff         ; Point to command buffer
 104:  169+17	0020' CD0605  	                call clr_cmd_buff       ; Clear command buffer
 105:  186+19	0023' DD360000	                ld (ix + MMC_CMD), MMC_CMD_GO_IDLE_STATE
 106:  205+17	0027' CD9A03  	                call command
 107:  222+4	002A' A7      	                and a
 108:  226+10	002B' C28D02  	                jp nz, init_exit        ; Jump on error
 109:				;
 110:  236+17	002E' CDD103  	                call wait_r1_resp       ; Await R1 response.
 111:  253+4	0031' A7      	                and a
 112:  257+10	0032' C28D02  	                jp nz, init_exit        ; Jump on error
 113:  267+17	0035' CD1B05  	                call deselect           ; Remove slave select
 114:  284+4	0038' 79      	                ld a, c
 115:  288+7	0039' FE01    	                cp MMC_R1_IDLE_MASK     ; We should have only idle set
 116:  295+10	003B' C28B02  	                jp nz, init_fail        ; Initialisation failure if not
 117:				;
 118:				; The card is continuously polled with the commands CMD55 and ACMD41 until the idle
 119:				; bit becomes clear, indicating that the card is fully initialized and ready to
 120:				; respond to general commands.
 121:  305+7	003E' 0600    	                ld b, 0                 ; Try up to 256 times
 122:  312+17	0040' CD1505  	init_acmd41_lp  call select             ; Set slave select
 123:  329+19	0043' DD360037	                ld (ix + MMC_CMD), MMC_CMD_APP_CMD   ; ACMD follows
 124:  348+17	0047' CD9A03  	                call command
 125:  365+4	004A' A7      	                and a
 126:  369+10	004B' C28D02  	                jp nz, init_exit        ; Jump on error
 127:  379+17	004E' CDD103  	                call wait_r1_resp
 128:  396+4	0051' A7      	                and a
 129:  400+10	0052' C28D02  	                jp nz, init_exit        ; Jump on error
 130:  410+17	0055' CD1B05  	                call deselect           ; Remove slave select
 131:				; C - received byte
 132:  427+8	0058' CB51    	                bit MMC_R1_ILL_CMD_BIT, c    ; Illegal command
 133:  435+7+5	005A' 2032    	                jr nz, init_mmc_init    ; Try alternate init if bad command
 134:  442+4	005C' 79      	                ld a, c
 135:  446+13	005D' 322E00  	                ld (r1_err_resp), a
 136:  459+17	0060' CD4105  	                call mcperr             ; Display any errors
 137:  476+4	0063' 79      	                ld a, c
 138:				; We may or may not be in the idle state at this point, but any other bits indicate
 139:				; an error.
 140:  480+7	0064' E6FE    	                and not (MMC_R1_IDLE_MASK)
 141:  487+10	0066' C28B02  	                jp nz, init_fail
 142:				;
 143:  497+17	0069' CD1505  	                call select             ; Set slave select
 144:  514+19	006C' DD360029	                ld (ix + MMC_CMD), MMC_ACMD_MC_SEND_OP_COND   ; Send details & init
 145:  533+17	0070' CD9A03  	                call command
 146:  550+4	0073' A7      	                and a
 147:  554+10	0074' C28D02  	                jp nz, init_exit        ; Jump on error
 148:  564+17	0077' CDD103  	                call wait_r1_resp       ; Await R1 response.
 149:  581+4	007A' A7      	                and a
 150:  585+10	007B' C28D02  	                jp nz, init_exit        ; Jump on error
 151:				; There is no further response in SPI mode.
 152:  595+17	007E' CD1B05  	                call deselect           ; Remove slave select
 153:				; C - received byte
 154:  612+8	0081' CB51    	                bit MMC_R1_ILL_CMD_BIT, c    ; Illegal command
 155:  620+7+5	0083' 2009    	                jr nz, init_mmc_init    ; Try alternate init if bad command
 156:  627+4	0085' 79      	                ld a, c
 157:  631+4	0086' A7      	                and a
 158:  635+7+5	0087' 2828    	                jr z, init_ok_fast      ; OK if response is zero
 159:  642+8+5	0089' 10B5    	                djnz init_acmd41_lp
 160:				; Too many retries.
 161:  650+10	008B' C38B02  	                jp init_fail
 162:				;
 163:				; Alternate initialisation for use if ACMD_MC_SEND_OP_COND is not recognised. The
 164:				; card is continuously polled with the command CMD1 until the idle bit becomes
 165:				; clear, indicating that the card is fully initialised.
 166:  660+7	008E' 0600    	init_mmc_init   ld b, 0                 ; Try up to 256 times
 167:  667+17	0090' CD1505  	init_cmd1_lp    call select             ; Set slave select
 168:  684+19	0093' DD360001	                ld (ix + MMC_CMD), MMC_CMD_SEND_OP_COND  ; Send details & init
 169:  703+17	0097' CD9A03  	                call command
 170:  720+4	009A' A7      	                and a
 171:  724+10	009B' C28D02  	                jp nz, init_exit        ; Jump on error
 172:  734+17	009E' CDD103  	                call wait_r1_resp       ; Await R1 response.
 173:  751+4	00A1' A7      	                and a
 174:  755+10	00A2' C28D02  	                jp nz, init_exit        ; Jump on error
 175:  765+17	00A5' CD1B05  	                call deselect           ; Remove slave select
 176:				; C - received byte
 177:  782+4	00A8' 79      	                ld a, c
 178:  786+4	00A9' A7      	                and a
 179:  790+7+5	00AA' 280A    	                jr z, init_ok_slow      ; OK if response is zero
 180:  797+8+5	00AC' 10E2    	                djnz init_cmd1_lp
 181:				; Too many retries.
 182:  805+10	00AE' C38B02  	                jp init_fail
 183:				;
 184:				; Card initialisation is complete.
 185:				; The maximum clock speed in this state is 20 MHz. Set clock speed to normal
 186:				; (CPU clock / 2 = 4 MHz).
 187:  815+7	00B1' 3E01    	init_ok_fast    ld a, SPI_CSR_FAST_MASK ; Set fast mode
 188:  822+17	00B3' CD0000  	                call spiini             ; Initialise SPI interface and set speed
 189:				; Entry point for MMC cards as we need to remain at low clock speed.
 190:				; Enable CRC (disabled by default in SPI mode).
 191:  839+17	00B6' CD1505  	init_ok_slow    call select             ; Set slave select
 192:  856+19	00B9' DD36003B	                ld (ix + MMC_CMD), MMC_CMD_CRC_ON_OFF   ; CMD59 CRC_ON_OFF
 193:  875+19	00BD' DD360401	                ld (ix + MMC_ARG4), 1   ; Enable CRC
 194:  894+17	00C1' CD9A03  	                call command
 195:  911+4	00C4' A7      	                and a
 196:  915+10	00C5' C28D02  	                jp nz, init_exit        ; Jump on error
 197:  925+17	00C8' CDD103  	                call wait_r1_resp       ; Await R1 response.
 198:  942+4	00CB' A7      	                and a
 199:  946+10	00CC' C28D02  	                jp nz, init_exit        ; Jump on error
 200:  956+17	00CF' CD1B05  	                call deselect           ; Remove slave select
 201:				; Check the response itself.
 202:  973+4	00D2' 79      	                ld a, c
 203:  977+4	00D3' A7      	                and a
 204:  981+10	00D4' C28502  	                jp nz, init_bad_r1      ; Initialisation failure if not
 205:  991+17	00D7' CD0605  	                call clr_cmd_buff       ; Clear command buffer (remove arguments)
 206:				;
 207:				; Read Card Specific Data (CSD)
 208: 1008+17	00DA' CD1505  	                call select             ; Set slave select
 209: 1025+19	00DD' DD360009	                ld (ix + MMC_CMD), MMC_CMD_SEND_CSD   ; CMD9 Read card specific data (CSD)
 210: 1044+17	00E1' CD9A03  	                call command
 211: 1061+4	00E4' A7      	                and a
 212: 1065+10	00E5' C28D02  	                jp nz, init_exit        ; Jump on error
 213: 1075+17	00E8' CDD103  	                call wait_r1_resp       ; Await R1 response.
 214: 1092+4	00EB' A7      	                and a
 215: 1096+10	00EC' C28D02  	                jp nz, init_exit        ; Jump on error
 216:				; Check the response itself.
 217: 1106+4	00EF' 79      	                ld a, c
 218: 1110+4	00F0' A7      	                and a
 219: 1114+10	00F1' C28502  	                jp nz, init_bad_r1      ; Initialisation failure if not
 220:				;
 221: 1124+10	00F4' 210600  	                ld hl, csd              ; Point to buffer
 222: 1134+10	00F7' 011000  	                ld bc, MMC_CSD_SIZE
 223: 1144+4	00FA' AF      	                xor a                   ; Flag read (not verify)
 224: 1148+17	00FB' CDEA03  	                call read_block         ; Read a block of data
 225: 1165+4	00FE' A7      	                and a
 226: 1169+10	00FF' C28D02  	                jp nz, init_exit        ; Jump on error
 227: 1179+17	0102' CD1B05  	                call deselect           ; Remove slave select
 228:				; CSD read complete.
 229:				;
 230:				; Read Card IDentification number
 231: 1196+17	0105' CD1505  	                call select             ; Set slave select
 232: 1213+19	0108' DD36000A	                ld (ix + MMC_CMD), MMC_CMD_SEND_CID ; CMD10 Read card identification (CID)
 233: 1232+17	010C' CD9A03  	                call command
 234: 1249+4	010F' A7      	                and a
 235: 1253+10	0110' C28D02  	                jp nz, init_exit        ; Jump on error
 236: 1263+17	0113' CDD103  	                call wait_r1_resp       ; Await R1 response.
 237: 1280+4	0116' A7      	                and a
 238: 1284+10	0117' C28D02  	                jp nz, init_exit        ; Jump on error
 239:				; Check the response itself.
 240: 1294+4	011A' 79      	                ld a, c
 241: 1298+4	011B' A7      	                and a
 242: 1302+10	011C' C28502  	                jp nz, init_bad_r1      ; Initialisation failure if not
 243:				;
 244: 1312+10	011F' 211600  	                ld hl, cid              ; Point to buffer
 245: 1322+10	0122' 011000  	                ld bc, MMC_CID_SIZE
 246: 1332+4	0125' AF      	                xor a                   ; Flag read (not verify)
 247: 1336+17	0126' CDEA03  	                call read_block         ; Read a block of data
 248: 1353+4	0129' A7      	                and a
 249: 1357+10	012A' C28D02  	                jp nz, init_exit        ; Jump on error
 250: 1367+17	012D' CD1B05  	                call deselect           ; Remove slave select
 251:				;
 252:				; Display some of this information.
 253: 1384+10	0130' 210D08  	                ld hl, prod_name_msg    ; "Product name: "
 254: 1394+11	0133' CF      	                CON_WR_MSG             ; Print message
 255: 1405+10	0134' 211900  	                ld hl, cid + MMC_CID_PNM
 256: 1415+7	0137' 0606    	                ld b, MMC_CID_PNM_SIZE
 257: 1422+7	0139' 7E      	init_prn_loop   ld a, (hl)
 258: 1429+7	013A' 0E2E    	                ld c, '.'               ; Substitution character
 259: 1436+17	013C' CD0000  	                call cwvich             ; Print visible characters only
 260: 1453+6	013F' 23      	                inc hl
 261: 1459+8+5	0140' 10F7    	                djnz init_prn_loop
 262: 1467+17	0142' CD0000  	                call cwnwln             ; Write new line characters to console
 263:				;
 264:				; Product serial number.
 265: 1484+10	0145' 211C08  	                ld hl, prod_serial_msg  ; "Serial number: "
 266: 1494+11	0148' CF      	                CON_WR_MSG             ; Print message
 267:				; Display as a 32-bit hexadecimal number, as Linux "disk" does.
 268: 1505+10	0149' 212000  	                ld hl, cid + MMC_CID_PSN ; Product serial number
 269: 1515+7	014C' 0604    	                ld b, 4
 270: 1522+7	014E' 7E      	init_psn_loop   ld a, (hl)
 271: 1529+17	014F' CD0000  	                call cwphby             ; Print byte
 272: 1546+6	0152' 23      	                inc hl
 273: 1552+8+5	0153' 10F9    	                djnz init_psn_loop
 274: 1560+17	0155' CD0000  	                call cwnwln             ; Write new line characters to console
 275:				;
 276:				; Manufacturing date.
 277: 1577+10	0158' 212C08  	                ld hl, man_date_msg     ; "Manufactured: "
 278: 1587+11	015B' CF      	                CON_WR_MSG             ; Print message
 279: 1598+13	015C' 3A2400  	                ld a, (cid + MMC_CID_MDT) ; Fetch manufacturing date byte
 280: 1611+4	015F' 4F      	                ld c, a
 281:				; Month
 282: 1615+4	0160' 0F      	                rrca                    ; Move month to MSN
 283: 1619+4	0161' 0F      	                rrca
 284: 1623+4	0162' 0F      	                rrca
 285: 1627+4	0163' 0F      	                rrca
 286: 1631+7	0164' E60F    	                and 0x0f
 287:				; Result should be 1 to 12.
 288: 1638+7+5	0166' 2806    	                jr z, init_mdt_year     ; Skip month if zero
 289: 1645+17	0168' CD0000  	                call cwpdby             ; Print A in decimal
 290: 1662+7	016B' 3E2F    	                ld a, '/'
 291: 1669+11	016D' D7      	                CON_WR_CHAR             ; Print separator
 292:				; Year
 293: 1680+10	016E' 21CD07  	init_mdt_year   ld hl, 1997             ; Year zero
 294: 1690+4	0171' 79      	                ld a, c
 295: 1694+7	0172' E60F    	                and 0x0f                ; Isolate year offset
 296: 1701+4	0174' 85      	                add a, l
 297: 1705+4	0175' 6F      	                ld l, a
 298: 1709+4	0176' 7C      	                ld a, h
 299: 1713+7	0177' CE00    	                adc 0                   ; Propagate carry
 300: 1720+4	0179' 67      	                ld h, a
 301: 1724+17	017A' CD0000  	                call cwpdwd             ; Print year in decimal
 302: 1741+17	017D' CD0000  	                call cwnwln             ; Write new line characters to console
 303:				;
 304:				; Calculate overall capacity. This is calculated from C_SIZE, C_SIZE_MULT and
 305:				; READ_BL_LEN.
 306:				; memory capacity = BLOCKNR * BLOCK_LEN
 307:				; BLOCKNR = (C_SIZE + 1) * MULT
 308:				; MULT = 2 ^ (C_SIZE_MULT + 2), (C_SIZE_MULT < 8)
 309:				; BLOCK_LEN = 2 ^ READ_BL_LEN, (READ_BL_LEN < 12)
 310: 1758+14	0180' FD210600	                ld iy, csd
 311:				; Read C_SIZE ("device size", bits [73:62]), which inconveniently spans three
 312:				; bytes.
 313: 1772+19	0184' FD7E06  	                ld a, (iy + MMC_CSD_79_72)    ; Flags and C_SIZE bits 10 and 11
 314: 1791+7	0187' E603    	                and 0x03
 315: 1798+4	0189' 57      	                ld d, a                 ; Build result in DE
 316: 1802+19	018A' FD5E07  	                ld e, (iy + MMC_CSD_71_64)    ; C_SIZE bits 2 to 9
 317: 1821+19	018D' FD7E08  	                ld a, (iy + MMC_CSD_63_56)    ; C_SIZE bits 1 to 0
 318: 1840+4	0190' 0F      	                rrca                    ; Move C_SIZE bit 1 into carry
 319: 1844+4	0191' 0F      	                rrca
 320:				; A bit 7 = C_SIZE bit 0
 321: 1848+8	0192' CB13    	                rl e                    ; Rotate into DE
 322: 1856+8	0194' CB12    	                rl d
 323: 1864+4	0196' 07      	                rlca                    ; Move C_SIZE bit 0 into carry
 324: 1868+8	0197' CB13    	                rl e                    ; Rotate into DE
 325: 1876+8	0199' CB12    	                rl d
 326:				; DE = C_SIZE
