**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/utility.i ****
   1:				; ***********************************
   2:				; * ZARC Monitor Utility Routines   *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 16/5/2020         *
   5:				; ***********************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant
   8:				;
   9:				; The following conditionals are intended to allow the same include file to be
  10:				; used in the defining module and elsewhere as required. Some includes are used
  11:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  12:				; the extern and public statements are not desirable.
  13:				;
  14:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  15:     -	0001'         	                ifndef utility      ; Inhibit for this module
  16:				;
  17:				                extern cwnwln       ; Write new line characters to console.
  18:				                extern conwms       ; Print null-terminated string to the console
  19:				                extern conwmn       ; Print message <n> in a list
  20:				                extern skpspc       ; Step hl past spaces
  21:				                extern toupca       ; Convert character in A to upper case
  22:				                extern toloca       ; Convert character in A to lower case
  23:				                extern cwvich       ; Print only visible 7-bit characters
  24:				                extern cwpspc       ; Print a space
  25:				                extern mtwdli       ; Match word in a string against list of options
  26:				                extern cwphnb       ; Print least-significant nibble in A in hexadecimal
  27:				                extern cwphby       ; Print A in hexadecimal
  28:				                extern cwphwd       ; Print HL in hexadecimal
  29:				                extern cwpdby       ; Print A in decimal. Leading zeros are suppressed
  30:				                extern cwpdwd       ; Print HL in decimal. Leading zeros are suppressed
  31:				                extern cwpdlo       ; Print DEHL in decimal. Leading zeros are suppressed
  32:				                extern rdhxwd       ; Read a 16-bit hexadecimal number from a string
  33:				                extern rdduwd       ; Read a 16-bit unsigned decimal number from a string
  34:				                extern rddulo       ; Read a 32-bit unsigned decimal number from a string
  35:				;
  36:				                endif
  37:				            endif
  38:				;
  39:				;
  40:				; mtwdli (match word in a string against list of options) option bits. Each bit
  41:				; has the described effect if set.
  42:     -	        	BITDEF MTWDLI_ABBREV, 0                 ; Enable "." abbreviation
  43:     -	        	BITDEF MTWDLI_ICASE, 1                  ; Ignore case when matching
  44:     -	        	BITDEF MTWDLI_TERM, 7                   ; Terminator found (internal use only)
  45:				
**** maths.z80 ****
  31:				;
  32:				;
  33:				; *************
  34:				; * Externals *
  35:				; *************
  36:				;
  37:				                public madlbu   ; 32-bit / 8-bit unsigned divide
  38:				                public madwbu   ; 16-bit / 8-bit unsigned divide
  39:				                public madbbu   ; 8-bit / 8-bit unsigned divide
  40:				                public mamwwu   ; 16-bit * 16-bit unsigned multiply
  41:				                public mamlbu   ; 32-bit * 8-bit unsigned multiply
  42:				                public crc16x   ; Software CRC-16 (XMODEM)
  43:				;                public malclr   ; 32-bit clear (HL)
  44:				                public malinc   ; 32-bit increment (HL)
  45:				                public mapcnt   ; Calculate percentage of two 32-bit values
  46:				                public malld	    ; Load a 32-bit number from memory
  47:				                public malst    ; Store 32-bit number to memory
  48:				                public maladd   ; 32-bit add
  49:				;
  50:				;
  51:				; *************
  52:				; * Constants *
  53:				; *************
  54:				;
  55:				; None
  56:				;
  57:				;
  58:				; *************
  59:				; * Main Code *
  60:				; *************
  61:				;
  62:				                cseg                    ; Code segment
  63:				;
  64:				; 32-bit / 8-bit unsigned divide. Uses restoring algorithm. Derived from code at
  65:				; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Division
  66:				; Call with:
  67:				; DEHL - dividend
  68:				; C - divisor
  69:				; Returns with:
  70:				; DEHL - quotient
  71:				; A - remainder
  72:    0+11	0000' C5      	madlbu          push bc
  73:   11+7	0001' 0620    	                ld b, 32                ; Loop counter
  74:   18+4	0003' AF      	                xor a
  75:   22+11	0004' 29      	dulb_bitloop    add	hl, hl              ; Shift MS bit of dividend into carry
  76:   33+8	0005' CB13    	                rl e
  77:   41+8	0007' CB12    	                rl d
  78:   49+4	0009' 17      	                rla                     ; Collect bit in LS of A
  79:   53+7+5	000A' 3803    	                jr c, dulb_dosub
  80:   60+4	000C' B9      	                cp c
  81:   64+7+5	000D' 3802    	                jr c, dulb_nextbit
  82:   71+4	000F' 91      	dulb_dosub      sub	a, c
  83:   75+4	0010' 2C      	                inc	l
  84:   79+8+5	0011' 10F1    	dulb_nextbit    djnz	dulb_bitloop
  85:   87+10	0013' C1      	                pop bc
  86:   97+10	0014' C9      	                ret
  87:				;
  88:				;
  89:				; 16-bit / 8-bit unsigned divide. Uses restoring algorithm. Derived from code at
  90:				; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Division
  91:				; Call with:
  92:				; HL - dividend
  93:				; C - divisor
  94:				; Returns with:
  95:				; HL - quotient
  96:				; A - remainder
  97:  107+11	0015' C5      	madwbu          push bc
  98:  118+7	0016' 0610    	                ld b, 16                ; Loop counter
  99:  125+4	0018' AF      	                xor a
 100:  129+11	0019' 29      	duwb_bitloop    add hl, hl              ; Shift MS bit of dividend into carry
 101:  140+4	001A' 17      	                rla                     ; Collect bit in LS of A
 102:  144+7+5	001B' 3803    	                jr c, duwb_dosub
 103:  151+4	001D' B9      	                cp c
 104:  155+7+5	001E' 3802    	                jr c, duwb_nextbit
 105:  162+4	0020' 91      	duwb_dosub      sub	a, c
 106:  166+4	0021' 2C      	                inc	l
 107:  170+8+5	0022' 10F5    	duwb_nextbit    djnz duwb_bitloop
 108:  178+10	0024' C1      	                pop bc
 109:  188+10	0025' C9      	                ret
 110:				;
 111:				;
 112:				; 8-bit / 8-bit unsigned divide. Uses restoring algorithm. Derived from code at
 113:				; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Division
 114:				; Call with:
 115:				; L - dividend
 116:				; C - divisor
 117:				; Returns with:
 118:				; L - quotient
 119:				; A - remainder
 120:  198+11	0026' C5      	madbbu          push bc
 121:  209+7	0027' 0608    	                ld b, 8                 ; Loop counter
 122:  216+4	0029' AF      	                xor a
 123:  220+8	002A' CB25    	dubb_bitloop    sla l                   ; Shift MS bit of dividend into carry
 124:  228+4	002C' 17      	                rla                     ; Collect bit in LS of A
 125:  232+4	002D' B9      	                cp c
 126:  236+7+5	002E' 3802    	                jr c, dubb_nextbit
 127:  243+4	0030' 91      	dubb_dosub      sub c
 128:  247+4	0031' 2C      	                inc l
 129:  251+8+5	0032' 10F6    	dubb_nextbit    djnz dubb_bitloop
 130:  259+10	0034' C1      	                pop bc
 131:  269+10	0035' C9      	                ret
 132:				;
 133:				;
 134:				; 16-bit * 16-bit unsigned multiply. Uses restoring algorithm. Derived from code at
 135:				; https://wikiti.brandonw.net/index.php?title=Z80_Routines:Math:Multiplication
 136:				; Call with:
 137:				; BC - multiplicand
 138:				; DE - multiplier
 139:				; Returns with:
 140:				; DEHL - result
 141:  279+10	0036' 210000  	mamwwu          ld hl, 0                ; Zero LSW of result
 142:				; Optimised 1st iteration
 143:  289+8	0039' CB23    	                sla	e                   ; Shift multiplier
 144:  297+8	003B' CB12    	                rl d
 145:  305+7+5	003D' 3002    	                jr nc, muww_sk_ld
 146:				; Set result to multiplicand if the MS bit of the multiplier was set.
 147:  312+4	003F' 60      	                ld h, b
 148:  316+4	0040' 69      	                ld l, c
 149:  320+7	0041' 3E0F    	muww_sk_ld      ld a, 15
 150:				; A - loop counter
 151:				; BC - multiplicand
 152:				; DE - multiplier (MS bits) and result (LS bits).
 153:				; HL - LSW of result
 154:  327+11	0043' 29      	muww_loop       add hl, hl              ; Shift result (DEHL) left
 155:  338+8	0044' CB13    	                rl e
 156:  346+8	0046' CB12    	                rl d
 157:  354+7+5	0048' 3004    	                jr nc, muww_nc          ; Jump if multiplier bit is zero
 158:  361+11	004A' 09      	                add hl, bc              ; Add multiplicand to result
 159:  372+7+5	004B' 3001    	                jr nc, muww_nc
 160:  379+6	004D' 13      	                inc de                  ; Propagate the carry into DE
 161:  385+4	004E' 3D      	muww_nc         dec a
 162:  389+7+5	004F' 20F2    	                jr nz, muww_loop
 163:  396+10	0051' C9      	                ret
 164:				;
 165:				;
 166:				; 32-bit * 8-bit unsigned multiply. Uses restoring algorithm. Derived from mamwwu
 167:				; above.
 168:				; Call with:
 169:				; DEHL - multiplicand
 170:				; C - multiplier
 171:				; Returns with:
 172:				; CDEHL - result
 173:  406+4	0052' 79      	mamlbu          ld a, c
 174:				; Save some registers.
 175:  410+11	0053' C5      	                push bc
 176:  421+4	0054' D9      	                exx
 177:  425+11	0055' C5      	                push bc
 178:  436+11	0056' E5      	                push hl
 179:  447+4	0057' D9      	                exx
 180:				; Setup registers for the multiply.
 181:  451+11	0058' D5      	                push de
 182:  462+11	0059' E5      	                push hl
 183:  473+10	005A' C1      	                pop bc                  ; LSW of multiplicand
 184:  483+4	005B' A7      	                and a                   ; Reset carry
 185:  487+15	005C' ED62    	                sbc hl, hl              ; Zero LS 32-bits of result
 186:  502+4	005E' D9      	                exx
 187:  506+10	005F' C1      	                pop bc                  ; MSW of multiplicand
