   1:				; *******************************************************
   2:				; * Mathematical routines for ZARC Z80 Computer         *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 29/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Simple support routines for use with the monitor program or other
   8:				; programmes.
   9:				;
  10:				; Routines preserve all registers not required as operands or return
  11:				; values except AF unless otherwise stated below.
  12:				;
  13:				;
  14:     -	0001'         	monitor         equ 1                   ; Flag part of monitor build
  15:     -	0001'         	maths           equ 1                   ; Flag module for includes
  16:				;
  17:				;
  18:				;
  19:				; ************
  20:				; * Includes *
  21:				; ************
  22:				;
  23:				                include "macros.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/macros.i ****
   1:				; ***********************************
   2:				; * ZARC Macro Definitions          *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 30/7/2020         *
   5:				; ***********************************
   6:				;
   7:				;
   8:				;
   9:				; **********
  10:				; * Macros *
  11:				; **********
  12:				;
  13:				;
  14:				; Initialise enumeration.
  15:				; The absolute segment is used so the offsets are not marked as relocatable. This
  16:				; avoids "Not relocatable" errors.
  17:				ENUM_START      macro
  18:				                .aseg
  19:				enum_counter    set 0
  20:				                endm
  21:				;
  22:				; Invoke for each item.
  23:				ENUM            macro x
  24:				x               equ enum_counter
  25:				enum_counter    set enum_counter + 1
  26:				                endm
  27:				;
  28:				ENUM_END        macro x
  29:				x               set enum_counter    ; Set label to count of items
  30:				                .cseg
  31:				                endm
  32:				;
  33:				;
  34:				; Initialise a structure. This is used to generate offsets for data structures.
  35:				; The absolute segment is used so the offsets are not marked as relocatable. This
  36:				; avoids "Not relocatable" errors.
  37:				STRUCT          macro
  38:				                .aseg
  39:				str_offset      set 0
  40:				                endm
  41:				;
  42:				; Add a byte entry.
  43:				STR_BYTE        macro x
  44:				x               equ str_offset
  45:				str_offset      set str_offset + 1
  46:				                endm
  47:				;
  48:				; Add a word (16-bit) entry.
  49:				STR_WORD        macro x
  50:				x               equ str_offset
  51:				str_offset      set str_offset + 2
  52:				                endm
  53:				;
  54:				; Add a 3 byte (24-bit) entry.
  55:				STR_24BIT       macro x
  56:				x               equ str_offset
  57:				str_offset      set str_offset + 3
  58:				                endm
  59:				;
  60:				; Add a long (32-bit) entry.
  61:				STR_LONG        macro x
  62:				x               equ str_offset
  63:				str_offset      set str_offset + 4
  64:				                endm
  65:				;
  66:				; Add an arbitrary length entry.
  67:				STR_BLOCK       macro x, size   ; <name>, <size>
  68:				x               equ str_offset
  69:				str_offset      set str_offset + size
  70:				                endm
  71:				;
  72:				; End of structure (used to set size)
  73:				STR_END         macro x
  74:				x               equ str_offset
  75:				                .cseg
  76:				                endm
  77:				;
  78:				;
  79:				; Allocate space. This is used to generate variable addresses, affectively
  80:				; providing a new variables segment. Allocated size is kept track of separately
  81:				; to the address as the latter may overflow in certain error cases.
  82:				ALLOC           macro x
  83:				                .aseg
  84:				all_addr        set x
  85:				all_size        set 0
  86:				                endm
  87:				;
  88:				; Add a byte entry.
  89:				ALL_BYTE        macro x
  90:				x               equ all_addr
  91:				all_addr        set all_addr + 1
  92:				all_size        set all_size + 1
  93:				                endm
  94:				;
  95:				; Add a word (16-bit) entry.
  96:				ALL_WORD        macro x
  97:				x               equ all_addr
  98:				all_addr        set all_addr + 2
  99:				all_size        set all_size + 2
 100:				                endm
 101:				;
 102:				; Add a 3 byte (24-bit) entry.
 103:				ALL_24BIT       macro x
 104:				x               equ all_addr
 105:				all_addr        set all_addr + 3
 106:				all_size        set all_size + 3
 107:				                endm
 108:				;
 109:				; Add a long (32-bit) entry.
 110:				ALL_LONG        macro x
 111:				x               equ all_addr
 112:				all_addr        set all_addr + 4
 113:				all_size        set all_size + 4
 114:				                endm
 115:				;
 116:				; Add an arbitrary length entry.
 117:				ALL_BLOCK       macro x, size   ; <name>, <size>
 118:				x               equ all_addr
 119:				all_addr        set all_addr + size
 120:				all_size        set all_size + size
 121:				                endm
 122:				;
 123:				; End of allocated space. Returns size of block.
 124:				ALL_END         macro x
 125:				x               equ all_size
 126:				                .cseg
 127:				                endm
 128:				;
 129:				;
 130:				; Calculate offsets into jump tables.
 131:				; The absolute segment is used so the offsets are not marked as relocatable. This
 132:				; avoids "Not relocatable" errors.
 133:				JPTBL_START     macro x
 134:				                .aseg
 135:				jptbl_addr      set x               ; Set start address
 136:				                endm
 137:				;
 138:				; Invoke for each item.
 139:				JPTBL_ENTRY     macro x
 140:				x               equ jptbl_addr
 141:				jptbl_addr      set jptbl_addr + 3
 142:				                endm
 143:				;
 144:				; Invoke for a data block in the jump table
 145:				JPTBL_BLOCK     macro x, size   ; <name>, <size>
 146:				x               equ jptbl_addr
 147:				jptbl_addr      set jptbl_addr + size
 148:				                endm
 149:				;
 150:				JPTBL_END       macro x
 151:				x               set jptbl_addr      ; Set label to next address
 152:				                .cseg
 153:				                endm
 154:				;
 155:				;
 156:				; Define bits and masks. This is inspired by the Commodore Amiga BITDEF mechanism.
 157:				; Given:
 158:				; BITDEF I2C_CSR_STOP, 2
 159:				; Yields:
 160:				; I2C_CSR_STOP_BIT  EQU 2       ; Bit number
 161:				; I2C_CSR_STOP_MASK EQU 1<<2    ; Bit mask
 162:				BITDEF          macro n, b      ; <Name>, <bit>
 163:				n`_BIT          equ b
 164:				n`_MASK         equ 1 << b
 165:				                endm
 166:				;
 167:				;
 168:				; Force alignment. This asserts an appropriate number of zero bytes to achieve
 169:				; the required alignment. Note that these macros cannot work for relocatable
 170:				; files.
 171:				; 16-bit
 172:				ALIGN_WORD      macro
 173:				                if $ and 1
 174:				                    byte 0
 175:				                endif
 176:				                endm
 177:				;
 178:				; 32-bit
 179:				ALIGN_LONG      macro
 180:				                ALIGN_WORD
 181:				                if $ and 2
 182:				                    byte 0, 0
 183:				                endif
 184:				                endm
 185:				;
 186:				;
 187:				; Write message to console (short for "call conwms").
 188:				CON_WR_MSG      macro
 189:				                rst 08
 190:				                endm
 191:				;
 192:				;
 193:				; Write character to console (short for "call conwch").
 194:				CON_WR_CHAR     macro
 195:				                rst 16
 196:				                endm
 197:				
**** maths.z80 ****
  24:				                include "z80.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/z80.i ****
   1:				; ***********************************
   2:				; * ZARC Z80 Definitions            *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 28/5/2020         *
   5:				; ***********************************
   6:				;
   7:				; Definitions related to the Z80 itself.
   8:				;
   9:				; Z80 Vectors
  10:     -	0000'         	Z80_RST00_VEC   equ 0x0000      ; RST instruction vectors
  11:     -	0008'         	Z80_RST08_VEC   equ 0x0008
  12:     -	0010'         	Z80_RST10_VEC   equ 0x0010
  13:     -	0018'         	Z80_RST18_VEC   equ 0x0018
  14:     -	0020'         	Z80_RST20_VEC   equ 0x0020
  15:     -	0028'         	Z80_RST28_VEC   equ 0x0028
  16:     -	0030'         	Z80_RST30_VEC   equ 0x0030
  17:     -	0038'         	Z80_RST38_VEC   equ 0x0038
  18:     -	0066'         	Z80_NMI_VEC     equ 0x0066      ; NMI vectors
  19:				
**** maths.z80 ****
  25:				                include "monitor.i"
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/monitor.i ****
   1:				; *******************************************************
   2:				; * ZARC Monitor Definitions                            *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 26/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Definitions related to the monitor programme.
   8:				;
   9:				; Note that ld80 only considers the first six characters of labels significant.
  10:				;
  11:				;
  12:				; The following conditionals are intended to allow the same include file to be
  13:				; used in the defining module and elsewhere as required. Some includes are used
  14:				; for other applications than the monitor, such as the CP/M BIOS. In these
  15:				; cases, the extern and public statements are not desirable.
  16:				;
  17:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  18:     -	0001'         	                ifndef main         ; Inhibit for this module
  19:				; Constants
  20:				;
  21:				; Variables
  22:				                extern mscnt            ; Monitor start count
  23:				                extern mcspd            ; Approximate CPU speed in KHz
  24:				                extern mstate           ; Machine state structure
  25:				;
  26:				; Functions
  27:				                extern panic            ; System error exception
  28:				                extern rusby            ; Read byte from user space
  29:				                extern ruswd            ; Read 16-bit word from user space
  30:				                extern wusby            ; Write byte to user space
  31:				                extern wuswd            ; Write 16-bit word to user space
  32:				                extern mcrun            ; Switch context to user code
  33:				                extern mdisrg           ; Display registers
  34:				;
  35:				                endif
  36:				            endif
  37:				;
  38:				;
  39:				;
  40:				; *****************
  41:				; * Monitor Calls *
  42:				; *****************
  43:				;
  44:				;
  45:				; Calculate offsets into jump tables. Entries here must match the jump table in
  46:				; monitor.z80.
  47:     -	        	    JPTBL_START %(Z80_NMI_VEC + 3)   ; Start after NMI vector
  48:				;
  49:				; From monitor.z80
  50:     -	        	    JPTBL_ENTRY MCALL_MON_ENTRY     ; Normal monitor entry
  51:     -	        	    JPTBL_ENTRY MCALL_PANIC         ; System error monitor entry
  52:				; From io.z80
  53:     -	        	    JPTBL_ENTRY MCALL_CONWCH        ; Write character to the console port
  54:     -	        	    JPTBL_ENTRY MCALL_CONRCH        ; Read character from the console port
  55:     -	        	    JPTBL_ENTRY MCALL_CONSTA        ; Fetch console port status
  56:     -	        	    JPTBL_ENTRY MCALL_S1WCH         ; Write character to serial port 1
  57:     -	        	    JPTBL_ENTRY MCALL_S1RCH         ; Read character from serial port 1
  58:     -	        	    JPTBL_ENTRY MCALL_S1STA         ; Fetch serial port 1 status
  59:     -	        	    JPTBL_ENTRY MCALL_S2WCH         ; Write character to serial port 2
  60:     -	        	    JPTBL_ENTRY MCALL_S2RCH         ; Read character from serial port 2
  61:     -	        	    JPTBL_ENTRY MCALL_S2STA         ; Fetch serial port 2 status
  62:				; From utility.z80
  63:     -	        	    JPTBL_ENTRY MCALL_CWNWLN        ; Write new line characters to console
  64:     -	        	    JPTBL_ENTRY MCALL_CONWMS        ; Print null-terminated string to the console
  65:     -	        	    JPTBL_ENTRY MCALL_CONWMN        ; Print message <n> in a list
  66:     -	        	    JPTBL_ENTRY MCALL_SKPSPC        ; Step hl past spaces
  67:     -	        	    JPTBL_ENTRY MCALL_TOUPCA        ; Convert character in A to upper case
  68:     -	        	    JPTBL_ENTRY MCALL_TOLOCA        ; Convert character in A to lower case
  69:     -	        	    JPTBL_ENTRY MCALL_CWVICH        ; Print only visible 7-bit characters
  70:     -	        	    JPTBL_ENTRY MCALL_CWPSPC        ; Print a space
  71:     -	        	    JPTBL_ENTRY MCALL_MTWDLI        ; Match word in a string against list of options
  72:     -	        	    JPTBL_ENTRY MCALL_CWPHNB        ; Print least-significant nibble in A in hexadecimal
  73:     -	        	    JPTBL_ENTRY MCALL_CWPHBY        ; Print A in hexadecimal
  74:     -	        	    JPTBL_ENTRY MCALL_CWPHWD        ; Print HL in hexadecimal
  75:     -	        	    JPTBL_ENTRY MCALL_CWPDBY        ; Print A in decimal. Leading zeros are suppressed.
  76:     -	        	    JPTBL_ENTRY MCALL_CWPDWD        ; Print HL in decimal. Leading zeros are suppressed.
  77:     -	        	    JPTBL_ENTRY MCALL_CWPDLO        ; Print DEHL in decimal. Leading zeros are suppressed
  78:     -	        	    JPTBL_ENTRY MCALL_RDHXWD        ; Read a 16-bit hexadecimal number from a string
  79:     -	        	    JPTBL_ENTRY MCALL_RDDUWD        ; Read a 16-bit unsigned decimal number from a string
  80:     -	        	    JPTBL_ENTRY MCALL_RDDULO        ; Read a 32-bit unsigned decimal number from a string
  81:				; From maths.z80
  82:     -	        	    JPTBL_ENTRY MCALL_MADLBU        ; 32-bit / 8-bit unsigned divide
  83:     -	        	    JPTBL_ENTRY MCALL_MADWBU        ; 16-bit / 8-bit unsigned divide
  84:     -	        	    JPTBL_ENTRY MCALL_MADBBU        ; 8-bit / 8-bit unsigned divide
  85:     -	        	    JPTBL_ENTRY MCALL_MAMWWU        ; 16-bit * 16-bit unsigned multiply
  86:     -	        	    JPTBL_ENTRY MCALL_MAMLBU        ; 32-bit * 8-bit unsigned multiply
  87:     -	        	    JPTBL_ENTRY MCALL_CRC16X        ; CRC-16 (XMODEM)
  88:				; From time.z80
  89:     -	        	    JPTBL_ENTRY MCALL_TIRD          ; Read current time and date
  90:     -	        	    JPTBL_ENTRY MCALL_TIWR          ; Set time and date
  91:     -	        	    JPTBL_ENTRY MCALL_TIITOS        ; Convert integer time to structure
  92:     -	        	    JPTBL_ENTRY MCALL_TISTOI        ; Convert structure time to integer
  93:     -	        	    JPTBL_ENTRY MCALL_CWPTM         ; Print time structure to console
  94:				; From mmc.z80
  95:     -	        	    JPTBL_ENTRY MCALL_MCPRER        ; Print memory card error text
  96:				; From cache.z80
  97:     -	        	    JPTBL_ENTRY MCALL_CACRS         ; CP/M read sector
  98:     -	        	    JPTBL_ENTRY MCALL_CACWS         ; CP/M write sector
  99:     -	        	    JPTBL_ENTRY MCALL_CARS          ; MMC read sector
 100:     -	        	    JPTBL_ENTRY MCALL_CAWS          ; MMC write sector
 101:     -	        	    JPTBL_ENTRY MCALL_CAFLUS        ; Flush cache (write dirty buffers)
 102:				; From memory.z80
 103:     -	        	    JPTBL_ENTRY MCALL_MPALL         ; Allocate new page
 104:     -	        	    JPTBL_ENTRY MCALL_MPFREE        ; Free allocated page
 105:     -	        	    JPTBL_ENTRY MCALL_MPSTAT        ; Allocation status
 106:				;
 107:     -	        	    JPTBL_END MCALL_JPTBL_NEXT
 108:				;
 109:				;
 110:				;
 111:				; **************
 112:				; * Structures *
 113:				; **************
 114:				;
 115:				;
 116:				; Machine state structure.
 117:     -	        	                STRUCT
 118:     -	        	                STR_BYTE MST_IEN        ; Non-zero if interrupts enabled
 119:     -	        	                STR_BYTE MST_MMAP_EN    ; Non-zero if memory mapping enabled
 120:     -	        	                STR_BYTE MST_MMAP0      ; Memory mapping registers
 121:     -	        	                STR_BYTE MST_MMAP1
 122:     -	        	                STR_BYTE MST_MMAP2
 123:     -	        	                STR_BYTE MST_MMAP3
 124:     -	        	                STR_WORD MST_SP
 125:     -	        	                STR_WORD MST_PC
 126:				; The sequence of the following entries must match those in the state save and
 127:				; load routines.
 128:     -	        	                STR_WORD MST_IY
 129:     -	        	                STR_WORD MST_IX
 130:     -	        	                STR_WORD MST_HL_P
 131:     -	        	                STR_WORD MST_DE_P
 132:     -	        	                STR_WORD MST_BC_P
 133:     -	        	                STR_WORD MST_AF_P       ; Alternate ("prime") registers
 134:     -	        	                STR_WORD MST_HL
 135:     -	        	                STR_WORD MST_DE
 136:     -	        	                STR_WORD MST_BC
 137:     -	        	                STR_WORD MST_AF
 138:				; End of sequence critical entries.
 139:     -	        	                STR_BYTE MST_I
 140:     -	        	                STR_BYTE MST_R
 141:     -	        	                STR_END MST_SIZE
 142:				;
 143:				;
 144:				;
 145:				; *************
 146:				; * Constants *
 147:				; *************
 148:				;
 149:				;
 150:				; Trace mode states for trace_mode.
 151:     -	        	                ENUM_START
 152:     -	        	                ENUM TRM_NONE
 153:     -	        	                ENUM TRM_SINGLE
 154:     -	        	                ENUM TRM_TO_ADDR        ; Trace to address
 155:     -	        	                ENUM TRM_XPT            ; Exception - start running normally
 156:     -	        	                ENUM_END TRM_STATES     ; Number of states
 157:				
**** maths.z80 ****
