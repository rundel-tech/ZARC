**** cache.z80 ****
  41:				                include "maths.i"       ; Mathematical functions
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/maths.i ****
   1:				; *******************************************************
   2:				; * Mathematical Routines for ZARC Z80 Computer         *
   3:				; * Written by: Merlin Skinner                          *
   4:				; * Date Started: 29/5/2020                             *
   5:				; *******************************************************
   6:				;
   7:				; Note that ld80 only considers the first six characters of labels significant.
   8:				;
   9:				; The following conditionals are intended to allow the same include file to be
  10:				; used in the defining module and elsewhere as required. Some includes are used
  11:				; for other applications than the monitor, such as the CP/M BIOS. In these cases,
  12:				; the extern and public statements are not desirable.
  13:				;
  14:     -	0001'         	            ifdef monitor           ; Meaningful for monitor build only
  15:     -	0001'         	                ifndef maths        ; Inhibit for this module
  16:				;
  17:				                extern madlbu       ; 32-bit / 8-bit unsigned divide
  18:				                extern madwbu       ; 16-bit / 8-bit unsigned divide
  19:				                extern madbbu       ; 8-bit / 8-bit unsigned divide
  20:				                extern mamwwu       ; 16-bit * 16-bit unsigned multiply
  21:				                extern mamlbu       ; 32-bit * 8-bit unsigned multiply
  22:				                extern crc16x       ; Software CRC-16 (XMODEM)
  23:				;                extern malclr       ; 32-bit clear (HL)
  24:				                extern malinc       ; 32-bit increment (HL)
  25:				                extern mapcnt       ; Calculate percentage of two 32-bit values
  26:				                extern malld	    ; Load 32-bit number from memory
  27:				                extern malst        ; Store 32-bit number to memory
  28:				                extern maladd       ; 32-bit add
  29:				;
  30:				                endif
  31:				            endif
  32:				
**** cache.z80 ****
  42:				                include "spi.i"         ; SPI master interface
**** /home/merlin/Dropbox/ZARC_Z80_Box/git_cpm3_dev/software/includes/spi.i ****
   1:				; ***********************************
   2:				; * ZARC SPI Definitions            *
   3:				; * Written by: Merlin Skinner      *
   4:				; * Date Started: 7/8/2020          *
   5:				; ***********************************
   6:				;
   7:				; Definitions associated with the SPI (Inter-Integrated Circuit) master interface.
   8:				; Used for the memory card initially, but it may turn out to have other uses.
   9:				;
  10:				;
  11:				; Memory card command structure
  12:     -	        	                STRUCT
  13:     -	        	                STR_BYTE MMC_CMD    ; Command including start bits
  14:     -	        	                STR_BYTE MMC_ARG1   ; Arguments
  15:     -	        	                STR_BYTE MMC_ARG2   ; Arguments
  16:     -	        	                STR_BYTE MMC_ARG3   ; Arguments
  17:     -	        	                STR_BYTE MMC_ARG4   ; Arguments
  18:     -	        	                STR_BYTE MMC_CRC    ; CRC and stop bit
  19:     -	        	                STR_END MMC_SIZE
  20:				
  21:				; SPI-related error codes. This should be maintained in sync with err_msgs in
  22:				; mmc_card.z80.
  23:     -	        	                ENUM_START
  24:     -	        	                ENUM SPI_ERR_OK         ; No error
  25:     -	        	                ENUM SPI_ERR_BUSY       ; Master interface stuck busy
  26:				; Memory card error codes.
  27:     -	        	                ENUM SPI_ERR_NORESP     ; No response received from card
  28:     -	        	                ENUM SPI_ERR_BADINIT    ; Initialisation failed
  29:     -	        	                ENUM SPI_ERR_BADCRC     ; CRC error
  30:     -	        	                ENUM SPI_ERR_BADSEC     ; Bad sector size
  31:     -	        	                ENUM SPI_ERR_RANGE      ; Parameter out of range
  32:     -	        	                ENUM SPI_ERR_DATAERR    ; Data error token received
  33:     -	        	                ENUM SPI_ERR_BAD_R1     ; Card reported error in R1 response
  34:     -	        	                ENUM SPI_ERR_BAD_R2     ; Card reported error in R2 response
  35:     -	        	                ENUM SPI_ERR_HEAP       ; Out of heap space
  36:     -	        	                ENUM SPI_ERR_TIMEOUT    ; Busy timeout
  37:     -	        	                ENUM SPI_ERR_WRITE      ; Write error
  38:     -	        	                ENUM SPI_ERR_UNKN       ; Unknown error
  39:     -	        	                ENUM SPI_ERR_PART       ; Sector is outside the partition
  40:     -	        	                ENUM_END SPI_ERR_NUM    ; Number of errors
  41:				
**** cache.z80 ****
  43:				;
  44:				;
  45:				; *************
  46:				; * Externals *
  47:				; *************
  48:				;
  49:				; Routines
  50:				                public cacold       ; Reset cache (cold start)
  51:				                public cawarm       ; Initialise cache (warm start)
  52:				                public carpt        ; Report status
  53:				                public caflus       ; Flush cache
  54:				                public cars         ; Read MMC sector
  55:				                public caws         ; Write MMC sector
  56:				                public cacrs        ; Read CP/M sector
  57:				                public cacws        ; Write CP/M sector
  58:				;
  59:				; Variables
  60:				;
  61:				; None
  62:				;
  63:				;
  64:				;
  65:				; *************
  66:				; * Constants *
  67:				; *************
  68:				;
  69:				; (None)
  70:				;
  71:				;
  72:				;
  73:				; *************
  74:				; * Main Code *
  75:				; *************
  76:				;
  77:				                cseg                    ; Code segment
  78:				;
  79:				; Reset cache. Deletes any cached data.
  80:    0+11	0000' C5      	cacold          push bc
  81:   11+11	0001' D5      	                push de
  82:   22+11	0002' E5      	                push hl
  83:   33+15	0003' DDE5    	                push ix
  84:				;
  85:				; Allocate memory pages. There should always be sufficient on a cold start,
  86:				; so if there are insufficient pages we simply "panic". We go here on a warm
  87:				; start if the cache is considered unrecoverable.
  88:   48+10	0005' 210F09  	caw_cold        ld hl, page_name        ; Initialise the name
  89:   58+10	0008' 364D    	                ld (hl), 'M'            ; "Memory"
  90:   68+6	000A' 23      	                inc hl
  91:   74+10	000B' 3643    	                ld (hl), 'C'            ; "Card"
  92:   84+6	000D' 23      	                inc hl
  93:   90+10	000E' 3643    	                ld (hl), 'C'            ; "Cache"
  94:  100+6	0010' 23      	                inc hl
  95:  106+10	0011' 3630    	                ld (hl), '0'
  96:				;
  97:  116+7	0013' 0608    	                ld b, MCCA_PAGES        ; Number of pages required
  98:  123+10	0015' 110709  	                ld de, pages            ; Store for page numbers
  99:				; Loop for each page.
 100:  133+10	0018' 210F09  	cac_page_loop   ld hl, page_name        ; Point to name
 101:  143+17	001B' CD0000  	                call mpall
 102:  160+10+7	001E' DC0000  	                call c, panic           ; Panic on error
 103:  170+7	0021' 12      	                ld (de), a              ; Save new page number
 104:  177+6	0022' 13      	                inc de
 105:  183+10	0023' 211209  	                ld hl, page_name + 3    ; Point to last character
 106:  193+11	0026' 34      	                inc (hl)                ; Increment digit
 107:				; Handle transition from numeric to alphabetic index.
 108:  204+7	0027' 3E3A    	                ld a, "9" + 1
 109:  211+7	0029' BE      	                cp (hl)
 110:  218+7+5	002A' 2002    	                jr nz, cac_page_done
 111:  225+10	002C' 3641    	                ld (hl), "A"
 112:  235+8+5	002E' 10E8    	cac_page_done   djnz cac_page_loop
 113:				;
 114:				; Initialise the cache, flagging all buffers as free.
 115:  243+14	0030' DD210700	                ld ix, cache_buffers        ; Point to first buffer
 116:  257+10	0034' 110900  	                ld de, MCCAS_SIZE           ; Pre-load structure size
 117:  267+10	0037' 010000  	                ld bc, 0                    ; Sector buffer counter
 118:				;
 119:				; MCCAS_STATUS will be zero due to variables RAM clear.
 120:  277+11	003A' C5      	cac_buff_loop   push bc
 121:  288+17	003B' CD7306  	                call calc_addr_page         ; Find address and page
 122:  305+10	003E' C1      	                pop bc
 123:  315+19	003F' DD7708  	                ld (ix + MCCAS_PAGE), a
 124:  334+19	0042' DD7506  	                ld (ix + MCCAS_ADDR), l
 125:  353+19	0045' DD7407  	                ld (ix + MCCAS_ADDR + 1), h
 126:				;
 127:  372+15	0048' DD19    	                add ix, de                  ; Next structure
 128:  387+6	004A' 03      	                inc bc
 129:  393+4	004B' 78      	                ld a, b
 130:  397+7	004C' FE01    	                cp high MCCA_BUFFERS
 131:  404+7+5	004E' 20EA    	                jr nz, cac_buff_loop
 132:  411+4	0050' 79      	                ld a, c
 133:  415+7	0051' FE00    	                cp low MCCA_BUFFERS
 134:  422+7+5	0053' 20E5    	                jr nz, cac_buff_loop
 135:				;
 136:				; Counters will all be zero due to variables RAM clear.
 137:				;
 138:  429+14	0055' DDE1    	                pop ix
 139:  443+10	0057' E1      	                pop hl
 140:  453+10	0058' D1      	                pop de
 141:  463+10	0059' C1      	                pop bc
 142:  473+10	005A' C9      	                ret
 143:				;
 144:				;
 145:				; Reinitialise the cache, preserving as much data as possible. This is intended
 146:				; for use during a monitor "warm start". Alternate register set is not
 147:				; preserved.
 148:  483+11	005B' C5      	cawarm          push bc
 149:  494+11	005C' D5      	                push de
 150:  505+11	005D' E5      	                push hl
 151:  516+15	005E' DDE5    	                push ix
 152:				;
 153:				; Also goes here after re-initialisation when corruption is found.
 154:  531+14	0060' DD210700	caw_start       ld ix, cache_buffers        ; Point to first buffer
 155:				; Initialise without disturbing cached data where possible. Buffers containing
 156:				; sectors with bad checksums are discarded. If the buffer pointer is corrupt,
 157:				; the entire cache is reinitialised as for a cold start.
 158:  545+10	0064' 010000  	                ld bc, 0                    ; Sector buffer counter
 159:  555+4	0067' D9      	                exx
 160:  559+10	0068' 010000  	                ld bc, 0                    ; Checksum error counter
 161:  569+10	006B' 110000  	                ld de, 0                    ; Used buffer count
 162:  579+10	006E' 210000  	                ld hl, 0                    ; Dirty buffer count
 163:  589+4	0071' D9      	                exx
 164:				;
 165:				; BC - sector buffer counter
 166:				; IX - pointer to current buffer structure
 167:				; BC' - checksum error counter
 168:				; DE' - used buffer count
 169:				; HL' - dirty buffer count
 170:				; Examine in buffer in turn.
 171:  593+11	0072' C5      	caw_sec_loop    push bc
 172:  604+17	0073' CD7306  	                call calc_addr_page         ; Find address and page
 173:  621+10	0076' C1      	                pop bc
 174:				; A - page
 175:				; HL - address (bank 2)
 176:  631+19	0077' DDBE08  	                cp (ix + MCCAS_PAGE)
 177:  650+7+5	007A' 206D    	                jr nz, caw_corrupt          ; Change to a cold start
 178:  657+4	007C' 7D      	                ld a, l
 179:  661+19	007D' DDBE06  	                cp (ix + MCCAS_ADDR)
 180:  680+7+5	0080' 2067    	                jr nz, caw_corrupt
 181:  687+4	0082' 7C      	                ld a, h
 182:  691+19	0083' DDBE07  	                cp (ix + MCCAS_ADDR + 1)
 183:  710+7+5	0086' 2061    	                jr nz, caw_corrupt
 184:				;
 185:				; Pointers to data are OK.
 186:  717+19	0088' DD7E00  	                ld a, (ix + MCCAS_STATUS)   ; Fetch status
 187:  736+8	008B' CB67    	                bit MCCAS_STAT_VALID_BIT, a
 188:  744+7+5	008D' 2828    	                jr z, caw_sec_done          ; Jump if buffer not in use
 189:				;
 190:				; There is sector data in the buffer, so verify the checksum.
 191:  751+17	008F' CD5906  	                call map_page               ; Map page to bank 2
 192:  768+17	0092' CD8B05  	                call calc_csum
 193:				; HL - newly computed checksum
 194:  785+4	0095' 7D      	                ld a, l
 195:  789+19	0096' DDBE04  	                cp (ix + MCCAS_CSUM)
 196:  808+7+5	0099' 2006    	                jr nz, caw_bad_buff
 197:  815+4	009B' 7C      	                ld a, h
 198:  819+19	009C' DDBE05  	                cp (ix + MCCAS_CSUM + 1)
 199:  838+7+5	009F' 2809    	                jr z, caw_good_buff
 200:				; If the checksum is bad, we can't trust the data regardless of what the status
 201:				; byte says.
 202:  845+4	00A1' D9      	caw_bad_buff    exx
 203:  849+6	00A2' 03      	                inc bc                      ; Count errors
 204:  855+4	00A3' D9      	                exx
 205:  859+19	00A4' DD360000	                ld (ix + MCCAS_STATUS), 0   ; Mark buffer as free
 206:  878+12	00A8' 180D    	                jr caw_sec_done
 207:				;
 208:				; The sector data checksum matches, so we have confidence in the data.
 209:  890+4	00AA' D9      	caw_good_buff   exx
 210:  894+6	00AB' 13      	                inc de                      ; Count used buffers
 211:  900+4	00AC' D9      	                exx
 212:				;
 213:  904+19	00AD' DD7E00  	                ld a, (ix + MCCAS_STATUS)   ; Fetch status
 214:  923+7	00B0' E60F    	                and MCCAS_STAT_DIRT_MASK
 215:  930+7+5	00B2' 2803    	                jr z, caw_sec_done
 216:				; Buffer is dirty (has some unwritten data).
 217:  937+4	00B4' D9      	                exx
 218:  941+6	00B5' 23      	                inc hl                      ; Count dirty buffers
 219:  947+4	00B6' D9      	                exx
 220:				;
 221:  951+10	00B7' 110900  	caw_sec_done    ld de, MCCAS_SIZE           ; Structure size
 222:  961+15	00BA' DD19    	                add ix, de
 223:  976+6	00BC' 03      	                inc bc
 224:  982+4	00BD' 78      	                ld a, b
 225:  986+7	00BE' FE01    	                cp high MCCA_BUFFERS
 226:  993+7+5	00C0' 20B0    	                jr nz, caw_sec_loop
 227: 1000+4	00C2' 79      	                ld a, c
 228: 1004+7	00C3' FE00    	                cp low MCCA_BUFFERS
 229: 1011+7+5	00C5' 20AB    	                jr nz, caw_sec_loop
 230:				;
 231:				; BC' - checksum error counter
 232:				; DE' - used buffer count
 233:				; HL' - dirty buffer count
 234: 1018+4	00C7' D9      	                exx
 235: 1022+20	00C8' ED530200	                ld (used_buffs), de         ; Number of buffers in use
 236: 1042+16	00CC' 220400  	                ld (dirty_buffs), hl        ; Number of dirty buffers
 237:				;
 238:				; Complain if we found buffers marked as valid but with bad checksums.
 239: 1058+4	00CF' 78      	                ld a, b
 240: 1062+4	00D0' B1      	                or c
 241: 1066+7+5	00D1' 2809    	                jr z, caw_all_good
 242:				; One or more sector buffers was corrupt.
 243: 1073+4	00D3' 60      	                ld h, b
 244: 1077+4	00D4' 69      	                ld l, c
 245: 1081+17	00D5' CD0000  	                call cwpdwd                 ; Print HL in decimal
 246: 1098+10	00D8' 214707  	                ld hl, caw_badsum_msg       ; "corrupt cache buffers discarded"
 247: 1108+11	00DB' CF      	                CON_WR_MSG                  ; Print message
 248:				;
 249:				; Set preferred next buffer to use.
 250: 1119+4	00DC' D9      	caw_all_good    exx
 251: 1123+10	00DD' 210000  	                ld hl, 0                    ; Use the first one
 252: 1133+13	00E0' 320000  	                ld (next_buff), a
 253:				;
 254: 1146+14	00E3' DDE1    	                pop ix
 255: 1160+10	00E5' E1      	                pop hl
 256: 1170+10	00E6' D1      	                pop de
 257: 1180+10	00E7' C1      	                pop bc
 258: 1190+10	00E8' C9      	                ret
 259:				;
 260:				; There is something seriously wrong with the cache. We should re-initialise
 261:				; as for a cold start.
 262: 1200+10	00E9' 216F07  	caw_corrupt     ld hl, caw_corr_msg         ; "Cache corrupt. Re-initialisating"
 263: 1210+11	00EC' CF      	                CON_WR_MSG                  ; Print message
 264: 1221+10	00ED' C30500  	                jp caw_cold                 ; Continue as cold start
 265:				;
 266:				;
 267:				; Report cache status to the console. This is mainly for debugging, but may be
 268:				; of more general interest. The report is of the form:
 269:				;   <buffer no.> - <status> [<checksum error>]
 270:				; for each buffer. <status> is one of:
 271:				;   <sector no.> "clean" - no unwritten data
 272:				;   <sector no.> "dirty" - unwritten sector
 273:				;   <sector no.> "grubby: xxxx" - partially unwritten (CP/M sectors)
 274:				; Last line is:
 275:				;   In use: x, 0, dirty: y, next read buffer: z
 276:				; Unused buffers are omitted. There is a summary at the end, with a single
 277:				; character representing each sector buffer. The characters are
 278:				; -CDG (unused, clean, dirty and grubby).
 279:     -	0001'         	                assert MCCAS_STAT_CPM0_BIT = 0  ; Assumed by this routine
 280: 1231+11	00F0' C5      	carpt           push bc
 281: 1242+11	00F1' D5      	                push de
 282: 1253+15	00F2' DDE5    	                push ix
 283:				;
 284: 1268+10	00F4' 219F06  	                ld hl, rpt_title_msg        ; "MMC Cache Status:"
 285: 1278+11	00F7' CF      	                CON_WR_MSG                  ; Print message
 286:				;
 287:				; Loop through each cache structure.
 288: 1289+14	00F8' DD210700	                ld ix, cache_buffers        ; Point to first buffer
 289: 1303+10	00FC' 010000  	                ld bc, 0                    ; Sector buffer structure count
 290:				;
 291: 1313+20	00FF' DDCB0066	rpt_buff_loop   bit MCCAS_STAT_VALID_BIT, (ix + MCCAS_STATUS)
 292: 1333+7+5	0103' 2861    	                jr z, rpt_buff_skip         ; Skip if buffer is unused
 293:				;
 294:				; Print buffer number.
 295: 1340+4	0105' 60      	                ld h, b
 296: 1344+4	0106' 69      	                ld l, c
 297: 1348+17	0107' CD0000  	                call cwpdwd                 ; Print HL in decimal
 298: 1365+10	010A' 21B306  	                ld hl, rpt_sep_msg          ; " - "
 299: 1375+11	010D' CF      	                CON_WR_MSG                  ; Print message
 300:				;
 301:				; Print sector number.
 302: 1386+19	010E' DD6E01  	                ld l, (ix + MCCAS_SECTOR)
 303: 1405+19	0111' DD6602  	                ld h, (ix + MCCAS_SECTOR + 1)
 304: 1424+19	0114' DD5E03  	                ld e, (ix + MCCAS_SECTOR + 2)
 305: 1443+7	0117' 1600    	                ld d, 0
 306: 1450+17	0119' CD0000  	                call cwpdlo                 ; Print DEHL in decimal
 307: 1467+17	011C' CD0000  	                call cwpspc                 ; Print a space
 308:				;
